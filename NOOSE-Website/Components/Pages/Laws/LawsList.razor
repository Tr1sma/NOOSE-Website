@* Searchable law knowledge base; readable by all, curated by leadership. *@
@page "/gesetze"
@inject ILawService LawService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Gesetzbuch · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
    <MudIcon Icon="@Icons.Material.Filled.Gavel" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h4">Gesetzbuch</MudText>
    <MudSpacer />
    <AuthorizeView Policy="@Policies.Leadership" Context="fuehrung">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   OnClick="NewAsync">Neuer Paragraf</MudButton>
    </AuthorizeView>
</MudStack>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-6">
    Rechtsgrundlagen der Ermittlungsarbeit. Paragrafen können über „Verknüpfen" mit Vorgängen,
    Doks und anderen Akten verbunden werden und tauchen in der globalen Suche auf.
</MudText>

@if (_load)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudTextField @bind-Value="_search" Placeholder="Suchen (Gesetzbuch, Paragraf, Titel, Text)…" Immediate="true"
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Class="mb-3" Variant="Variant.Outlined" />

    <MudTable Items="_filtered" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="2" Dense="true"
              T="Law" RowClass="cursor-pointer" OnRowClick="@(args => Open(args.Item))">
        <HeaderContent>
            <MudTh><MudTableSortLabel T="Law" SortBy="@(x => x.LawBook)" InitialDirection="SortDirection.Ascending">Gesetzbuch</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="Law" SortBy="@(x => x.Paragraph)">Paragraf</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="Law" SortBy="@(x => x.Title)">Titel</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="Law" SortBy="@(x => x.Sentence)">Strafmaß</MudTableSortLabel></MudTh>
            <MudTh Style="text-align:right;">Aktion</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Gesetzbuch">
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary">@context.LawBook</MudChip>
            </MudTd>
            <MudTd DataLabel="Paragraf"><MudText Typo="Typo.body2"><b>@context.Paragraph</b></MudText></MudTd>
            <MudTd DataLabel="Titel">
                <MudLink Href="@($"/gesetze/{context.Id}")" @onclick:stopPropagation="true">@context.Title</MudLink>
            </MudTd>
            <MudTd DataLabel="Strafmaß">
                <MudText Typo="Typo.body2" Class="mud-text-secondary">@(string.IsNullOrWhiteSpace(context.Sentence) ? "—" : context.Sentence)</MudText>
            </MudTd>
            <MudTd DataLabel="Aktion" Style="text-align:right;">
                @if (_isLeadership)
                {
                    @* Stop click propagation so the button doesn't open the row. *@
                    <span @onclick:stopPropagation="true">
                        <MudStack Row="true" Spacing="1" Justify="Justify.FlexEnd" AlignItems="AlignItems.Center">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                                           OnClick="@(() => EditAsync(context))" aria-label="Paragraf bearbeiten" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                           OnClick="@(() => DeleteAsync(context))" aria-label="Paragraf löschen" />
                        </MudStack>
                    </span>
                }
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <AuthorizeView Policy="@Policies.PartnerView" Context="partnerEmpty">
                <Authorized>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary pa-4">Für Ihre Behörde wurde noch kein Paragraf freigegeben.</MudText>
                </Authorized>
                <NotAuthorized>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary pa-4">Noch keine Paragrafen erfasst.</MudText>
                </NotAuthorized>
            </AuthorizeView>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _load = true;
    private bool _isLeadership;
    private string _search = string.Empty;
    private List<Law> _laws = new();
    private ClaimsPrincipal _user = default!;

    private IEnumerable<Law> _filtered => string.IsNullOrWhiteSpace(_search)
        ? _laws
        : _laws.Where(g => g.Title.Contains(_search.Trim(), StringComparison.OrdinalIgnoreCase)
                           || g.Paragraph.Contains(_search.Trim(), StringComparison.OrdinalIgnoreCase)
                           || g.LawBook.Contains(_search.Trim(), StringComparison.OrdinalIgnoreCase)
                           || g.Text.Contains(_search.Trim(), StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        _isLeadership = _user.IsLeadership();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _load = true;
        _laws = await LawService.GetListAsync(partnerAgency: _user.GetPartnerAgency(), partnerAgentId: _user.GetAgentId());
        _load = false;
    }

    private void Open(Law? g)
    {
        if (g is not null)
        {
            Nav.NavigateTo($"/gesetze/{g.Id}");
        }
    }

    private async Task NewAsync()
    {
        var input = await LawDialog.ShowAsync(DialogService, "Neuer Paragraf");
        if (input is null)
        {
            return;
        }
        try
        {
            await LawService.CreateAsync(input, _user);
            Snackbar.Add("Paragraf angelegt.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task EditAsync(Law law)
    {
        var input = await LawDialog.ShowAsync(DialogService, $"{law.Paragraph} bearbeiten", new LawInput
        {
            LawBook = law.LawBook,
            Paragraph = law.Paragraph,
            Title = law.Title,
            Text = law.Text,
            Sentence = law.Sentence,
        });
        if (input is null)
        {
            return;
        }
        try
        {
            await LawService.RefreshAsync(law.Id, input, _user);
            Snackbar.Add("Paragraf gespeichert.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task DeleteAsync(Law law)
    {
        var confirmed = await ConfirmDialog.ShowAsync(DialogService, "Paragraf löschen?",
            $"„{law.Paragraph} {law.Title}“ wirklich löschen? Bestehende Verknüpfungen zeigen ihn danach nicht mehr an.");
        if (!confirmed)
        {
            return;
        }
        try
        {
            await LawService.DeleteAsync(law.Id, _user);
            Snackbar.Add("Paragraf gelöscht.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
