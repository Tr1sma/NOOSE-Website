@* Anlegen/Bearbeiten eines Paragrafen (Gesetzbuch-Modul, Phase 7). Nur Führung. *@

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudStack Row="true" Spacing="2">
                <MudTextField @bind-Value="_eingabe.Gesetzbuch" Label="Gesetzbuch" Variant="Variant.Outlined"
                              Required="true" RequiredError="Gesetzbuch ist erforderlich"
                              Placeholder="z. B. StGB, StVO" />
                <MudTextField @bind-Value="_eingabe.Paragraf" Label="Paragraf" Variant="Variant.Outlined"
                              Required="true" RequiredError="Paragraf ist erforderlich"
                              Placeholder="z. B. § 31" Style="max-width:160px;" />
            </MudStack>
            <MudTextField @bind-Value="_eingabe.Titel" Label="Titel" Variant="Variant.Outlined"
                          Required="true" RequiredError="Titel ist erforderlich"
                          Placeholder="z. B. Landfriedensbruch" />
            <MudTextField @bind-Value="_eingabe.Text" Label="Gesetzestext" Variant="Variant.Outlined"
                          Lines="8" Required="true" RequiredError="Text ist erforderlich" />
            <MudTextField @bind-Value="_eingabe.Strafmass" Label="Strafmaß / Rechtsfolge (optional)" Variant="Variant.Outlined"
                          Placeholder="z. B. Freiheitsstrafe bis zu 3 Jahren oder Geldstrafe" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Abbrechen">Abbrechen</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Speichern"
                   Disabled="@(string.IsNullOrWhiteSpace(_eingabe.Gesetzbuch) || string.IsNullOrWhiteSpace(_eingabe.Paragraf)
                               || string.IsNullOrWhiteSpace(_eingabe.Titel) || string.IsNullOrWhiteSpace(_eingabe.Text))">
            Speichern
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public GesetzEingabe? Vorbelegung { get; set; }

    private GesetzEingabe _eingabe = new();

    protected override void OnParametersSet()
    {
        if (Vorbelegung is not null)
        {
            _eingabe = new GesetzEingabe
            {
                Gesetzbuch = Vorbelegung.Gesetzbuch,
                Paragraf = Vorbelegung.Paragraf,
                Titel = Vorbelegung.Titel,
                Text = Vorbelegung.Text,
                Strafmass = Vorbelegung.Strafmass,
            };
        }
    }

    private void Abbrechen() => MudDialog.Cancel();

    private void Speichern() => MudDialog.Close(DialogResult.Ok(_eingabe));

    /// <summary>Zeigt den Dialog; liefert die Eingabe oder <c>null</c> bei Abbruch.</summary>
    public static async Task<GesetzEingabe?> ZeigenAsync(IDialogService dialog, string titel, GesetzEingabe? vorbelegung = null)
    {
        var parameters = new DialogParameters<GesetzDialog>
        {
            { x => x.Vorbelegung, vorbelegung },
        };
        var referenz = await dialog.ShowAsync<GesetzDialog>(titel, parameters,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseOnEscapeKey = true });
        var ergebnis = await referenz.Result;
        return ergebnis is { Canceled: false, Data: GesetzEingabe e } ? e : null;
    }
}
