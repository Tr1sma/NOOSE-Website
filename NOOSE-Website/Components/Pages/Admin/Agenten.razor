@page "/admin/agenten"
@attribute [Authorize(Policy = Policies.Admin)]
@inject IAgentVerwaltungService AgentService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Agenten-Verwaltung · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
    <MudIcon Icon="@Icons.Material.Filled.ManageAccounts" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h4">Agenten-Verwaltung</MudText>
</MudStack>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-6">
    Dienstgrade vergeben, TRU-, TeamLeitung- und Admin-Rechte verwalten sowie Accounts sperren. Eine Sperre beendet
    alle laufenden Sitzungen des Agents sofort (Kill-Switch). TeamLeitungen (FiveM-Aufsicht) sind im RP-Betrieb
    überall ausgeblendet und nur hier sichtbar – Vollzugriff erst durch den Admin-Haken.
</MudText>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudTable Items="_agenten" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="2" Dense="true">
        <HeaderContent>
            <MudTh>Agent</MudTh>
            <MudTh Style="min-width:220px;">Dienstgrad</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>TRU</MudTh>
            <MudTh>TeamLeitung</MudTh>
            <MudTh>Admin</MudTh>
            <MudTh Style="text-align:right;">Aktion</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Agent">
                <MudText Typo="Typo.body2">@AnzeigeName(context)</MudText>
                @if (!string.IsNullOrWhiteSpace(KlarnameDienstnummer(context)))
                {
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@KlarnameDienstnummer(context)</MudText>
                }
                <MudText Typo="Typo.caption" Class="mud-text-secondary d-block">@(context.DiscordUsername ?? context.DiscordId)</MudText>
                @if (context.IstTeamLeitung)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Tertiary" Variant="Variant.Outlined" Class="mt-1">TeamLeitung</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="Dienstgrad">
                <MudSelect T="Dienstgrad" Value="@(context.Dienstgrad ?? Dienstgrad.JuniorAgent)"
                           ValueChanged="@(grad => RangAendern(context, grad))"
                           Dense="true" Margin="Margin.Dense" Variant="Variant.Outlined"
                           Disabled="@(context.Status != AgentStatus.Aktiv)">
                    @foreach (var dg in DienstgradAnzeige.Alle)
                    {
                        <MudSelectItem Value="dg">@DienstgradAnzeige.Name(dg)</MudSelectItem>
                    }
                </MudSelect>
            </MudTd>
            <MudTd DataLabel="Status">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudIcon Icon="@StatusIcon(context.Status)" Color="@StatusFarbe(context.Status)" Size="Size.Small" />
                    <MudText Typo="Typo.body2" Color="@StatusFarbe(context.Status)">@AgentStatusAnzeige.Name(context.Status)</MudText>
                </MudStack>
            </MudTd>
            <MudTd DataLabel="TRU">
                <MudSwitch T="bool" Value="context.IstTRU" ValueChanged="@(v => TruSetzen(context, v))" Color="Color.Primary" />
            </MudTd>
            <MudTd DataLabel="TeamLeitung">
                <MudSwitch T="bool" Value="context.IstTeamLeitung" ValueChanged="@(v => TeamLeitungSetzen(context, v))" Color="Color.Tertiary" />
            </MudTd>
            <MudTd DataLabel="Admin">
                <MudSwitch T="bool" Value="context.IstAdmin" ValueChanged="@(v => AdminSetzen(context, v))"
                           Color="Color.Secondary" Disabled="@(context.Id == _meineId)" />
            </MudTd>
            <MudTd DataLabel="Aktion" Style="text-align:right;">
                <MudStack Row="true" Spacing="1" Justify="Justify.FlexEnd" AlignItems="AlignItems.Center">
                    <MudTooltip Text="Personalakte">
                        <MudIconButton Icon="@Icons.Material.Filled.Badge" Size="Size.Small" Color="Color.Default"
                                       Href="@($"/personal/{context.Id}")" aria-label="Personalakte öffnen" />
                    </MudTooltip>
                    <MudTooltip Text="Stammdaten bearbeiten">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                                       OnClick="() => Bearbeiten(context)" aria-label="Stammdaten bearbeiten" />
                    </MudTooltip>
                    @if (context.Status == AgentStatus.Gesperrt)
                    {
                        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success"
                                   StartIcon="@Icons.Material.Filled.LockOpen"
                                   OnClick="() => Entsperren(context)">Entsperren</MudButton>
                    }
                    else
                    {
                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error"
                                   StartIcon="@Icons.Material.Filled.Block"
                                   Disabled="@(context.Id == _meineId)"
                                   OnClick="() => Sperren(context)">Sperren</MudButton>
                    }
                </MudStack>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _laden = true;
    private List<Agent> _agenten = new();
    private string? _meineId;

    protected override async Task OnInitializedAsync()
    {
        _meineId = (await AuthStateTask).User.GetAgentId();
        await LadenAsync();
    }

    private async Task LadenAsync()
    {
        _laden = true;
        _agenten = await AgentService.GetAlleAsync();
        _laden = false;
    }

    private async Task Bearbeiten(Agent agent)
    {
        var ergebnis = await AgentBearbeitenDialog.ZeigenAsync(DialogService, agent);
        if (ergebnis is null)
        {
            return;
        }
        var user = (await AuthStateTask).User;
        try
        {
            await AgentService.StammdatenAendernAsync(agent.Id, ergebnis.Klarname, ergebnis.Codename, ergebnis.Dienstnummer, user);
            Snackbar.Add($"Stammdaten von {ergebnis.Codename} gespeichert.", Severity.Success);
            await LadenAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task RangAendern(Agent agent, Dienstgrad grad)
    {
        if (agent.Dienstgrad == grad)
        {
            return;
        }
        var user = (await AuthStateTask).User;
        try
        {
            await AgentService.RangAendernAsync(agent.Id, grad, user);
            Snackbar.Add($"{AnzeigeName(agent)}: Dienstgrad auf {DienstgradAnzeige.Name(grad)} gesetzt.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        await LadenAsync();
    }

    private async Task TruSetzen(Agent agent, bool wert)
    {
        var user = (await AuthStateTask).User;
        try
        {
            await AgentService.TruSetzenAsync(agent.Id, wert, user);
            Snackbar.Add($"{AnzeigeName(agent)}: TRU {(wert ? "gesetzt" : "entfernt")}.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        await LadenAsync();
    }

    private async Task TeamLeitungSetzen(Agent agent, bool wert)
    {
        var user = (await AuthStateTask).User;
        try
        {
            await AgentService.TeamLeitungSetzenAsync(agent.Id, wert, user);
            Snackbar.Add($"{AnzeigeName(agent)}: TeamLeitung {(wert ? "markiert" : "entfernt")}.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        await LadenAsync();
    }

    private async Task AdminSetzen(Agent agent, bool wert)
    {
        var user = (await AuthStateTask).User;
        try
        {
            await AgentService.AdminSetzenAsync(agent.Id, wert, user);
            Snackbar.Add($"{AnzeigeName(agent)}: Admin-Rechte {(wert ? "vergeben" : "entzogen")}.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        await LadenAsync();
    }

    private async Task Sperren(Agent agent)
    {
        // Destruktive Aktion (beendet alle Sitzungen sofort) → Bestätigung + optionale Begründung einholen.
        var grund = await GrundDialog.ZeigenAsync(DialogService,
            $"{AnzeigeName(agent)} sperren?",
            "Die Sperre beendet alle laufenden Sitzungen des Agents sofort (Kill-Switch).",
            bestaetigenText: "Sperren", label: "Begründung (optional)", farbe: Color.Error);
        if (grund is null)
        {
            return;
        }
        var user = (await AuthStateTask).User;
        try
        {
            await AgentService.SperrenAsync(agent.Id, string.IsNullOrWhiteSpace(grund) ? "Notfall-Sperre durch Admin" : grund, user);
            Snackbar.Add($"{AnzeigeName(agent)} gesperrt – alle Sitzungen werden beendet.", Severity.Warning);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        await LadenAsync();
    }

    private async Task Entsperren(Agent agent)
    {
        var user = (await AuthStateTask).User;
        try
        {
            await AgentService.EntsperrenAsync(agent.Id, user);
            Snackbar.Add($"{AnzeigeName(agent)} entsperrt.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        await LadenAsync();
    }

    private static string AnzeigeName(Agent agent)
        => string.IsNullOrWhiteSpace(agent.Codename) ? "Unbenannter Agent" : agent.Codename;

    private static string KlarnameDienstnummer(Agent agent)
        => string.Join(" · ", new[] { agent.Klarname, agent.Dienstnummer }
            .Where(s => !string.IsNullOrWhiteSpace(s)));

    private static Color StatusFarbe(AgentStatus status) => status switch
    {
        AgentStatus.Aktiv => Color.Success,
        AgentStatus.Ausstehend => Color.Warning,
        AgentStatus.Gesperrt => Color.Error,
        _ => Color.Default,
    };

    private static string StatusIcon(AgentStatus status) => status switch
    {
        AgentStatus.Aktiv => Icons.Material.Filled.CheckCircle,
        AgentStatus.Ausstehend => Icons.Material.Filled.HourglassTop,
        AgentStatus.Gesperrt => Icons.Material.Filled.Block,
        _ => Icons.Material.Filled.Help,
    };
}
