@page "/admin/bedrohungs-score"
@attribute [Authorize(Policy = Policies.FuehrungSeite)]
@inject IBedrohungsScoreKonfigService KonfigService
@inject IBedrohungsScoreService ScoreService
@inject ISnackbar Snackbar

<PageTitle>Bedrohungs-Score · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
    <MudIcon Icon="@Icons.Material.Filled.Speed" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h4">Bedrohungs-Score</MudText>
</MudStack>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
    Stellschrauben des automatischen Bedrohungs-Scores (Algorithmus „EHK-Score"). Die Caps müssen je Subjekt
    auf 100 summieren; die Einstufungs-Sockel und die Stufen-Schwellen (25/50/75) sind bewusst fix. Nach dem
    Speichern bitte „Alle Scores neu berechnen", damit die gespeicherten Werte die neue Konfiguration nutzen.
</MudText>

@if (_k is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudExpansionPanels MultiExpansion="true" Class="mb-4">
        <MudExpansionPanel Text="Geteilt (Person + Fraktion)" Expanded="true">
            <div class="d-flex flex-wrap gap-4">
                <MudNumericField @bind-Value="_k.HalbwertszeitTage" Label="Halbwertszeit (Tage)" Min="1" Step="5" />
                <MudNumericField @bind-Value="_k.KonfidenzFrischeTage" Label="Konfidenz-Frische (Tage)" Min="1" />
                <MudNumericField @bind-Value="_k.TriageSchwelle" Label="Triage-Schwelle" Min="0" Max="100" />
                <MudNumericField @bind-Value="_k.ArtGewichtSchwer" Label="Art schwer" Min="1" Step="0.5" />
                <MudNumericField @bind-Value="_k.ArtGewichtMittel" Label="Art mittel" Min="1" Step="0.5" />
                <MudNumericField @bind-Value="_k.ArtGewichtLeicht" Label="Art leicht" Min="1" Step="0.5" />
                <MudNumericField @bind-Value="_k.AusgangErschossen" Label="Ausgang: Erschossen" Min="0" Step="0.5" />
                <MudNumericField @bind-Value="_k.AusgangSpritze" Label="Ausgang: Spritze" Min="0" Step="0.5" />
                <MudNumericField @bind-Value="_k.AusgangLaeuftNoch" Label="Ausgang: läuft noch" Min="0" Step="0.5" />
                <MudNumericField @bind-Value="_k.AusgangEntlassen" Label="Ausgang: entlassen" Min="0" Step="0.5" />
            </div>
        </MudExpansionPanel>

        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudText>Fraktion – Teilscores S1–S4</MudText>
                    <MudChip T="string" Size="Size.Small" Color="@(FraktionSummeOk ? Color.Success : Color.Error)">Σ Caps @($"{FraktionCapsSumme:0.##}")/100</MudChip>
                    <MudChip T="string" Size="Size.Small" Color="@(S2SubOk ? Color.Success : Color.Error)">S2-Sub @($"{S2SubSumme:0.##}")/@($"{_k.CapS2:0.##}")</MudChip>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <div class="d-flex flex-wrap gap-4">
                    <MudNumericField @bind-Value="_k.CapS1" Label="Cap S1 (Heat)" Min="0" />
                    <MudNumericField @bind-Value="_k.S1Nenner" Label="S1-Nenner" Min="0.1" Step="0.5" />
                    <MudNumericField @bind-Value="_k.DokHeatGewicht" Label="Dok-Heat-Gewicht" Min="0" Step="0.1" />
                    <MudNumericField @bind-Value="_k.ProMitgliedDokCap" Label="Pro-Mitglied-Dok-Cap" Min="0" />
                    <MudNumericField @bind-Value="_k.CapS2" Label="Cap S2 (Organisation)" Min="0" />
                    <MudNumericField @bind-Value="_k.CapGroesse" Label="• Größe" Min="0" />
                    <MudNumericField @bind-Value="_k.GroesseNenner" Label="Größen-Nenner" Min="0.1" />
                    <MudNumericField @bind-Value="_k.RaengeMaxPunkte" Label="• Ränge max" Min="0" />
                    <MudNumericField @bind-Value="_k.LeitungPunkte" Label="• Leitung" Min="0" Step="0.5" />
                    <MudNumericField @bind-Value="_k.AnwesenPunkte" Label="• Anwesen" Min="0" Step="0.5" />
                    <MudNumericField @bind-Value="_k.CapWaffen" Label="• Waffen" Min="0" Step="0.5" />
                    <MudNumericField @bind-Value="_k.WaffenNenner" Label="Waffen-Nenner" Min="0.1" />
                    <MudNumericField @bind-Value="_k.CapInfra" Label="• Infrastruktur" Min="0" Step="0.5" />
                    <MudNumericField @bind-Value="_k.InfraNenner" Label="Infra-Nenner" Min="0.1" />
                    <MudNumericField @bind-Value="_k.DrogenrouteGewicht" Label="Drogenroute-Gewicht" Min="0" Step="0.5" />
                    <MudNumericField @bind-Value="_k.CapS3" Label="Cap S3 (Konflikt)" Min="0" />
                    <MudNumericField @bind-Value="_k.S3Nenner" Label="S3-Nenner" Min="0.1" />
                    <MudNumericField @bind-Value="_k.KonfliktGewicht" Label="Konflikt-Gewicht" Min="0" Step="0.5" />
                    <MudNumericField @bind-Value="_k.BuendnisGewicht" Label="Bündnis-Gewicht" Min="0" Step="0.5" />
                    <MudNumericField @bind-Value="_k.CapS4" Label="Cap S4 (Netzwerk)" Min="0" />
                    <MudNumericField @bind-Value="_k.S4Nenner" Label="S4-Nenner" Min="0.1" />
                </div>
                <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2">
                    Hinweis: „Ränge max" ist zugleich Obergrenze (Math.Min) und Baustein der S2-Sub-Summe
                    (Größe + Ränge-max + Leitung + Anwesen + Waffen + Infrastruktur = Cap S2).
                </MudText>
            </ChildContent>
        </MudExpansionPanel>

        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudText>Person – Teilscores P1–P5</MudText>
                    <MudChip T="string" Size="Size.Small" Color="@(PersonSummeOk ? Color.Success : Color.Error)">Σ Caps @($"{PersonCapsSumme:0.##}")/100</MudChip>
                    <MudChip T="string" Size="Size.Small" Color="@(P2SubOk ? Color.Success : Color.Error)">P2-Sub @($"{P2SubSumme:0.##}")/@($"{_k.CapP2:0.##}")</MudChip>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <div class="d-flex flex-wrap gap-4">
                    <MudNumericField @bind-Value="_k.CapP1" Label="Cap P1 (Heat)" Min="0" />
                    <MudNumericField @bind-Value="_k.P1Nenner" Label="P1-Nenner" Min="0.1" />
                    <MudNumericField @bind-Value="_k.CapP2" Label="Cap P2 (Bewaffnung)" Min="0" />
                    <MudNumericField @bind-Value="_k.PersonCapWaffen" Label="• Waffen" Min="0" />
                    <MudNumericField @bind-Value="_k.PersonWaffenNenner" Label="Waffen-Nenner" Min="0.1" />
                    <MudNumericField @bind-Value="_k.FluechtigPunkte" Label="• Flüchtig" Min="0" Step="0.5" />
                    <MudNumericField @bind-Value="_k.CapP3" Label="Cap P3 (Observationen)" Min="0" />
                    <MudNumericField @bind-Value="_k.P3Nenner" Label="P3-Nenner" Min="0.1" />
                    <MudNumericField @bind-Value="_k.ObservationAbgeschlossenGewicht" Label="Obs. abgeschl.-Gewicht" Min="0" Step="0.1" />
                    <MudNumericField @bind-Value="_k.CapP4" Label="Cap P4 (Soziale Gefahr)" Min="0" />
                    <MudNumericField @bind-Value="_k.P4Nenner" Label="P4-Nenner" Min="0.1" />
                    <MudNumericField @bind-Value="_k.FeindGewicht" Label="Feind-Gewicht" Min="0" Step="0.5" />
                    <MudNumericField @bind-Value="_k.VerbuendeterGewicht" Label="Verbündeter-Gewicht" Min="0" Step="0.5" />
                    <MudNumericField @bind-Value="_k.GpGewicht" Label="Geschäftspartner-Gewicht" Min="0" Step="0.5" />
                    <MudNumericField @bind-Value="_k.LeitungGewicht" Label="Leitungsrollen-Gewicht" Min="0" Step="0.5" />
                    <MudNumericField @bind-Value="_k.CapP5" Label="Cap P5 (Netzwerk)" Min="0" />
                    <MudNumericField @bind-Value="_k.P5Nenner" Label="P5-Nenner" Min="0.1" />
                </div>
            </ChildContent>
        </MudExpansionPanel>
    </MudExpansionPanels>

    @if (!IstGueltig)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-3">
            Die Caps summieren noch nicht korrekt (Fraktion S1–S4 = 100, S2-Sub = Cap S2, Person P1–P5 = 100,
            P2-Sub = Cap P2). Speichern ist erst möglich, wenn alle Summen stimmen.
        </MudAlert>
    }

    <MudStack Row="true" Spacing="2" Class="mb-6">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save"
                   Disabled="@(!IstGueltig || _speichert)" OnClick="SpeichernAsync">Speichern</MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.RestartAlt"
                   OnClick="AufStandardZuruecksetzen">Auf Standard zurücksetzen</MudButton>
    </MudStack>

    <MudDivider Class="my-4" />

    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-2">
        Gespeicherte Scores nutzen die Konfiguration vom Zeitpunkt ihrer letzten Berechnung. Nach einer Änderung
        hier sind sie veraltet, bis sie neu berechnet werden (geschieht automatisch beim nächsten Schreibvorgang
        oder dem nächtlichen Lauf – oder sofort per Knopf).
    </MudAlert>
    <MudButton Variant="Variant.Filled" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Calculate"
               Disabled="_rechnet" OnClick="AlleNeuBerechnenAsync">
        @if (_rechnet)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            <span>Berechne…</span>
        }
        else
        {
            <span>Alle Scores jetzt neu berechnen</span>
        }
    </MudButton>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private BedrohungsScoreKonfiguration? _k;
    private ClaimsPrincipal _user = default!;
    private bool _speichert;
    private bool _rechnet;

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        _k = await KonfigService.GetBearbeitbarAsync();
    }

    private double FraktionCapsSumme => _k is null ? 0 : _k.CapS1 + _k.CapS2 + _k.CapS3 + _k.CapS4;
    private double S2SubSumme => _k is null ? 0 : _k.CapGroesse + (_k.RaengeMaxPunkte + _k.LeitungPunkte + _k.AnwesenPunkte) + _k.CapWaffen + _k.CapInfra;
    private double PersonCapsSumme => _k is null ? 0 : _k.CapP1 + _k.CapP2 + _k.CapP3 + _k.CapP4 + _k.CapP5;
    private double P2SubSumme => _k is null ? 0 : _k.PersonCapWaffen + _k.FluechtigPunkte;

    private bool FraktionSummeOk => Math.Abs(FraktionCapsSumme - 100) < 0.001;
    private bool S2SubOk => _k is not null && Math.Abs(S2SubSumme - _k.CapS2) < 0.001;
    private bool PersonSummeOk => Math.Abs(PersonCapsSumme - 100) < 0.001;
    private bool P2SubOk => _k is not null && Math.Abs(P2SubSumme - _k.CapP2) < 0.001;
    private bool IstGueltig => FraktionSummeOk && S2SubOk && PersonSummeOk && P2SubOk;

    private async Task SpeichernAsync()
    {
        if (_k is null)
        {
            return;
        }
        _speichert = true;
        try
        {
            await KonfigService.SpeichernAsync(_k, _user);
            Snackbar.Add("Konfiguration gespeichert. Bitte Scores neu berechnen.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _speichert = false;
        }
    }

    private void AufStandardZuruecksetzen()
    {
        _k = BedrohungsScoreKonfiguration.Default();
        Snackbar.Add("Standardwerte geladen (noch nicht gespeichert).", Severity.Info);
    }

    private async Task AlleNeuBerechnenAsync()
    {
        _rechnet = true;
        try
        {
            var fraktionen = await ScoreService.NeuBerechnenAlleAsync();
            var personen = await ScoreService.NeuBerechnenAllePersonenScoresAsync();
            Snackbar.Add($"Neu berechnet: {fraktionen} Fraktionen, {personen} Personen.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _rechnet = false;
        }
    }
}
