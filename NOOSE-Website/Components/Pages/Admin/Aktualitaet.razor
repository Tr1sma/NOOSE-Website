@page "/admin/aktualitaet"
@attribute [Authorize(Policy = Policies.Fuehrung)]
@inject IAktualitaetService AktualitaetService
@inject ISnackbar Snackbar

<PageTitle>Aktualitäts-Ampel · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
    <MudIcon Icon="@Icons.Material.Filled.Timelapse" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h4">Aktualitäts-Ampel</MudText>
</MudStack>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
    Die Ampel zeigt je Akte, wie lange die letzte Änderung zurückliegt. Lege je Aktentyp fest, ab wie vielen
    Tagen ohne Änderung eine Akte „gelb" (wird älter) bzw. „rot" (veraltet) wird.
</MudText>

<MudPaper Class="pa-3 mb-4" Elevation="1">
    <MudStack Row="true" Spacing="4" AlignItems="AlignItems.Center" Class="flex-wrap">
        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.Circle" Color="Color.Success" Size="Size.Small" /><MudText Typo="Typo.caption">Aktuell</MudText>
        </MudStack>
        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.Circle" Color="Color.Warning" Size="Size.Small" /><MudText Typo="Typo.caption">Wird älter (ab „Gelb")</MudText>
        </MudStack>
        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.Circle" Color="Color.Error" Size="Size.Small" /><MudText Typo="Typo.caption">Veraltet (ab „Rot")</MudText>
        </MudStack>
    </MudStack>
</MudPaper>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudTable Items="_zeilen" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="2" Dense="true">
        <HeaderContent>
            <MudTh>Aktentyp</MudTh>
            <MudTh Style="width:160px;">Gelb ab (Tage)</MudTh>
            <MudTh Style="width:160px;">Rot ab (Tage)</MudTh>
            <MudTh Style="text-align:right;">Aktion</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Aktentyp"><b>@context.Anzeige</b></MudTd>
            <MudTd DataLabel="Gelb ab (Tage)">
                <MudNumericField @bind-Value="context.WarnungTage" Min="0" Max="3650" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudTd>
            <MudTd DataLabel="Rot ab (Tage)">
                <MudNumericField @bind-Value="context.VeraltetTage" Min="0" Max="3650" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudTd>
            <MudTd DataLabel="Aktion" Style="text-align:right;">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Save" OnClick="@(() => SpeichernAsync(context))">
                    Speichern
                </MudButton>
            </MudTd>
        </RowTemplate>
    </MudTable>
    <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2">
        Hinweis: „Rot ab" wird automatisch auf mindestens „Gelb ab" gesetzt.
    </MudText>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _laden = true;
    private List<Zeile> _zeilen = new();
    private ClaimsPrincipal _user = default!;

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        await LadenAsync();
    }

    private async Task LadenAsync()
    {
        _laden = true;
        var schwellen = await AktualitaetService.GetSchwellenAsync();
        _zeilen = AktualitaetService.UnterstuetzteTypen.Select(t =>
        {
            var (warnung, veraltet) = schwellen.TryGetValue(t.Typ, out var s) ? s : (t.StandardWarnungTage, t.StandardVeraltetTage);
            return new Zeile { Typ = t.Typ, Anzeige = t.Anzeige, WarnungTage = warnung, VeraltetTage = veraltet };
        }).ToList();
        _laden = false;
    }

    private async Task SpeichernAsync(Zeile zeile)
    {
        try
        {
            await AktualitaetService.SpeichernAsync(zeile.Typ, zeile.WarnungTage, zeile.VeraltetTage, _user);
            Snackbar.Add($"Schwellwerte für „{zeile.Anzeige}“ gespeichert.", Severity.Success);
            await LadenAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private sealed class Zeile
    {
        public string Typ { get; set; } = string.Empty;
        public string Anzeige { get; set; } = string.Empty;
        public int WarnungTage { get; set; }
        public int VeraltetTage { get; set; }
    }
}
