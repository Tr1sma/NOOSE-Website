@page "/admin/tags"
@page "/tags"
@attribute [Authorize(Policy = Policies.LeadershipPage)]
@inject ITagService TagService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Tags · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
    <MudIcon Icon="@Icons.Material.Filled.Label" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h4">Tags</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="NewAsync">
        Neuer Tag
    </MudButton>
</MudStack>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-6">
    Tags sind übergreifende Labels, die jeder aktive Agent an Akten vergeben kann. Hier werden sie zentral
    verwaltet (anlegen, umbenennen, einfärben, löschen). Beim Löschen verschwindet das Tag von allen Akten.
</MudText>

@if (_load)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudTable Items="_entries" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="2" Dense="true">
        <HeaderContent>
            <MudTh><MudTableSortLabel T="TagUsage" SortBy="@(x => x.Tag.Name)">Tag</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="TagUsage" SortBy="@(x => x.Tag.Colour)">Farbe</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="TagUsage" SortBy="@(x => x.Count)">Verwendungen</MudTableSortLabel></MudTh>
            <MudTh Style="text-align:right;">Aktion</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Tag">
                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="@ColourBy(context.Tag.Colour)">@context.Tag.Name</MudChip>
            </MudTd>
            <MudTd DataLabel="Farbe">
                <MudText Typo="Typo.body2" Class="mud-text-secondary">@(context.Tag.Colour ?? "Standard")</MudText>
            </MudTd>
            <MudTd DataLabel="Verwendungen">
                <MudText Typo="Typo.body2">@context.Count</MudText>
            </MudTd>
            <MudTd DataLabel="Aktion" Style="text-align:right;">
                <MudStack Row="true" Spacing="1" Justify="Justify.FlexEnd" AlignItems="AlignItems.Center">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                                   OnClick="@(() => EditAsync(context))" aria-label="Tag bearbeiten" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                   OnClick="@(() => DeleteAsync(context))" aria-label="Tag löschen" />
                </MudStack>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Typo="Typo.body2" Class="mud-text-secondary pa-4">Noch keine Tags angelegt.</MudText>
        </NoRecordsContent>
    </MudTable>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _load = true;
    private List<TagUsage> _entries = new();
    private ClaimsPrincipal _user = default!;

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _load = true;
        _entries = await TagService.GetWithUsageAsync();
        _load = false;
    }

    private async Task NewAsync()
    {
        var input = await TagDialog.ShowAsync(DialogService, "Neuer Tag");
        if (input is null)
        {
            return;
        }
        try
        {
            await TagService.CreateAsync(input.Name, input.Colour, _user);
            Snackbar.Add($"Tag „{input.Name}“ angelegt.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task EditAsync(TagUsage entry)
    {
        var input = await TagDialog.ShowAsync(DialogService, "Tag bearbeiten", entry.Tag.Name, entry.Tag.Colour);
        if (input is null)
        {
            return;
        }
        try
        {
            await TagService.RefreshAsync(entry.Tag.Id, input.Name, input.Colour, _user);
            Snackbar.Add("Tag gespeichert.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task DeleteAsync(TagUsage entry)
    {
        var text = entry.Count > 0
            ? $"„{entry.Tag.Name}“ wird gelöscht und von {entry.Count} Akte(n) entfernt."
            : $"„{entry.Tag.Name}“ wird gelöscht.";
        var ok = await ConfirmDialog.ShowAsync(DialogService, "Tag löschen?", text);
        if (!ok)
        {
            return;
        }
        await TagService.DeleteAsync(entry.Tag.Id, _user);
        Snackbar.Add("Tag gelöscht.", Severity.Success);
        await LoadAsync();
    }

    private static Color ColourBy(string? colour) => Enum.TryParse<Color>(colour, out var c) ? c : Color.Default;
}
