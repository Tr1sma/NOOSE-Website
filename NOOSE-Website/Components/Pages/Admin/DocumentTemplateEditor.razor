@* Volltext-Editor für eine Dokument-Vorlage (HTML-Body mit Platzhaltern). Nur Führung. *@
@page "/admin/vorlagen/dokument-vorlage/neu"
@page "/admin/vorlagen/dokument-vorlage/{Id}/bearbeiten"
@attribute [Authorize(Policy = Policies.LeadershipPage)]
@inject IDocumentTemplateService TemplateService
@inject IPlaceholderService Placeholder
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>@(_edit ? "Vorlage bearbeiten" : "Neue Dokument-Vorlage") · NOOSE</PageTitle>

@if (_load)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_edit && !_found)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">Vorlage nicht gefunden.</MudAlert>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="Cancel" aria-label="Zurück" />
        <MudIcon Icon="@Icons.Material.Filled.Dvr" Color="Color.Primary" Size="Size.Large" />
        <MudText Typo="Typo.h4">@(_edit ? "Dokument-Vorlage bearbeiten" : "Neue Dokument-Vorlage")</MudText>
        <MudSpacer />
        <MudButton OnClick="Cancel" Variant="Variant.Text" Color="Color.Default">Abbrechen</MudButton>
        <MudButton OnClick="SaveAsync" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" Disabled="_saves">Speichern</MudButton>
    </MudStack>

    <MudPaper Class="pa-4" Elevation="2">
        <MudStack Spacing="3">
            <MudGrid>
                <MudItem xs="12" md="7">
                    <MudTextField @bind-Value="_name" Label="Name der Vorlage" Variant="Variant.Outlined" Required="true"
                                  RequiredError="Name ist erforderlich" AutoFocus="true" />
                </MudItem>
                <MudItem xs="12" md="5">
                    <MudTextField @bind-Value="_category" Label="Kategorie (optional)" Variant="Variant.Outlined"
                                  Placeholder="z. B. SOP, Formular, Vermerk" />
                </MudItem>
            </MudGrid>
            <MudTextField @bind-Value="_description" Label="Beschreibung (optional)" Lines="2" Variant="Variant.Outlined" />
            <MudGrid>
                <MudItem xs="6">
                    <MudSwitch @bind-Value="_isActive" Color="Color.Primary" Label="Aktiv (im Picker auswählbar)" />
                </MudItem>
                <MudItem xs="6">
                    <MudNumericField @bind-Value="_sorting" Label="Sortierung" Variant="Variant.Outlined" Min="0" />
                </MudItem>
            </MudGrid>

            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                <MudText Typo="Typo.body2" Class="mb-1">Verfügbare Platzhalter (beim Anlegen eines Dokuments automatisch ersetzt):</MudText>
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                    @foreach (var (token, description) in Placeholder.AvailablePlaceholder)
                    {
                        <MudTooltip Text="@description">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info">@token</MudChip>
                        </MudTooltip>
                    }
                </MudStack>
            </MudAlert>

            <MudText Typo="Typo.subtitle2">Vorlagen-Inhalt</MudText>
            <RichTextEditor @ref="_editor" Value="@_contentHtml" />
        </MudStack>
    </MudPaper>
}

@code {
    [Parameter] public string? Id { get; set; }

    private RichTextEditor _editor = default!;
    private ClaimsPrincipal _user = default!;

    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _load = true;
    private bool _edit;
    private bool _found;
    private bool _saves;

    private string _name = string.Empty;
    private string? _description;
    private string? _category;
    private bool _isActive = true;
    private int _sorting;
    private string? _contentHtml;

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        _edit = !string.IsNullOrEmpty(Id);

        if (_edit)
        {
            var template = await TemplateService.GetAsync(Id!);
            if (template is not null)
            {
                _found = true;
                _name = template.Name;
                _description = template.Description;
                _category = template.Category;
                _isActive = template.IsActive;
                _sorting = template.Sorting;
                _contentHtml = template.ContentHtml;
            }
        }

        _load = false;
    }

    private async Task SaveAsync()
    {
        var name = _name?.Trim() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(name))
        {
            Snackbar.Add("Bitte einen Namen angeben.", Severity.Warning);
            return;
        }

        _saves = true;
        try
        {
            var html = await _editor.GetHtmlAsync();
            var input = new DocumentTemplateInput
            {
                Name = name,
                Description = _description,
                Category = _category,
                ContentHtml = html,
                IsActive = _isActive,
                Sorting = _sorting,
            };

            if (_edit)
            {
                await TemplateService.RefreshAsync(Id!, input, _user);
            }
            else
            {
                await TemplateService.CreateAsync(input, _user);
            }

            Snackbar.Add("Vorlage gespeichert.", Severity.Success);
            Nav.NavigateTo("/admin/vorlagen?tab=dokument-vorlagen");
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _saves = false;
        }
    }

    private void Cancel() => Nav.NavigateTo("/admin/vorlagen?tab=dokument-vorlagen");
}
