@* Verwaltung der Dok-Vorlagen (Erfassungsmasken für Personen-Doks). Eingebettet als Reiter in der
   Vorlagen-Verwaltung (/admin/vorlagen). *@
@inject IDokVorlageService VorlageService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
    <MudText Typo="Typo.h6">Dok-Vorlagen</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="NeuAsync">
        Neue Vorlage
    </MudButton>
</MudStack>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
    Vorlagen (Erfassungsmasken) geben Standard-Werte für neue Personen-Doks vor. Beim Anlegen eines Doks
    kann eine aktive Vorlage gewählt werden – das Formular wird vorbefüllt und bleibt frei editierbar.
</MudText>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudTable Items="_vorlagen" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="2" Dense="true">
        <HeaderContent>
            <MudTh><MudTableSortLabel T="DokVorlage" SortBy="@(x => x.Name)">Name</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="DokVorlage" SortBy="@(x => x.Beschreibung)">Beschreibung</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="DokVorlage" SortBy="@(x => MassnahmeAusgangAnzeige.Name(x.StandardAusgang))">Standard-Ausgang</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="DokVorlage" SortBy="@(x => x.IstAktiv)">Status</MudTableSortLabel></MudTh>
            <MudTh Style="text-align:right;">Aktion</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="Beschreibung">
                <MudText Typo="Typo.body2" Class="mud-text-secondary">@(string.IsNullOrWhiteSpace(context.Beschreibung) ? "—" : context.Beschreibung)</MudText>
            </MudTd>
            <MudTd DataLabel="Standard-Ausgang">
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@MassnahmeAusgangAnzeige.Name(context.StandardAusgang)</MudChip>
            </MudTd>
            <MudTd DataLabel="Status">
                @if (context.IstAktiv)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">Aktiv</MudChip>
                }
                else
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">Inaktiv</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="Aktion" Style="text-align:right;">
                <MudStack Row="true" Spacing="1" Justify="Justify.FlexEnd" AlignItems="AlignItems.Center">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                                   OnClick="@(() => BearbeitenAsync(context))" aria-label="Vorlage bearbeiten" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                   OnClick="@(() => LoeschenAsync(context))" aria-label="Vorlage löschen" />
                </MudStack>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Typo="Typo.body2" Class="mud-text-secondary pa-4">Noch keine Vorlagen angelegt.</MudText>
        </NoRecordsContent>
    </MudTable>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _laden = true;
    private List<DokVorlage> _vorlagen = new();
    private ClaimsPrincipal _user = default!;

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        await LadenAsync();
    }

    private async Task LadenAsync()
    {
        _laden = true;
        _vorlagen = await VorlageService.GetAlleAsync();
        _laden = false;
    }

    private async Task NeuAsync()
    {
        var eingabe = await DokVorlageDialog.ZeigenAsync(DialogService, "Neue Dok-Vorlage");
        if (eingabe is null)
        {
            return;
        }
        try
        {
            await VorlageService.ErstellenAsync(eingabe, _user);
            Snackbar.Add($"Vorlage „{eingabe.Name}“ angelegt.", Severity.Success);
            await LadenAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task BearbeitenAsync(DokVorlage vorlage)
    {
        var eingabe = await DokVorlageDialog.ZeigenAsync(DialogService, "Dok-Vorlage bearbeiten", vorlage);
        if (eingabe is null)
        {
            return;
        }
        try
        {
            await VorlageService.AktualisierenAsync(vorlage.Id, eingabe, _user);
            Snackbar.Add("Vorlage gespeichert.", Severity.Success);
            await LadenAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task LoeschenAsync(DokVorlage vorlage)
    {
        var ok = await BestaetigenDialog.ZeigenAsync(DialogService, "Vorlage löschen?",
            $"„{vorlage.Name}“ wird in den Papierkorb verschoben.");
        if (!ok)
        {
            return;
        }
        try
        {
            await VorlageService.LoeschenAsync(vorlage.Id, _user);
            Snackbar.Add("Vorlage gelöscht.", Severity.Success);
            await LadenAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
