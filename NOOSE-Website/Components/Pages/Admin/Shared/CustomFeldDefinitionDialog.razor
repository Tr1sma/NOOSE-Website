@* Dialog zum Anlegen/Bearbeiten einer Custom-Feld-Definition (Zusatzfeld). Liefert eine CustomFeldDefinitionEingabe zurück. *@

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form">
            <MudStack Spacing="3">
                <MudTextField @bind-Value="_eingabe.Name" Label="Feld-Name" Variant="Variant.Outlined"
                              Required="true" RequiredError="Name ist erforderlich" AutoFocus="true" Immediate="true"
                              HelperText="Label des Felds, z. B. „Decknamen-Quelle“ oder „Risiko-Einschätzung“." />

                <MudSelect T="string" Label="Aktentyp" @bind-Value="_eingabe.EntitaetTyp" Variant="Variant.Outlined"
                           Required="true" RequiredError="Aktentyp ist erforderlich"
                           HelperText="Auf welchem Aktentyp das Feld erscheint.">
                    @foreach (var t in CustomFeldAktentypen.Alle)
                    {
                        <MudSelectItem Value="@t.TypName">@t.Anzeige</MudSelectItem>
                    }
                </MudSelect>

                <MudSelect T="CustomFeldTyp" Label="Feld-Typ" @bind-Value="_eingabe.FeldTyp" Variant="Variant.Outlined">
                    @foreach (var ft in CustomFeldTypAnzeige.Alle)
                    {
                        <MudSelectItem Value="ft">@CustomFeldTypAnzeige.Name(ft)</MudSelectItem>
                    }
                </MudSelect>

                @if (_eingabe.FeldTyp == CustomFeldTyp.Auswahl)
                {
                    <MudTextField @bind-Value="_eingabe.Optionen" Label="Auswahl-Optionen" Lines="4" Variant="Variant.Outlined"
                                  HelperText="Eine Option pro Zeile." />
                }

                <MudGrid>
                    <MudItem xs="6">
                        <MudSwitch T="bool" @bind-Value="_eingabe.Pflicht" Color="Color.Warning" Label="Pflichtfeld" />
                    </MudItem>
                    <MudItem xs="6">
                        <MudSwitch T="bool" @bind-Value="_eingabe.IstAktiv" Color="Color.Primary" Label="Aktiv (sichtbar)" />
                    </MudItem>
                    <MudItem xs="6">
                        <MudNumericField T="int" @bind-Value="_eingabe.Reihenfolge" Label="Reihenfolge" Variant="Variant.Outlined"
                                         HelperText="Kleinere Werte zuerst." />
                    </MudItem>
                </MudGrid>
            </MudStack>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Abbrechen">Abbrechen</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Speichern">Speichern</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    /// <summary>Beim Bearbeiten gesetzt: vorhandene Definition zum Vorbefüllen. Null = Anlegen.</summary>
    [Parameter] public CustomFeldDefinition? Vorhanden { get; set; }

    /// <summary>Beim Anlegen optional vorausgewählter Aktentyp.</summary>
    [Parameter] public string? VorgabeTyp { get; set; }

    private MudForm _form = default!;
    private readonly CustomFeldDefinitionEingabe _eingabe = new();

    protected override void OnInitialized()
    {
        if (Vorhanden is null)
        {
            if (!string.IsNullOrWhiteSpace(VorgabeTyp))
            {
                _eingabe.EntitaetTyp = VorgabeTyp;
            }
            return;
        }
        _eingabe.Name = Vorhanden.Name;
        _eingabe.EntitaetTyp = Vorhanden.EntitaetTyp;
        _eingabe.FeldTyp = Vorhanden.FeldTyp;
        _eingabe.Optionen = Vorhanden.Optionen;
        _eingabe.Pflicht = Vorhanden.Pflicht;
        _eingabe.Reihenfolge = Vorhanden.Reihenfolge;
        _eingabe.IstAktiv = Vorhanden.IstAktiv;
    }

    private async Task Speichern()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid)
        {
            return;
        }
        _eingabe.Name = _eingabe.Name.Trim();
        MudDialog.Close(DialogResult.Ok(_eingabe));
    }

    private void Abbrechen() => MudDialog.Cancel();

    /// <summary>Zeigt den Dialog zum Anlegen (ohne Werte) oder Bearbeiten (mit Definition). Liefert null bei Abbruch.</summary>
    public static async Task<CustomFeldDefinitionEingabe?> ZeigenAsync(IDialogService dialog, string titel,
        CustomFeldDefinition? vorhanden = null, string? vorgabeTyp = null)
    {
        var parameters = new DialogParameters<CustomFeldDefinitionDialog>
        {
            { x => x.Vorhanden, vorhanden },
            { x => x.VorgabeTyp, vorgabeTyp },
        };
        var referenz = await dialog.ShowAsync<CustomFeldDefinitionDialog>(titel, parameters);
        var ergebnis = await referenz.Result;
        return ergebnis is { Canceled: false, Data: CustomFeldDefinitionEingabe e } ? e : null;
    }
}
