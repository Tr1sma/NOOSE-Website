@* Dialog zum Anlegen/Bearbeiten einer Dok-Vorlage (Erfassungsmaske). Liefert eine DokVorlageEingabe zurück. *@

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form">
            <MudStack Spacing="3">
                <MudTextField @bind-Value="_eingabe.Name" Label="Name der Vorlage" Variant="Variant.Outlined"
                              Required="true" RequiredError="Name ist erforderlich" AutoFocus="true" Immediate="true"
                              HelperText="z. B. „Verhör – Standard“ oder „Routine-Kontrolle“." />
                <MudTextField @bind-Value="_eingabe.Beschreibung" Label="Beschreibung (optional)" Lines="2" Variant="Variant.Outlined"
                              HelperText="Wird in der Verwaltung und im Vorlagen-Picker angezeigt." />
                <MudGrid>
                    <MudItem xs="6">
                        <MudSwitch T="bool" @bind-Value="_eingabe.IstAktiv" Color="Color.Primary"
                                   Label="Aktiv (im Picker auswählbar)" />
                    </MudItem>
                    <MudItem xs="6">
                        <MudNumericField T="int" @bind-Value="_eingabe.Sortierung" Label="Sortierung" Variant="Variant.Outlined"
                                         HelperText="Kleinere Werte zuerst." />
                    </MudItem>
                </MudGrid>

                <MudDivider />
                <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">Vorbelegte Dok-Felder</MudText>

                <MudSelect T="MassnahmeAusgang" Label="Beendigung der Maßnahme" @bind-Value="_eingabe.StandardAusgang" Variant="Variant.Outlined">
                    @foreach (var a in MassnahmeAusgangAnzeige.Alle)
                    {
                        <MudSelectItem Value="a">@MassnahmeAusgangAnzeige.Name(a)</MudSelectItem>
                    }
                </MudSelect>
                <MudTextField @bind-Value="_eingabe.StandardGrund" Label="Grund (Vorgabe)" Lines="2" Variant="Variant.Outlined" />
                <MudTextField @bind-Value="_eingabe.StandardFraktion" Label="Fraktionszugehörigkeit – Freitext (Vorgabe)" Variant="Variant.Outlined"
                              HelperText="Org-Verknüpfung wird beim Dok selbst gewählt; hier nur der Freitext-Default." />
                <MudTextField @bind-Value="_eingabe.StandardErhalteneInformationen" Label="Erhaltene Informationen (Vorgabe)" Lines="3" Variant="Variant.Outlined" />
                <MudSwitch T="bool" @bind-Value="_eingabe.StandardWahrheitsserum" Color="Color.Primary" Label="Wahrheitsserum vorbelegen" />
            </MudStack>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Abbrechen">Abbrechen</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Speichern">Speichern</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    /// <summary>Beim Bearbeiten gesetzt: vorhandene Vorlage zum Vorbefüllen. Null = Anlegen.</summary>
    [Parameter] public DokVorlage? Vorhanden { get; set; }

    private MudForm _form = default!;
    private readonly DokVorlageEingabe _eingabe = new();

    protected override void OnInitialized()
    {
        if (Vorhanden is null)
        {
            return;
        }
        _eingabe.Name = Vorhanden.Name;
        _eingabe.Beschreibung = Vorhanden.Beschreibung;
        _eingabe.IstAktiv = Vorhanden.IstAktiv;
        _eingabe.Sortierung = Vorhanden.Sortierung;
        _eingabe.StandardGrund = Vorhanden.StandardGrund;
        _eingabe.StandardFraktion = Vorhanden.StandardFraktion;
        _eingabe.StandardErhalteneInformationen = Vorhanden.StandardErhalteneInformationen;
        _eingabe.StandardWahrheitsserum = Vorhanden.StandardWahrheitsserum;
        _eingabe.StandardAusgang = Vorhanden.StandardAusgang;
    }

    private async Task Speichern()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid)
        {
            return;
        }
        _eingabe.Name = _eingabe.Name.Trim();
        MudDialog.Close(DialogResult.Ok(_eingabe));
    }

    private void Abbrechen() => MudDialog.Cancel();

    /// <summary>Zeigt den Dialog zum Anlegen (ohne Werte) oder Bearbeiten (mit Vorlage). Liefert null bei Abbruch.</summary>
    public static async Task<DokVorlageEingabe?> ZeigenAsync(IDialogService dialog, string titel, DokVorlage? vorhanden = null)
    {
        var parameters = new DialogParameters<DokVorlageDialog> { { x => x.Vorhanden, vorhanden } };
        var referenz = await dialog.ShowAsync<DokVorlageDialog>(titel, parameters);
        var ergebnis = await referenz.Result;
        return ergebnis is { Canceled: false, Data: DokVorlageEingabe e } ? e : null;
    }
}
