@* Verwaltung der Dokument-Vorlagen (HTML-Body mit Platzhaltern). Anlegen/Bearbeiten öffnet den
   Volltext-Editor; Löschen erfolgt inline. Eingebettet als Reiter in /admin/vorlagen. *@
@inject IDokumentVorlageService VorlageService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
    <MudText Typo="Typo.h6">Dokument-Vorlagen</MudText>
    <MudSpacer />
    <MudButton Href="/admin/vorlagen/dokument-vorlage/neu" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add">
        Neue Vorlage
    </MudButton>
</MudStack>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
    Vorlagen für Bibliotheks-Dokumente: ein formatierter Text mit optionalen Platzhaltern (z. B.
    <code>{{Name}}</code>, <code>{{Aktenzeichen}}</code>), der beim Anlegen eines Dokuments übernommen und
    mit den Kontextdaten gefüllt wird.
</MudText>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudTable Items="_vorlagen" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="2" Dense="true">
        <HeaderContent>
            <MudTh><MudTableSortLabel T="DokumentVorlage" SortBy="@(x => x.Name)">Name</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="DokumentVorlage" SortBy="@(x => x.Beschreibung)">Beschreibung</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="DokumentVorlage" SortBy="@(x => x.Kategorie)">Kategorie</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="DokumentVorlage" SortBy="@(x => x.IstAktiv)">Status</MudTableSortLabel></MudTh>
            <MudTh Style="text-align:right;">Aktion</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="Beschreibung">
                <MudText Typo="Typo.body2" Class="mud-text-secondary">@(string.IsNullOrWhiteSpace(context.Beschreibung) ? "—" : context.Beschreibung)</MudText>
            </MudTd>
            <MudTd DataLabel="Kategorie">
                <MudText Typo="Typo.body2" Class="mud-text-secondary">@(string.IsNullOrWhiteSpace(context.Kategorie) ? "—" : context.Kategorie)</MudText>
            </MudTd>
            <MudTd DataLabel="Status">
                @if (context.IstAktiv)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">Aktiv</MudChip>
                }
                else
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">Inaktiv</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="Aktion" Style="text-align:right;">
                <MudStack Row="true" Spacing="1" Justify="Justify.FlexEnd" AlignItems="AlignItems.Center">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                                   Href="@($"/admin/vorlagen/dokument-vorlage/{context.Id}/bearbeiten")" aria-label="Vorlage bearbeiten" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                   OnClick="@(() => LoeschenAsync(context))" aria-label="Vorlage löschen" />
                </MudStack>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Typo="Typo.body2" Class="mud-text-secondary pa-4">Noch keine Dokument-Vorlagen angelegt.</MudText>
        </NoRecordsContent>
    </MudTable>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _laden = true;
    private List<DokumentVorlage> _vorlagen = new();
    private ClaimsPrincipal _user = default!;

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        await LadenAsync();
    }

    private async Task LadenAsync()
    {
        _laden = true;
        _vorlagen = await VorlageService.GetAlleAsync();
        _laden = false;
    }

    private async Task LoeschenAsync(DokumentVorlage vorlage)
    {
        var ok = await BestaetigenDialog.ZeigenAsync(DialogService, "Vorlage löschen?",
            $"„{vorlage.Name}“ wird in den Papierkorb verschoben.");
        if (!ok)
        {
            return;
        }
        try
        {
            await VorlageService.LoeschenAsync(vorlage.Id, _user);
            Snackbar.Add("Vorlage gelöscht.", Severity.Success);
            await LadenAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
