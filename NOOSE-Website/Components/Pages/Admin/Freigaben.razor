@page "/admin/freigaben"
@* Posteingang: Hochstufungs-Anträge entscheidet bereits Senior Special Agent+ (Policy HoechsteEinstufung);
   die vier übrigen Bereiche bleiben der Führung vorbehalten und sind unten gekapselt. *@
@attribute [Authorize(Policy = Policies.HoechsteEinstufungSeite)]
@inject IAgentVerwaltungService AgentService
@inject ITaskforceService TaskforceService
@inject IPersonalakteService PersonalakteService
@inject IAntragService AntragService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject FreigabenBroadcaster FreigabenBroadcaster

<PageTitle>Freigaben · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
    <MudIcon Icon="@Icons.Material.Filled.HowToReg" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h4">Freigabe-Posteingang</MudText>
</MudStack>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-6">
    Hochstufungs-Anträge sowie – für die Führung – neu registrierte Discord-Konten, beantragte
    Stammdatenänderungen, Taskforce- und Beförderungsanträge warten hier auf Entscheidung.
</MudText>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudText Typo="Typo.h6" Class="mb-2">Hochstufungs-Anträge</MudText>
    <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mb-3">
        Anträge auf die Einstufung „Gesichert staatsgefährdend“. Die Entscheidung trifft Senior Special Agent
        aufwärts bzw. ein Admin; bei Genehmigung wird die Einstufung der Akte gesetzt und im Verlauf protokolliert.
    </MudText>
    @if (_offeneHochstufungen.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">Keine offenen Hochstufungs-Anträge.</MudAlert>
    }
    else
    {
        <MudTable Items="_offeneHochstufungen" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="2">
            <HeaderContent>
                <MudTh><MudTableSortLabel T="Antrag" SortBy="@(x => x.ZielBezeichnung)">Ziel-Akte</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="Antrag" SortBy="@(x => x.ZielEinstufung)">Gewünscht</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="Antrag" SortBy="@(x => x.Begruendung)">Begründung</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="Antrag" SortBy="@(x => x.ErstelltAm)">Beantragt</MudTableSortLabel></MudTh>
                <MudTh Style="text-align:right;">Aktion</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Ziel-Akte">
                    <MudLink Href="@SuchNavigation.Route(context.ZielTyp, context.ZielId)" Typo="Typo.body2">@context.ZielBezeichnung</MudLink>
                </MudTd>
                <MudTd DataLabel="Gewünscht"><EinstufungBadge Wert="context.ZielEinstufung" /></MudTd>
                <MudTd DataLabel="Begründung">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@(string.IsNullOrWhiteSpace(context.Begruendung) ? "—" : context.Begruendung)</MudText>
                </MudTd>
                <MudTd DataLabel="Beantragt">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@(context.AntragstellerName ?? "—") · @context.ErstelltAm.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</MudText>
                </MudTd>
                <MudTd DataLabel="Aktion" Style="text-align:right;">
                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success"
                               StartIcon="@Icons.Material.Filled.Check" Class="mr-2"
                               OnClick="() => HochstufungEntscheiden(context, true)">Genehmigen</MudButton>
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error"
                               StartIcon="@Icons.Material.Filled.Close"
                               OnClick="() => HochstufungEntscheiden(context, false)">Ablehnen</MudButton>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }

    <AuthorizeView Policy="@Policies.Fuehrung" Context="fuehrung">
    <MudDivider Class="my-6" />

    <MudText Typo="Typo.h6" Class="mb-2">Registrierungen</MudText>
    <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mb-3">
        Beim Freischalten wird ein Dienstgrad vergeben; danach erhält der Agent beim nächsten Login Zugriff.
    </MudText>
    @if (_ausstehende.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">Keine ausstehenden Registrierungen.</MudAlert>
    }
    else
    {
        <MudTable Items="_ausstehende" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="2">
            <HeaderContent>
                <MudTh><MudTableSortLabel T="Agent" SortBy="@(x => AnzeigeName(x))">Agent</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="Agent" SortBy="@(x => x.DiscordUsername ?? x.DiscordId)">Discord</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="Agent" SortBy="@(x => x.RegistriertAm)">Registriert</MudTableSortLabel></MudTh>
                <MudTh Style="min-width:220px;"><MudTableSortLabel T="Agent" SortBy="@(x => (int)Auswahl(x.Id).Grad)">Dienstgrad</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="Agent" SortBy="@(x => Auswahl(x.Id).Tru)">TRU</MudTableSortLabel></MudTh>
                <MudTh Style="text-align:right;">Aktion</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Agent">
                    <MudText Typo="Typo.body2">@AnzeigeName(context)</MudText>
                </MudTd>
                <MudTd DataLabel="Discord">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@(context.DiscordUsername ?? context.DiscordId)</MudText>
                </MudTd>
                <MudTd DataLabel="Registriert">
                    <MudText Typo="Typo.caption">@context.RegistriertAm.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</MudText>
                </MudTd>
                <MudTd DataLabel="Dienstgrad">
                    <MudSelect T="Dienstgrad" @bind-Value="Auswahl(context.Id).Grad" Dense="true" Margin="Margin.Dense"
                               Variant="Variant.Outlined">
                        @foreach (var dg in DienstgradAnzeige.Alle)
                        {
                            <MudSelectItem Value="dg">@DienstgradAnzeige.Name(dg)</MudSelectItem>
                        }
                    </MudSelect>
                </MudTd>
                <MudTd DataLabel="TRU">
                    <MudCheckBox T="bool" @bind-Value="Auswahl(context.Id).Tru" Color="Color.Primary" />
                </MudTd>
                <MudTd DataLabel="Aktion" Style="text-align:right;">
                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success"
                               StartIcon="@Icons.Material.Filled.Check" Class="mr-2"
                               OnClick="() => Freigeben(context)">Freigeben</MudButton>
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error"
                               StartIcon="@Icons.Material.Filled.Close"
                               OnClick="() => Ablehnen(context)">Ablehnen</MudButton>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }

    <MudDivider Class="my-6" />

    <MudText Typo="Typo.h6" Class="mb-2">Namensänderungen</MudText>
    <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mb-3">
        Selbst beantragte Stammdatenänderungen von Agenten unterhalb Supervisory. Beim Genehmigen werden die
        Werte übernommen; der Agent sieht den neuen Namen beim nächsten Login.
    </MudText>
    @if (_namensaenderungen.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">Keine offenen Namensänderungen.</MudAlert>
    }
    else
    {
        <MudTable Items="_namensaenderungen" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="2">
            <HeaderContent>
                <MudTh><MudTableSortLabel T="Agent" SortBy="@(x => AnzeigeName(x))">Agent</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="Agent" SortBy="@(x => x.NamensaenderungBeantragtAm)">Beantragt</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="Agent" SortBy="@(x => Aenderungen(x).Count)">Änderungen</MudTableSortLabel></MudTh>
                <MudTh Style="text-align:right;">Aktion</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Agent">
                    <MudText Typo="Typo.body2">@AnzeigeName(context)</MudText>
                </MudTd>
                <MudTd DataLabel="Beantragt">
                    <MudText Typo="Typo.caption">@(context.NamensaenderungBeantragtAm?.ToLocalTime().ToString("dd.MM.yyyy HH:mm"))</MudText>
                </MudTd>
                <MudTd DataLabel="Änderungen">
                    <MudStack Spacing="0">
                        @foreach (var feld in Aenderungen(context))
                        {
                            <MudText Typo="Typo.caption">
                                <b>@feld.Label:</b> <span>@feld.Alt → @feld.Neu</span>
                            </MudText>
                        }
                    </MudStack>
                </MudTd>
                <MudTd DataLabel="Aktion" Style="text-align:right;">
                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success"
                               StartIcon="@Icons.Material.Filled.Check" Class="mr-2"
                               OnClick="() => NamenGenehmigen(context)">Genehmigen</MudButton>
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error"
                               StartIcon="@Icons.Material.Filled.Close"
                               OnClick="() => NamenAblehnen(context)">Ablehnen</MudButton>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }

    <MudDivider Class="my-6" />

    <MudText Typo="Typo.h6" Class="mb-2">Taskforce-Anträge</MudText>
    <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mb-3">
        Beantragte Taskforces warten auf Genehmigung. Beim Genehmigen wird die Einsatzgruppe aktiv; beim Ablehnen wird der Antrag abgelehnt.
    </MudText>
    @if (_beantragteTaskforces.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">Keine offenen Taskforce-Anträge.</MudAlert>
    }
    else
    {
        <MudTable Items="_beantragteTaskforces" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="2">
            <HeaderContent>
                <MudTh><MudTableSortLabel T="Taskforce" SortBy="@(x => x.Aktenzeichen)">Aktenzeichen</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="Taskforce" SortBy="@(x => x.Name)">Name</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="Taskforce" SortBy="@(x => TaskforceGeltungsbereichAnzeige.Name(x.Geltungsbereich))">Geltungsbereich</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="Taskforce" SortBy="@(x => x.ErstelltAm)">Beantragt</MudTableSortLabel></MudTh>
                <MudTh Style="text-align:right;">Aktion</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Aktenzeichen"><MudText Typo="Typo.caption" Class="mud-text-secondary">@context.Aktenzeichen</MudText></MudTd>
                <MudTd DataLabel="Name">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudLink Href="@($"/taskforces/{context.Id}")" Typo="Typo.body2">@context.Name</MudLink>
                        @if (context.IstVerschlusssache)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Warning" Size="Size.Small" Title="Verschlusssache" />
                        }
                    </MudStack>
                </MudTd>
                <MudTd DataLabel="Geltungsbereich">
                    <MudText Typo="Typo.caption">@TaskforceGeltungsbereichAnzeige.Name(context.Geltungsbereich)</MudText>
                </MudTd>
                <MudTd DataLabel="Beantragt">
                    <MudText Typo="Typo.caption">@context.ErstelltAm.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</MudText>
                </MudTd>
                <MudTd DataLabel="Aktion" Style="text-align:right;">
                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success"
                               StartIcon="@Icons.Material.Filled.Check" Class="mr-2"
                               OnClick="() => TaskforceGenehmigen(context)">Genehmigen</MudButton>
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error"
                               StartIcon="@Icons.Material.Filled.Close"
                               OnClick="() => TaskforceAblehnen(context)">Ablehnen</MudButton>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }

    <MudDivider Class="my-6" />

    <MudText Typo="Typo.h6" Class="mb-2">Beförderungsanträge</MudText>
    <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mb-3">
        Beantragte Beförderungen. Die Entscheidung trifft Deputy Director aufwärts bzw. ein Admin; bei Genehmigung
        wird der Rang gesetzt und der betroffene Agent muss sich neu anmelden.
    </MudText>
    @if (_offeneBefoerderungen.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">Keine offenen Beförderungsanträge.</MudAlert>
    }
    else
    {
        <MudTable Items="_offeneBefoerderungen" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="2">
            <HeaderContent>
                <MudTh><MudTableSortLabel T="AgentBefoerderungsantrag" SortBy="@(x => AgentName(x.AgentId))">Agent</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="AgentBefoerderungsantrag" SortBy="@(x => x.ZielDienstgrad)">Ziel-Dienstgrad</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="AgentBefoerderungsantrag" SortBy="@(x => x.Begruendung)">Begründung</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="AgentBefoerderungsantrag" SortBy="@(x => x.ErstelltAm)">Beantragt</MudTableSortLabel></MudTh>
                <MudTh Style="text-align:right;">Aktion</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Agent">
                    <MudLink Href="@($"/personal/{context.AgentId}")" Typo="Typo.body2">@AgentName(context.AgentId)</MudLink>
                </MudTd>
                <MudTd DataLabel="Ziel-Dienstgrad"><MudText Typo="Typo.body2">@DienstgradAnzeige.Name(context.ZielDienstgrad)</MudText></MudTd>
                <MudTd DataLabel="Begründung"><MudText Typo="Typo.caption" Class="mud-text-secondary">@(string.IsNullOrWhiteSpace(context.Begruendung) ? "—" : context.Begruendung)</MudText></MudTd>
                <MudTd DataLabel="Beantragt">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@(context.AntragstellerName ?? "—") · @context.ErstelltAm.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</MudText>
                </MudTd>
                <MudTd DataLabel="Aktion" Style="text-align:right;">
                    <AuthorizeView Policy="@Policies.BefoerderungEntscheiden" Context="auth">
                        <Authorized>
                            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success"
                                       StartIcon="@Icons.Material.Filled.Check" Class="mr-2"
                                       OnClick="() => BefoerderungEntscheiden(context, true)">Genehmigen</MudButton>
                            <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error"
                                       StartIcon="@Icons.Material.Filled.Close"
                                       OnClick="() => BefoerderungEntscheiden(context, false)">Ablehnen</MudButton>
                        </Authorized>
                        <NotAuthorized>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Entscheidung: Deputy Director+/Admin</MudText>
                        </NotAuthorized>
                    </AuthorizeView>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
    </AuthorizeView>
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _laden = true;
    private bool _istFuehrung;
    private List<Antrag> _offeneHochstufungen = new();
    private List<Agent> _ausstehende = new();
    private List<Agent> _namensaenderungen = new();
    private List<Taskforce> _beantragteTaskforces = new();
    private List<AgentBefoerderungsantrag> _offeneBefoerderungen = new();
    private Dictionary<string, string> _agentNamen = new();
    private ClaimsPrincipal _user = default!;
    private readonly Dictionary<string, Auswahlzustand> _auswahl = new();

    private sealed class Auswahlzustand
    {
        public Dienstgrad Grad { get; set; } = Dienstgrad.JuniorAgent;
        public bool Tru { get; set; }
    }

    private Auswahlzustand Auswahl(string agentId)
    {
        if (!_auswahl.TryGetValue(agentId, out var zustand))
        {
            zustand = new Auswahlzustand();
            _auswahl[agentId] = zustand;
        }
        return zustand;
    }

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        await LadenAsync();
    }

    private async Task LadenAsync()
    {
        _laden = true;
        _istFuehrung = _user.IstFuehrung();

        // Hochstufungs-Anträge sieht/entscheidet bereits Senior Special Agent+ (breiter als die Führung).
        _offeneHochstufungen = await AntragService.GetOffeneAsync(_istFuehrung);

        // Die übrigen vier Posteingangs-Bereiche sind der Führung vorbehalten.
        if (_istFuehrung)
        {
            _ausstehende = await AgentService.GetAusstehendeAsync();
            _namensaenderungen = await AgentService.GetAusstehendeNamensaenderungenAsync();
            _beantragteTaskforces = await TaskforceService.GetBeantragteAsync();
            _offeneBefoerderungen = await PersonalakteService.GetOffeneBefoerderungsantraegeAsync();
            _agentNamen = (await AgentService.GetAlleAsync())
                .ToDictionary(a => a.Id, a => string.IsNullOrWhiteSpace(a.Codename) ? "Unbenannter Agent" : a.Codename);
            foreach (var agent in _ausstehende)
            {
                _ = Auswahl(agent.Id);
            }
        }
        _laden = false;

        // Nach jeder Entscheidung (alle Aktionen rufen LadenAsync auf) den NavMenu-Badge live neu zählen lassen.
        FreigabenBroadcaster.Melde();
    }

    private async Task HochstufungEntscheiden(Antrag antrag, bool genehmigt)
    {
        var notiz = await GrundDialog.ZeigenAsync(DialogService,
            genehmigt ? $"Hochstufung von {antrag.ZielBezeichnung} genehmigen?" : $"Hochstufung von {antrag.ZielBezeichnung} ablehnen?",
            genehmigt
                ? "Die Akte wird auf „Gesichert staatsgefährdend“ eingestuft. Eine Notiz ist optional."
                : "Der Antrag wird abgelehnt. Eine Notiz ist optional.",
            bestaetigenText: genehmigt ? "Genehmigen" : "Ablehnen",
            label: "Notiz (optional)",
            farbe: genehmigt ? Color.Success : Color.Error);
        if (notiz is null)
        {
            return; // Abgebrochen
        }
        try
        {
            await AntragService.EntscheidenAsync(antrag.Id, genehmigt, string.IsNullOrWhiteSpace(notiz) ? null : notiz, _user);
            Snackbar.Add(genehmigt
                ? $"Hochstufung von {antrag.ZielBezeichnung} genehmigt."
                : $"Hochstufungs-Antrag von {antrag.ZielBezeichnung} abgelehnt.", genehmigt ? Severity.Success : Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        await LadenAsync();
    }

    private async Task Freigeben(Agent agent)
    {
        var auswahl = Auswahl(agent.Id);
        try
        {
            await AgentService.FreigebenAsync(agent.Id, auswahl.Grad, auswahl.Tru, _user);
            Snackbar.Add($"{AnzeigeName(agent)} als {DienstgradAnzeige.Name(auswahl.Grad)} freigegeben.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        await LadenAsync();
    }

    private async Task Ablehnen(Agent agent)
    {
        var grund = await GrundDialog.ZeigenAsync(DialogService,
            $"{AnzeigeName(agent)} ablehnen?",
            "Das Konto wird abgelehnt (gesperrt). Die Begründung wird protokolliert.",
            bestaetigenText: "Ablehnen", label: "Begründung (optional)", farbe: Color.Error);
        if (grund is null)
        {
            return;
        }
        try
        {
            await AgentService.AblehnenAsync(agent.Id, string.IsNullOrWhiteSpace(grund) ? "Registrierung abgelehnt" : grund, _user);
            Snackbar.Add($"{AnzeigeName(agent)} abgelehnt.", Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        await LadenAsync();
    }

    private async Task NamenGenehmigen(Agent agent)
    {
        try
        {
            await AgentService.NamensaenderungGenehmigenAsync(agent.Id, _user);
            Snackbar.Add($"Namensänderung von {AnzeigeName(agent)} genehmigt.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        await LadenAsync();
    }

    private async Task NamenAblehnen(Agent agent)
    {
        var grund = await GrundDialog.ZeigenAsync(DialogService,
            $"Namensänderung von {AnzeigeName(agent)} ablehnen?",
            "Der Antrag wird verworfen. Die Begründung wird protokolliert.",
            bestaetigenText: "Ablehnen", label: "Begründung (optional)", farbe: Color.Error);
        if (grund is null)
        {
            return;
        }
        try
        {
            await AgentService.NamensaenderungAblehnenAsync(agent.Id, string.IsNullOrWhiteSpace(grund) ? "Namensänderung abgelehnt" : grund, _user);
            Snackbar.Add($"Namensänderung von {AnzeigeName(agent)} abgelehnt.", Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        await LadenAsync();
    }

    private async Task TaskforceGenehmigen(Taskforce taskforce)
    {
        try
        {
            await TaskforceService.GenehmigungSetzenAsync(taskforce.Id, TaskforceStatus.Genehmigt, _user);
            Snackbar.Add($"Taskforce {taskforce.Aktenzeichen} genehmigt.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        await LadenAsync();
    }

    private async Task TaskforceAblehnen(Taskforce taskforce)
    {
        var ok = await BestaetigenDialog.ZeigenAsync(DialogService,
            $"Taskforce {taskforce.Aktenzeichen} ablehnen?",
            $"Der Antrag „{taskforce.Name}“ wird abgelehnt. Die Statusänderung wird protokolliert.",
            "Ablehnen");
        if (!ok)
        {
            return;
        }
        try
        {
            await TaskforceService.GenehmigungSetzenAsync(taskforce.Id, TaskforceStatus.Abgelehnt, _user);
            Snackbar.Add($"Taskforce {taskforce.Aktenzeichen} abgelehnt.", Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        await LadenAsync();
    }

    private string AgentName(string agentId) => _agentNamen.GetValueOrDefault(agentId) ?? "Agent";

    private async Task BefoerderungEntscheiden(AgentBefoerderungsantrag antrag, bool genehmigt)
    {
        try
        {
            await AgentService.BefoerderungEntscheidenAsync(antrag.Id, genehmigt, null, _user);
            Snackbar.Add(genehmigt
                ? $"Beförderung von {AgentName(antrag.AgentId)} genehmigt."
                : $"Beförderungsantrag von {AgentName(antrag.AgentId)} abgelehnt.", genehmigt ? Severity.Success : Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        await LadenAsync();
    }

    // Liefert nur die tatsächlich geänderten Felder als „alt → neu". Die Seite ist Führungs-gated, und die
    // Führungsebene darf den Klarnamen sehen (DarfKlarnameSehen) – daher hier keine Maskierung nötig.
    private static List<FeldAenderung> Aenderungen(Agent a)
    {
        var liste = new List<FeldAenderung>();
        void Pruefe(string label, string? alt, string? neu)
        {
            if (!string.Equals(alt ?? string.Empty, neu ?? string.Empty, StringComparison.Ordinal))
            {
                liste.Add(new FeldAenderung(label, Anzeige(alt), Anzeige(neu)));
            }
        }
        Pruefe("Codename", a.Codename, a.AusstehenderCodename);
        Pruefe("Klarname", a.Klarname, a.AusstehenderKlarname);
        Pruefe("Dienstnummer", a.Dienstnummer, a.AusstehendeDienstnummer);
        return liste;
    }

    private static string Anzeige(string? wert) => string.IsNullOrWhiteSpace(wert) ? "—" : wert;

    private sealed record FeldAenderung(string Label, string Alt, string Neu);

    // Neu registrierte Konten haben noch keinen Codenamen – zur Identifikation dient die Discord-Spalte.
    private static string AnzeigeName(Agent agent)
        => string.IsNullOrWhiteSpace(agent.Codename) ? "Neuer Agent" : agent.Codename;
}
