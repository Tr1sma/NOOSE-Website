@page "/admin/aktualitaet"
@attribute [Authorize(Policy = Policies.LeadershipPage)]
@inject IRecencyService RecencyService
@inject ISnackbar Snackbar

<PageTitle>Aktualitäts-Ampel · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
    <MudIcon Icon="@Icons.Material.Filled.Timelapse" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h4">Aktualitäts-Ampel</MudText>
</MudStack>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
    Die Ampel zeigt je Akte, wie lange die letzte Änderung zurückliegt. Lege je Aktentyp fest, ab wie vielen
    Tagen ohne Änderung eine Akte „gelb" (wird älter) bzw. „rot" (veraltet) wird.
</MudText>

<MudPaper Class="pa-3 mb-4" Elevation="1">
    <MudStack Row="true" Spacing="4" AlignItems="AlignItems.Center" Class="flex-wrap">
        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.Circle" Color="Color.Success" Size="Size.Small" /><MudText Typo="Typo.caption">Aktuell</MudText>
        </MudStack>
        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.Circle" Color="Color.Warning" Size="Size.Small" /><MudText Typo="Typo.caption">Wird älter (ab „Gelb")</MudText>
        </MudStack>
        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.Circle" Color="Color.Error" Size="Size.Small" /><MudText Typo="Typo.caption">Veraltet (ab „Rot")</MudText>
        </MudStack>
    </MudStack>
</MudPaper>

@if (_load)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudTable Items="_rows" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="2" Dense="true">
        <HeaderContent>
            <MudTh><MudTableSortLabel T="Row" SortBy="@(x => x.Display)">Aktentyp</MudTableSortLabel></MudTh>
            <MudTh Style="width:160px;"><MudTableSortLabel T="Row" SortBy="@(x => x.WarningDays)">Gelb ab (Tage)</MudTableSortLabel></MudTh>
            <MudTh Style="width:160px;"><MudTableSortLabel T="Row" SortBy="@(x => x.StaleDays)">Rot ab (Tage)</MudTableSortLabel></MudTh>
            <MudTh Style="text-align:right;">Aktion</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Aktentyp"><b>@context.Display</b></MudTd>
            <MudTd DataLabel="Gelb ab (Tage)">
                <MudNumericField @bind-Value="context.WarningDays" Min="0" Max="3650" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudTd>
            <MudTd DataLabel="Rot ab (Tage)">
                <MudNumericField @bind-Value="context.StaleDays" Min="0" Max="3650" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudTd>
            <MudTd DataLabel="Aktion" Style="text-align:right;">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Save" OnClick="@(() => SaveAsync(context))">
                    Speichern
                </MudButton>
            </MudTd>
        </RowTemplate>
    </MudTable>
    <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2">
        Hinweis: „Rot ab" wird automatisch auf mindestens „Gelb ab" gesetzt.
    </MudText>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _load = true;
    private List<Row> _rows = new();
    private ClaimsPrincipal _user = default!;

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _load = true;
        var thresholds = await RecencyService.GetThresholdsAsync();
        _rows = RecencyService.SupportedTypes.Select(t =>
        {
            var (warning, stale) = thresholds.TryGetValue(t.Type, out var s) ? s : (t.DefaultWarningDays, t.DefaultStaleDays);
            return new Row { Type = t.Type, Display = t.Display, WarningDays = warning, StaleDays = stale };
        }).ToList();
        _load = false;
    }

    private async Task SaveAsync(Row row)
    {
        try
        {
            await RecencyService.SaveAsync(row.Type, row.WarningDays, row.StaleDays, _user);
            Snackbar.Add($"Schwellwerte für „{row.Display}“ gespeichert.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private sealed class Row
    {
        public string Type { get; set; } = string.Empty;
        public string Display { get; set; } = string.Empty;
        public int WarningDays { get; set; }
        public int StaleDays { get; set; }
    }
}
