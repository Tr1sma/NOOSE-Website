@* Central tabbed template management bundling capture masks and document templates. *@
@page "/admin/vorlagen"
@attribute [Authorize(Policy = Policies.LeadershipPage)]
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Vorlagen · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
    <MudIcon Icon="@Icons.Material.Filled.Dvr" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h4">Vorlagen</MudText>
</MudStack>

<MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" TabPanelsClass="pa-4"
         @bind-ActivePanelIndex="_activeTab"
         @bind-ActivePanelIndex:after="@(() => TabUrlState.WriteAsync(JS, Nav, _tabs, _activeTab))">
    <MudTabPanel Text="Dok-Vorlagen" Icon="@Icons.Material.Filled.Dvr">
        <DocTemplatesManagement />
    </MudTabPanel>
    <MudTabPanel Text="Dokument-Vorlagen" Icon="@Icons.Material.Filled.Article">
        <DocumentTemplatesManagement />
    </MudTabPanel>
</MudTabs>

@code {
    private int _activeTab;
    // Slugs in panel order; keep active tab in the URL.
    private static readonly string[] _tabs = { "dok-vorlagen", "dokument-vorlagen" };

    protected override void OnInitialized() => _activeTab = TabUrlState.Read(Nav, _tabs);
}
