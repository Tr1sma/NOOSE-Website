@* Lookup/master-data admin overview: documents code-defined enums and links to editable lists. *@
@page "/admin/basisdaten"
@attribute [Authorize(Policy = Policies.LeadershipPage)]

<PageTitle>Basisdaten · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
    <MudIcon Icon="@Icons.Material.Filled.Storage" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h4">Basisdaten &amp; Wertelisten</MudText>
</MudStack>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-6">
    Übersicht aller Stammwerte. Pflegbare Basisdaten sind verlinkt; fest hinterlegte Wertelisten
    (Dienstgrade, Einstufungen …) sind hier dokumentiert und werden bei Bedarf per Code-Änderung erweitert.
</MudText>

<MudGrid Spacing="3">
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Pflegbare Basisdaten</MudText>
            <MudList T="string" Dense="true">
                <MudListItem T="string" Icon="@Icons.Material.Filled.Groups" Href="/fraktionen">Fraktionsliste (Akten)</MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Filled.Label" Href="/admin/tags">Tags</MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Filled.Dvr" Href="/admin/vorlagen">Vorlagen (Dok- &amp; Dokument-Vorlagen)</MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Filled.Tune" Href="/admin/custom-felder">Custom-Felder je Aktentyp</MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Filled.Gavel" Href="/gesetze">Gesetzbuch / Rechtsgrundlagen</MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Filled.Timelapse" Href="/admin/aktualitaet">Aktualitäts-Schwellwerte</MudListItem>
                <AuthorizeView Policy="@Policies.AdminPage" Context="partnerVis">
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Handshake" Href="/admin/partner-sichtbarkeit">Partner-Sichtbarkeit (je Rang)</MudListItem>
                </AuthorizeView>
            </MudList>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Dienstgrade</MudText>
            <MudStack Row="true" Spacing="1" Class="flex-wrap">
                @foreach (var dg in RankDisplay.All)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@RankDisplay.Name(dg)</MudChip>
                }
            </MudStack>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Einstufungen</MudText>
            <MudStack Row="true" Spacing="1" Class="flex-wrap">
                @foreach (var e in ClassificationDisplay.All)
                {
                    <ClassificationBadge Value="e" />
                }
            </MudStack>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Maßnahme-Ausgänge (Doks)</MudText>
            <MudStack Row="true" Spacing="1" Class="flex-wrap">
                @foreach (var a in MeasureOutcomeDisplay.All)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@MeasureOutcomeDisplay.Name(a)</MudChip>
                }
            </MudStack>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Beziehungstypen (Person ↔ Person)</MudText>
            <MudStack Row="true" Spacing="1" Class="flex-wrap">
                @foreach (var t in RelationTypeDisplay.All)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@RelationTypeDisplay.Name(t)</MudChip>
                }
            </MudStack>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Taskforce-Geltungsbereiche</MudText>
            <MudStack Row="true" Spacing="1" Class="flex-wrap">
                @foreach (var g in TaskforceScopeDisplay.All)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@TaskforceScopeDisplay.Name(g)</MudChip>
                }
            </MudStack>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Lebensstatus</MudText>
            <MudStack Row="true" Spacing="1" Class="flex-wrap">
                @foreach (var s in LifeStatusDisplay.All)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@LifeStatusDisplay.Name(s)</MudChip>
                }
            </MudStack>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Gruppen-Arten</MudText>
            <MudStack Row="true" Spacing="1" Class="flex-wrap">
                @foreach (var a in GroupsKindDisplay.All)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@GroupsKindDisplay.Name(a)</MudChip>
                }
            </MudStack>
        </MudPaper>
    </MudItem>
</MudGrid>
