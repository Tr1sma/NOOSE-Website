@* Archiv der automatischen Monats-Lageberichte (Phase 8 / Block D, Schritt 2). Nur für die Führung
   (FuehrungSeite öffnet auch der Nur-Lese-Aufsicht das Lesen; das manuelle Erzeugen bleibt an Fuehrung
   gebunden). Jeder Bericht ist ein eingefrorener Schnappschuss der vollständigen Lage. *@
@page "/lageberichte"
@attribute [Authorize(Policy = Policies.FuehrungSeite)]
@inject ILageberichtService LageberichtService
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Lageberichte · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2" Wrap="Wrap.Wrap" Class="mb-1">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
        <MudIcon Icon="@Icons.Material.Filled.Assessment" Color="Color.Primary" Size="Size.Large" />
        <MudText Typo="Typo.h4">Lageberichte</MudText>
    </MudStack>
    <AuthorizeView Policy="@Policies.Fuehrung">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PostAdd"
                   OnClick="ErzeugeAktuellen" Disabled="_arbeite">
            Bericht für diesen Monat erzeugen
        </MudButton>
    </AuthorizeView>
</MudStack>
<MudText Typo="Typo.body1" Class="mud-text-secondary mb-6">
    Automatisch erzeugte Monats-Lageberichte – ein eingefrorener Schnappschuss der vollständigen Lage
    (inkl. Verschlusssachen-Aggregate), daher der Führung vorbehalten. Der Bericht des Vormonats entsteht
    automatisch nach Monatsende.
</MudText>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_berichte.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
        Noch keine Lageberichte vorhanden. Der erste entsteht automatisch nach Monatsende – oder erzeuge jetzt manuell einen.
    </MudAlert>
}
else
{
    <MudPaper Elevation="2">
        <MudList T="string">
            @foreach (var b in _berichte)
            {
                <MudListItem T="string" OnClick="@(() => Oeffnen(b.Id))" Icon="@Icons.Material.Filled.Assessment" Style="cursor:pointer;">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <div>
                            <MudText Typo="Typo.body1"><b>@b.Titel</b></MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                Berichtsstand @b.ErzeugtAm.ToLocalTime().ToString("dd.MM.yyyy HH:mm") · erzeugt von @(b.ErzeugtVon ?? "System")
                            </MudText>
                        </div>
                        <AuthorizeView Policy="@Policies.Fuehrung">
                            @* Klick auf den Löschen-Knopf nicht zur Zeile durchreichen (sonst öffnet sich der Bericht). *@
                            <span @onclick:stopPropagation="true">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                               OnClick="@(() => Loeschen(b))" />
                            </span>
                        </AuthorizeView>
                    </MudStack>
                </MudListItem>
            }
        </MudList>
    </MudPaper>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private System.Security.Claims.ClaimsPrincipal _user = default!;
    private bool _laden = true;
    private bool _arbeite;
    private List<LageberichtKopf> _berichte = new();

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        await Laden();
    }

    private async Task Laden()
    {
        _laden = true;
        _berichte = await LageberichtService.GetArchivAsync();
        _laden = false;
    }

    private void Oeffnen(string id) => Nav.NavigateTo($"/lageberichte/{id}");

    private async Task ErzeugeAktuellen()
    {
        _arbeite = true;
        try
        {
            var jetzt = DateTime.UtcNow;
            // Aktuellen Monat (Stand jetzt) erzeugen bzw. auffrischen – ermöglicht einen sofort sichtbaren Bericht.
            var bericht = await LageberichtService.ErzeugeMonatAsync(jetzt.Year, jetzt.Month, ersetzeVorhandene: true, _user.GetAgentId());
            await Laden();
            Snackbar.Add(bericht is null ? "Es wurde kein Bericht erzeugt." : $"{bericht.Titel} erzeugt.", Severity.Success);
        }
        catch (Exception)
        {
            Snackbar.Add("Der Lagebericht konnte nicht erzeugt werden.", Severity.Error);
        }
        finally
        {
            _arbeite = false;
        }
    }

    private async Task Loeschen(LageberichtKopf b)
    {
        var bestaetigt = await DialogService.ShowMessageBoxAsync("Lagebericht löschen?",
            $"{b.Titel} in den Papierkorb verschieben?", yesText: "Löschen", cancelText: "Abbrechen");
        if (bestaetigt == true)
        {
            await LageberichtService.LoeschenAsync(b.Id, _user);
            await Laden();
            Snackbar.Add("Lagebericht in den Papierkorb verschoben.", Severity.Success);
        }
    }
}
