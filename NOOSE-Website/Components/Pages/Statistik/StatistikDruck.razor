@* Druckansicht der Statistik (Phase 8 / Block D): rendert die Auswertungen als reine Tabellen
   (keine Donuts – die invertiert das Druck-CSS sauber auf Papier) im gemeinsamen DruckRahmen,
   der den Behördenkopf, den Druckvermerk und den automatischen Browser-Druckdialog liefert.
   Aus Sicht des Aufrufers VS-gefiltert; in einem neuen Tab geöffnet → „Als PDF speichern". *@
@page "/statistik/druck"
@layout DruckLayout
@using NOOSE_Website.Models.Dashboard
@inject IStatistikService Statistik

<PageTitle>Statistik – Druckansicht · NOOSE</PageTitle>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_report is { } r)
{
    <DruckRahmen Titel="Statistik &amp; Auswertungen" ZurueckHref="/statistik" ZurueckText="Zurück zur Statistik"
                 GedrucktVon="@_druckVon" IstVerschlusssache="false"
                 Fusszeile="NOOSE-interne Auswertung · Stand der Erzeugung · Weitergabe nur nach Freigabe durch die Führung.">
        <StatistikReportTabellen Report="r" />
    </DruckRahmen>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _laden = true;
    private string? _druckVon;
    private StatistikReport? _report;

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthStateTask).User;
        _druckVon = user.GetCodename();
        _report = await Statistik.GetReportAsync(user.IstFuehrung(), user.GetAgentId());
        _laden = false;
    }
}
