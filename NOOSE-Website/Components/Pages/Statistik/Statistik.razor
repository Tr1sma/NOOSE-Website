@* Statistik & Auswertungen (Phase 8 / Block D): aggregierte Verteilungen, 12-Monats-Verlauf und die
   Top-Listen der gefährlichsten Akten – mit CSV- und Druck-Export. Für alle aktiven Agenten sichtbar
   (App-Default-Policy AktiverAgent); alle Zahlen sind aus Sicht des Aufrufers VS-gefiltert. *@
@page "/statistik"
@inject IStatistikService StatistikService
@inject NavigationManager Nav

<PageTitle>Statistik & Auswertungen · NOOSE</PageTitle>

<div class="dashboard-seite">
<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2" Wrap="Wrap.Wrap" Class="mb-1">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
        <MudIcon Icon="@Icons.Material.Filled.QueryStats" Color="Color.Primary" Size="Size.Large" />
        <MudText Typo="Typo.h4">Statistik &amp; Auswertungen</MudText>
    </MudStack>
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
        @* Browser-Navigation (Target="_blank") liefert die CSV über den Minimal-API-Endpunkt aus –
           Content-Disposition=attachment startet den Download, ohne die Seite zu verlassen. *@
        <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.Download"
                   Href="/statistik/export/verteilungen.csv" Target="_blank">Verteilungen (CSV)</MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.Download"
                   Href="/statistik/export/personen.csv" Target="_blank">Personen (CSV)</MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.Download"
                   Href="/statistik/export/fraktionen.csv" Target="_blank">Fraktionen (CSV)</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Print"
                   Href="/statistik/druck" Target="_blank">Druck / PDF</MudButton>
    </MudStack>
</MudStack>
<MudText Typo="Typo.body1" Class="mud-text-secondary mb-6">
    Aggregierte Auswertungen über den gesamten Aktenbestand – aus deiner Sicht (Verschlusssachen werden gefiltert).
</MudText>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_report is { } r)
{
    @* ---- Kennzahl-Streifen (identisch zum Lagezentrum) ---- *@
    <MudGrid>
        <MudItem xs="6" sm="4" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Badge" Color="Color.Primary" />
                    <MudText Typo="Typo.overline" Class="mud-text-secondary">Personen</MudText>
                </MudStack>
                <MudText Typo="Typo.h4" Class="mt-2">@r.Kennzahlen.Personen</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Groups" Color="Color.Primary" />
                    <MudText Typo="Typo.overline" Class="mud-text-secondary">Organisationen</MudText>
                </MudStack>
                <MudText Typo="Typo.h4" Class="mt-2">@r.Kennzahlen.FraktionenUndGruppen</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Radar" Color="Color.Primary" />
                    <MudText Typo="Typo.overline" Class="mud-text-secondary">Operationen</MudText>
                </MudStack>
                <MudText Typo="Typo.h4" Class="mt-2">@r.Kennzahlen.Operationen</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.FolderSpecial" Color="Color.Primary" />
                    <MudText Typo="Typo.overline" Class="mud-text-secondary">Offene Vorgänge</MudText>
                </MudStack>
                <MudText Typo="Typo.h4" Class="mt-2">@r.Kennzahlen.OffeneVorgaenge</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* ---- Verteilungs-Diagramme (Donuts) ---- *@
    <MudText Typo="Typo.h6" Class="mt-6 mb-2">Verteilungen</MudText>
    <MudGrid>
        <MudItem xs="12" sm="6" md="4" Class="d-flex">
            <VerteilungChart Titel="Personen nach Einstufung" Segmente="@r.PersonenNachEinstufung" Farben="_farbenEinstufung" Height="260px" />
        </MudItem>
        <MudItem xs="12" sm="6" md="4" Class="d-flex">
            <VerteilungChart Titel="Personen nach Gefährdung" Segmente="@r.PersonenNachGefaehrdung" Farben="_farbenGefaehrdung" Height="260px" />
        </MudItem>
        <MudItem xs="12" sm="6" md="4" Class="d-flex">
            <VerteilungChart Titel="Personen nach Lebensstatus" Segmente="@r.PersonenNachLebensstatus" Farben="_farbenLebensstatus" Height="260px" />
        </MudItem>
        <MudItem xs="12" sm="6" md="4" Class="d-flex">
            <VerteilungChart Titel="Fraktionen nach Gefährdung" Segmente="@r.FraktionenNachGefaehrdung" Farben="_farbenGefaehrdung" Height="260px" />
        </MudItem>
        <MudItem xs="12" sm="6" md="4" Class="d-flex">
            <VerteilungChart Titel="Maßnahme-Ausgänge" Segmente="@r.MassnahmeAusgaenge" Farben="_farbenAusgang" Height="260px" />
        </MudItem>
        <MudItem xs="12" sm="6" md="4" Class="d-flex">
            <VerteilungChart Titel="Vorgänge nach Status" Segmente="@r.VorgaengeNachStatus" Farben="_farbenStatus" Height="260px" />
        </MudItem>
    </MudGrid>

    @* ---- 12-Monats-Verlauf ---- *@
    <MudText Typo="Typo.h6" Class="mt-6 mb-2">Verlauf der letzten 12 Monate</MudText>
    <MudPaper Class="pa-4" Elevation="2">
        <ZeitverlaufChart Titel="Erfasste Maßnahmen &amp; neue Personenakten" Punkte="@r.Zeitverlauf"
                          Reihen="@_zeitreihen" Farben="_farbenZeitverlauf" Height="320px" />
    </MudPaper>

    @* ---- Top-Listen der gefährlichsten Akten ---- *@
    <MudText Typo="Typo.h6" Class="mt-6 mb-2">Gefährlichste Akten</MudText>
    <MudGrid>
        <MudItem xs="12" md="6">@TopListe("Gefährlichste Personen", r.TopPersonen)</MudItem>
        <MudItem xs="12" md="6">@TopListe("Gefährlichste Fraktionen", r.TopFraktionen)</MudItem>
    </MudGrid>
}
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _laden = true;
    private StatistikReport? _report;
    private (string Name, IReadOnlyList<int> Werte)[] _zeitreihen = Array.Empty<(string, IReadOnlyList<int>)>();

    // NOOSE-Farben je Diagramm – Reihenfolge identisch zur jeweiligen *Anzeige.Alle-Reihenfolge (stabile Legende).
    private static readonly string[] _farbenEinstufung = { "#9BA8B8", "#22D3EE", "#D29922", "#F85149" };          // Unbekannt · Prüffall · Verdachtsfall · Gesichert staatsgefährdend
    private static readonly string[] _farbenGefaehrdung = { "#9BA8B8", "#3FB950", "#22D3EE", "#D29922", "#F85149" }; // Keine · Niedrig · Mittel · Hoch · Kritisch
    private static readonly string[] _farbenLebensstatus = { "#3FB950", "#F85149", "#D29922" };                    // Lebend · Tot · Flüchtig
    private static readonly string[] _farbenAusgang = { "#22D3EE", "#3FB950", "#D29922", "#F85149" };              // Läuft noch · Offiziell entlassen · Amnestie-Spritze · Erschossen
    private static readonly string[] _farbenStatus = { "#22D3EE", "#7C8CF8", "#D29922", "#3FB950", "#9BA8B8" };    // Offen · In Bearbeitung · Ruht · Abgeschlossen · Archiviert
    private static readonly string[] _farbenZeitverlauf = { "#F85149", "#22D3EE" };                                // Maßnahmen · Neuzugänge

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthStateTask).User;
        _report = await StatistikService.GetReportAsync(user.IstFuehrung(), user.GetAgentId());
        _zeitreihen = new (string, IReadOnlyList<int>)[]
        {
            ("Maßnahmen", _report.Zeitverlauf.Select(m => m.Massnahmen).ToList()),
            ("Neuzugänge", _report.Zeitverlauf.Select(m => m.Neuzugaenge).ToList()),
        };
        _laden = false;
    }

    private string GefaehrdungFarbe(GefaehrdungsStufe stufe)
    {
        var i = (int)stufe;
        return i >= 0 && i < _farbenGefaehrdung.Length ? _farbenGefaehrdung[i] : "#9BA8B8";
    }

    private RenderFragment TopListe(string titel, IReadOnlyList<StatistikTopEintrag> eintraege) =>@<MudPaper Class="pa-4" Elevation="2">
        <MudText Typo="Typo.subtitle1" Class="mb-2">@titel</MudText>
        @if (eintraege.Count == 0)
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine bewerteten Akten.</MudText>
        }
        else
        {
            <MudSimpleTable Dense="true" Hover="true" Striped="true" Elevation="0">
                <thead>
                    <tr>
                        <th style="width:2.5rem;">#</th>
                        <th>Akte</th>
                        <th style="width:5rem;text-align:right;">Score</th>
                        <th style="width:7rem;">Stufe</th>
                    </tr>
                </thead>
                <tbody>
                    @{ var rang = 0; }
                    @foreach (var e in eintraege)
                    {
                        rang++;
                        <tr style="cursor:pointer;" @onclick="@(() => Nav.NavigateTo(e.Href))">
                            <td>@rang</td>
                            <td>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <span style="@($"display:inline-block;width:10px;height:10px;border-radius:50%;background:{GefaehrdungFarbe(e.Stufe)};flex:none;")"></span>
                                    <div>
                                        <MudText Typo="Typo.body2"><b>@e.Name</b></MudText>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@e.Aktenzeichen</MudText>
                                    </div>
                                </MudStack>
                            </td>
                            <td style="text-align:right;"><b>@e.Score</b></td>
                            <td>@GefaehrdungsStufeLogic.Name(e.Stufe)</td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        }
    </MudPaper>;
}
