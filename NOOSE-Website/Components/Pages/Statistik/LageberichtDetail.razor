@* Detailansicht eines archivierten Lageberichts (Phase 8 / Block D, Schritt 2): rendert den eingefrorenen
   Schnappschuss als Dokument im DruckRahmen (ohne automatischen Druckdialog – der Drucken-/PDF-Knopf bleibt).
   Nur für die Führung; der Bericht enthält die vollständige Lage inkl. Verschlusssachen-Aggregate. *@
@page "/lageberichte/{Id}"
@layout DruckLayout
@attribute [Authorize(Policy = Policies.FuehrungSeite)]
@inject ILageberichtService Lageberichte

<PageTitle>@(_anzeige?.Titel ?? "Lagebericht") · NOOSE</PageTitle>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_anzeige is null)
{
    <div class="pa-6">
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-3">
            Dieser Lagebericht existiert nicht (mehr) oder ist nicht lesbar.
        </MudAlert>
        <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack" Href="/lageberichte">Zurück zum Archiv</MudButton>
    </div>
}
else
{
    <DruckRahmen Titel="@_anzeige.Titel" ZurueckHref="/lageberichte" ZurueckText="Zurück zum Archiv"
                 IstVerschlusssache="false" AutomatischDrucken="false"
                 Fusszeile="NOOSE-interne Auswertung · automatisch erzeugter Lagebericht · Weitergabe nur nach Freigabe durch die Führung.">
        <p class="druck-meta">
            Automatisch erzeugter Lagebericht · Berichtsstand @_anzeige.ErzeugtAm.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
            · erzeugt von @(_anzeige.ErzeugtVon ?? "System")
        </p>
        <StatistikReportTabellen Report="_anzeige.Report" />
    </DruckRahmen>
}

@code {
    [Parameter] public string Id { get; set; } = string.Empty;

    private bool _laden = true;
    private LageberichtAnzeige? _anzeige;

    protected override async Task OnInitializedAsync()
    {
        _anzeige = await Lageberichte.GetAnzeigeAsync(Id);
        _laden = false;
    }
}
