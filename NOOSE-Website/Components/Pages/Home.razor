@page "/dashboard"
@using NOOSE_Website.Models.Dashboard
@inject IDashboardService Dashboard
@inject IFollowupService FollowupService
@inject NavigationManager Nav

<PageTitle>Dashboard · NOOSE</PageTitle>

<div class="dashboard-seite">
<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
    <MudIcon Icon="@Icons.Material.Filled.Shield" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h4">Lagezentrum</MudText>
</MudStack>
<MudText Typo="Typo.body1" Class="mud-text-secondary mb-6">
    <AuthorizeView>
        <Authorized Context="auth">Willkommen zurück, <b>@Codename(auth.User)</b>. </Authorized>
    </AuthorizeView>
    Überblick über den aktuellen Bestand und die jüngsten Aktivitäten im Dienst.
</MudText>

@if (_isPartner)
{
    <MudPaper Class="pa-6" Elevation="2">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
            <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Primary" />
            <MudText Typo="Typo.h6">Partner-Lesezugriff</MudText>
        </MudStack>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
            Willkommen. Sie sehen ausschließlich die für Ihre Behörde freigegebenen Akten – schreibgeschützt.
        </MudText>
        <MudStack Row="true" Spacing="2">
            <MudButton Href="/personen" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Badge">Personen-Akten</MudButton>
            <MudButton Href="/fraktionen" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Groups">Fraktionen</MudButton>
        </MudStack>
    </MudPaper>
}
else
{
<MudGrid>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Badge" Color="Color.Primary" />
                <MudText Typo="Typo.overline" Class="mud-text-secondary">Personen-Akten</MudText>
            </MudStack>
            <MudText Typo="Typo.h4" Class="mt-2">@Number(k => k.People)</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Groups" Color="Color.Primary" />
                <MudText Typo="Typo.overline" Class="mud-text-secondary">Organisationen</MudText>
            </MudStack>
            <MudText Typo="Typo.h4" Class="mt-2">@Number(k => k.FactionsAndGroups)</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Radar" Color="Color.Primary" />
                <MudText Typo="Typo.overline" Class="mud-text-secondary">Operationen</MudText>
            </MudStack>
            <MudText Typo="Typo.h4" Class="mt-2">@Number(k => k.Operations)</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.FolderSpecial" Color="Color.Primary" />
                <MudText Typo="Typo.overline" Class="mud-text-secondary">Offene Vorgänge</MudText>
            </MudStack>
            <MudText Typo="Typo.h4" Class="mt-2">@Number(k => k.OpenCases)</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Inbox" Color="Color.Warning" />
                <MudText Typo="Typo.overline" Class="mud-text-secondary">Offene Anträge</MudText>
            </MudStack>
            <MudText Typo="Typo.h4" Class="mt-2">@Number(k => k.OpenRequests)</MudText>
        </MudPaper>
    </MudItem>
    @* Classified count is itself classified; leadership-only tile. *@
    @if (_isLeadership)
    {
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Error" />
                    <MudText Typo="Typo.overline" Class="mud-text-secondary">Verschlusssachen</MudText>
                </MudStack>
                <MudText Typo="Typo.h4" Class="mt-2">@Number(k => k.Classified)</MudText>
            </MudPaper>
        </MudItem>
    }
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Timelapse" Color="Color.Warning" />
                <MudText Typo="Typo.overline" Class="mud-text-secondary">Veraltete Akten</MudText>
            </MudStack>
            <MudText Typo="Typo.h4" Class="mt-2">@Number(k => k.StaleRecords)</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.EventRepeat" Color="Color.Info" />
                <MudText Typo="Typo.overline" Class="mud-text-secondary">Fällige Wiedervorlagen</MudText>
            </MudStack>
            <MudText Typo="Typo.h4" Class="mt-2">@(_load ? "…" : _myDue.Count.ToString())</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudText Typo="Typo.h6" Class="mt-6 mb-2">Verteilungen</MudText>
@if (_load)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_distributions is { } v)
{
    <MudGrid>
        <MudItem xs="12" md="6" Class="d-flex">
            <MudPaper Class="pa-4 flex-grow-1" Elevation="2">
                <MudGrid>
                    <MudItem xs="12" sm="6" Class="d-flex">
                        <DistributionChart Bare="true" Height="170px" Title="Fälle nach Einstufung" Segments="@v.CasesByClassification" Colours="_coloursClassification" />
                    </MudItem>
                    <MudItem xs="12" sm="6" Class="d-flex">
                        <DistributionChart Bare="true" Height="170px" Title="Maßnahme-Ausgänge" Segments="@v.MeasureOutcomes" Colours="_coloursOutcome" />
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6" Class="d-flex">
            <MudPaper Class="pa-4 flex-grow-1" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-2">Fraktionen nach Gefährdung</MudText>
                @if (_factionsHazard.Count == 0)
                {
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Fraktionen erfasst.</MudText>
                }
                else
                {
                    <div class="dashboard-fraktionsliste">
                        <MudList T="string" Dense="true">
                            @foreach (var f in _factionsHazard)
                            {
                                <MudListItem T="string" OnClick="@(() => OpenRecord(f.Href))" Style="cursor:pointer;">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                            <span style="@($"display:inline-block;width:12px;height:12px;border-radius:50%;background:{HazardColour(f.Level)};flex:none;")"></span>
                                            <div>
                                                <MudText Typo="Typo.body2"><b>@f.Name</b></MudText>
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@f.CaseNumber</MudText>
                                            </div>
                                        </MudStack>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@HazardLevelLogic.Name(f.Level)</MudText>
                                    </MudStack>
                                </MudListItem>
                            }
                        </MudList>
                    </div>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudGrid Class="mt-1">
        <MudItem xs="12" md="6" Class="d-flex">
            <MudPaper Class="pa-4 flex-grow-1" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-2">Personen nach Gefährdung</MudText>
                @if (_peopleHazard.Count == 0)
                {
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine bewerteten Personen.</MudText>
                }
                else
                {
                    <div class="dashboard-fraktionsliste">
                        <MudList T="string" Dense="true">
                            @foreach (var p in _peopleHazard)
                            {
                                <MudListItem T="string" OnClick="@(() => OpenRecord(p.Href))" Style="cursor:pointer;">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                            <span style="@($"display:inline-block;width:12px;height:12px;border-radius:50%;background:{HazardColour(p.Level)};flex:none;")"></span>
                                            <div>
                                                <MudText Typo="Typo.body2"><b>@p.Name</b></MudText>
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@p.CaseNumber</MudText>
                                            </div>
                                        </MudStack>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@HazardLevelLogic.Name(p.Level)</MudText>
                                    </MudStack>
                                </MudListItem>
                            }
                        </MudList>
                    </div>
                }
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6" Class="d-flex">
            <MudPaper Class="pa-4 flex-grow-1 d-flex flex-column" Elevation="2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.QueryStats" Color="Color.Primary" />
                    <MudText Typo="Typo.h6">Statistik & Auswertungen</MudText>
                </MudStack>
                <MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
                    Verteilungen über Einstufung, Gefährdung, Lebensstatus, Maßnahmen und Vorgänge,
                    der 12-Monats-Verlauf und die gefährlichsten Akten – mit CSV- und Druck-Export.
                </MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.QueryStats"
                           Href="/statistik" Class="mt-auto align-self-start">Zur vollständigen Statistik</MudButton>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@if (!_load && _myDue.Count > 0)
{
    <MudPaper Class="pa-4 mt-6" Elevation="2">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
            <MudIcon Icon="@Icons.Material.Filled.EventRepeat" Color="Color.Info" />
            <MudText Typo="Typo.h6">Meine fälligen Wiedervorlagen</MudText>
        </MudStack>
        <MudList T="string" Dense="true">
            @foreach (var w in _myDue)
            {
                <MudListItem T="string" Icon="@Icons.Material.Filled.EventBusy" IconColor="Color.Error"
                             OnClick="@(() => OpenRecord(w.Href))" Style="@(w.Href is null ? null : "cursor:pointer;")">
                    <MudText Typo="Typo.body2"><b>@w.Display</b> · fällig @w.DueAt.ToLocalTime().ToString("dd.MM.yyyy")</MudText>
                    @if (!string.IsNullOrWhiteSpace(w.Note))
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@w.Note</MudText>
                    }
                </MudListItem>
            }
        </MudList>
    </MudPaper>
}

@if (!_load && _distributions is { } va)
{
    <MudGrid Class="mt-1">
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4" Elevation="2" Style="height:28rem;display:flex;flex-direction:column;">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
                    <MudIcon Icon="@Icons.Material.Filled.Timelapse" Color="Color.Warning" />
                    <MudText Typo="Typo.h6">Aktualisierungsbedarf</MudText>
                </MudStack>
                @if (_updateNeed.Count == 0)
                {
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">Alles aktuell – kein Aktualisierungsbedarf.</MudText>
                }
                else
                {
                    <div class="dashboard-spalte-body">
                        <MudList T="string" Dense="true">
                            @foreach (var a in _updateNeed)
                            {
                                <MudListItem T="string" OnClick="@(() => OpenRecord(a.Href))" Style="cursor:pointer;">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                        <RecencyIndicator Level="a.Level" ReferenceDateUtc="a.ReferenceUtc" />
                                        <div>
                                            <MudText Typo="Typo.body2"><b>@TypeLabel(a.Type)</b> »@a.Name«</MudText>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                                @a.CaseNumber · zuletzt @a.ReferenceUtc.ToLocalTime().ToString("dd.MM.yyyy")
                                            </MudText>
                                        </div>
                                    </MudStack>
                                </MudListItem>
                            }
                        </MudList>
                        @if (_updateNeed.Count >= 30)
                        {
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">… weitere vorhanden (älteste 30 angezeigt).</MudText>
                        }
                    </div>
                }
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4" Elevation="2" Style="height:28rem;display:flex;flex-direction:column;">
                <div class="dashboard-spalte-body d-flex flex-column justify-center">
                    <DistributionChart Bare="true" Height="240px" Title="Offene Anträge nach Art" Segments="@va.OpenRequestsByKind" Colours="_coloursRequests" />
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4" Elevation="2" Style="height:28rem;display:flex;flex-direction:column;">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.History" Color="Color.Primary" />
                    <MudText Typo="Typo.h6">Letzte Änderungen</MudText>
                </MudStack>
                @if (_changes.Count == 0)
                {
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Änderungen erfasst.</MudText>
                }
                else
                {
                    <div class="dashboard-spalte-body">
                        <MudTimeline TimelinePosition="TimelinePosition.Start" Class="mt-2">
                            @foreach (var x in _changes)
                            {
                                <MudTimelineItem Color="@Colour(x.Action)" Size="Size.Small">
                                    <MudText Typo="Typo.body2">
                                        <b>@TypeLabel(x.RecordType)</b>
                                        @if (x.RecordDeleted)
                                        {
                                            <span>»@x.RecordName«</span>
                                            <span class="mud-text-secondary"> (im Papierkorb)</span>
                                        }
                                        else
                                        {
                                            <MudLink Href="@Link(x)">»@x.RecordName«</MudLink>
                                        }
                                        <span class="mud-text-secondary"> · @ActionText(x)</span>
                                    </MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                        @x.CaseNumber · @x.Timestamp.ToLocalTime().ToString("dd.MM.yyyy HH:mm") · @(x.AgentName ?? "System")
                                    </MudText>
                                </MudTimelineItem>
                            }
                        </MudTimeline>
                    </div>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
}
}
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _load = true;
    private bool _isLeadership;
    private bool _isPartner;
    private DashboardMetrics? _metrics;
    private DashboardDistributions? _distributions;
    private List<DashboardChange> _changes = new();
    private List<FollowupDashboardItem> _myDue = new();
    private List<DashboardStaleRecord> _updateNeed = new();
    private List<DashboardFactionHazard> _factionsHazard = new();
    private List<DashboardFactionHazard> _peopleHazard = new();

    // Colour order must match the segment order in DashboardService
    private static readonly string[] _coloursClassification = { "#9BA8B8", "#22D3EE", "#D29922", "#F85149" };
    private static readonly string[] _coloursOutcome = { "#22D3EE", "#3FB950", "#D29922", "#F85149" };
    private static readonly string[] _coloursHazard = { "#9BA8B8", "#3FB950", "#22D3EE", "#D29922", "#F85149" };
    private static readonly string[] _coloursRequests = { "#22D3EE", "#3FB950", "#7C8CF8", "#D29922", "#F85149" };

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthStateTask).User;
        _isPartner = user.IsPartner();
        if (_isPartner)
        {
            // partner-safe landing
            _load = false;
            return;
        }
        _isLeadership = user.IsLeadership();
        var meId = user.GetAgentId(); // for taskforce-membership visibility of metrics/lists
        _metrics = await Dashboard.GetMetricsAsync(_isLeadership, meId);
        _distributions = await Dashboard.GetDistributionsAsync(_isLeadership, meId);
        _changes = await Dashboard.GetLastChangesAsync(_isLeadership, meId, 50);
        _myDue = await FollowupService.GetMyDueAsync(user);
        _updateNeed = await Dashboard.GetUpdateNeedAsync(_isLeadership, meId);
        _factionsHazard = await Dashboard.GetFactionsByHazardAsync(_isLeadership);
        _peopleHazard = await Dashboard.GetPeopleByHazardAsync(_isLeadership);
        _load = false;
    }

    private string HazardColour(HazardLevel level)
    {
        var i = (int)level;
        return i >= 0 && i < _coloursHazard.Length ? _coloursHazard[i] : "#9BA8B8";
    }

    private void OpenRecord(string? href)
    {
        if (!string.IsNullOrEmpty(href))
        {
            Nav.NavigateTo(href);
        }
    }

    private string Number(Func<DashboardMetrics, int> selection)
        => _metrics is { } k ? selection(k).ToString() : "…";

    private static string Codename(System.Security.Claims.ClaimsPrincipal user)
    {
        var codename = user.GetCodename();
        return string.IsNullOrWhiteSpace(codename) ? "Unbenannter Agent" : codename;
    }

    private static string TypeLabel(DashboardRecordType t) => t switch
    {
        DashboardRecordType.Person => "Person",
        DashboardRecordType.Faction => "Fraktion",
        DashboardRecordType.Party => "Partei",
        DashboardRecordType.Operation => "Operation",
        DashboardRecordType.Taskforce => "Taskforce",
        DashboardRecordType.Case => "Vorgang",
        _ => "Personengruppe",
    };

    private static string Link(DashboardChange x) => x.RecordType switch
    {
        DashboardRecordType.Person => $"/personen/{x.RecordId}",
        DashboardRecordType.Faction => $"/fraktionen/{x.RecordId}",
        DashboardRecordType.Party => $"/parteien/{x.RecordId}",
        DashboardRecordType.Operation => $"/operationen/{x.RecordId}",
        DashboardRecordType.Taskforce => $"/taskforces/{x.RecordId}",
        DashboardRecordType.Case => $"/vorgaenge/{x.RecordId}",
        _ => $"/personengruppen/{x.RecordId}",
    };

    private static string ActionText(DashboardChange x)
    {
        var verb = x.Action switch
        {
            AuditAction.Created => x.Detail is null ? "angelegt" : "hinzugefügt",
            AuditAction.Modified => "geändert",
            AuditAction.Deleted => x.Detail is null ? "in den Papierkorb verschoben" : "entfernt",
            AuditAction.Restored => "wiederhergestellt",
            _ => x.Action.ToString(),
        };
        return x.Detail is null ? verb : $"{x.Detail} {verb}";
    }

    private static Color Colour(AuditAction a) => a switch
    {
        AuditAction.Created => Color.Success,
        AuditAction.Modified => Color.Info,
        AuditAction.Deleted => Color.Error,
        AuditAction.Restored => Color.Warning,
        _ => Color.Default,
    };
}
