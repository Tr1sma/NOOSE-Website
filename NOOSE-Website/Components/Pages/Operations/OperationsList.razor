@page "/operationen"
@inject IOperationService OperationService
@inject IRecencyService Recency
@inject NavigationManager Nav

<PageTitle>Operationen · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
    <MudIcon Icon="@Icons.Material.Filled.Radar" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h4">Operationen</MudText>
    <MudSpacer />
    <AuthorizeView Policy="@Policies.Leadership">
        <MudButton Href="/operationen/papierkorb" Variant="Variant.Text" Color="Color.Default" StartIcon="@Icons.Material.Filled.Delete">Papierkorb</MudButton>
    </AuthorizeView>
    <AuthorizeView Policy="@Policies.WriteAccess" Context="schreib">
        <MudButton Href="/operationen/neu" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add">Neue Operation</MudButton>
    </AuthorizeView>
</MudStack>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-6">
    Einsätze und Einsatzberichte mit Zeitraum, Ablauf, Ergebnis, beteiligten Agents und Einstufung.
</MudText>

@if (_load)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudDataGrid T="OperationRow" Items="_rows" Hover="true" Filterable="false" SortMode="SortMode.Multiple"
                 QuickFilter="Filter" Elevation="2" RowClick="@(args => Open(args.Item))" Dense="true">
        <ToolBarContent>
            <MudTextField @bind-Value="_search" Placeholder="Suchen (Titel, Aktenzeichen, Typ)…" Immediate="true"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" />
            <MudSpacer />
            <MudSelect T="OperationStatus?" Value="_statusFilter" ValueChanged="StatusSelected" Label="Status" Dense="true"
                       Clearable="true" Variant="Variant.Outlined" Style="max-width:220px;">
                <MudSelectItem T="OperationStatus?" Value="@((OperationStatus?)null)">Alle</MudSelectItem>
                @foreach (var s in OperationStatusDisplay.All)
                {
                    <MudSelectItem T="OperationStatus?" Value="@s">@OperationStatusDisplay.Name(s)</MudSelectItem>
                }
            </MudSelect>
        </ToolBarContent>
        <Columns>
            <PropertyColumn Property="x => x.CaseNumber" Title="Aktenzeichen" />
            <TemplateColumn Sortable="true" Title="Titel" SortBy="x => x.Title">
                <CellTemplate>
                    @* Real link for middle-click/keyboard reachability. *@
                    <MudLink Href="@($"/operationen/{context.Item.Id}")" @onclick:stopPropagation="true">@context.Item.Title</MudLink>
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.Type" Title="Typ" />
            <TemplateColumn Sortable="true" Title="Status" SortBy="x => x.Status">
                <CellTemplate>
                    <OperationStatusChip Status="context.Item.Status" />
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.Start" Title="Beginn" Format="dd.MM.yyyy" />
            <TemplateColumn Sortable="true" Title="Einstufung" SortBy="x => x.Classification">
                <CellTemplate>
                    <ClassificationBadge Value="context.Item.Classification" />
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Sortable="true" Title="Verschluss" SortBy="x => x.IsClassified">
                <CellTemplate>
                    @if (context.Item.IsClassified)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Lock">@DocumentClassificationDisplay.ChipLabel(context.Item.SecrecyLevel)</MudChip>
                    }
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Sortable="true" Title="Aktualität" SortBy="x => x.Level">
                <CellTemplate>
                    <RecencyIndicator Level="context.Item.Level" ReferenceDateUtc="context.Item.RefreshedUtc" />
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.Refreshed" Title="Zuletzt" Format="dd.MM.yyyy HH:mm" />
        </Columns>
        <NoRecordsContent>
            <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-6">
                <MudIcon Icon="@Icons.Material.Filled.Radar" Color="Color.Default" Size="Size.Large" />
                <AuthorizeView Policy="@Policies.PartnerView" Context="partnerEmpty">
                    <Authorized>
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">Für Ihre Behörde wurde noch keine Operation freigegeben.</MudText>
                    </Authorized>
                    <NotAuthorized>
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Operationen – lege die erste an.</MudText>
                    </NotAuthorized>
                </AuthorizeView>
                <AuthorizeView Policy="@Policies.WriteAccess" Context="schreib">
                    <MudButton Href="/operationen/neu" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add">Neue Operation</MudButton>
                </AuthorizeView>
            </MudStack>
        </NoRecordsContent>
        <PagerContent>
            <MudDataGridPager T="OperationRow" />
        </PagerContent>
    </MudDataGrid>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _load = true;
    private string _search = string.Empty;
    private OperationStatus? _statusFilter;
    private List<OperationRow> _rows = new();

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthStateTask).User;
        var operations = await OperationService.GetListAsync(ViewerScope.From(user));
        var settings = await Recency.GetSettingsAsync(nameof(Operation));
        var now = DateTime.UtcNow;
        _rows = operations.Select(o =>
        {
            var referenceUtc = o.ModifiedAt ?? o.CreatedAt;
            return new OperationRow
            {
                Id = o.Id,
                CaseNumber = o.CaseNumber,
                Title = o.Title,
                Type = o.Type ?? string.Empty,
                Status = o.Status,
                Start = o.Start?.ToLocalTime(),
                Classification = o.Classification,
                IsClassified = o.IsClassified,
                SecrecyLevel = o.SecrecyLevel,
                RefreshedUtc = referenceUtc,
                Refreshed = referenceUtc.ToLocalTime(),
                Level = settings.AgingDisabled || o.AgingDisabled ? RecencyLevel.Fresh : RecencyAssessment.Level(settings.WarningDays, settings.StaleDays, referenceUtc, now),
            };
        }).ToList();
        _load = false;
    }

    private void StatusSelected(OperationStatus? status)
    {
        _statusFilter = status;
        StateHasChanged();
    }

    private bool Filter(OperationRow z)
    {
        if (_statusFilter is not null && z.Status != _statusFilter)
        {
            return false;
        }
        if (string.IsNullOrWhiteSpace(_search))
        {
            return true;
        }
        var s = _search.Trim();
        return z.Title.Contains(s, StringComparison.OrdinalIgnoreCase)
            || z.CaseNumber.Contains(s, StringComparison.OrdinalIgnoreCase)
            || z.Type.Contains(s, StringComparison.OrdinalIgnoreCase);
    }

    private void Open(OperationRow z) => Nav.NavigateTo($"/operationen/{z.Id}");

    private sealed class OperationRow
    {
        public string Id { get; set; } = string.Empty;
        public string CaseNumber { get; set; } = string.Empty;
        public string Title { get; set; } = string.Empty;
        public string Type { get; set; } = string.Empty;
        public OperationStatus Status { get; set; }
        public DateTime? Start { get; set; }
        public Classification Classification { get; set; }
        public bool IsClassified { get; set; }
        public DocumentClassification SecrecyLevel { get; set; }
        public DateTime RefreshedUtc { get; set; }
        public DateTime Refreshed { get; set; }
        public RecencyLevel Level { get; set; }
    }
}
