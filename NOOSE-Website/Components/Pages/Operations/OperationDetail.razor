@page "/operationen/{Id}"
@inject IOperationService OperationService
@inject IAccessLogService AccessLog
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject IPartnerVisibilityPolicyService PartnerPolicy

<PageTitle>@(_operation?.Title ?? "Operation") · NOOSE</PageTitle>

@if (_load)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_operation is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
        Operation nicht gefunden oder nicht zugänglich (ggf. Verschlusssache).
    </MudAlert>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/operationen" aria-label="Zurück" />
        <MudSpacer />
        <MudTooltip Text="Druckansicht – Akte drucken / als PDF speichern">
            <MudIconButton Icon="@Icons.Material.Filled.Print" Color="Color.Default"
                           Href="@($"/operationen/{Id}/druck")" Target="_blank"
                           aria-label="Druckansicht öffnen" />
        </MudTooltip>
        @if (!_isPartner)
        {
            <FollowButton EntityType="@nameof(Operation)" EntityId="@_operation.Id" User="_user" />
            <JobCreateButton EntityType="@nameof(Operation)" EntityId="@_operation.Id" />
        }
        <AuthorizeView Policy="@Policies.Leadership" Context="freigabe">
            <PartnerShareButton EntityType="@nameof(Operation)" EntityId="@_operation.Id" />
        </AuthorizeView>
        <AuthorizeView Policy="@Policies.WriteAccess" Context="schreib">
            <MudButton Href="@($"/operationen/{_operation.Id}/bearbeiten")" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit">Bearbeiten</MudButton>
        </AuthorizeView>
        <AuthorizeView Policy="@Policies.Leadership">
            <MudButton Color="Color.Error" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Delete" OnClick="DeleteAsync">Löschen</MudButton>
        </AuthorizeView>
    </MudStack>

    @if (!_isPartner)
    {
        <MudPaper Class="pa-2 mb-4" Elevation="1">
            <TagChips EntityType="@nameof(Operation)" EntityId="@_operation.Id" User="_user" />
        </MudPaper>
    }

    <MudGrid>
        <MudItem xs="12" md="4" lg="3">
            <div class="akte-steckkarte">
                <OperationCard Operation="_operation" InvestigationLead="_investigationLead" />
            </div>
        </MudItem>

        <MudItem xs="12" md="8" lg="9">
            @if (_renderTabs.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    Für Ihren Zugang sind in dieser Akte keine Bereiche freigegeben.
                </MudAlert>
            }
            else
            {
            <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" TabPanelsClass="pa-4"
                     @bind-ActivePanelIndex="_activeTab"
                     @bind-ActivePanelIndex:after="@(() => TabUrlState.Write(Nav, _renderTabs, _activeTab))">
                @if (TabOn("stammdaten"))
                {
                <MudTabPanel Text="Stammdaten" Icon="@Icons.Material.Filled.Info">
                    <MudStack Spacing="3">
                        @if (!string.IsNullOrWhiteSpace(_operation.Expiry))
                        {
                            <div>
                                <MudText Typo="Typo.subtitle2">Ablauf</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary" Style="white-space:pre-line;">@_operation.Expiry</MudText>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(_operation.Result))
                        {
                            <div>
                                <MudText Typo="Typo.subtitle2">Ergebnis</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary" Style="white-space:pre-line;">@_operation.Result</MudText>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(_operation.Remarks))
                        {
                            <div>
                                <MudText Typo="Typo.subtitle2">Bemerkungen</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary" Style="white-space:pre-line;">@_operation.Remarks</MudText>
                            </div>
                        }
                        @if (string.IsNullOrWhiteSpace(_operation.Expiry) && string.IsNullOrWhiteSpace(_operation.Result) && string.IsNullOrWhiteSpace(_operation.Remarks))
                        {
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">Keine weiteren Stammdaten erfasst.</MudText>
                        }
                    </MudStack>
                </MudTabPanel>
                }
                @* assigned NOOSE agents: internal only *@
                @if (!_isPartner)
                {
                <MudTabPanel Text="Beteiligte Agents" Icon="@Icons.Material.Filled.ManageAccounts">
                    <OperationAgentsPanel OperationId="@_operation.Id" User="_user" Changed="InvestigationLeadRefreshAsync" />
                </MudTabPanel>
                }
                @if (TabOn("beziehungen"))
                {
                <MudTabPanel Text="Beteiligte / Beziehungen" Icon="@Icons.Material.Filled.Hub">
                    <OperationInvolvedPanel OperationId="@_operation.Id" User="_user" />
                </MudTabPanel>
                }
                @if (TabOn("einstufung"))
                {
                <MudTabPanel Text="Einstufung" Icon="@Icons.Material.Filled.Shield">
                    <ClassificationPanel Current="_operation.Classification" History="_classificationHistory" User="_user" OnSet="ClassificationSetAsync"
                                     EntityType="@nameof(Operation)" EntityId="@_operation.Id" TargetDesignation="@($"{_operation.Title} ({_operation.CaseNumber})")" />
                </MudTabPanel>
                }
                @* partner-safe: Sources child service is partner-safe *@
                @if (TabOn("quellen"))
                {
                <MudTabPanel Text="Quellen" Icon="@Icons.Material.Filled.AttachFile">
                    <SourcesPanel EntityType="@nameof(Operation)" EntityId="@_operation.Id" User="_user" />
                </MudTabPanel>
                }
                @* partner-safe child tabs *@
                @if (TabOn("wiedervorlagen"))
                {
                <MudTabPanel Text="Wiedervorlagen" Icon="@Icons.Material.Filled.EventRepeat">
                    <FollowupPanel EntityType="@nameof(Operation)" EntityId="@_operation.Id" User="_user" />
                </MudTabPanel>
                }
                @if (TabOn("kommentare"))
                {
                <MudTabPanel Text="Kommentare" Icon="@Icons.Material.Filled.Comment">
                    <CommentPanel EntityType="@nameof(Operation)" EntityId="@_operation.Id" User="_user" />
                </MudTabPanel>
                }
                @if (TabOn("zusatzfelder"))
                {
                <MudTabPanel Text="Zusatzfelder" Icon="@Icons.Material.Filled.Tune">
                    <CustomFieldsPanel EntityType="@nameof(Operation)" EntityId="@_operation.Id" User="_user" />
                </MudTabPanel>
                }
                @* partner-safe: timeline filters cross-refs for partners *@
                @if (TabOn("historie"))
                {
                <MudTabPanel Text="Zeitstrahl" Icon="@Icons.Material.Filled.Timeline">
                    <TimelinePanel EntityType="@nameof(Operation)" EntityId="@_operation.Id" User="_user" @key="_historyKey" />
                </MudTabPanel>
                }
            </MudTabs>
            }
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public string Id { get; set; } = default!;
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _load = true;
    private bool _isPartner;
    private Operation? _operation;
    private List<string> _investigationLead = new();
    private List<ClassificationHistory> _classificationHistory = new();
    private ClaimsPrincipal _user = default!;
    private Guid _historyKey = Guid.NewGuid();
    private string? _loadedId;

    // Aktiver Tab wird in der URL (?tab=…) gehalten – Reihenfolge muss den MudTabPanels entsprechen.
    private int _activeTab;
    private static readonly string[] _tabs =
    {
        "stammdaten", "agents", "beziehungen", "einstufung",
        "quellen", "wiedervorlagen", "kommentare", "zusatzfelder", "historie",
    };

    // partner tab gating: null = no restriction (internal/unconfigured/individually released)
    private IReadOnlySet<string>? _visibleTabs;
    private List<string> _renderTabs = new();
    private bool TabOn(string slug) => _visibleTabs is null || _visibleTabs.Contains(slug);
    private void RebuildRenderTabs() => _renderTabs = _tabs.Where(s => (s != "agents" || !_isPartner) && TabOn(s)).ToList();

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        _isPartner = _user.IsPartner();
    }

    // Diese Seite wird bei Navigation /operationen/{A} → /operationen/{B} WIEDERVERWENDET (gleiche Komponente);
    // OnInitializedAsync läuft dann NICHT erneut. Daher hier auf den Id-Wechsel reagieren – sonst bliebe die alte
    // Akte stehen. Das kurze _laden=true mountet den Tab-Baum (samt Kind-Panels) frisch. Tab-/Query-Wechsel: Id
    // bleibt gleich → kein Neuladen.
    protected override async Task OnParametersSetAsync()
    {
        if (_loadedId == Id)
        {
            return;
        }
        _loadedId = Id;
        _load = true;
        _operation = null;
        await LoadAsync();
        _activeTab = TabUrlState.Read(Nav, _renderTabs);
        if (_operation is not null)
        {
            await AccessLog.LogViewAsync(nameof(Operation), _operation.Id);
        }
    }

    private async Task LoadAsync()
    {
        // Kein _laden = true beim Neuladen: sonst entfernt das @if (_laden) die MudTabs aus dem
        // Render-Baum, ein frisch gemountetes MudTabs springt auf den ersten Tab.
        var scope = ViewerScope.From(_user);
        _operation = await OperationService.GetDetailAsync(Id, scope);
        if (_operation is not null)
        {
            _classificationHistory = await OperationService.GetClassificationHistoryAsync(_operation.Id, scope);
            // partners: skip agent fan-out
            if (!_isPartner)
            {
                await InvestigationLeadLoadAsync();
            }
        }
        _visibleTabs = _isPartner && _operation is not null
            ? await PartnerPolicy.GetVisibleTabsAsync(_user, nameof(Operation), _operation.Id)
            : null;
        RebuildRenderTabs();
        _load = false;
    }

    private async Task InvestigationLeadLoadAsync()
    {
        if (_operation is null)
        {
            return;
        }
        var el = await OperationService.GetInvestigationLeadAsync(_operation.Id);
        _investigationLead = el.Select(a => a.Agent?.Codename ?? "?").ToList();
    }

    private async Task InvestigationLeadRefreshAsync()
    {
        await InvestigationLeadLoadAsync();
        StateHasChanged();
    }

    private async Task NewLoadAsync()
    {
        await LoadAsync();
        _historyKey = Guid.NewGuid();
        StateHasChanged();
    }

    private async Task ClassificationSetAsync((Classification New, string? Justification) input)
    {
        if (_operation is null)
        {
            return;
        }
        await OperationService.ClassificationSetAsync(_operation.Id, input.New, input.Justification, _user);
        await NewLoadAsync();
    }

    private async Task DeleteAsync()
    {
        if (_operation is null)
        {
            return;
        }
        var ok = await ConfirmDialog.ShowAsync(DialogService, "Operation löschen?",
            "Die Operation wird in den Papierkorb verschoben und kann von der Führung wiederhergestellt werden.");
        if (!ok)
        {
            return;
        }
        await OperationService.DeleteAsync(_operation.Id, _user);
        Snackbar.Add("Operation in den Papierkorb verschoben.", Severity.Success);
        Nav.NavigateTo("/operationen");
    }
}
