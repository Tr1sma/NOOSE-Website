@* Shared create/edit form for an operation. *@
@inject IProfileSuggestionService SuggestionService

<MudGrid>
    <MudItem xs="12">
        <MudTextField @bind-Value="Input.Title" Label="Titel" Required="true" RequiredError="Titel ist erforderlich"
                      Variant="Variant.Outlined" />
    </MudItem>

    <MudItem xs="12" md="6">
        <MudAutocomplete T="string" @bind-Value="Input.Type" Label="Typ / Kategorie (optional)"
                         SearchFunc="@TypeSearch" Variant="Variant.Outlined"
                         CoerceText="false" CoerceValue="true" ResetValueOnEmptyText="false"
                         MinCharacters="0" Immediate="true" MaxItems="20" Clearable="true"
                         Placeholder="z. B. Razzia, Observation, Infiltration" />
    </MudItem>
    <MudItem xs="12" md="6">
        <MudSelect T="OperationStatus" @bind-Value="Input.Status" Label="Status" Variant="Variant.Outlined">
            @foreach (var s in OperationStatusDisplay.All)
            {
                <MudSelectItem Value="s">@OperationStatusDisplay.Name(s)</MudSelectItem>
            }
        </MudSelect>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudDatePicker @bind-Date="Input.Start" Label="Beginn (optional)" Variant="Variant.Outlined"
                       Clearable="true" Editable="true" DateFormat="dd.MM.yyyy" />
    </MudItem>
    <MudItem xs="12" md="6">
        <MudDatePicker @bind-Date="Input.End" Label="Ende (optional)" Variant="Variant.Outlined"
                       Clearable="true" Editable="true" DateFormat="dd.MM.yyyy" />
    </MudItem>

    <MudItem xs="12" md="6">
        <MudTextField @bind-Value="Input.Location" Label="Ort (optional)" Variant="Variant.Outlined"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Place" />
    </MudItem>

    @if (ShowClassification)
    {
        <MudItem xs="12" md="6">
            <MudSelect T="Classification" @bind-Value="Input.Classification" Label="Einstufung" Variant="Variant.Outlined">
                @foreach (var e in ClassificationDisplay.All)
                {
                    <MudSelectItem Value="e" Disabled="@(e == Classification.SecuredStateThreatening && !MayHighest)">
                        @ClassificationDisplay.Name(e)
                    </MudSelectItem>
                }
            </MudSelect>
        </MudItem>
    }
    @if (SecrecyOptions.Count > 1)
    {
        <MudItem xs="12" md="6">
            <MudSelect T="DocumentClassification" @bind-Value="Input.SecrecyLevel" Label="Verschluss-Stufe"
                       Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock"
                       HelperText="Bestimmt, wer die Akte sehen darf.">
                @foreach (var o in SecrecyOptions)
                {
                    <MudSelectItem T="DocumentClassification" Value="@o">@DocumentClassificationDisplay.Label(o)</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
    }

    <MudItem xs="12">
        <MudTextField @bind-Value="Input.Expiry" Label="Ablauf" Lines="4" Variant="Variant.Outlined"
                      HelperText="Verlauf des Einsatzes." />
    </MudItem>
    <MudItem xs="12">
        <MudTextField @bind-Value="Input.Result" Label="Ergebnis" Lines="3" Variant="Variant.Outlined"
                      HelperText="Ausgang/Resultat des Einsatzes." />
    </MudItem>
    <MudItem xs="12">
        <MudTextField @bind-Value="Input.Remarks" Label="Bemerkungen" Lines="3" Variant="Variant.Outlined"
                      HelperText="Interne Vermerke (getrennt von Ablauf/Ergebnis)." />
    </MudItem>
</MudGrid>

@code {
    [Parameter, EditorRequired] public OperationInput Input { get; set; } = default!;
    /// <summary>Show classification in the form (create only).</summary>
    [Parameter] public bool ShowClassification { get; set; }
    [Parameter] public bool MayHighest { get; set; }
    [Parameter] public bool IsLeadership { get; set; }
    /// <summary>Secrecy levels the current user may assign (DocumentViewerScope.AssignableOptions).</summary>
    [Parameter] public IReadOnlyList<DocumentClassification> SecrecyOptions { get; set; } = Array.Empty<DocumentClassification>();

    private IReadOnlyList<string> _typeSuggestions = Array.Empty<string>();

    protected override async Task OnInitializedAsync()
    {
        _typeSuggestions = await SuggestionService.GetAsync(SuggestionType.OperationType);
    }

    private Task<IEnumerable<string>> TypeSearch(string value, CancellationToken token)
    {
        IEnumerable<string> hit = string.IsNullOrWhiteSpace(value)
            ? _typeSuggestions
            : _typeSuggestions.Where(v => v.Contains(value.Trim(), StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(hit);
    }
}
