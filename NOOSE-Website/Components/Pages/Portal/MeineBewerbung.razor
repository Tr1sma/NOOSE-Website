@page "/portal"
@layout ApplicantPortalLayout
@attribute [AllowAnonymous]
@inject IBewerbungService BewerbungService
@inject IBewerbungssperreService SperreService
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Bewerbung · NOOSE</PageTitle>

@if (_blocked && _ban is not null)
{
    <MudPaper Elevation="4" Class="pa-8">
        <BewerbungssperreCard Ban="_ban" />
    </MudPaper>
}
else if (_ready)
{
    <MudPaper Elevation="4" Class="pa-8">
        <MudStack Spacing="4">
            <MudText Typo="Typo.h4">Deine Bewerbung</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Bitte fülle die folgenden Angaben sorgfältig aus. Nach dem Absenden kannst du den Status hier im
                Portal verfolgen und mit dem HRB kommunizieren.
            </MudText>

            <MudTextField @bind-Value="_model.AcademicDegree" Label="Akademischer Grad (optional)" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="_model.Name" Label="Name" Required="true" Variant="Variant.Outlined" />
            <MudDatePicker @bind-Date="_model.BirthDate" Label="Geburtsdatum" Variant="Variant.Outlined"
                           MaxDate="DateTime.Today" />
            <MudTextField @bind-Value="_model.Employer" Label="Arbeitgeber" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="_model.PriorExperience" Label="Vorerfahrung" Variant="Variant.Outlined"
                          Lines="3" Placeholder="z. B. 05.10.2024 – 14.06.2026 LSPD" />
            <MudTextField @bind-Value="_model.CoverLetter" Label="Anschreiben" Variant="Variant.Outlined"
                          Lines="6" Placeholder="Deine Motivation und weitere Angaben …" />

            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                <MudButton HtmlTag="label" Variant="Variant.Outlined" Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.AttachFile" for="anhang">
                    Anhang wählen (optional)
                </MudButton>
                <InputFile id="anhang" OnChange="OnFile" accept=".pdf,.doc,.docx,.png,.jpg,.jpeg" style="display:none;" />
                @if (_file is not null)
                {
                    <MudText Typo="Typo.body2">@_file.Name</MudText>
                }
            </MudStack>

            <MudStack Row="true" Justify="Justify.FlexEnd">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Send"
                           OnClick="SubmitAsync" Disabled="_busy">Bewerbung absenden</MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private const long MaxBytes = 15 * 1024 * 1024;
    private ClaimsPrincipal _user = default!;
    private bool _ready;
    private bool _blocked;
    private bool _busy;
    private BewerbungssperreInfo? _ban;
    private readonly BewerbungSubmitModel _model = new();
    private IBrowserFile? _file;

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        if (!_user.IsApplicant())
        {
            Nav.NavigateTo("/karriere", forceLoad: true);
            return;
        }
        var own = await BewerbungService.GetOwnAsync(_user);
        if (own is not null && own.Status != BewerbungStatus.Abgelehnt && own.Status != BewerbungStatus.Geschlossen)
        {
            // an open or accepted application already exists
            Nav.NavigateTo("/portal/status");
            return;
        }
        // no application, or a closed/rejected one — eligible to (re)apply unless banned or blacklisted
        _ban = await SperreService.GetActiveAsync(_user.GetAgentId() ?? string.Empty);
        if (_ban is not null)
        {
            _blocked = true;
            return;
        }
        _ready = true;
    }

    private void OnFile(InputFileChangeEventArgs e) => _file = e.File;

    private async Task SubmitAsync()
    {
        if (string.IsNullOrWhiteSpace(_model.Name))
        {
            Snackbar.Add("Bitte gib deinen Namen an.", Severity.Warning);
            return;
        }
        _busy = true;
        try
        {
            if (_file is not null)
            {
                await using var stream = _file.OpenReadStream(MaxBytes);
                await BewerbungService.SubmitAsync(_model, stream, _file.Name, _file.ContentType, _user);
            }
            else
            {
                await BewerbungService.SubmitAsync(_model, null, null, null, _user);
            }
            Snackbar.Add("Deine Bewerbung wurde eingereicht.", Severity.Success);
            // full reload guarantees the status page re-evaluates the freshly created application
            Nav.NavigateTo("/portal/status", forceLoad: true);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }
}
