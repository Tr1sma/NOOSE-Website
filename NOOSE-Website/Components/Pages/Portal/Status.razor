@page "/portal/status"
@layout ApplicantPortalLayout
@attribute [AllowAnonymous]
@inject IBewerbungService BewerbungService
@inject IBewerbungTestService TestService
@inject IBewerbungssperreService SperreService
@inject NavigationManager Nav

<PageTitle>Status · NOOSE</PageTitle>

@if (_ready)
{
    <div style="display:flex;flex-direction:column;height:calc(100dvh - 180px);min-height:460px;gap:16px;">
        @* compact status bar keeps the chat as the centrepiece *@
        <MudPaper Elevation="4" Class="pa-4" Style="flex:0 0 auto;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Wrap="Wrap.Wrap" Spacing="2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Wrap="Wrap.Wrap">
                    <MudChip T="string" Color="BewerbungStatusDisplay.ChipColor(_bewerbung.Status)" Variant="Variant.Filled">
                        @BewerbungStatusDisplay.Name(_bewerbung.Status)
                    </MudChip>
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle2" Style="line-height:1.15;">@_bewerbung.Name</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Aktenzeichen @_bewerbung.CaseNumber</MudText>
                    </MudStack>
                </MudStack>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    @if (_test is { Completed: false } && _bewerbung.Status == BewerbungStatus.ImTest)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Quiz" Href="/portal/test">Eignungstest ausfüllen</MudButton>
                    }
                    @if (_bewerbung.Status != BewerbungStatus.Abgelehnt && _bewerbung.Status != BewerbungStatus.Geschlossen)
                    {
                        <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small"
                                   EndIcon="@(_detailsOpen ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                   OnClick="@(() => _detailsOpen = !_detailsOpen)">Details</MudButton>
                    }
                </MudStack>
            </MudStack>

            @if (_bewerbung.Status == BewerbungStatus.Abgelehnt || _bewerbung.Status == BewerbungStatus.Geschlossen)
            {
                <MudDivider Class="my-3" />
                @if (_ban is not null)
                {
                    <BewerbungssperreCard Ban="_ban" />
                }
                else
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                        Dein Auswahlverfahren wurde abgeschlossen. Weitere Auskünfte werden nicht erteilt.
                    </MudAlert>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Send"
                               Href="/portal" Class="mt-3">Neue Bewerbung</MudButton>
                }
            }
            else
            {
                <MudCollapse Expanded="_detailsOpen">
                    <MudDivider Class="my-3" />
                    <MudTimeline TimelinePosition="TimelinePosition.Start">
                        @foreach (var step in Steps)
                        {
                            <MudTimelineItem Color="@(StepReached(step) ? Color.Primary : Color.Default)"
                                             Variant="@(step == _bewerbung.Status ? Variant.Filled : Variant.Outlined)">
                                <MudText Typo="Typo.body2">@BewerbungStatusDisplay.Name(step)</MudText>
                            </MudTimelineItem>
                        }
                    </MudTimeline>
                    @if (_test is { Completed: true })
                    {
                        <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Dense="true">
                            Dein Eignungstest wurde übermittelt.
                        </MudAlert>
                    }
                </MudCollapse>
            }
        </MudPaper>

        @* chat takes all remaining viewport height *@
        <MudPaper Elevation="4" Class="pa-4" Style="flex:1 1 auto;min-height:0;display:flex;flex-direction:column;">
            <MudText Typo="Typo.subtitle1" Class="mb-2" Style="flex:0 0 auto;">Kommunikation mit dem NOOSE</MudText>
            <div style="flex:1 1 auto;min-height:0;">
                <BewerbungMessagePanel BewerbungId="@_bewerbung.Id" User="_user"
                                       Audience="BewerbungMessageAudience.Bewerber" IsApplicantView="true"
                                       CanWrite="true" CollapsibleComposer="true" HeightCss="100%" />
            </div>
        </MudPaper>
    </div>
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private static readonly BewerbungStatus[] Steps =
    [
        BewerbungStatus.Eingereicht,
        BewerbungStatus.InSicherheitspruefung,
        BewerbungStatus.ImTest,
        BewerbungStatus.ImVorstellungsgespraech,
        BewerbungStatus.Angenommen,
    ];

    private ClaimsPrincipal _user = default!;
    private bool _ready;
    private bool _detailsOpen;
    private Bewerbung _bewerbung = default!;
    private TestView? _test;
    private BewerbungssperreInfo? _ban;

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        if (!_user.IsApplicant())
        {
            Nav.NavigateTo("/karriere", forceLoad: true);
            return;
        }
        var own = await BewerbungService.GetOwnAsync(_user);
        if (own is null)
        {
            Nav.NavigateTo("/portal");
            return;
        }
        _bewerbung = own;
        if (own.Status is BewerbungStatus.Abgelehnt or BewerbungStatus.Geschlossen)
        {
            _ban = await SperreService.GetActiveAsync(_user.GetAgentId() ?? string.Empty);
        }
        _test = await TestService.GetAssignedForApplicantAsync(_user);
        _ready = true;
    }

    private bool StepReached(BewerbungStatus step) => (int)_bewerbung.Status >= (int)step;
}
