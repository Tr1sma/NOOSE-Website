@page "/profil"
@* Selbstbedienungs-Profil: ein Agent ändert seine eigenen Stammdaten (Codename, Klarname, Dienstnummer).
   Supervisory+ (IstFuehrung) wirkt sofort; darunter wird die Änderung als Antrag in den Freigabe-
   Posteingang gelegt. Authentifizierung erbt die App-weite Policy „AktiverAgent" aus _Imports.razor. *@
@inject IAgentVerwaltungService AgentService
@inject IAntragService AntragService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Mein Profil · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
    <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h4">Mein Profil</MudText>
</MudStack>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-6">
    Hier änderst du deine eigenen Stammdaten.
    @if (_istFuehrung)
    {
        <span>Als Führungskraft greifen deine Änderungen <b>sofort</b>.</span>
    }
    else
    {
        <span>Deine Änderungen müssen von der Führung <b>freigegeben</b> werden, bevor sie wirksam werden.</span>
    }
</MudText>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_agent is null)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
        Dein Konto konnte nicht geladen werden. Bitte melde dich neu an.
    </MudAlert>
}
else
{
    @if (_agent.NamensaenderungBeantragtAm is not null)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4" Icon="@Icons.Material.Filled.HourglassTop">
            Dein Antrag auf Stammdatenänderung wartet auf Freigabe durch die Führung
            (eingereicht am @_agent.NamensaenderungBeantragtAm.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")).
            Beantragter Codename: <b>@_agent.AusstehenderCodename</b>.
            Du kannst die Eingaben unten anpassen und den Antrag erneut absenden.
        </MudAlert>
    }

    <MudPaper Class="pa-6" Elevation="2" Style="max-width:640px;">
        <MudForm @ref="_form">
            <MudStack Spacing="3">
                <MudAlert Severity="Severity.Normal" Dense="true" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Shield">
                    @DienstgradAnzeige.Name(_agent.Dienstgrad)
                    @if (!string.IsNullOrWhiteSpace(_agent.DiscordUsername))
                    {
                        <span class="mud-text-secondary"> · Discord: @_agent.DiscordUsername</span>
                    }
                </MudAlert>

                <MudTextField @bind-Value="_klarname" Label="Klarname (echter Name)" Variant="Variant.Outlined"
                              AutoFocus="true"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.VisibilityOff"
                              HelperText="Nur für die Führungsebene sichtbar – wird rangniedrigeren Nutzern nie angezeigt." />

                <MudTextField @bind-Value="_codename" Label="Codename (Deckname)" Variant="Variant.Outlined"
                              Required="true" RequiredError="Der Codename darf nicht leer sein."
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Badge"
                              HelperText="Für alle Nutzer sichtbar – dein überall angezeigter Name." />

                <MudTextField @bind-Value="_dienstnummer" Label="Dienstnummer" Variant="Variant.Outlined"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Numbers"
                              HelperText="Für alle Nutzer sichtbar (Freitext, optional)." />

                <MudStack Row="true" Justify="Justify.FlexEnd">
                    <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SpeichernAsync"
                               Disabled="_speichern" StartIcon="@(_istFuehrung ? Icons.Material.Filled.Save : Icons.Material.Filled.Send)">
                        @(_istFuehrung ? "Speichern" : "Zur Freigabe einreichen")
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudForm>
    </MudPaper>

    @if (_meineAntraege.Count > 0)
    {
        <MudPaper Class="pa-6 mt-6" Elevation="2" Style="max-width:640px;">
            <MudText Typo="Typo.h6" Class="mb-1">Meine Hochstufungs-Anträge</MudText>
            <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mb-3">
                Von dir gestellte Anträge auf die Einstufung „Gesichert staatsgefährdend“.
            </MudText>
            <MudStack Spacing="2">
                @foreach (var a in _meineAntraege)
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudChip T="string" Size="Size.Small" Color="@StatusFarbe(a.Status)" Variant="Variant.Filled">@AntragStatusAnzeige.Name(a.Status)</MudChip>
                        <MudText Typo="Typo.body2">@a.ZielBezeichnung</MudText>
                        <MudSpacer />
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@a.ErstelltAm.ToLocalTime().ToString("dd.MM.yyyy")</MudText>
                    </MudStack>
                    @if (!string.IsNullOrWhiteSpace(a.Entscheidungsnotiz))
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary ml-1">Notiz: @a.Entscheidungsnotiz</MudText>
                    }
                }
            </MudStack>
        </MudPaper>
    }
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _laden = true;
    private bool _speichern;
    private bool _istFuehrung;
    private ClaimsPrincipal _user = default!;
    private Agent? _agent;
    private List<Antrag> _meineAntraege = new();

    private MudForm _form = default!;
    private string _codename = string.Empty;
    private string? _klarname;
    private string? _dienstnummer;

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        _istFuehrung = _user.IstFuehrung();

        var id = _user.GetAgentId();
        _agent = string.IsNullOrWhiteSpace(id) ? null : await AgentService.FindAsync(id);
        if (_agent is not null)
        {
            FelderVorbefuellen();
        }
        if (!string.IsNullOrWhiteSpace(id))
        {
            _meineAntraege = await AntragService.GetMeineAsync(id);
        }
        _laden = false;
    }

    private static Color StatusFarbe(AntragStatus status) => status switch
    {
        AntragStatus.Beantragt => Color.Info,
        AntragStatus.Genehmigt => Color.Success,
        AntragStatus.Abgelehnt => Color.Error,
        _ => Color.Default,
    };

    // Liegt ein offener Antrag vor, werden dessen Werte vorbefüllt (man bearbeitet den Antrag weiter);
    // sonst die aktuellen Live-Stammdaten.
    private void FelderVorbefuellen()
    {
        if (_agent!.NamensaenderungBeantragtAm is not null)
        {
            _codename = _agent.AusstehenderCodename ?? string.Empty;
            _klarname = _agent.AusstehenderKlarname;
            _dienstnummer = _agent.AusstehendeDienstnummer;
        }
        else
        {
            _codename = _agent.Codename;
            _klarname = _agent.Klarname;
            _dienstnummer = _agent.Dienstnummer;
        }
    }

    private async Task SpeichernAsync()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid || _agent is null)
        {
            return;
        }

        _speichern = true;
        try
        {
            if (_istFuehrung)
            {
                await AgentService.StammdatenAendernAsync(_agent.Id, _klarname, _codename.Trim(), _dienstnummer, _user);
                // Der erneuerte SecurityStamp invalidiert die aktuelle Sitzung. Kontrolliert zur Neuanmeldung
                // leiten, statt den Nutzer kurz darauf vom Kill-Switch überraschend trennen zu lassen.
                Nav.NavigateTo("/Account/Login", forceLoad: true);
                return;
            }

            await AgentService.NamensaenderungBeantragenAsync(_agent.Id, _klarname, _codename.Trim(), _dienstnummer, _user);
            Snackbar.Add("Antrag eingereicht. Die Änderung greift nach Freigabe durch die Führung.", Severity.Success);

            // Frisch laden, damit der Status-Banner stimmt.
            _agent = await AgentService.FindAsync(_agent.Id);
            if (_agent is not null)
            {
                FelderVorbefuellen();
            }
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _speichern = false;
        }
    }
}
