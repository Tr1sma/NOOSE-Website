@inject IDialogService DialogService

<MudGrid>
    <MudItem xs="12">
        <MudTextField @bind-Value="Input.Name" Label="Name" Required="true" RequiredError="Name ist erforderlich"
                      Variant="Variant.Outlined" />
    </MudItem>

    @if (ShowClassification)
    {
        <MudItem xs="12" md="6">
            <MudSelect T="Classification" @bind-Value="Input.Classification" Label="Einstufung" Variant="Variant.Outlined">
                @foreach (var e in ClassificationDisplay.All)
                {
                    <MudSelectItem Value="e" Disabled="@(e == Classification.SecuredStateThreatening && !MayHighest)">
                        @ClassificationDisplay.Name(e)
                    </MudSelectItem>
                }
            </MudSelect>
        </MudItem>
    }
    @if (SecrecyOptions.Count > 1)
    {
        <MudItem xs="12" md="6">
            <MudSelect T="DocumentClassification" @bind-Value="Input.SecrecyLevel" Label="Verschluss-Stufe"
                       Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock"
                       HelperText="Bestimmt, wer die Akte sehen darf.">
                @foreach (var o in SecrecyOptions)
                {
                    <MudSelectItem T="DocumentClassification" Value="@o">@DocumentClassificationDisplay.Label(o)</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
    }

    <MudItem xs="12">
        <MudTextField @bind-Value="Input.Targets" Label="Ziele" Lines="2" Variant="Variant.Outlined" />
    </MudItem>
    <MudItem xs="12">
        <MudTextField @bind-Value="Input.Description" Label="Beschreibung" Lines="3" Variant="Variant.Outlined" />
    </MudItem>
    <MudItem xs="12">
        <MudTextField @bind-Value="Input.Remarks" Label="Bemerkungen" Lines="3" Variant="Variant.Outlined"
                      HelperText="Interne Vermerke (getrennt von Zielen/Beschreibung)." />
    </MudItem>
</MudGrid>

@if (ShowMembers)
{
    <MudDivider Class="my-4" />
    <MudStack Spacing="2">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudText Typo="Typo.h6">Mitglieder</MudText>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd" OnClick="MemberAddAsync">
                Mitglied hinzufügen
            </MudButton>
        </MudStack>
        @if (Input.Members.Count == 0)
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Mitglieder – optional. Können auch später in der Akte ergänzt werden.</MudText>
        }
        else
        {
            @foreach (var m in Input.Members)
            {
                <MudPaper Class="pa-2" Elevation="1">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Badge" Color="Color.Primary" Size="Size.Small" />
                            <MudText Typo="Typo.body2"><b>@m.PersonName</b></MudText>
                            @if (m.IsLead)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled" Icon="@Icons.Material.Filled.Star">Leitung</MudChip>
                            }
                            @if (!string.IsNullOrWhiteSpace(m.Role))
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">@m.Role</MudChip>
                            }
                        </MudStack>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                       OnClick="@(() => Input.Members.Remove(m))" aria-label="Mitglied entfernen" />
                    </MudStack>
                </MudPaper>
            }
        }
    </MudStack>
}

@code {
    [Parameter, EditorRequired] public PartyInput Input { get; set; } = default!;
    [Parameter] public bool ShowClassification { get; set; }
    [Parameter] public bool MayHighest { get; set; }
    [Parameter] public bool ShowMembers { get; set; }
    [Parameter] public bool IsLeadership { get; set; }
    /// <summary>Secrecy levels the current user may assign (DocumentViewerScope.AssignableOptions).</summary>
    [Parameter] public IReadOnlyList<DocumentClassification> SecrecyOptions { get; set; } = Array.Empty<DocumentClassification>();

    private async Task MemberAddAsync()
    {
        var exclusion = Input.Members.Select(m => m.PersonId).ToList();
        var @new = await PartyMemberDialog.ShowAsync(DialogService, IsLeadership, exclusion);
        if (@new is null)
        {
            return;
        }
        // avoid duplicate: same existing person or same new name
        var alreadyExists =
            (!string.IsNullOrWhiteSpace(@new.PersonId) && Input.Members.Any(m => m.PersonId == @new.PersonId))
            || (!string.IsNullOrWhiteSpace(@new.NewPersonName)
                && Input.Members.Any(m => string.Equals(m.NewPersonName, @new.NewPersonName, StringComparison.OrdinalIgnoreCase)));
        if (!alreadyExists)
        {
            Input.Members.Add(@new);
        }
    }
}
