@page "/parteien/{Id}"
@inject IPartyService PartyService
@inject IAccessLogService AccessLog
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>@(_party?.Name ?? "Partei") · NOOSE</PageTitle>

@if (_load)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_party is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
        Partei nicht gefunden oder nicht zugänglich (ggf. Verschlusssache).
    </MudAlert>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/parteien" aria-label="Zurück" />
        <MudSpacer />
        <MudTooltip Text="Druckansicht – Akte drucken / als PDF speichern">
            <MudIconButton Icon="@Icons.Material.Filled.Print" Color="Color.Default"
                           Href="@($"/parteien/{Id}/druck")" Target="_blank"
                           aria-label="Druckansicht öffnen" />
        </MudTooltip>
        <FollowButton EntityType="@nameof(Party)" EntityId="@_party.Id" User="_user" />
        <JobCreateButton EntityType="@nameof(Party)" EntityId="@_party.Id" />
        <AuthorizeView Policy="@Policies.WriteAccess" Context="schreib">
            <MudButton Href="@($"/parteien/{_party.Id}/bearbeiten")" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit">Bearbeiten</MudButton>
        </AuthorizeView>
        <AuthorizeView Policy="@Policies.Leadership">
            <MudButton Color="Color.Error" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Delete" OnClick="DeleteAsync">Löschen</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-2 mb-4" Elevation="1">
        <TagChips EntityType="@nameof(Party)" EntityId="@_party.Id" User="_user" />
    </MudPaper>

    <MudGrid>
        <MudItem xs="12" md="4" lg="3">
            <div class="akte-steckkarte">
                <PartyCard Party="_party" MemberCount="_memberCount" InvestigationLead="_investigationLead" />
            </div>
        </MudItem>

        <MudItem xs="12" md="8" lg="9">
            <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" TabPanelsClass="pa-4"
                     @bind-ActivePanelIndex="_activeTab"
                     @bind-ActivePanelIndex:after="@(() => TabUrlState.Write(Nav, _tabs, _activeTab))">
                <MudTabPanel Text="Stammdaten" Icon="@Icons.Material.Filled.Info">
                    <MudStack Spacing="3">
                        @if (!string.IsNullOrWhiteSpace(_party.Targets))
                        {
                            <div>
                                <MudText Typo="Typo.subtitle2">Ziele</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary">@_party.Targets</MudText>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(_party.Description))
                        {
                            <div>
                                <MudText Typo="Typo.subtitle2">Beschreibung</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary">@_party.Description</MudText>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(_party.Remarks))
                        {
                            <div>
                                <MudText Typo="Typo.subtitle2">Bemerkungen</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary" Style="white-space:pre-line;">@_party.Remarks</MudText>
                            </div>
                        }
                        @if (string.IsNullOrWhiteSpace(_party.Targets) && string.IsNullOrWhiteSpace(_party.Description) && string.IsNullOrWhiteSpace(_party.Remarks))
                        {
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">Keine weiteren Stammdaten erfasst.</MudText>
                        }
                    </MudStack>
                </MudTabPanel>
                <MudTabPanel Text="Mitglieder" Icon="@Icons.Material.Filled.Group">
                    <PartyMembersPanel PartyId="@_party.Id" User="_user" Changed="MembersModifiedAsync" />
                </MudTabPanel>
                <MudTabPanel Text="Zugeteilte Agents" Icon="@Icons.Material.Filled.ManageAccounts">
                    <PartyAgentsPanel PartyId="@_party.Id" User="_user" Changed="InvestigationLeadRefreshAsync" />
                </MudTabPanel>
                <MudTabPanel Text="Einstufung" Icon="@Icons.Material.Filled.Shield">
                    <ClassificationPanel Current="_party.Classification" History="_classificationHistory" User="_user" OnSet="ClassificationSetAsync"
                                     EntityType="@nameof(Party)" EntityId="@_party.Id" TargetDesignation="@($"{_party.Name} ({_party.CaseNumber})")" />
                </MudTabPanel>
                <MudTabPanel Text="Doks" Icon="@Icons.Material.Filled.Description">
                    <OrgDocsPanel OrgType="@nameof(Party)" OrgId="@_party.Id" User="_user" />
                </MudTabPanel>
                <MudTabPanel Text="Beziehungen" Icon="@Icons.Material.Filled.Hub">
                    <OrgRelationsPanel EntityType="@nameof(Party)" EntityId="@_party.Id" User="_user" />
                </MudTabPanel>
                <MudTabPanel Text="Quellen" Icon="@Icons.Material.Filled.AttachFile">
                    <SourcesPanel EntityType="@nameof(Party)" EntityId="@_party.Id" User="_user" />
                </MudTabPanel>
                <MudTabPanel Text="Wiedervorlagen" Icon="@Icons.Material.Filled.EventRepeat">
                    <FollowupPanel EntityType="@nameof(Party)" EntityId="@_party.Id" User="_user" />
                </MudTabPanel>
                <MudTabPanel Text="Kommentare" Icon="@Icons.Material.Filled.Comment">
                    <CommentPanel EntityType="@nameof(Party)" EntityId="@_party.Id" User="_user" />
                </MudTabPanel>
                <MudTabPanel Text="Zusatzfelder" Icon="@Icons.Material.Filled.Tune">
                    <CustomFieldsPanel EntityType="@nameof(Party)" EntityId="@_party.Id" User="_user" />
                </MudTabPanel>
                <MudTabPanel Text="Zeitstrahl" Icon="@Icons.Material.Filled.Timeline">
                    <TimelinePanel EntityType="@nameof(Party)" EntityId="@_party.Id" User="_user" @key="_historyKey" />
                </MudTabPanel>
            </MudTabs>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public string Id { get; set; } = default!;
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _load = true;
    private Party? _party;
    private int _memberCount;
    private List<string> _investigationLead = new();
    private List<ClassificationHistory> _classificationHistory = new();
    private ClaimsPrincipal _user = default!;
    private Guid _historyKey = Guid.NewGuid();
    private string? _loadedId;

    // Aktiver Tab wird in der URL (?tab=…) gehalten – Reihenfolge muss den MudTabPanels entsprechen.
    private int _activeTab;
    private static readonly string[] _tabs =
    {
        "stammdaten", "mitglieder", "agents", "einstufung", "doks",
        "beziehungen", "quellen", "wiedervorlagen", "kommentare", "zusatzfelder", "historie",
    };

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
    }

    // Diese Seite wird bei Navigation /parteien/{A} → /parteien/{B} WIEDERVERWENDET (gleiche Komponente);
    // OnInitializedAsync läuft dann NICHT erneut. Daher hier auf den Id-Wechsel reagieren – sonst bliebe die alte
    // Akte stehen. Das kurze _laden=true mountet den Tab-Baum (samt Kind-Panels) frisch. Tab-/Query-Wechsel: Id
    // bleibt gleich → kein Neuladen.
    protected override async Task OnParametersSetAsync()
    {
        if (_loadedId == Id)
        {
            return;
        }
        _loadedId = Id;
        _load = true;
        _party = null;
        _activeTab = TabUrlState.Read(Nav, _tabs);
        await LoadAsync();
        if (_party is not null)
        {
            await AccessLog.LogViewAsync(nameof(Party), _party.Id);
        }
    }

    private async Task LoadAsync()
    {
        // Kein _laden = true beim Neuladen: sonst entfernt das @if (_laden) die MudTabs aus dem
        // Render-Baum, ein frisch gemountetes MudTabs springt auf den ersten Tab. Der erste Aufruf
        // zeigt den Ladebalken weiterhin über den Feld-Initialwert (_laden = true).
        var mayClassifiedRead = _user.MayClassifiedRead();
        _party = await PartyService.GetDetailAsync(Id, mayClassifiedRead);
        if (_party is not null)
        {
            _classificationHistory = await PartyService.GetClassificationHistoryAsync(_party.Id, mayClassifiedRead);
            _memberCount = (await PartyService.GetMembersAsync(_party.Id, mayClassifiedRead)).Count;
            await InvestigationLeadLoadAsync();
        }
        _load = false;
    }

    private async Task InvestigationLeadLoadAsync()
    {
        if (_party is null)
        {
            return;
        }
        var el = await PartyService.GetInvestigationLeadAsync(_party.Id);
        _investigationLead = el.Select(a => a.Agent?.Codename ?? "?").ToList();
    }

    private async Task InvestigationLeadRefreshAsync()
    {
        await InvestigationLeadLoadAsync();
        StateHasChanged();
    }

    private async Task NewLoadAsync()
    {
        await LoadAsync();
        _historyKey = Guid.NewGuid();
        StateHasChanged();
    }

    private async Task MembersModifiedAsync()
    {
        if (_party is not null)
        {
            _memberCount = (await PartyService.GetMembersAsync(_party.Id, _user.MayClassifiedRead())).Count;
            StateHasChanged();
        }
    }

    private async Task ClassificationSetAsync((Classification New, string? Justification) input)
    {
        if (_party is null)
        {
            return;
        }
        await PartyService.ClassificationSetAsync(_party.Id, input.New, input.Justification, _user);
        await NewLoadAsync();
    }

    private async Task DeleteAsync()
    {
        if (_party is null)
        {
            return;
        }
        var ok = await ConfirmDialog.ShowAsync(DialogService, "Partei löschen?",
            "Die Partei wird in den Papierkorb verschoben und kann von der Führung wiederhergestellt werden.");
        if (!ok)
        {
            return;
        }
        await PartyService.DeleteAsync(_party.Id, _user);
        Snackbar.Add("Partei in den Papierkorb verschoben.", Severity.Success);
        Nav.NavigateTo("/parteien");
    }
}
