@page "/parteien"
@inject IPartyService PartyService
@inject IRecencyService Recency
@inject NavigationManager Nav

<PageTitle>Parteien · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
    <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h4">Parteien</MudText>
    <MudSpacer />
    <AuthorizeView Policy="@Policies.Leadership">
        <MudButton Href="/parteien/papierkorb" Variant="Variant.Text" Color="Color.Default" StartIcon="@Icons.Material.Filled.Delete">Papierkorb</MudButton>
    </AuthorizeView>
    <AuthorizeView Policy="@Policies.WriteAccess" Context="schreib">
        <MudButton Href="/parteien/neu" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add">Neue Partei</MudButton>
    </AuthorizeView>
</MudStack>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-6">
    Politische Organisationen mit Leitung, Mitgliedern, Einstufung und zugeteilten Special Agents.
</MudText>

@if (_load)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudDataGrid T="PartyRow" Items="_rows" Hover="true" Filterable="false" SortMode="SortMode.Multiple"
                 QuickFilter="Filter" Elevation="2" RowClick="@(args => Open(args.Item))" Dense="true">
        <ToolBarContent>
            <MudTextField @bind-Value="_search" Placeholder="Suchen (Name, Aktenzeichen)…" Immediate="true"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" />
        </ToolBarContent>
        <Columns>
            <PropertyColumn Property="x => x.CaseNumber" Title="Aktenzeichen" />
            <TemplateColumn Sortable="true" Title="Name" SortBy="x => x.Name">
                <CellTemplate>
                    @* Echter Link: Mittelklick/Strg+Klick öffnet die Akte im neuen Tab; tastatur-/screenreader-erreichbar. *@
                    <MudLink Href="@($"/parteien/{context.Item.Id}")" @onclick:stopPropagation="true">@context.Item.Name</MudLink>
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.MemberCount" Title="Mitglieder" />
            <TemplateColumn Sortable="true" Title="Einstufung" SortBy="x => x.Classification">
                <CellTemplate>
                    <ClassificationBadge Value="context.Item.Classification" />
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Sortable="true" Title="Verschluss" SortBy="x => x.IsClassified">
                <CellTemplate>
                    @if (context.Item.IsClassified)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Warning" Size="Size.Small" Title="Verschlusssache" />
                    }
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Sortable="true" Title="Aktualität" SortBy="x => x.Level">
                <CellTemplate>
                    <RecencyIndicator Level="context.Item.Level" ReferenceDateUtc="context.Item.RefreshedUtc" />
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.Refreshed" Title="Zuletzt" Format="dd.MM.yyyy HH:mm" />
        </Columns>
        <NoRecordsContent>
            <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-6">
                <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Color="Color.Default" Size="Size.Large" />
                <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Parteien – lege die erste an.</MudText>
                <AuthorizeView Policy="@Policies.WriteAccess" Context="schreib">
                    <MudButton Href="/parteien/neu" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add">Neue Partei</MudButton>
                </AuthorizeView>
            </MudStack>
        </NoRecordsContent>
        <PagerContent>
            <MudDataGridPager T="PartyRow" />
        </PagerContent>
    </MudDataGrid>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _load = true;
    private string _search = string.Empty;
    private List<PartyRow> _rows = new();

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthStateTask).User;
        var mayClassifiedRead = user.MayClassifiedRead();
        var parties = await PartyService.GetListAsync(mayClassifiedRead);
        var (warningDays, staleDays) = await Recency.GetThresholdAsync(nameof(Party));
        var now = DateTime.UtcNow;
        _rows = parties.Select(p =>
        {
            var referenceUtc = p.ModifiedAt ?? p.CreatedAt;
            return new PartyRow
            {
                Id = p.Id,
                CaseNumber = p.CaseNumber,
                Name = p.Name,
                // Wie in der Detailansicht zählen: nur Mitglieder mit sichtbarer (nicht gelöschter, ggf. nicht-VS) Akte.
                MemberCount = p.Members.Count(m => m.Person is not null && (mayClassifiedRead || !m.Person.IsClassified)),
                Classification = p.Classification,
                IsClassified = p.IsClassified,
                RefreshedUtc = referenceUtc,
                Refreshed = referenceUtc.ToLocalTime(),
                Level = RecencyAssessment.Level(warningDays, staleDays, referenceUtc, now),
            };
        }).ToList();
        _load = false;
    }

    private bool Filter(PartyRow z)
    {
        if (string.IsNullOrWhiteSpace(_search))
        {
            return true;
        }
        var s = _search.Trim();
        return z.Name.Contains(s, StringComparison.OrdinalIgnoreCase)
            || z.CaseNumber.Contains(s, StringComparison.OrdinalIgnoreCase);
    }

    private void Open(PartyRow z) => Nav.NavigateTo($"/parteien/{z.Id}");

    private sealed class PartyRow
    {
        public string Id { get; set; } = string.Empty;
        public string CaseNumber { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public int MemberCount { get; set; }
        public Classification Classification { get; set; }
        public bool IsClassified { get; set; }
        public DateTime RefreshedUtc { get; set; }
        public DateTime Refreshed { get; set; }
        public RecencyLevel Level { get; set; }
    }
}
