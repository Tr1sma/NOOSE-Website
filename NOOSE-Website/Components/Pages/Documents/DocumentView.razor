@* Read-only viewer for a library document and the records it is attached to. *@
@page "/dokumente/{Id}"
@inject IDocumentService DocumentService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>@(_document?.Title ?? "Dokument") · NOOSE</PageTitle>

@if (_load)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_document is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">Dokument nicht gefunden oder nicht zugänglich.</MudAlert>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/dokumente" aria-label="Zurück zur Bibliothek" />
        <MudIcon Icon="@Icons.Material.Filled.Article" Color="Color.Primary" Size="Size.Large" />
        <MudText Typo="Typo.h4">@_document.Title</MudText>
        @if (_document.IsRestricted)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Icon="@Icons.Material.Filled.Lock" Variant="Variant.Outlined">@DocumentClassificationDisplay.Label(_document.Classification)</MudChip>
        }
        @if (_document.Pinned)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Icon="@Icons.Material.Filled.PushPin" Variant="Variant.Outlined">Angepinnt</MudChip>
        }
        <MudSpacer />
        <MudTooltip Text="Druckansicht – Akte drucken / als PDF speichern">
            <MudIconButton Icon="@Icons.Material.Filled.Print" Color="Color.Default"
                           Href="@($"/dokumente/{Id}/druck")" Target="_blank"
                           aria-label="Druckansicht öffnen" />
        </MudTooltip>
        @if (_isLeadership)
        {
            <MudButton Variant="Variant.Text" Color="Color.Primary"
                       StartIcon="@(_document.Pinned ? Icons.Material.Filled.PushPin : Icons.Material.Outlined.PushPin)"
                       OnClick="PinToggleAsync">@(_document.Pinned ? "Lösen" : "Anpinnen")</MudButton>
        }
        @if (_mayDelete)
        {
            <MudButton Variant="Variant.Text" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" OnClick="DeleteAsync">Löschen</MudButton>
        }
        <AuthorizeView Policy="@Policies.WriteAccess" Context="freigabe">
            <PartnerShareButton EntityType="@nameof(Document)" EntityId="@_document.Id" />
        </AuthorizeView>
        <AuthorizeView Policy="@Policies.WriteAccess" Context="schreib">
            <MudButton Href="@($"/dokumente/{_document.Id}/bearbeiten")" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit">Bearbeiten</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudGrid>
        <MudItem xs="12" md="8" lg="9">
            <MudPaper Class="pa-6" Elevation="2">
                @* Sanitized server-side on save, so safe as MarkupString. *@
                <div class="dokument-html">@((MarkupString)_document.ContentHtml)</div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="4" lg="3">
            <MudPaper Class="pa-4" Elevation="1">
                <MudText Typo="Typo.subtitle2" Class="mb-2">Details</MudText>
                @if (!string.IsNullOrWhiteSpace(_document.Category))
                {
                    <MudText Typo="Typo.body2"><b>Kategorie:</b> @_document.Category</MudText>
                }
                <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mt-1">
                    Erstellt: @_document.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                </MudText>
                @if (_document.ModifiedAt is { } g)
                {
                    <MudText Typo="Typo.caption" Class="mud-text-secondary d-block">
                        Geändert: @g.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                    </MudText>
                }

                @* attachments fan-out: internal only *@
                @if (!_isPartner)
                {
                <MudDivider Class="my-3" />
                <MudText Typo="Typo.subtitle2" Class="mb-2">Angehängt an (@_attachments.Count)</MudText>
                @if (_attachments.Count == 0)
                {
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch an keine Akte angehängt.</MudText>
                }
                else
                {
                    <MudStack Spacing="1">
                        @foreach (var a in _attachments)
                        {
                            @if (a.Href is not null)
                            {
                                <MudLink Href="@a.Href" Typo="Typo.body2">
                                    <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" Class="mr-1" />@a.Display
                                </MudLink>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2">@a.Display</MudText>
                            }
                        }
                    </MudStack>
                }
                }
            </MudPaper>

            @* access list: leadership manages who may see this document *@
            @if (_isLeadership)
            {
                <div class="mt-4">
                    <DocumentAccessList DocumentId="@_document.Id" />
                </div>
            }
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public string Id { get; set; } = default!;
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _load = true;
    private bool _isPartner;
    private Document? _document;
    private List<DocumentAttachment> _attachments = new();
    private bool _mayDelete;
    private bool _isLeadership;
    private ClaimsPrincipal _user = default!;
    private string? _loadedId;

    protected override async Task OnParametersSetAsync()
    {
        if (_loadedId == Id)
        {
            return;
        }
        _loadedId = Id;
        _user = (await AuthStateTask).User;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _load = true;
        _isLeadership = _user.IsLeadership();
        _isPartner = _user.IsPartner();
        _document = await DocumentService.GetAsync(Id, DocumentViewerScope.From(_user), partnerAgency: _user.GetPartnerAgency(), partnerAgentId: _user.GetAgentId());
        if (_document is not null && !_isPartner)
        {
            // partners: skip attachment fan-out
            _attachments = await DocumentService.GetAttachmentsAsync(Id, _isLeadership, _user.GetAgentId());
            _mayDelete = _isLeadership
                || (_document.CreatedById is not null && _document.CreatedById == _user.GetAgentId());
        }
        _load = false;
    }

    private async Task PinToggleAsync()
    {
        if (_document is null)
        {
            return;
        }
        try
        {
            var @new = !_document.Pinned;
            await DocumentService.PinSetAsync(_document.Id, @new, _user);
            _document.Pinned = @new;
            Snackbar.Add(@new ? "Dokument angepinnt." : "Anpinnen gelöst.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task DeleteAsync()
    {
        var ok = await ConfirmDialog.ShowAsync(DialogService, "Dokument löschen?",
            $"„{_document!.Title}“ wird in den Papierkorb verschoben.");
        if (!ok)
        {
            return;
        }
        try
        {
            await DocumentService.DeleteAsync(Id, _user);
            Snackbar.Add("Dokument gelöscht.", Severity.Success);
            Nav.NavigateTo("/dokumente");
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
