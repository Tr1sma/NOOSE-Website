@* Zentrale Dokumenten-Bibliothek: durchsuchbare Liste aller (für den Aufrufer sichtbaren) Dokumente. *@
@page "/dokumente"
@inject IDocumentService DocumentService
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Dokumente · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
    <MudIcon Icon="@Icons.Material.Filled.MenuBook" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h4">Dokumente</MudText>
    <MudSpacer />
    <AuthorizeView Policy="@Policies.WriteAccess" Context="schreib">
        <MudButton Href="/dokumente/neu" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add">Neues Dokument</MudButton>
    </AuthorizeView>
</MudStack>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-6">
    Zentrale Bibliothek formatierter Dokumente und hochgeladener Dateien (Formulare, SOPs, Vorlagen).
    Ein Dokument kann an beliebig viele Akten als Quelle angehängt werden. Verschlusssachen sind je
    nach Stufe nur der Führung, der TRU oder dem HRB sichtbar.
</MudText>

<MudTabs Elevation="0" Rounded="true" Class="mb-3">
<MudTabPanel Icon="@Icons.Material.Filled.Article" Text="Dokumente">

@if (_load)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    @if (_pinned.Count > 0)
    {
        <MudPaper Class="pa-3 mb-4" Elevation="2">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-2">
                <MudIcon Icon="@Icons.Material.Filled.PushPin" Color="Color.Primary" Size="Size.Small" />
                <MudText Typo="Typo.subtitle2">Angepinnt</MudText>
            </MudStack>
            <MudStack Spacing="1">
                @foreach (var p in _pinned)
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Article" Color="Color.Default" Size="Size.Small" />
                        <MudLink Href="@($"/dokumente/{p.Id}")">@p.Title</MudLink>
                        @if (!string.IsNullOrWhiteSpace(p.Category))
                        {
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@p.Category</MudText>
                        }
                        @if (p.IsRestricted)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Warning" Size="Size.Small"
                                     Title="@DocumentClassificationDisplay.Label(p.Classification)" />
                        }
                        <MudSpacer />
                        @if (_isLeadership)
                        {
                            <MudTooltip Text="Lösen">
                                <MudIconButton Icon="@Icons.Material.Filled.PushPin" Color="Color.Primary" Size="Size.Small"
                                               OnClick="() => PinSet(p, false)" aria-label="Anpinnen lösen" />
                            </MudTooltip>
                        }
                    </MudStack>
                }
            </MudStack>
        </MudPaper>
    }

    <MudDataGrid T="DocumentListItem" Items="_rows" Hover="true" Filterable="false" SortMode="SortMode.Multiple"
                 QuickFilter="Filter" Elevation="2" RowClick="@(args => Open(args.Item))" Dense="true">
        <ToolBarContent>
            <MudTextField @bind-Value="_search" Placeholder="Suchen (Titel, Kategorie)…" Immediate="true"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" />
        </ToolBarContent>
        <Columns>
            @if (_isLeadership)
            {
                <TemplateColumn Title="" Sortable="false">
                    <CellTemplate>
                        @* span stoppt die Klick-Propagation, damit der Pin-Klick nicht zusätzlich die Zeile öffnet. *@
                        <span @onclick:stopPropagation="true">
                            <MudTooltip Text="Anpinnen">
                                <MudIconButton Icon="@Icons.Material.Outlined.PushPin" Color="Color.Default" Size="Size.Small"
                                               OnClick="@(() => PinSet(context.Item, true))"
                                               aria-label="Dokument anpinnen" />
                            </MudTooltip>
                        </span>
                    </CellTemplate>
                </TemplateColumn>
            }
            <TemplateColumn Sortable="true" Title="Titel" SortBy="x => x.Title">
                <CellTemplate>
                    @* Echter Link: Mittelklick/Strg+Klick öffnet im neuen Tab; tastatur-/screenreader-erreichbar. *@
                    <MudLink Href="@($"/dokumente/{context.Item.Id}")" @onclick:stopPropagation="true">@context.Item.Title</MudLink>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Sortable="true" Title="Kategorie" SortBy="x => x.Category">
                <CellTemplate>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">@(string.IsNullOrWhiteSpace(context.Item.Category) ? "—" : context.Item.Category)</MudText>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Sortable="true" Title="Verschluss" SortBy="x => x.Classification">
                <CellTemplate>
                    @if (context.Item.IsRestricted)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined"
                                 Icon="@Icons.Material.Filled.Lock">@DocumentClassificationDisplay.ChipLabel(context.Item.Classification)</MudChip>
                    }
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.Refreshed" Title="Zuletzt" Format="dd.MM.yyyy HH:mm" />
        </Columns>
        <NoRecordsContent>
            <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-6">
                <MudIcon Icon="@Icons.Material.Filled.MenuBook" Color="Color.Default" Size="Size.Large" />
                <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Dokumente – lege das erste an.</MudText>
                <AuthorizeView Policy="@Policies.WriteAccess" Context="schreib">
                    <MudButton Href="/dokumente/neu" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add">Neues Dokument</MudButton>
                </AuthorizeView>
            </MudStack>
        </NoRecordsContent>
        <PagerContent>
            <MudDataGridPager T="DocumentListItem" />
        </PagerContent>
    </MudDataGrid>
}

</MudTabPanel>
@if (!_isPartner)
{
<MudTabPanel Icon="@Icons.Material.Filled.FolderOpen" Text="Dateien">
    @* internal file library *@
    <LibraryPanel />
</MudTabPanel>
}
</MudTabs>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _load = true;
    private bool _isLeadership;
    private bool _isPartner;
    private string _search = string.Empty;
    private ClaimsPrincipal _user = default!;
    private List<DocumentListItem> _rows = new();      // Nicht angepinnte – im Grid darunter.
    private List<DocumentListItem> _pinned = new();   // Angepinnte – im Block oben.

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        _isLeadership = _user.IsLeadership();
        _isPartner = _user.IsPartner();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        var all = await DocumentService.GetListAsync(DocumentViewerScope.From(_user), partnerAgency: _user.GetPartnerAgency(), partnerAgentId: _user.GetAgentId());
        _pinned = all.Where(d => d.Pinned).ToList();
        _rows = all.Where(d => !d.Pinned).ToList();
        _load = false;
    }

    private async Task PinSet(DocumentListItem item, bool pinned)
    {
        try
        {
            await DocumentService.PinSetAsync(item.Id, pinned, _user);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private bool Filter(DocumentListItem z)
    {
        if (string.IsNullOrWhiteSpace(_search))
        {
            return true;
        }
        var s = _search.Trim();
        return z.Title.Contains(s, StringComparison.OrdinalIgnoreCase)
            || (z.Category?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false);
    }

    private void Open(DocumentListItem z) => Nav.NavigateTo($"/dokumente/{z.Id}");
}
