@* Archive of monthly situation reports; leadership-only, manual generation gated to Leadership. *@
@page "/lageberichte"
@attribute [Authorize(Policy = Policies.LeadershipPage)]
@inject ISituationReportService SituationReportService
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Lageberichte · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2" Wrap="Wrap.Wrap" Class="mb-1">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
        <MudIcon Icon="@Icons.Material.Filled.Assessment" Color="Color.Primary" Size="Size.Large" />
        <MudText Typo="Typo.h4">Lageberichte</MudText>
    </MudStack>
    <AuthorizeView Policy="@Policies.Leadership">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PostAdd"
                   OnClick="GenerateCurrent" Disabled="_work">
            Bericht für diesen Monat erzeugen
        </MudButton>
    </AuthorizeView>
</MudStack>
<MudText Typo="Typo.body1" Class="mud-text-secondary mb-6">
    Automatisch erzeugte Monats-Lageberichte – ein eingefrorener Schnappschuss der vollständigen Lage
    (inkl. Verschlusssachen-Aggregate), daher der Führung vorbehalten. Der Bericht des Vormonats entsteht
    automatisch nach Monatsende.
</MudText>

@if (_load)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_bulletins.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
        Noch keine Lageberichte vorhanden. Der erste entsteht automatisch nach Monatsende – oder erzeuge jetzt manuell einen.
    </MudAlert>
}
else
{
    <MudPaper Elevation="2">
        <MudList T="string">
            @foreach (var b in _bulletins)
            {
                <MudListItem T="string" OnClick="@(() => Open(b.Id))" Icon="@Icons.Material.Filled.Assessment" Style="cursor:pointer;">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <div>
                            <MudText Typo="Typo.body1"><b>@b.Title</b></MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                Berichtsstand @b.GeneratedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm") · erzeugt von @(b.GeneratedBy ?? "System")
                            </MudText>
                        </div>
                        <AuthorizeView Policy="@Policies.Leadership">
                            @* Don't let the delete click bubble to the row. *@
                            <span @onclick:stopPropagation="true">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                               OnClick="@(() => Delete(b))" />
                            </span>
                        </AuthorizeView>
                    </MudStack>
                </MudListItem>
            }
        </MudList>
    </MudPaper>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private System.Security.Claims.ClaimsPrincipal _user = default!;
    private bool _load = true;
    private bool _work;
    private List<SituationReportHead> _bulletins = new();

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        await Load();
    }

    private async Task Load()
    {
        _load = true;
        _bulletins = await SituationReportService.GetArchiveAsync();
        _load = false;
    }

    private void Open(string id) => Nav.NavigateTo($"/lageberichte/{id}");

    private async Task GenerateCurrent()
    {
        _work = true;
        try
        {
            var now = DateTime.UtcNow;
            // Generate/refresh the current month for an immediately visible report
            var bulletin = await SituationReportService.GenerateMonthAsync(now.Year, now.Month, replaceExisting: true, _user.GetAgentId());
            await Load();
            Snackbar.Add(bulletin is null ? "Es wurde kein Bericht erzeugt." : $"{bulletin.Title} erzeugt.", Severity.Success);
        }
        catch (Exception)
        {
            Snackbar.Add("Der Lagebericht konnte nicht erzeugt werden.", Severity.Error);
        }
        finally
        {
            _work = false;
        }
    }

    private async Task Delete(SituationReportHead b)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync("Lagebericht löschen?",
            $"{b.Title} in den Papierkorb verschieben?", yesText: "Löschen", cancelText: "Abbrechen");
        if (confirmed == true)
        {
            await SituationReportService.DeleteAsync(b.Id, _user);
            await Load();
            Snackbar.Add("Lagebericht in den Papierkorb verschoben.", Severity.Success);
        }
    }
}
