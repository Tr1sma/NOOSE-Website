@page "/kalender/papierkorb"
@attribute [Authorize(Policy = Policies.FuehrungSeite)]
@inject ITerminService TerminService
@inject ISnackbar Snackbar

<PageTitle>Papierkorb – Termine · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/kalender" aria-label="Zurück" />
    <MudIcon Icon="@Icons.Material.Filled.Delete" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h4">Papierkorb – Termine</MudText>
</MudStack>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-6">
    Gelöschte Termine. Die Führung kann sie wiederherstellen; sie erscheinen dann wieder im Kalender.
</MudText>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_termine.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">Der Papierkorb ist leer.</MudAlert>
}
else
{
    <MudTable Items="_termine" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="2" Dense="true">
        <HeaderContent>
            <MudTh><MudTableSortLabel T="Termin" SortBy="@(x => x.Aktenzeichen)">Aktenzeichen</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="Termin" SortBy="@(x => x.Titel)">Titel</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="Termin" SortBy="@(x => x.Beginn)">Beginn</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="Termin" SortBy="@(x => x.GeloeschtAm)" InitialDirection="SortDirection.Descending">Gelöscht am</MudTableSortLabel></MudTh>
            <MudTh Style="text-align:right;">Aktion</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Aktenzeichen"><MudText Typo="Typo.body2">@context.Aktenzeichen</MudText></MudTd>
            <MudTd DataLabel="Titel"><MudText Typo="Typo.body2">@context.Titel</MudText></MudTd>
            <MudTd DataLabel="Beginn">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    @DateTime.SpecifyKind(context.Beginn, DateTimeKind.Utc).ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                </MudText>
            </MudTd>
            <MudTd DataLabel="Gelöscht am">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    @(context.GeloeschtAm?.ToLocalTime().ToString("dd.MM.yyyy HH:mm") ?? "—")
                </MudText>
            </MudTd>
            <MudTd DataLabel="Aktion" Style="text-align:right;">
                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success"
                           StartIcon="@Icons.Material.Filled.Restore"
                           OnClick="@(() => WiederherstellenAsync(context))">Wiederherstellen</MudButton>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _laden = true;
    private List<Termin> _termine = new();

    protected override Task OnInitializedAsync() => LadenAsync();

    private async Task LadenAsync()
    {
        _laden = true;
        _termine = await TerminService.GetPapierkorbAsync();
        _laden = false;
    }

    private async Task WiederherstellenAsync(Termin termin)
    {
        var user = (await AuthStateTask).User;
        try
        {
            await TerminService.WiederherstellenAsync(termin.Id, user);
            Snackbar.Add($"Termin {termin.Aktenzeichen} wiederhergestellt.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        await LadenAsync();
    }
}
