@* Dem Termin zugeteilte NOOSE-Teilnehmer: Liste + Zuteilen/Entfernen. Verwalten darf der Ersteller oder die
   Führung (über das Flag <see cref="KannVerwalten"/>). Vorlage: AufgabeAgentePanel. *@
@inject ITerminService TerminService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudText Typo="Typo.subtitle1">Teilnehmer (@_teilnehmer.Count)</MudText>
        @if (KannVerwalten)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.GroupAdd" OnClick="ZuweisenAsync">
                Teilnehmer hinzufügen
            </MudButton>
        }
    </MudStack>

    @if (_laden)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_teilnehmer.Count == 0)
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch niemand zugeteilt.</MudText>
    }
    else
    {
        @foreach (var z in _teilnehmer)
        {
            <MudPaper Class="pa-3" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Primary" Size="Size.Small" />
                        <MudText Typo="Typo.body2"><b>@z.Agent?.Codename</b></MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">@DienstgradAnzeige.Name(z.Agent?.Dienstgrad)</MudChip>
                    </MudStack>
                    @if (KannVerwalten)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                       OnClick="@(() => EntfernenAsync(z))" aria-label="Teilnahme aufheben" />
                    }
                </MudStack>
            </MudPaper>
        }
    }
</MudStack>

@code {
    [Parameter, EditorRequired] public string TerminId { get; set; } = default!;
    [Parameter, EditorRequired] public ClaimsPrincipal User { get; set; } = default!;

    /// <summary>Darf der Aufrufer zuteilen/entfernen (Ersteller oder Führung)? Vom Detail berechnet.</summary>
    [Parameter] public bool KannVerwalten { get; set; }

    /// <summary>Wird nach jeder Änderung der Teilnehmer ausgelöst.</summary>
    [Parameter] public EventCallback Changed { get; set; }

    private bool _laden = true;
    private List<TerminZuweisung> _teilnehmer = new();

    protected override async Task OnInitializedAsync() => await LadenAsync();

    private async Task LadenAsync()
    {
        _laden = true;
        _teilnehmer = await TerminService.GetTeilnehmerAsync(TerminId);
        _laden = false;
    }

    private async Task ZuweisenAsync()
    {
        var ausschluss = _teilnehmer.Select(z => z.AgentId).ToList();
        var wahl = await AgentZuteilenDialog.ZeigenAsync(DialogService, ausschluss, User.DarfKlarnameSehen(), false);
        if (wahl is null)
        {
            return;
        }
        try
        {
            await TerminService.AgentZuweisenAsync(TerminId, wahl.AgentId, User);
            Snackbar.Add("Teilnehmer hinzugefügt.", Severity.Success);
            await LadenAsync();
            await Changed.InvokeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task EntfernenAsync(TerminZuweisung z)
    {
        var ok = await BestaetigenDialog.ZeigenAsync(DialogService, "Teilnahme aufheben?",
            $"„{z.Agent?.Codename}“ ist diesem Termin nicht mehr zugeteilt.", "Entfernen");
        if (!ok)
        {
            return;
        }
        try
        {
            await TerminService.AgentEntfernenAsync(z.Id, User);
            Snackbar.Add("Teilnahme aufgehoben.", Severity.Success);
            await LadenAsync();
            await Changed.InvokeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
