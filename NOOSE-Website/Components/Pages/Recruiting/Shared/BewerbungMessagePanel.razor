@implements IAsyncDisposable
@inject IBewerbungService BewerbungService
@inject IDocumentTemplateService TemplateService
@inject BewerbungBroadcaster Broadcaster
@inject ISnackbar Snackbar

<MudStack Spacing="2" Style="@($"height:{HeightCss};")">
    <div style="flex:1 1 auto; min-height:0; display:flex; flex-direction:column-reverse; overflow-y:auto; gap:8px; padding:4px;">
        @if (_load)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else
        {
            @foreach (var m in _messages.AsEnumerable().Reverse())
            {
                var own = IsOwn(m);
                <div style="@(own ? "align-self:flex-end;" : "align-self:flex-start;")max-width:85%;">
                    <MudPaper Class="pa-2" Elevation="@(own ? 0 : 1)" Outlined="@(!own)"
                              Style="@(own ? "background-color:var(--mud-palette-primary-hover);" : "")">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudText Typo="Typo.caption"><b>@AuthorLabel(m)</b></MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">· @m.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</MudText>
                        </MudStack>
                        @if (_richMode)
                        {
                            <div class="dokument-html bewerbung-chat-html mud-typography-body2">@((MarkupString)m.Text)</div>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Style="white-space:pre-wrap;">@m.Text</MudText>
                        }
                    </MudPaper>
                </div>
            }
            @if (_messages.Count == 0)
            {
                <MudText Typo="Typo.body2" Class="mud-text-secondary" Style="align-self:center;">Noch keine Nachrichten.</MudText>
            }
        }
    </div>

    @if (CanWrite)
    {
        @if (CollapsibleComposer && !_composerOpen)
        {
            <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.Edit" Style="justify-content:flex-start;"
                       OnClick="@(() => _composerOpen = true)">Antwort schreiben …</MudButton>
        }
        else
        {
        <div>
            @if (ShowTemplates && _templates.Count > 0)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
                    <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" Color="Color.Default" />
                    <MudMenu Label="Vorlage einfügen" Variant="Variant.Outlined" Size="Size.Small"
                             EndIcon="@Icons.Material.Filled.ArrowDropDown">
                        @foreach (var t in _templates)
                        {
                            <MudMenuItem OnClick="@(() => InsertTemplate(t))">@t.Name</MudMenuItem>
                        }
                    </MudMenu>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Name wird automatisch geschwärzt.</MudText>
                </MudStack>
            }
            @if (_richMode && (_needsDate || _needsTime))
            {
                <MudPaper Outlined="true" Class="pa-2 mb-1">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
                        <MudIcon Icon="@Icons.Material.Filled.Event" Size="Size.Small" Color="Color.Default" />
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Termin der Vorlage:</MudText>
                        @if (_needsDate)
                        {
                            <MudDatePicker @bind-Date="_pickDate" Label="Datum" DateFormat="dd.MM.yyyy" ShowToolbar="false"
                                           Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:160px;" />
                        }
                        @if (_needsTime)
                        {
                            <MudTimePicker @bind-Time="_pickTime" Label="Uhrzeit" AmPm="false" ShowToolbar="false"
                                           Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:140px;" />
                        }
                        <MudButton Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Check" OnClick="ApplyDateTime"
                                   Disabled="@(!CanApplyDateTime)">Einsetzen</MudButton>
                    </MudStack>
                </MudPaper>
            }
            @if (_richMode)
            {
                <div class="bewerbung-chat-editor">
                    <RichTextEditor @ref="_editor" ValueChanged="@(v => _html = v)" />
                </div>
            }
            else
            {
                <MudTextField @bind-Value="_text" Variant="Variant.Outlined" Lines="3"
                              Placeholder="@Placeholder" Immediate="true" />
            }
            <MudStack Row="true" AlignItems="AlignItems.Center"
                      Justify="@(CollapsibleComposer ? Justify.SpaceBetween : Justify.FlexEnd)" Class="mt-1">
                @if (CollapsibleComposer)
                {
                    <MudButton Variant="Variant.Text" Color="Color.Default" StartIcon="@Icons.Material.Filled.Close"
                               OnClick="CloseComposer">Schließen</MudButton>
                }
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Send"
                           OnClick="SendAsync" Disabled="@(_sends || ComposeEmpty)">Senden</MudButton>
            </MudStack>
        </div>
        }
    }
</MudStack>

@code {
    [Parameter, EditorRequired] public string BewerbungId { get; set; } = default!;
    [Parameter, EditorRequired] public ClaimsPrincipal User { get; set; } = default!;
    [Parameter] public BewerbungMessageAudience Audience { get; set; } = BewerbungMessageAudience.Intern;
    [Parameter] public bool IsApplicantView { get; set; }
    [Parameter] public bool CanWrite { get; set; } = true;
    [Parameter] public bool ShowTemplates { get; set; }
    [Parameter] public string? ApplicantName { get; set; }
    // applicant view fills the page; default keeps the agent-side panel unchanged
    [Parameter] public string HeightCss { get; set; } = "52vh";
    // collapse composer to a one-line bar so reading gets the full height
    [Parameter] public bool CollapsibleComposer { get; set; }

    private const string Placeholder = "Nachricht verfassen …";
    private bool _load = true;
    private bool _sends;
    private string _text = string.Empty;
    private string _html = string.Empty;
    private RichTextEditor? _editor;
    private bool _needsDate;
    private bool _needsTime;
    private DateTime? _pickDate;
    private TimeSpan? _pickTime;
    private string? _myId;
    private bool _composerOpen;
    private List<BewerbungMessage> _messages = new();
    private List<DocumentTemplate> _templates = new();

    // applicant-facing thread is rich text (formatting preserved); internal thread stays plain text + mentions
    private bool _richMode => Audience == BewerbungMessageAudience.Bewerber;
    private bool ComposeEmpty => _richMode ? string.IsNullOrWhiteSpace(_html) : string.IsNullOrWhiteSpace(_text);

    // enable "Einsetzen" only once every token the template still carries has a picked value
    private bool CanApplyDateTime
        => (!_needsDate || _pickDate is not null) && (!_needsTime || _pickTime is not null);

    protected override async Task OnInitializedAsync()
    {
        _myId = User.GetAgentId();
        Broadcaster.Modified += OnModified;
        await LoadAsync();
        if (ShowTemplates)
        {
            try
            {
                var all = await TemplateService.GetActiveAsync();
                _templates = all.Where(t => string.Equals(t.Category, "Bewerbung", StringComparison.OrdinalIgnoreCase)).ToList();
            }
            catch { /* best effort */ }
        }
    }

    private async Task LoadAsync()
    {
        _load = true;
        try
        {
            _messages = await BewerbungService.GetMessagesAsync(BewerbungId, Audience, User);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        _load = false;
    }

    private bool IsOwn(BewerbungMessage m)
        => Audience == BewerbungMessageAudience.Intern
            ? m.CreatedById == _myId
            : (IsApplicantView ? m.AuthorIsApplicant : !m.AuthorIsApplicant);

    private string AuthorLabel(BewerbungMessage m)
    {
        if (m.AuthorIsApplicant)
        {
            return IsApplicantView ? "Du" : "Bewerber";
        }
        return string.IsNullOrWhiteSpace(m.AuthorName) ? "NOOSE" : m.AuthorName!;
    }

    private async Task InsertTemplate(DocumentTemplate t)
    {
        var dienstgrad = User.GetRank() is { } rank ? RankDisplay.Name(rank) : null;
        var rendered = BewerbungTemplateRenderer.RenderForApplicant(t.ContentHtml, ApplicantName, dienstgrad);
        if (_editor is not null)
        {
            await _editor.SetHtmlAsync(rendered);
            _html = rendered;
        }
        else
        {
            _text = BewerbungTemplateRenderer.HtmlToText(rendered);
        }
        // reveal date/time pickers only when the inserted letter still needs those tokens filled
        _needsDate = BewerbungTemplateRenderer.HasDateToken(rendered);
        _needsTime = BewerbungTemplateRenderer.HasTimeToken(rendered);
        _pickDate = null;
        _pickTime = null;
    }

    private async Task ApplyDateTime()
    {
        var date = _pickDate?.ToString("dd.MM.yyyy");
        var time = _pickTime is { } t ? t.ToString(@"hh\:mm") : null;
        if (_editor is not null)
        {
            var html = BewerbungTemplateRenderer.FillDateTime(await _editor.GetHtmlAsync(), date, time);
            await _editor.SetHtmlAsync(html);
            _html = html;
        }
        else
        {
            _text = BewerbungTemplateRenderer.FillDateTime(_text, date, time);
        }
        _needsDate = false;
        _needsTime = false;
    }

    private async Task SendAsync()
    {
        if (_sends)
        {
            return;
        }
        var content = _richMode
            ? (_editor is not null ? await _editor.GetHtmlAsync() : _html)
            : _text;
        if (string.IsNullOrWhiteSpace(content))
        {
            return;
        }
        _sends = true;
        try
        {
            if (Audience == BewerbungMessageAudience.Intern)
            {
                await BewerbungService.PostInternalAsync(BewerbungId, content, User);
            }
            else if (IsApplicantView)
            {
                await BewerbungService.PostAsApplicantAsync(BewerbungId, content, User);
            }
            else
            {
                await BewerbungService.PostToApplicantAsync(BewerbungId, content, User);
            }
            _text = string.Empty;
            _html = string.Empty;
            _needsDate = false;
            _needsTime = false;
            _pickDate = null;
            _pickTime = null;
            if (CollapsibleComposer)
            {
                _composerOpen = false; // unmount editor; clean on reopen
            }
            else if (_editor is not null)
            {
                await _editor.SetHtmlAsync(string.Empty); // broadcaster refreshes the thread
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        _sends = false;
    }

    private void CloseComposer()
    {
        _composerOpen = false;
        _text = string.Empty;
        _html = string.Empty;
        _needsDate = false;
        _needsTime = false;
        _pickDate = null;
        _pickTime = null;
    }

    private void OnModified(string bewerbungId)
    {
        if (bewerbungId != BewerbungId)
        {
            return;
        }
        _ = InvokeAsync(async () =>
        {
            await LoadAsync();
            StateHasChanged();
        });
    }

    public ValueTask DisposeAsync()
    {
        Broadcaster.Modified -= OnModified;
        return ValueTask.CompletedTask;
    }
}
