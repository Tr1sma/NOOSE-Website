@page "/operationen/{Id}"
@inject IOperationService OperationService
@inject IZugriffsLogService ZugriffsLog
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>@(_operation?.Titel ?? "Operation") · NOOSE</PageTitle>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_operation is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
        Operation nicht gefunden oder nicht zugänglich (ggf. Verschlusssache).
    </MudAlert>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/operationen" aria-label="Zurück" />
        <MudSpacer />
        <MudTooltip Text="Druckansicht – Akte drucken / als PDF speichern">
            <MudIconButton Icon="@Icons.Material.Filled.Print" Color="Color.Default"
                           Href="@($"/operationen/{Id}/druck")" Target="_blank"
                           aria-label="Druckansicht öffnen" />
        </MudTooltip>
        <FolgenButton EntitaetTyp="@nameof(Operation)" EntitaetId="@_operation.Id" User="_user" />
        <AufgabeErstellenButton EntitaetTyp="@nameof(Operation)" EntitaetId="@_operation.Id" />
        <AuthorizeView Policy="@Policies.Schreibrecht" Context="schreib">
            <MudButton Href="@($"/operationen/{_operation.Id}/bearbeiten")" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit">Bearbeiten</MudButton>
        </AuthorizeView>
        <AuthorizeView Policy="@Policies.Fuehrung">
            <MudButton Color="Color.Error" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Delete" OnClick="LoeschenAsync">Löschen</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-2 mb-4" Elevation="1">
        <TagChips EntitaetTyp="@nameof(Operation)" EntitaetId="@_operation.Id" User="_user" />
    </MudPaper>

    <MudGrid>
        <MudItem xs="12" md="4" lg="3">
            <div class="akte-steckkarte">
                <Operationskarte Operation="_operation" Ermittlungsleiter="_ermittlungsleiter" />
            </div>
        </MudItem>

        <MudItem xs="12" md="8" lg="9">
            <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" TabPanelsClass="pa-4"
                     @bind-ActivePanelIndex="_aktiverTab"
                     @bind-ActivePanelIndex:after="@(() => TabUrlState.Write(Nav, _tabs, _aktiverTab))">
                <MudTabPanel Text="Stammdaten" Icon="@Icons.Material.Filled.Info">
                    <MudStack Spacing="3">
                        @if (!string.IsNullOrWhiteSpace(_operation.Ablauf))
                        {
                            <div>
                                <MudText Typo="Typo.subtitle2">Ablauf</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary" Style="white-space:pre-line;">@_operation.Ablauf</MudText>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(_operation.Ergebnis))
                        {
                            <div>
                                <MudText Typo="Typo.subtitle2">Ergebnis</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary" Style="white-space:pre-line;">@_operation.Ergebnis</MudText>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(_operation.Bemerkungen))
                        {
                            <div>
                                <MudText Typo="Typo.subtitle2">Bemerkungen</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary" Style="white-space:pre-line;">@_operation.Bemerkungen</MudText>
                            </div>
                        }
                        @if (string.IsNullOrWhiteSpace(_operation.Ablauf) && string.IsNullOrWhiteSpace(_operation.Ergebnis) && string.IsNullOrWhiteSpace(_operation.Bemerkungen))
                        {
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">Keine weiteren Stammdaten erfasst.</MudText>
                        }
                    </MudStack>
                </MudTabPanel>
                <MudTabPanel Text="Beteiligte Agents" Icon="@Icons.Material.Filled.ManageAccounts">
                    <OperationAgentePanel OperationId="@_operation.Id" User="_user" Changed="ErmittlungsleiterAktualisierenAsync" />
                </MudTabPanel>
                <MudTabPanel Text="Beteiligte / Beziehungen" Icon="@Icons.Material.Filled.Hub">
                    <OperationBeteiligtePanel OperationId="@_operation.Id" User="_user" />
                </MudTabPanel>
                <MudTabPanel Text="Einstufung" Icon="@Icons.Material.Filled.Shield">
                    <EinstufungPanel Aktuell="_operation.Einstufung" Verlauf="_einstufungVerlauf" User="_user" OnSetzen="EinstufungSetzenAsync"
                                     EntitaetTyp="@nameof(Operation)" EntitaetId="@_operation.Id" ZielBezeichnung="@($"{_operation.Titel} ({_operation.Aktenzeichen})")" />
                </MudTabPanel>
                <MudTabPanel Text="Quellen" Icon="@Icons.Material.Filled.AttachFile">
                    <QuellenPanel EntitaetTyp="@nameof(Operation)" EntitaetId="@_operation.Id" User="_user" />
                </MudTabPanel>
                <MudTabPanel Text="Wiedervorlagen" Icon="@Icons.Material.Filled.EventRepeat">
                    <WiedervorlagePanel EntitaetTyp="@nameof(Operation)" EntitaetId="@_operation.Id" User="_user" />
                </MudTabPanel>
                <MudTabPanel Text="Kommentare" Icon="@Icons.Material.Filled.Comment">
                    <KommentarPanel EntitaetTyp="@nameof(Operation)" EntitaetId="@_operation.Id" User="_user" />
                </MudTabPanel>
                <MudTabPanel Text="Zusatzfelder" Icon="@Icons.Material.Filled.Tune">
                    <CustomFelderPanel EntitaetTyp="@nameof(Operation)" EntitaetId="@_operation.Id" User="_user" />
                </MudTabPanel>
                <MudTabPanel Text="Zeitstrahl" Icon="@Icons.Material.Filled.Timeline">
                    <ZeitstrahlPanel EntitaetTyp="@nameof(Operation)" EntitaetId="@_operation.Id" User="_user" @key="_historieKey" />
                </MudTabPanel>
            </MudTabs>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public string Id { get; set; } = default!;
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _laden = true;
    private Operation? _operation;
    private List<string> _ermittlungsleiter = new();
    private List<EinstufungVerlauf> _einstufungVerlauf = new();
    private ClaimsPrincipal _user = default!;
    private Guid _historieKey = Guid.NewGuid();
    private string? _geladeneId;

    // Aktiver Tab wird in der URL (?tab=…) gehalten – Reihenfolge muss den MudTabPanels entsprechen.
    private int _aktiverTab;
    private static readonly string[] _tabs =
    {
        "stammdaten", "agents", "beziehungen", "einstufung",
        "quellen", "wiedervorlagen", "kommentare", "zusatzfelder", "historie",
    };

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
    }

    // Diese Seite wird bei Navigation /operationen/{A} → /operationen/{B} WIEDERVERWENDET (gleiche Komponente);
    // OnInitializedAsync läuft dann NICHT erneut. Daher hier auf den Id-Wechsel reagieren – sonst bliebe die alte
    // Akte stehen. Das kurze _laden=true mountet den Tab-Baum (samt Kind-Panels) frisch. Tab-/Query-Wechsel: Id
    // bleibt gleich → kein Neuladen.
    protected override async Task OnParametersSetAsync()
    {
        if (_geladeneId == Id)
        {
            return;
        }
        _geladeneId = Id;
        _laden = true;
        _operation = null;
        _aktiverTab = TabUrlState.Read(Nav, _tabs);
        await LadenAsync();
        if (_operation is not null)
        {
            await ZugriffsLog.LogAnsichtAsync(nameof(Operation), _operation.Id);
        }
    }

    private async Task LadenAsync()
    {
        // Kein _laden = true beim Neuladen: sonst entfernt das @if (_laden) die MudTabs aus dem
        // Render-Baum, ein frisch gemountetes MudTabs springt auf den ersten Tab.
        var darfVsLesen = _user.DarfVerschlusssacheLesen();
        _operation = await OperationService.GetDetailAsync(Id, darfVsLesen);
        if (_operation is not null)
        {
            _einstufungVerlauf = await OperationService.GetEinstufungVerlaufAsync(_operation.Id, darfVsLesen);
            await ErmittlungsleiterLadenAsync();
        }
        _laden = false;
    }

    private async Task ErmittlungsleiterLadenAsync()
    {
        if (_operation is null)
        {
            return;
        }
        var el = await OperationService.GetErmittlungsleiterAsync(_operation.Id);
        _ermittlungsleiter = el.Select(a => a.Agent?.Codename ?? "?").ToList();
    }

    private async Task ErmittlungsleiterAktualisierenAsync()
    {
        await ErmittlungsleiterLadenAsync();
        StateHasChanged();
    }

    private async Task NeuLadenAsync()
    {
        await LadenAsync();
        _historieKey = Guid.NewGuid();
        StateHasChanged();
    }

    private async Task EinstufungSetzenAsync((Einstufung Neu, string? Begruendung) eingabe)
    {
        if (_operation is null)
        {
            return;
        }
        await OperationService.EinstufungSetzenAsync(_operation.Id, eingabe.Neu, eingabe.Begruendung, _user);
        await NeuLadenAsync();
    }

    private async Task LoeschenAsync()
    {
        if (_operation is null)
        {
            return;
        }
        var ok = await BestaetigenDialog.ZeigenAsync(DialogService, "Operation löschen?",
            "Die Operation wird in den Papierkorb verschoben und kann von der Führung wiederhergestellt werden.");
        if (!ok)
        {
            return;
        }
        await OperationService.LoeschenAsync(_operation.Id, _user);
        Snackbar.Add("Operation in den Papierkorb verschoben.", Severity.Success);
        Nav.NavigateTo("/operationen");
    }
}
