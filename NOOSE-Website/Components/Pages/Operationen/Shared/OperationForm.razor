@* Gemeinsames Formular für Anlegen/Bearbeiten einer Operation/eines Einsatzberichts.
   Der Typ ist ein Freitextfeld mit Vorschlägen aus dem gemeinsamen Katalog (wie die Fraktions-Art). *@
@inject ISteckbriefVorschlagService VorschlagService

<MudGrid>
    <MudItem xs="12">
        <MudTextField @bind-Value="Eingabe.Titel" Label="Titel" Required="true" RequiredError="Titel ist erforderlich"
                      Variant="Variant.Outlined" />
    </MudItem>

    <MudItem xs="12" md="6">
        @* Wie das Art-/Waffen-Feld: Autocomplete mit Vorschlägen aus dem gemeinsamen Katalog; freie Eingabe erlaubt. *@
        <MudAutocomplete T="string" @bind-Value="Eingabe.Typ" Label="Typ / Kategorie (optional)"
                         SearchFunc="@TypSuchen" Variant="Variant.Outlined"
                         CoerceText="false" CoerceValue="true" ResetValueOnEmptyText="false"
                         MinCharacters="0" Immediate="true" MaxItems="20" Clearable="true"
                         Placeholder="z. B. Razzia, Observation, Infiltration" />
    </MudItem>
    <MudItem xs="12" md="6">
        <MudSelect T="OperationStatus" @bind-Value="Eingabe.Status" Label="Status" Variant="Variant.Outlined">
            @foreach (var s in OperationStatusAnzeige.Alle)
            {
                <MudSelectItem Value="s">@OperationStatusAnzeige.Name(s)</MudSelectItem>
            }
        </MudSelect>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudDatePicker @bind-Date="Eingabe.Beginn" Label="Beginn (optional)" Variant="Variant.Outlined"
                       Clearable="true" Editable="true" DateFormat="dd.MM.yyyy" />
    </MudItem>
    <MudItem xs="12" md="6">
        <MudDatePicker @bind-Date="Eingabe.Ende" Label="Ende (optional)" Variant="Variant.Outlined"
                       Clearable="true" Editable="true" DateFormat="dd.MM.yyyy" />
    </MudItem>

    <MudItem xs="12" md="6">
        <MudTextField @bind-Value="Eingabe.Ort" Label="Ort (optional)" Variant="Variant.Outlined"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Place" />
    </MudItem>

    @if (ZeigeEinstufung)
    {
        <MudItem xs="12" md="6">
            <MudSelect T="Einstufung" @bind-Value="Eingabe.Einstufung" Label="Einstufung" Variant="Variant.Outlined">
                @foreach (var e in EinstufungAnzeige.Alle)
                {
                    <MudSelectItem Value="e" Disabled="@(e == Einstufung.GesichertStaatsgefaehrdend && !DarfHoechste)">
                        @EinstufungAnzeige.Name(e)
                    </MudSelectItem>
                }
            </MudSelect>
        </MudItem>
    }
    <MudItem xs="12" md="6" Class="d-flex flex-column justify-center">
        <MudSwitch T="bool" @bind-Value="Eingabe.IstVerschlusssache" Color="Color.Warning"
                   Label="Verschlusssache (nur Führung sichtbar)" />
        @if (Eingabe.IstVerschlusssache && !IstFuehrung)
        {
            <MudText Typo="Typo.caption" Color="Color.Warning">
                Achtung: Du verlierst als Nicht-Führung nach dem Speichern selbst den Zugriff auf diese Akte.
            </MudText>
        }
    </MudItem>

    <MudItem xs="12">
        <MudTextField @bind-Value="Eingabe.Ablauf" Label="Ablauf" Lines="4" Variant="Variant.Outlined"
                      HelperText="Verlauf des Einsatzes." />
    </MudItem>
    <MudItem xs="12">
        <MudTextField @bind-Value="Eingabe.Ergebnis" Label="Ergebnis" Lines="3" Variant="Variant.Outlined"
                      HelperText="Ausgang/Resultat des Einsatzes." />
    </MudItem>
    <MudItem xs="12">
        <MudTextField @bind-Value="Eingabe.Bemerkungen" Label="Bemerkungen" Lines="3" Variant="Variant.Outlined"
                      HelperText="Interne Vermerke (getrennt von Ablauf/Ergebnis)." />
    </MudItem>
</MudGrid>

@code {
    [Parameter, EditorRequired] public OperationEingabe Eingabe { get; set; } = default!;
    /// <summary>Einstufung im Formular zeigen (nur beim Anlegen; im Bearbeiten über den Tab „Einstufung").</summary>
    [Parameter] public bool ZeigeEinstufung { get; set; }
    [Parameter] public bool DarfHoechste { get; set; }
    [Parameter] public bool IstFuehrung { get; set; }

    private IReadOnlyList<string> _typVorschlaege = Array.Empty<string>();

    protected override async Task OnInitializedAsync()
    {
        _typVorschlaege = await VorschlagService.GetAsync(VorschlagTyp.Operationstyp);
    }

    private Task<IEnumerable<string>> TypSuchen(string value, CancellationToken token)
    {
        IEnumerable<string> treffer = string.IsNullOrWhiteSpace(value)
            ? _typVorschlaege
            : _typVorschlaege.Where(v => v.Contains(value.Trim(), StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(treffer);
    }
}
