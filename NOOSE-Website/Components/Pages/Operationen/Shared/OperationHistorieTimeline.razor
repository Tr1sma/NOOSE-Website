@* Akten-Historie der Operation: Audit-Einträge der Operation, Agent-Zuteilungen und Beziehungen. *@
@inject IOperationService OperationService

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_logs.Count == 0)
{
    <MudText Typo="Typo.body2" Class="mud-text-secondary">Keine Historie vorhanden.</MudText>
}
else
{
    <MudTimeline TimelinePosition="TimelinePosition.Start">
        @foreach (var log in _logs)
        {
            <MudTimelineItem Color="@Farbe(log.Aktion)" Size="Size.Small">
                <MudText Typo="Typo.body2"><b>@AktionText(log)</b></MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    @log.Zeitpunkt.ToLocalTime().ToString("dd.MM.yyyy HH:mm") · @(log.AgentName ?? "System")
                </MudText>
                @{
                    var aenderungen = AuditAnzeige.Parse(log.AenderungenJson);
                }
                @if (aenderungen.Count > 0)
                {
                    <MudStack Spacing="0" Class="mt-1">
                        @foreach (var a in aenderungen)
                        {
                            <MudText Typo="Typo.caption">
                                <b>@a.Feld:</b> <span class="mud-text-secondary">@a.Alt → @a.Neu</span>
                            </MudText>
                        }
                    </MudStack>
                }
            </MudTimelineItem>
        }
    </MudTimeline>
}

@code {
    [Parameter, EditorRequired] public string OperationId { get; set; } = default!;
    [Parameter] public bool IstFuehrung { get; set; }

    private bool _laden = true;
    private List<AuditLog> _logs = new();

    protected override async Task OnInitializedAsync()
    {
        _logs = await OperationService.GetHistorieAsync(OperationId, IstFuehrung);
        _laden = false;
    }

    private static string AktionText(AuditLog log)
    {
        var typ = log.EntitaetTyp switch
        {
            nameof(OperationAgent) => "Agent-Zuteilung",
            nameof(Verknuepfung) => "Beziehung",
            _ => "Operation",
        };
        var aktion = log.Aktion switch
        {
            AuditAktion.Erstellt => "erstellt",
            AuditAktion.Geaendert => "geändert",
            AuditAktion.Geloescht => "entfernt",
            AuditAktion.Wiederhergestellt => "wiederhergestellt",
            _ => log.Aktion.ToString(),
        };
        return $"{typ} {aktion}";
    }

    private static Color Farbe(AuditAktion a) => a switch
    {
        AuditAktion.Erstellt => Color.Success,
        AuditAktion.Geaendert => Color.Info,
        AuditAktion.Geloescht => Color.Error,
        AuditAktion.Wiederhergestellt => Color.Warning,
        _ => Color.Default,
    };
}
