@* Beteiligte einer Operation (Personen & Organisationen) über die generische Verknüpfungs-Engine
   (VerknuepfungArt.Standard). Beidseitig klickbar; die Notiz dient als Rolle/Funktion des Beteiligten.
   Beteiligte Agents laufen separat über das Agent-Panel. *@
@inject IVerknuepfungService VerknuepfungService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudText Typo="Typo.subtitle1">Beteiligte Personen &amp; Organisationen (@_liste.Count)</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AddLink" OnClick="HinzufuegenAsync">
            Beteiligten hinzufügen
        </MudButton>
    </MudStack>

    @if (_laden)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_liste.Count == 0)
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">
            Noch keine Beteiligten erfasst. (Agents werden im Tab „Beteiligte Agents" zugeteilt.)
        </MudText>
    }
    else
    {
        @foreach (var v in _liste)
        {
            <MudPaper Class="pa-3" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@TypIcon(v.AndereTyp)" Color="Color.Primary" Size="Size.Small" />
                        @if (v.Href is not null)
                        {
                            <MudLink Href="@v.Href" Typo="Typo.body2"><b>@v.AndereBezeichnung</b></MudLink>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2"><b>@v.AndereBezeichnung</b></MudText>
                        }
                        @if (!string.IsNullOrWhiteSpace(v.Label))
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">@v.Label</MudChip>
                        }
                    </MudStack>
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                   OnClick="@(() => EntfernenAsync(v))" aria-label="Beteiligten entfernen" />
                </MudStack>
            </MudPaper>
        }
    }
</MudStack>

@code {
    [Parameter, EditorRequired] public string OperationId { get; set; } = default!;
    [Parameter, EditorRequired] public ClaimsPrincipal User { get; set; } = default!;

    private bool _laden = true;
    private List<VerknuepfungAnzeige> _liste = new();

    protected override async Task OnInitializedAsync() => await LadenAsync();

    private async Task LadenAsync()
    {
        _laden = true;
        _liste = await VerknuepfungService.GetFuerAkteAsync(nameof(Operation), OperationId, User.IstFuehrung(), VerknuepfungArt.Standard);
        _laden = false;
    }

    private async Task HinzufuegenAsync()
    {
        // Bereits beteiligte Ziele je Typ ausschließen. Die Operation selbst ist kein Person/Org-Ziel → keine Selbstverknüpfung möglich.
        var fraktionAus = _liste.Where(v => v.AndereTyp == nameof(Fraktion)).Select(v => v.AndereId).ToList();
        var gruppenAus = _liste.Where(v => v.AndereTyp == nameof(Personengruppe)).Select(v => v.AndereId).ToList();
        var parteiAus = _liste.Where(v => v.AndereTyp == nameof(Partei)).Select(v => v.AndereId).ToList();
        var personAus = _liste.Where(v => v.AndereTyp == nameof(Person)).Select(v => v.AndereId).ToList();

        var wahl = await OrgBeziehungDialog.ZeigenAsync(DialogService, "Beteiligten", User.IstFuehrung(),
            fraktionAus, gruppenAus, parteiAus, personAus, personenErlauben: true);
        if (wahl is null)
        {
            return;
        }
        try
        {
            await VerknuepfungService.ErstellenAsync(nameof(Operation), OperationId, wahl.ZielTyp, wahl.ZielId, wahl.Notiz, User, VerknuepfungArt.Standard);
            Snackbar.Add("Beteiligter gespeichert.", Severity.Success);
            await LadenAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task EntfernenAsync(VerknuepfungAnzeige v)
    {
        var ok = await BestaetigenDialog.ZeigenAsync(DialogService, "Beteiligten entfernen?",
            $"Die Beziehung zu „{v.AndereBezeichnung}“ wird entfernt.");
        if (!ok)
        {
            return;
        }
        await VerknuepfungService.EntfernenAsync(v.VerknuepfungId, User);
        Snackbar.Add("Beteiligter entfernt.", Severity.Success);
        await LadenAsync();
    }

    private static string TypIcon(string typ) => typ switch
    {
        nameof(Person) => Icons.Material.Filled.Badge,
        nameof(Fraktion) => Icons.Material.Filled.Groups,
        nameof(Personengruppe) => Icons.Material.Filled.Diversity3,
        nameof(Partei) => Icons.Material.Filled.AccountBalance,
        _ => Icons.Material.Filled.Hub,
    };
}
