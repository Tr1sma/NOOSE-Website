@* Farbiger Status-Chip einer Operation (Geplant/Laufend/Abgeschlossen/Abgebrochen). Zentralisiert
   Beschriftung und Farbgebung für Karte, Liste und Detailseite. *@
<MudChip T="string" Size="@Size" Variant="Variant.Filled" Color="@Farbe(Status)" Icon="@Symbol(Status)">
    @OperationStatusAnzeige.Name(Status)
</MudChip>

@code {
    [Parameter, EditorRequired] public OperationStatus Status { get; set; }
    [Parameter] public Size Size { get; set; } = Size.Small;

    private static Color Farbe(OperationStatus status) => status switch
    {
        OperationStatus.Geplant => Color.Info,
        OperationStatus.Laufend => Color.Warning,
        OperationStatus.Abgeschlossen => Color.Success,
        OperationStatus.Abgebrochen => Color.Error,
        _ => Color.Default,
    };

    private static string Symbol(OperationStatus status) => status switch
    {
        OperationStatus.Geplant => Icons.Material.Filled.Event,
        OperationStatus.Laufend => Icons.Material.Filled.PlayArrow,
        OperationStatus.Abgeschlossen => Icons.Material.Filled.CheckCircle,
        OperationStatus.Abgebrochen => Icons.Material.Filled.Cancel,
        _ => Icons.Material.Filled.HelpOutline,
    };
}
