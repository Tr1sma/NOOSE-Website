@* Druckansicht der Operationsakte (Phase 7): kompletter Einsatzbericht als strukturiertes Dokument. *@
@page "/operationen/{Id}/druck"
@layout DruckLayout
@inject IOperationService OperationService
@inject IVerknuepfungService VerknuepfungService
@inject IKommentarService KommentarService
@inject IZugriffsLogService ZugriffsLog

<PageTitle>@(_operation is null ? "Druckansicht" : $"Operationsakte {_operation.Aktenzeichen}") · NOOSE</PageTitle>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_operation is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">Diese Akte existiert nicht (mehr) oder ist nicht sichtbar.</MudAlert>
}
else
{
    <DruckRahmen Titel="@($"Operationsakte {_operation.Aktenzeichen}")" ZurueckHref="@($"/operationen/{Id}")"
                 GedrucktVon="@_druckVon" IstVerschlusssache="_operation.IstVerschlusssache">
        <section>
            <h2>Stammdaten</h2>
            <table class="druck-felder">
                <tbody>
                    <tr><th>Titel</th><td>@_operation.Titel</td></tr>
                    <tr><th>Aktenzeichen</th><td>@_operation.Aktenzeichen</td></tr>
                    <tr><th>Status</th><td>@OperationStatusAnzeige.Name(_operation.Status)</td></tr>
                    @if (!string.IsNullOrWhiteSpace(_operation.Typ))
                    {
                        <tr><th>Typ</th><td>@_operation.Typ</td></tr>
                    }
                    <tr><th>Einstufung</th><td>@EinstufungAnzeige.Name(_operation.Einstufung)</td></tr>
                    @if (!string.IsNullOrWhiteSpace(_operation.Ort))
                    {
                        <tr><th>Einsatzort</th><td>@_operation.Ort</td></tr>
                    }
                    @if (_operation.Beginn is { } beginn)
                    {
                        <tr><th>Beginn</th><td>@beginn.ToLocalTime().ToString("dd.MM.yyyy")</td></tr>
                    }
                    @if (_operation.Ende is { } ende)
                    {
                        <tr><th>Ende</th><td>@ende.ToLocalTime().ToString("dd.MM.yyyy")</td></tr>
                    }
                    <tr><th>Zuletzt aktualisiert</th><td>@((_operation.GeaendertAm ?? _operation.ErstelltAm).ToLocalTime().ToString("dd.MM.yyyy HH:mm"))</td></tr>
                </tbody>
            </table>
        </section>

        @if (!string.IsNullOrWhiteSpace(_operation.Ablauf))
        {
            <section>
                <h2>Ablauf</h2>
                <div class="druck-mehrzeilig">@_operation.Ablauf</div>
            </section>
        }

        @if (!string.IsNullOrWhiteSpace(_operation.Ergebnis))
        {
            <section>
                <h2>Ergebnis</h2>
                <div class="druck-mehrzeilig">@_operation.Ergebnis</div>
            </section>
        }

        @if (!string.IsNullOrWhiteSpace(_operation.Bemerkungen))
        {
            <section>
                <h2>Bemerkungen</h2>
                <div class="druck-mehrzeilig">@_operation.Bemerkungen</div>
            </section>
        }

        @if (_operation.Agenten.Count > 0)
        {
            <section>
                <h2>Eingesetzte Agenten</h2>
                <table class="druck-tabelle">
                    <thead><tr><th>Agent</th><th>Funktion</th></tr></thead>
                    <tbody>
                        @foreach (var a in _operation.Agenten)
                        {
                            <tr>
                                <td>@(a.Agent?.Codename ?? "—")</td>
                                <td>@(a.IstErmittlungsleiter ? "Ermittlungsleiter" : "Einsatzkraft")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>
        }

        <DruckEinstufungVerlauf Eintraege="_einstufungVerlauf" />
        <DruckVerknuepfungen Eintraege="_verknuepfungen" Ueberschrift="Beteiligte / verknüpfte Akten" />
        <DruckKommentare Eintraege="_kommentare" />
    </DruckRahmen>
}

@code {
    [Parameter] public string Id { get; set; } = string.Empty;
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _laden = true;
    private string? _druckVon;
    private Operation? _operation;
    private List<EinstufungVerlauf> _einstufungVerlauf = new();
    private List<VerknuepfungAnzeige> _verknuepfungen = new();
    private List<Kommentar> _kommentare = new();

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthStateTask).User;
        var istFuehrung = user.IstFuehrung();
        _druckVon = user.GetCodename();

        _operation = await OperationService.GetDetailAsync(Id, istFuehrung);
        if (_operation is not null)
        {
            _einstufungVerlauf = await OperationService.GetEinstufungVerlaufAsync(Id, istFuehrung);
            _verknuepfungen = await VerknuepfungService.GetFuerAkteAsync(nameof(Operation), Id, istFuehrung, user.GetAgentId());
            _kommentare = await KommentarService.GetFuerAkteAsync(nameof(Operation), Id, istFuehrung);
            await ZugriffsLog.LogAnsichtAsync(nameof(Operation), Id);
        }
        _laden = false;
    }
}
