@page "/profil"
@* Selbstbedienungs-Profil: ein Agent ändert seine eigenen Stammdaten (Codename, Klarname, Dienstnummer).
   Supervisory+ (IstFuehrung) wirkt sofort; darunter wird die Änderung als Antrag in den Freigabe-
   Posteingang gelegt. Authentifizierung erbt die App-weite Policy „AktiverAgent" aus _Imports.razor. *@
@inject IAgentManagementService AgentService
@inject IRequestService RequestService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Mein Profil · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
    <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h4">Mein Profil</MudText>
</MudStack>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-6">
    @if (!_mayWrite)
    {
        <span>Hier siehst du deine Stammdaten. Änderungen sind in deiner Rolle nicht möglich.</span>
    }
    else if (_isLeadership)
    {
        <span>Hier änderst du deine eigenen Stammdaten. Als Führungskraft greifen deine Änderungen <b>sofort</b>.</span>
    }
    else
    {
        <span>Hier änderst du deine eigenen Stammdaten. Deine Änderungen müssen von der Führung <b>freigegeben</b> werden, bevor sie wirksam werden.</span>
    }
</MudText>

@if (_load)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_agent is null)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
        Dein Konto konnte nicht geladen werden. Bitte melde dich neu an.
    </MudAlert>
}
else
{
    @if (_agent.NameChangeRequestedAt is not null)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4" Icon="@Icons.Material.Filled.HourglassTop">
            Dein Antrag auf Stammdatenänderung wartet auf Freigabe durch die Führung
            (eingereicht am @_agent.NameChangeRequestedAt.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")).
            Beantragter Codename: <b>@_agent.PendingCodename</b>.
            Du kannst die Eingaben unten anpassen und den Antrag erneut absenden.
        </MudAlert>
    }

    <MudPaper Class="pa-6" Elevation="2" Style="max-width:640px;">
        <MudForm @ref="_form">
            <MudStack Spacing="3">
                <MudAlert Severity="Severity.Normal" Dense="true" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Shield">
                    @RankDisplay.Name(_agent.Rank)
                    @if (!string.IsNullOrWhiteSpace(_agent.DiscordUsername))
                    {
                        <span class="mud-text-secondary"> · Discord: @_agent.DiscordUsername</span>
                    }
                </MudAlert>

                @if (!_mayWrite)
                {
                    <MudAlert Severity="Severity.Info" Dense="true" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Lock">
                        @(_isPartner ? "Als Partnerbehörde" : "In der Aufsichtsrolle") können Sie Ihre Stammdaten nur einsehen, nicht ändern.
                    </MudAlert>
                }

                <MudTextField @bind-Value="_realName" Label="Klarname (echter Name)" Variant="Variant.Outlined"
                              AutoFocus="@_mayWrite" ReadOnly="@(!_mayWrite)"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.VisibilityOff"
                              HelperText="Nur für die Führungsebene sichtbar – wird rangniedrigeren Nutzern nie angezeigt." />

                <MudTextField @bind-Value="_codename" Label="Codename (Deckname)" Variant="Variant.Outlined"
                              Required="true" RequiredError="Der Codename darf nicht leer sein." ReadOnly="@(!_mayWrite)"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Badge"
                              HelperText="Für alle Nutzer sichtbar – dein überall angezeigter Name." />

                <MudTextField @bind-Value="_badgeNumber" Label="Dienstnummer" Variant="Variant.Outlined"
                              ReadOnly="@(!_mayWrite)"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Numbers"
                              HelperText="Für alle Nutzer sichtbar (Freitext, optional)." />

                @if (_mayWrite)
                {
                    <MudStack Row="true" Justify="Justify.FlexEnd">
                        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync"
                                   Disabled="_save" StartIcon="@(_isLeadership ? Icons.Material.Filled.Save : Icons.Material.Filled.Send)">
                            @(_isLeadership ? "Speichern" : "Zur Freigabe einreichen")
                        </MudButton>
                    </MudStack>
                }
            </MudStack>
        </MudForm>
    </MudPaper>

    @if (_myRequests.Count > 0)
    {
        <MudPaper Class="pa-6 mt-6" Elevation="2" Style="max-width:640px;">
            <MudText Typo="Typo.h6" Class="mb-1">Meine Hochstufungs-Anträge</MudText>
            <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mb-3">
                Von dir gestellte Anträge auf die Einstufung „Gesichert staatsgefährdend“.
            </MudText>
            <MudStack Spacing="2">
                @foreach (var a in _myRequests)
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudChip T="string" Size="Size.Small" Color="@StatusColour(a.Status)" Variant="Variant.Filled">@RequestStatusDisplay.Name(a.Status)</MudChip>
                        <MudText Typo="Typo.body2">@a.TargetDesignation</MudText>
                        <MudSpacer />
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@a.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")</MudText>
                    </MudStack>
                    @if (!string.IsNullOrWhiteSpace(a.DecisionNote))
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary ml-1">Notiz: @a.DecisionNote</MudText>
                    }
                }
            </MudStack>
        </MudPaper>
    }
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _load = true;
    private bool _save;
    private bool _isLeadership;
    private bool _mayWrite;
    private bool _isPartner;
    private ClaimsPrincipal _user = default!;
    private Agent? _agent;
    private List<Request> _myRequests = new();

    private MudForm _form = default!;
    private string _codename = string.Empty;
    private string? _realName;
    private string? _badgeNumber;

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        _isLeadership = _user.IsLeadership();
        _isPartner = _user.IsPartner();
        _mayWrite = _user.MayWrite();

        var id = _user.GetAgentId();
        _agent = string.IsNullOrWhiteSpace(id) ? null : await AgentService.FindAsync(id);
        if (_agent is not null)
        {
            FieldsPrefill();
        }
        if (!string.IsNullOrWhiteSpace(id))
        {
            _myRequests = await RequestService.GetMyAsync(id);
        }
        _load = false;
    }

    private static Color StatusColour(RequestStatus status) => status switch
    {
        RequestStatus.Requested => Color.Info,
        RequestStatus.Approved => Color.Success,
        RequestStatus.Rejected => Color.Error,
        _ => Color.Default,
    };

    // Liegt ein offener Antrag vor, werden dessen Werte vorbefüllt (man bearbeitet den Antrag weiter);
    // sonst die aktuellen Live-Stammdaten.
    private void FieldsPrefill()
    {
        if (_agent!.NameChangeRequestedAt is not null)
        {
            _codename = _agent.PendingCodename ?? string.Empty;
            _realName = _agent.PendingRealName;
            _badgeNumber = _agent.PendingBadgeNumber;
        }
        else
        {
            _codename = _agent.Codename;
            _realName = _agent.RealName;
            _badgeNumber = _agent.BadgeNumber;
        }
    }

    private async Task SaveAsync()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid || _agent is null)
        {
            return;
        }

        _save = true;
        try
        {
            if (_isLeadership)
            {
                await AgentService.MasterDataChangeAsync(_agent.Id, _realName, _codename.Trim(), _badgeNumber, _user);
                // Der erneuerte SecurityStamp invalidiert die aktuelle Sitzung. Kontrolliert zur Neuanmeldung
                // leiten, statt den Nutzer kurz darauf vom Kill-Switch überraschend trennen zu lassen.
                Nav.NavigateTo("/Account/Login", forceLoad: true);
                return;
            }

            await AgentService.NameChangeRequestAsync(_agent.Id, _realName, _codename.Trim(), _badgeNumber, _user);
            Snackbar.Add("Antrag eingereicht. Die Änderung greift nach Freigabe durch die Führung.", Severity.Success);

            // Frisch laden, damit der Status-Banner stimmt.
            _agent = await AgentService.FindAsync(_agent.Id);
            if (_agent is not null)
            {
                FieldsPrefill();
            }
        }
        catch (Exception ex)
        {
            // never let a write-block or service error kill the circuit
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _save = false;
        }
    }
}
