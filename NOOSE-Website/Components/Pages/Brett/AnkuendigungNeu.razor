@page "/brett/neu"
@inject IAnkuendigungService BrettService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Neue Ankündigung · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/brett" aria-label="Zurück" />
    <MudIcon Icon="@Icons.Material.Filled.Campaign" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h4">Neue Ankündigung</MudText>
</MudStack>

<MudForm @ref="_form">
    <AnkuendigungForm Eingabe="_eingabe" ZeigeBroadcastOptionen="_istFuehrung" IstFuehrung="_istFuehrung" />
</MudForm>

<MudStack Row="true" Spacing="2" Class="mt-4">
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SpeichernAsync" Disabled="_speichert">Veröffentlichen</MudButton>
    <MudButton Variant="Variant.Text" Href="/brett">Abbrechen</MudButton>
</MudStack>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private MudForm _form = default!;
    private readonly AnkuendigungEingabe _eingabe = new();
    private ClaimsPrincipal _user = default!;
    private bool _istFuehrung;
    private bool _speichert;

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        _istFuehrung = _user.IstFuehrung();
    }

    private async Task SpeichernAsync()
    {
        if (_speichert)
        {
            return;
        }
        await _form.ValidateAsync();
        if (!_form.IsValid)
        {
            return;
        }

        _speichert = true;
        try
        {
            var a = await BrettService.ErstellenAsync(_eingabe, _user);
            Snackbar.Add($"Ankündigung {a.Aktenzeichen} veröffentlicht.", Severity.Success);
            Nav.NavigateTo($"/brett/{a.Id}");
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _speichert = false;
        }
    }
}
