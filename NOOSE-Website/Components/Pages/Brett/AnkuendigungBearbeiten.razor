@page "/brett/{Id}/bearbeiten"
@inject IAnkuendigungService BrettService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Ankündigung bearbeiten · NOOSE</PageTitle>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_keinZugriff)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
        Diese Ankündigung darf nur ihr Verfasser oder die Führung bearbeiten.
        <MudButton Href="@($"/brett/{Id}")" Variant="Variant.Text" Color="Color.Primary" Class="ml-2">Zur Ankündigung</MudButton>
    </MudAlert>
}
else if (_eingabe is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">Ankündigung nicht gefunden.</MudAlert>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="@($"/brett/{Id}")" aria-label="Zurück" />
        <MudIcon Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Large" />
        <MudText Typo="Typo.h4">Ankündigung bearbeiten</MudText>
    </MudStack>

    <MudForm @ref="_form">
        <AnkuendigungForm Eingabe="_eingabe" ZeigeBroadcastOptionen="false" IstFuehrung="_istFuehrung" />
    </MudForm>
    <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2">
        Hinweis: Zielgruppe, Glocken-Push und Quittierung werden beim Anlegen festgelegt und sind hier nicht änderbar.
    </MudText>

    <MudStack Row="true" Spacing="2" Class="mt-4">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SpeichernAsync" Disabled="_speichert">Speichern</MudButton>
        <MudButton Variant="Variant.Text" Href="@($"/brett/{Id}")">Abbrechen</MudButton>
    </MudStack>
}

@code {
    [Parameter] public string Id { get; set; } = default!;
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private MudForm _form = default!;
    private AnkuendigungEingabe? _eingabe;
    private ClaimsPrincipal _user = default!;
    private bool _istFuehrung;
    private bool _laden = true;
    private bool _keinZugriff;
    private bool _speichert;
    private string? _geladeneId;

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        _istFuehrung = _user.IstFuehrung();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_geladeneId == Id)
        {
            return;
        }
        _geladeneId = Id;
        _laden = true;
        _eingabe = null;
        _keinZugriff = false;

        var detail = await BrettService.GetDetailAsync(Id, _user);
        if (detail is not null)
        {
            // Bearbeiten ist Verfasser/Führung vorbehalten (serverseitig in AktualisierenAsync erzwungen) – hier
            // proaktiv gespiegelt, damit kein nicht-berechtigtes Formular erscheint.
            if (!detail.Zeile.DarfVerwalten)
            {
                _keinZugriff = true;
            }
            else
            {
                _eingabe = new AnkuendigungEingabe
                {
                    Titel = detail.Zeile.Titel,
                    Inhalt = detail.Zeile.Inhalt,
                    Wichtig = detail.Zeile.Wichtig,
                };
            }
        }
        _laden = false;
    }

    private async Task SpeichernAsync()
    {
        if (_eingabe is null || _speichert)
        {
            return;
        }
        await _form.ValidateAsync();
        if (!_form.IsValid)
        {
            return;
        }

        _speichert = true;
        try
        {
            await BrettService.AktualisierenAsync(Id, _eingabe, _user);
            Snackbar.Add("Änderungen gespeichert.", Severity.Success);
            Nav.NavigateTo($"/brett/{Id}");
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
            _speichert = false;
        }
    }
}
