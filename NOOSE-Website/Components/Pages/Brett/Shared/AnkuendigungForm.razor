@* Formular zum Anlegen/Bearbeiten einer Ankündigung. Inhalt mit @-Erwähnungen. Die Broadcast-Optionen
   (Zielgruppe/Push/Quittierung) erscheinen nur, wenn ZeigeBroadcastOptionen gesetzt ist (= Führung beim Anlegen);
   beim Bearbeiten sind sie bewusst ausgeblendet (nach dem Anlegen fix). *@
@inject ITaskforceService TaskforceService

<MudGrid>
    <MudItem xs="12">
        <MudTextField @bind-Value="Eingabe.Titel" Label="Titel" Required="true" RequiredError="Titel ist erforderlich"
                      Variant="Variant.Outlined" />
    </MudItem>

    <MudItem xs="12">
        <MudText Typo="Typo.subtitle2" Class="mb-1">Inhalt</MudText>
        <MentionEingabe @bind-Text="_inhalt" IstFuehrung="IstFuehrung" Placeholder="@Platzhalter" />
    </MudItem>

    <MudItem xs="12">
        <MudSwitch T="bool" @bind-Value="Eingabe.Wichtig" Color="Color.Warning" Label="Wichtig (oben am Brett anpinnen)" />
    </MudItem>

    @if (ZeigeBroadcastOptionen)
    {
        <MudItem xs="12">
            <MudDivider Class="my-2" />
            <MudText Typo="Typo.subtitle1">Behörden-Broadcast (nur Führung)</MudText>
            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                Die Zielgruppe bestimmt, wer den Eintrag am Brett sieht. „In die Glocke senden" pusht zusätzlich eine
                Benachrichtigung; „Quittierung verlangen" fordert eine Lesebestätigung an.
            </MudText>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudSelect T="AnkuendigungZielgruppe" @bind-Value="Eingabe.Zielgruppe" Label="Zielgruppe" Variant="Variant.Outlined">
                @foreach (var z in AnkuendigungZielgruppeAnzeige.Alle)
                {
                    <MudSelectItem Value="z">@AnkuendigungZielgruppeAnzeige.Name(z)</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        @if (Eingabe.Zielgruppe == AnkuendigungZielgruppe.Taskforce)
        {
            <MudItem xs="12" md="6">
                <MudSelect T="string" @bind-Value="Eingabe.ZielId" Label="Taskforce" Variant="Variant.Outlined" Clearable="true">
                    @foreach (var t in _taskforces)
                    {
                        <MudSelectItem T="string" Value="@t.Id">@t.Name (@t.Aktenzeichen)</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
        }
        else if (Eingabe.Zielgruppe == AnkuendigungZielgruppe.AbDienstgrad)
        {
            <MudItem xs="12" md="6">
                <MudSelect T="Dienstgrad?" @bind-Value="Eingabe.MinDienstgrad" Label="Mindest-Dienstgrad" Variant="Variant.Outlined">
                    @foreach (var d in DienstgradAnzeige.Alle)
                    {
                        <MudSelectItem T="Dienstgrad?" Value="@((Dienstgrad?)d)">@DienstgradAnzeige.Name(d)</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
        }
        <MudItem xs="12" md="6">
            <MudSwitch T="bool" @bind-Value="Eingabe.AlsBroadcast" Color="Color.Primary" Label="In die Glocke senden (Broadcast)" />
        </MudItem>
        <MudItem xs="12" md="6">
            <MudSwitch T="bool" @bind-Value="Eingabe.QuittierungVerlangt" Color="Color.Primary" Label="Quittierung verlangen (Lesebestätigung)" />
        </MudItem>
    }
</MudGrid>

@code {
    [Parameter, EditorRequired] public AnkuendigungEingabe Eingabe { get; set; } = default!;

    /// <summary>Broadcast-Optionen anzeigen (nur Führung, nur beim Anlegen).</summary>
    [Parameter] public bool ZeigeBroadcastOptionen { get; set; }

    /// <summary>Steuert die Klarname-Sichtbarkeit im @-Picker (Führung).</summary>
    [Parameter] public bool IstFuehrung { get; set; }

    // Platzhalter als Konstante – ein @ in einem Komponenten-Attributwert bräche sonst den Razor-Parser.
    private const string Platzhalter = "Text der Ankündigung … (Akten/Agenten verlinken per @)";

    private List<Taskforce> _taskforces = new();

    // MentionEingabe bindet an einen Nicht-Null-String; mit dem optionalen Inhalt synchronisieren.
    private string _inhalt
    {
        get => Eingabe.Inhalt ?? string.Empty;
        set => Eingabe.Inhalt = value;
    }

    protected override async Task OnInitializedAsync()
    {
        if (ZeigeBroadcastOptionen)
        {
            // Sichtbare Taskforces als Ziel-Auswahl (Führung sieht auch Verschlusssachen).
            _taskforces = await TaskforceService.GetListeAsync(IstFuehrung);
        }
    }
}
