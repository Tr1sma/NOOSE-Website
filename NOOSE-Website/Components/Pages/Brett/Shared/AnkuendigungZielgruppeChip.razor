@* Kleiner Chip, der die Zielgruppe einer Ankündigung anzeigt (Icon je Art + aufgelöster Anzeigetext). *@

<MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default" Icon="@Symbol">
    @(string.IsNullOrWhiteSpace(Anzeige) ? AnkuendigungZielgruppeAnzeige.Name(Zielgruppe) : Anzeige)
</MudChip>

@code {
    [Parameter, EditorRequired] public AnkuendigungZielgruppe Zielgruppe { get; set; }

    /// <summary>Aufgelöster Anzeigetext (z. B. „Taskforce: Nightfall" oder „Ab Senior Special Agent").</summary>
    [Parameter] public string? Anzeige { get; set; }

    private string Symbol => Zielgruppe switch
    {
        AnkuendigungZielgruppe.AlleAktiven => Icons.Material.Filled.Public,
        AnkuendigungZielgruppe.Taskforce => Icons.Material.Filled.Groups2,
        AnkuendigungZielgruppe.TruEinheit => Icons.Material.Filled.Security,
        AnkuendigungZielgruppe.HrbEinheit => Icons.Material.Filled.Groups,
        AnkuendigungZielgruppe.AbDienstgrad => Icons.Material.Filled.MilitaryTech,
        _ => Icons.Material.Filled.Group,
    };
}
