@page "/brett"
@inject IAnkuendigungService BrettService
@inject IMentionService MentionService
@inject ISnackbar Snackbar

<PageTitle>Schwarzes Brett · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
    <MudIcon Icon="@Icons.Material.Filled.Campaign" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h4">Schwarzes Brett</MudText>
    <MudSpacer />
    <AuthorizeView Policy="@Policies.Fuehrung">
        <MudButton Href="/brett/papierkorb" Variant="Variant.Text" Color="Color.Default" StartIcon="@Icons.Material.Filled.Delete">Papierkorb</MudButton>
    </AuthorizeView>
    <AuthorizeView Policy="@Policies.Schreibrecht" Context="schreib">
        <MudButton Href="/brett/neu" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add">Neue Ankündigung</MudButton>
    </AuthorizeView>
</MudStack>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
    Ankündigungen &amp; Behörden-Broadcasts. Jeder aktive Agent kann eine Brett-Notiz posten; gezielte Broadcasts an
    Gruppen, Glocken-Push und Quittierungen sind der Führung vorbehalten.
</MudText>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_eintraege.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">Noch keine Ankündigungen am Brett.</MudAlert>
}
else
{
    <MudStack Spacing="3">
        @foreach (var e in _eintraege)
        {
            <AnkuendigungKarte Zeile="e.Zeile" Segmente="e.Segmente" OnQuittieren="@(() => QuittierenAsync(e.Zeile))" />
        }
    </MudStack>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _laden = true;
    private ClaimsPrincipal _user = default!;
    private List<Eintrag> _eintraege = new();

    private sealed record Eintrag(AnkuendigungZeile Zeile, IReadOnlyList<MentionSegment> Segmente);

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        await LadenAsync();
    }

    private async Task LadenAsync()
    {
        _laden = true;
        var zeilen = await BrettService.GetBrettAsync(_user);
        // Mentions aller Inhalte in einer Sammelabfrage auflösen (Verschlusssachen für Nicht-Führung verborgen).
        var segmente = await MentionService.AufloesenVieleAsync(zeilen.Select(z => (string?)z.Inhalt).ToList(), _user.DarfVerschlusssacheLesen(), _user.GetAgentId());
        _eintraege = zeilen.Select((z, i) => new Eintrag(z, segmente[i])).ToList();
        _laden = false;
    }

    private async Task QuittierenAsync(AnkuendigungZeile zeile)
    {
        try
        {
            await BrettService.QuittierenAsync(zeile.Id, _user);
            Snackbar.Add("Kenntnis genommen.", Severity.Success);
            await LadenAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
