@page "/taskforces/{Id}/bearbeiten"
@inject ITaskforceService TaskforceService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Taskforce bearbeiten · NOOSE</PageTitle>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_eingabe is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
        Taskforce nicht gefunden oder nicht zugänglich.
    </MudAlert>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="@($"/taskforces/{Id}")" aria-label="Zurück" />
        <MudIcon Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Large" />
        <MudText Typo="Typo.h4">Taskforce bearbeiten</MudText>
    </MudStack>

    <MudForm @ref="_form">
        <TaskforceForm Eingabe="_eingabe" IstFuehrung="_istFuehrung" />
    </MudForm>
    <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2">
        Hinweis: Der Genehmigungs-Status wird in der Akte über das Menü „Genehmigung" geändert (nur Führung).
    </MudText>

    <MudStack Row="true" Spacing="2" Class="mt-4">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SpeichernAsync" Disabled="_speichert">Speichern</MudButton>
        <MudButton Variant="Variant.Text" Href="@($"/taskforces/{Id}")">Abbrechen</MudButton>
    </MudStack>
}

@code {
    [Parameter] public string Id { get; set; } = default!;
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private MudForm _form = default!;
    private TaskforceEingabe? _eingabe;
    private ClaimsPrincipal _user = default!;
    private bool _istFuehrung;
    private bool _laden = true;
    private bool _speichert;

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        _istFuehrung = _user.IstFuehrung();
        var t = await TaskforceService.GetDetailAsync(Id, _istFuehrung);
        if (t is not null)
        {
            _eingabe = new TaskforceEingabe
            {
                Name = t.Name,
                Zweck = t.Zweck,
                Geltungsbereich = t.Geltungsbereich,
                Bemerkungen = t.Bemerkungen,
                IstVerschlusssache = t.IstVerschlusssache,
            };
        }
        _laden = false;
    }

    private async Task SpeichernAsync()
    {
        if (_eingabe is null)
        {
            return;
        }
        await _form.ValidateAsync();
        if (!_form.IsValid)
        {
            return;
        }

        _speichert = true;
        try
        {
            await TaskforceService.AktualisierenAsync(Id, _eingabe, _user);
            Snackbar.Add("Änderungen gespeichert.", Severity.Success);
            Nav.NavigateTo($"/taskforces/{Id}");
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
            _speichert = false;
        }
    }
}
