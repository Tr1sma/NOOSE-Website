@* Der Taskforce zugeteilte NOOSE-Agents: Mitglieder + Leitung (Chefermittler/CID-Lead/TRU-Lead).
   Liste + Zuteilen/Entfernen (Führung oder Leitung) + Rollenvergabe (nur Führung).
   Komponentenname bewusst „TaskforceAgentePanel" wegen globaler @using-Tag-Auflösung der Shared-Ordner. *@
@inject ITaskforceService TaskforceService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudText Typo="Typo.subtitle1">Zugeteilte Agents (@_agenten.Count)</MudText>
        @if (_kannVerwalten)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.GroupAdd" OnClick="ZuteilenAsync">
                Agent zuteilen
            </MudButton>
        }
    </MudStack>

    @if (_laden)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_agenten.Count == 0)
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Agents zugeteilt.</MudText>
    }
    else
    {
        @foreach (var a in _agenten)
        {
            <MudPaper Class="pa-3" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@(TaskforceRolleAnzeige.IstLeitung(a.Rolle) ? Icons.Material.Filled.LocalPolice : Icons.Material.Filled.Person)"
                                 Color="@(TaskforceRolleAnzeige.IstLeitung(a.Rolle) ? Color.Warning : Color.Primary)" Size="Size.Small" />
                        <MudText Typo="Typo.body2"><b>@a.Agent?.Codename</b></MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">@DienstgradAnzeige.Name(a.Agent?.Dienstgrad)</MudChip>
                        @if (TaskforceRolleAnzeige.IstLeitung(a.Rolle))
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled" Icon="@Icons.Material.Filled.LocalPolice">@TaskforceRolleAnzeige.Name(a.Rolle)</MudChip>
                        }
                    </MudStack>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="0">
                        @if (_istFuehrung)
                        {
                            <MudMenu Icon="@Icons.Material.Filled.MilitaryTech" Size="Size.Small" Dense="true"
                                     Color="@(TaskforceRolleAnzeige.IstLeitung(a.Rolle) ? Color.Warning : Color.Default)"
                                     AriaLabel="Rolle ändern">
                                @foreach (var r in TaskforceRolleAnzeige.Alle)
                                {
                                    <MudMenuItem Disabled="@(r == a.Rolle)" OnClick="@(() => RolleSetzenAsync(a, r))">@TaskforceRolleAnzeige.Name(r)</MudMenuItem>
                                }
                            </MudMenu>
                        }
                        @if (_kannVerwalten)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                           OnClick="@(() => EntfernenAsync(a))" aria-label="Agent entfernen" />
                        }
                    </MudStack>
                </MudStack>
            </MudPaper>
        }
    }
</MudStack>

@code {
    [Parameter, EditorRequired] public string TaskforceId { get; set; } = default!;
    [Parameter, EditorRequired] public ClaimsPrincipal User { get; set; } = default!;

    /// <summary>Wird nach jeder Änderung der Zuteilungen/Rollen ausgelöst (Steckkarte aktualisieren).</summary>
    [Parameter] public EventCallback Changed { get; set; }

    private bool _laden = true;
    private bool _istFuehrung;
    private bool _kannVerwalten;
    private List<TaskforceAgent> _agenten = new();

    protected override async Task OnInitializedAsync()
    {
        _istFuehrung = User.IstFuehrung();
        await LadenAsync();
    }

    private async Task LadenAsync()
    {
        _laden = true;
        _agenten = await TaskforceService.GetAgentenAsync(TaskforceId);
        // Verwalten (zuteilen/entfernen) darf die Führung oder die Leitung (Rolle != Mitglied) dieser Akte.
        var meineId = User.GetAgentId();
        _kannVerwalten = _istFuehrung || _agenten.Any(a => a.AgentId == meineId && TaskforceRolleAnzeige.IstLeitung(a.Rolle));
        _laden = false;
    }

    private async Task ZuteilenAsync()
    {
        var ausschluss = _agenten.Select(a => a.AgentId).ToList();
        // Rolle (Leitung) wird nicht im Dialog gesetzt – neue Agents kommen als Mitglied, Rolle danach per Menü (Führung).
        var wahl = await AgentZuteilenDialog.ZeigenAsync(DialogService, ausschluss, User.DarfKlarnameSehen(), darfErmittlungsleiterSetzen: false);
        if (wahl is null)
        {
            return;
        }
        try
        {
            await TaskforceService.AgentZuteilenAsync(TaskforceId, wahl.AgentId, User);
            Snackbar.Add("Agent zugeteilt.", Severity.Success);
            await LadenAsync();
            await Changed.InvokeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task RolleSetzenAsync(TaskforceAgent a, TaskforceRolle rolle)
    {
        try
        {
            await TaskforceService.RolleSetzenAsync(a.Id, rolle, User);
            Snackbar.Add($"Rolle gesetzt: {TaskforceRolleAnzeige.Name(rolle)}.", Severity.Success);
            await LadenAsync();
            await Changed.InvokeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task EntfernenAsync(TaskforceAgent a)
    {
        var ok = await BestaetigenDialog.ZeigenAsync(DialogService, "Zuteilung aufheben?",
            $"„{a.Agent?.Codename}“ wird der Taskforce nicht mehr zugeteilt.", "Entfernen");
        if (!ok)
        {
            return;
        }
        try
        {
            await TaskforceService.AgentEntfernenAsync(a.Id, User);
            Snackbar.Add("Zuteilung aufgehoben.", Severity.Success);
            await LadenAsync();
            await Changed.InvokeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
