@implements IAsyncDisposable
@inject ITaskforceChatService ChatService
@inject IMentionService MentionService
@inject TaskforceChatBroadcaster Broadcaster
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudStack Spacing="2" Style="height:60vh;">
    @* Column-reverse keeps newest pinned to bottom, no JS *@
    <div style="flex:1 1 auto; display:flex; flex-direction:column-reverse; overflow-y:auto; gap:8px; padding:4px;">
        @if (_load)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else
        {
            @foreach (var e in _entries.AsEnumerable().Reverse())
            {
                var own = e.Msg.CreatedById == _myId;
                <div style="@(own ? "align-self:flex-end;" : "align-self:flex-start;")max-width:80%;">
                    <MudPaper Class="pa-2" Elevation="@(own ? 0 : 1)" Outlined="@(!own)"
                              Style="@(own ? "background-color:var(--mud-palette-primary-hover);" : "")">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudText Typo="Typo.caption"><b>@(string.IsNullOrWhiteSpace(e.Msg.AuthorName) ? "Unbekannt" : e.Msg.AuthorName)</b></MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">· @e.Msg.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</MudText>
                            @if (_mayWrite && (own || _isLeadership))
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                               OnClick="@(() => DeleteAsync(e.Msg))" aria-label="Nachricht zurückziehen" />
                            }
                        </MudStack>
                        <MentionText Segments="e.Segments" />
                    </MudPaper>
                </div>
            }
            @if (_morePossible)
            {
                <div style="align-self:center;">
                    <MudButton Variant="Variant.Text" Size="Size.Small" StartIcon="@Icons.Material.Filled.ExpandLess"
                               OnClick="OlderLoadAsync" Disabled="_loadsMore">Ältere laden</MudButton>
                </div>
            }
            @if (_entries.Count == 0)
            {
                <MudText Typo="Typo.body2" Class="mud-text-secondary" Style="align-self:center;">Noch keine Nachrichten – beginne den Chat.</MudText>
            }
        }
    </div>

    @if (_mayWrite)
    {
        <div>
            <MentionInput @bind-Text="_text" IsLeadership="_isLeadership"
                            MayClassifiedRead="_mayClassifiedRead" MayRealName="_mayRealName"
                            Placeholder="@Placeholder" OnSubmit="SendAsync" />
            <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-1">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Send"
                           OnClick="SendAsync" Disabled="@(_sends || string.IsNullOrWhiteSpace(_text))">Senden</MudButton>
            </MudStack>
        </div>
    }
</MudStack>

@code {
    [Parameter, EditorRequired] public string TaskforceId { get; set; } = default!;
    [Parameter, EditorRequired] public ClaimsPrincipal User { get; set; } = default!;

    private const int Page = 50;
    private const string Placeholder = "Nachricht verfassen … (Verlinken per @, Strg+Enter sendet)";
    private bool _load = true;
    private bool _loadsMore;
    private bool _sends;
    private bool _morePossible;
    private bool _isLeadership;
    private bool _mayClassifiedRead;
    private bool _mayRealName;
    private bool _mayWrite;
    private string? _myId;
    private string _text = string.Empty;
    private List<Entry> _entries = new();

    private sealed record Entry(TaskforceMessage Msg, IReadOnlyList<MentionSegment> Segments);

    protected override async Task OnInitializedAsync()
    {
        _isLeadership = User.IsLeadership();
        _mayClassifiedRead = User.MayClassifiedRead();
        _mayRealName = User.MayRealNameSee();
        _mayWrite = User.MayWrite();
        _myId = User.GetAgentId();
        Broadcaster.Modified += OnModified;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _load = true;
        var messages = await ChatService.GetMessagesAsync(TaskforceId, _mayClassifiedRead, Page);
        _morePossible = messages.Count >= Page;
        _entries = await ToEntriesAsync(messages);
        _load = false;
    }

    private async Task<List<Entry>> ToEntriesAsync(List<TaskforceMessage> messages)
    {
        var segments = await MentionService.ResolveManyAsync(
            messages.Select(n => (string?)n.Text).ToList(), _mayClassifiedRead, _myId);
        return messages.Select((n, i) => new Entry(n, segments[i])).ToList();
    }

    private async Task OlderLoadAsync()
    {
        if (_entries.Count == 0 || _loadsMore)
        {
            return;
        }
        _loadsMore = true;
        var oldest = _entries[0].Msg.CreatedAt;
        var more = await ChatService.GetMessagesAsync(TaskforceId, _mayClassifiedRead, Page, oldest);
        _morePossible = more.Count >= Page;
        if (more.Count > 0)
        {
            var @new = await ToEntriesAsync(more);
            _entries = @new.Concat(_entries).ToList();
        }
        _loadsMore = false;
    }

    private async Task SendAsync()
    {
        if (string.IsNullOrWhiteSpace(_text) || _sends)
        {
            return;
        }
        _sends = true;
        try
        {
            await ChatService.SendAsync(TaskforceId, _text, User);
            _text = string.Empty; // broadcaster refreshes the list
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        _sends = false;
    }

    private async Task DeleteAsync(TaskforceMessage m)
    {
        var ok = await ConfirmDialog.ShowAsync(DialogService, "Nachricht zurückziehen?",
            "Die Nachricht wird aus dem Chat entfernt.", "Zurückziehen");
        if (!ok)
        {
            return;
        }
        try
        {
            await ChatService.DeleteAsync(m.Id, User); // broadcaster reloads
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    // Marshal cross-circuit signal into own circuit, reload
    private void OnModified(string taskforceId)
    {
        if (taskforceId != TaskforceId)
        {
            return;
        }
        _ = InvokeAsync(async () =>
        {
            await LoadAsync();
            StateHasChanged();
        });
    }

    public ValueTask DisposeAsync()
    {
        Broadcaster.Modified -= OnModified;
        return ValueTask.CompletedTask;
    }
}
