<MudPaper Class="pa-4" Elevation="2">
    <MudStack Spacing="3">
        <MudStack AlignItems="AlignItems.Center" Class="py-2">
            <MudAvatar Color="Color.Primary" Rounded="true" Style="height:120px;width:120px;">
                <MudIcon Icon="@Icons.Material.Filled.Groups2" Style="font-size:3rem;" />
            </MudAvatar>
        </MudStack>

        <div>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudText Typo="Typo.h5">@Taskforce.Name</MudText>
                @if (Taskforce.IsClassified)
                {
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Warning" Size="Size.Small" Title="Verschlusssache" />
                }
            </MudStack>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">@Taskforce.CaseNumber</MudText>
        </div>

        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="flex-wrap">
            <TaskforceStatusChip Status="Taskforce.Status" />
            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                @TaskforceScopeDisplay.Name(Taskforce.Scope)
            </MudChip>
        </MudStack>

        <MudDivider />

        <div>
            <MudText Typo="Typo.caption" Class="mud-text-secondary">Leitung</MudText>
            @if (Lead.Count == 0)
            {
                <MudText Typo="Typo.body2" Class="mud-text-secondary">—</MudText>
            }
            else
            {
                <MudStack Spacing="1" Class="mt-1">
                    @foreach (var l in Lead)
                    {
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.LocalPolice" Color="Color.Warning" Size="Size.Small" />
                            <MudText Typo="Typo.body2"><b>@l.Codename</b></MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">@TaskforceRoleDisplay.Name(l.Role)</MudChip>
                        </MudStack>
                    }
                </MudStack>
            }
        </div>

        <MudDivider />

        <MudStack Spacing="1">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <RecencyIndicator Level="@(Taskforce.AgingDisabled ? RecencyLevel.Fresh : (RecencyLevel?)null)"
                                  RecordsType="@nameof(Taskforce)" ReferenceDateUtc="@(Taskforce.ModifiedAt ?? Taskforce.CreatedAt)" />
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    Zuletzt aktualisiert: @((Taskforce.ModifiedAt ?? Taskforce.CreatedAt).ToLocalTime().ToString("dd.MM.yyyy HH:mm"))
                </MudText>
            </MudStack>
            <AuthorizeView Policy="@Policies.Leadership">
                <MudSwitch T="bool" Value="Taskforce.AgingDisabled" ValueChanged="ToggleAgingAsync"
                           Color="Color.Info" Size="Size.Small" Label="Veralterung deaktiviert" />
            </AuthorizeView>
        </MudStack>
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired] public Taskforce Taskforce { get; set; } = default!;

    /// <summary>Taskforce lead (codename + role) for prominent display.</summary>
    [Parameter] public IReadOnlyList<(string Codename, TaskforceRole Role)> Lead { get; set; } = Array.Empty<(string, TaskforceRole)>();

    [Parameter] public ClaimsPrincipal? User { get; set; }
    [Parameter] public EventCallback Changed { get; set; }

    [Inject] private IRecencyService Recency { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    /// <summary>Toggle this record's aging exemption.</summary>
    private async Task ToggleAgingAsync(bool value)
    {
        if (User is null)
        {
            return;
        }
        try
        {
            await Recency.SetRecordExemptionAsync(nameof(Taskforce), Taskforce.Id, value, User);
            Snackbar.Add(value ? "Veralterung für diese Akte deaktiviert." : "Veralterung wieder aktiv.", Severity.Success);
            await Changed.InvokeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
            StateHasChanged();
        }
    }
}
