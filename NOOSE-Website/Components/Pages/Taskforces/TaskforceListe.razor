@page "/taskforces"
@inject ITaskforceService TaskforceService
@inject IAktualitaetService Aktualitaet
@inject NavigationManager Nav

<PageTitle>Taskforces · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
    <MudIcon Icon="@Icons.Material.Filled.Groups2" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h4">Taskforces</MudText>
    <MudSpacer />
    <AuthorizeView Policy="@Policies.Fuehrung">
        <MudButton Href="/taskforces/papierkorb" Variant="Variant.Text" Color="Color.Default" StartIcon="@Icons.Material.Filled.Delete">Papierkorb</MudButton>
    </AuthorizeView>
    <MudButton Href="/taskforces/neu" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add">Neue Taskforce</MudButton>
</MudStack>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-6">
    Einsatzgruppen mit Leitung (Chefermittler/CID-Lead/TRU-Lead), zugeteilten Agents, Geltungsbereich und Genehmigungsstatus.
</MudText>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudDataGrid T="TaskforceZeile" Items="_zeilen" Hover="true" Filterable="false" SortMode="SortMode.Multiple"
                 QuickFilter="Filter" Elevation="2" RowClick="@(args => Oeffnen(args.Item))" Dense="true">
        <ToolBarContent>
            <MudTextField @bind-Value="_suche" Placeholder="Suchen (Name, Aktenzeichen)…" Immediate="true"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" />
            <MudSpacer />
            <MudSelect T="TaskforceStatus?" Value="_statusFilter" ValueChanged="StatusGewaehlt" Label="Status" Dense="true"
                       Clearable="true" Variant="Variant.Outlined" Style="max-width:220px;">
                <MudSelectItem T="TaskforceStatus?" Value="@((TaskforceStatus?)null)">Alle</MudSelectItem>
                @foreach (var s in TaskforceStatusAnzeige.Alle)
                {
                    <MudSelectItem T="TaskforceStatus?" Value="@s">@TaskforceStatusAnzeige.Name(s)</MudSelectItem>
                }
            </MudSelect>
        </ToolBarContent>
        <Columns>
            <PropertyColumn Property="x => x.Aktenzeichen" Title="Aktenzeichen" />
            <TemplateColumn Title="Name" SortBy="x => x.Name">
                <CellTemplate>
                    @* Echter Link: Mittelklick/Strg+Klick öffnet die Akte im neuen Tab; tastatur-/screenreader-erreichbar. *@
                    <MudLink Href="@($"/taskforces/{context.Item.Id}")" @onclick:stopPropagation="true">@context.Item.Name</MudLink>
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.Geltungsbereich" Title="Geltungsbereich" />
            <TemplateColumn Title="Status" SortBy="x => x.Status">
                <CellTemplate>
                    <TaskforceStatusChip Status="context.Item.Status" />
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Verschluss" Sortable="false">
                <CellTemplate>
                    @if (context.Item.IstVerschlusssache)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Warning" Size="Size.Small" Title="Verschlusssache" />
                    }
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Aktualität" SortBy="x => x.Stufe">
                <CellTemplate>
                    <AktualitaetsAmpel Stufe="context.Item.Stufe" ReferenzdatumUtc="context.Item.AktualisiertUtc" />
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.Aktualisiert" Title="Zuletzt" Format="dd.MM.yyyy HH:mm" />
        </Columns>
        <NoRecordsContent>
            <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-6">
                <MudIcon Icon="@Icons.Material.Filled.Groups2" Color="Color.Default" Size="Size.Large" />
                <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Taskforces – lege die erste an.</MudText>
                <MudButton Href="/taskforces/neu" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add">Neue Taskforce</MudButton>
            </MudStack>
        </NoRecordsContent>
        <PagerContent>
            <MudDataGridPager T="TaskforceZeile" />
        </PagerContent>
    </MudDataGrid>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _laden = true;
    private string _suche = string.Empty;
    private TaskforceStatus? _statusFilter;
    private List<TaskforceZeile> _zeilen = new();

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthStateTask).User;
        var istFuehrung = user.IstFuehrung();
        var taskforces = await TaskforceService.GetListeAsync(istFuehrung);
        var (warnungTage, veraltetTage) = await Aktualitaet.GetSchwelleAsync(nameof(Taskforce));
        var jetzt = DateTime.UtcNow;
        _zeilen = taskforces.Select(t =>
        {
            var referenzUtc = t.GeaendertAm ?? t.ErstelltAm;
            return new TaskforceZeile
            {
                Id = t.Id,
                Aktenzeichen = t.Aktenzeichen,
                Name = t.Name,
                Geltungsbereich = TaskforceGeltungsbereichAnzeige.Name(t.Geltungsbereich),
                Status = t.Status,
                IstVerschlusssache = t.IstVerschlusssache,
                AktualisiertUtc = referenzUtc,
                Aktualisiert = referenzUtc.ToLocalTime(),
                Stufe = AktualitaetsBewertung.Stufe(warnungTage, veraltetTage, referenzUtc, jetzt),
            };
        }).ToList();
        _laden = false;
    }

    private void StatusGewaehlt(TaskforceStatus? status)
    {
        _statusFilter = status;
        StateHasChanged();
    }

    private bool Filter(TaskforceZeile z)
    {
        if (_statusFilter is not null && z.Status != _statusFilter)
        {
            return false;
        }
        if (string.IsNullOrWhiteSpace(_suche))
        {
            return true;
        }
        var s = _suche.Trim();
        return z.Name.Contains(s, StringComparison.OrdinalIgnoreCase)
            || z.Aktenzeichen.Contains(s, StringComparison.OrdinalIgnoreCase);
    }

    private void Oeffnen(TaskforceZeile z) => Nav.NavigateTo($"/taskforces/{z.Id}");

    private sealed class TaskforceZeile
    {
        public string Id { get; set; } = string.Empty;
        public string Aktenzeichen { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string Geltungsbereich { get; set; } = string.Empty;
        public TaskforceStatus Status { get; set; }
        public bool IstVerschlusssache { get; set; }
        public DateTime AktualisiertUtc { get; set; }
        public DateTime Aktualisiert { get; set; }
        public AktualitaetsStufe Stufe { get; set; }
    }
}
