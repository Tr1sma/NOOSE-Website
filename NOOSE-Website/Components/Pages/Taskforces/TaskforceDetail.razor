@page "/taskforces/{Id}"
@inject ITaskforceService TaskforceService
@inject IZugriffsLogService ZugriffsLog
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>@(_taskforce?.Name ?? "Taskforce") · NOOSE</PageTitle>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_taskforce is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
        Taskforce nicht gefunden oder nicht zugänglich (ggf. Verschlusssache).
    </MudAlert>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/taskforces" aria-label="Zurück" />
        <MudSpacer />
        <FolgenButton EntitaetTyp="@nameof(Taskforce)" EntitaetId="@_taskforce.Id" User="_user" />
        <AufgabeErstellenButton EntitaetTyp="@nameof(Taskforce)" EntitaetId="@_taskforce.Id" />
        <AuthorizeView Policy="@Policies.Fuehrung">
            <MudMenu Label="Genehmigung" StartIcon="@Icons.Material.Filled.Gavel" EndIcon="@Icons.Material.Filled.ArrowDropDown"
                     Variant="Variant.Outlined" Color="Color.Secondary">
                <MudMenuItem Disabled="@(_taskforce.Status == TaskforceStatus.Genehmigt)" OnClick="@(() => StatusSetzenAsync(TaskforceStatus.Genehmigt))">Genehmigen</MudMenuItem>
                <MudMenuItem Disabled="@(_taskforce.Status == TaskforceStatus.Abgelehnt)" OnClick="@(() => StatusSetzenAsync(TaskforceStatus.Abgelehnt))">Ablehnen</MudMenuItem>
                <MudMenuItem Disabled="@(_taskforce.Status == TaskforceStatus.Aufgeloest)" OnClick="@(() => StatusSetzenAsync(TaskforceStatus.Aufgeloest))">Auflösen</MudMenuItem>
            </MudMenu>
        </AuthorizeView>
        <MudButton Href="@($"/taskforces/{_taskforce.Id}/bearbeiten")" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit">Bearbeiten</MudButton>
        <AuthorizeView Policy="@Policies.Fuehrung">
            <MudButton Color="Color.Error" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Delete" OnClick="LoeschenAsync">Löschen</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-2 mb-4" Elevation="1">
        <TagChips EntitaetTyp="@nameof(Taskforce)" EntitaetId="@_taskforce.Id" User="_user" />
    </MudPaper>

    <MudGrid>
        <MudItem xs="12" md="4" lg="3">
            <div class="akte-steckkarte">
                <Taskforcekarte Taskforce="_taskforce" Leitung="_leitung" />
            </div>
        </MudItem>

        <MudItem xs="12" md="8" lg="9">
            <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" TabPanelsClass="pa-4"
                     @bind-ActivePanelIndex="_aktiverTab"
                     @bind-ActivePanelIndex:after="@(() => TabUrlState.Write(Nav, _tabs, _aktiverTab))">
                <MudTabPanel Text="Stammdaten" Icon="@Icons.Material.Filled.Info">
                    <MudStack Spacing="3">
                        @if (!string.IsNullOrWhiteSpace(_taskforce.Zweck))
                        {
                            <div>
                                <MudText Typo="Typo.subtitle2">Sinn / Zweck</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary" Style="white-space:pre-line;">@_taskforce.Zweck</MudText>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(_taskforce.Bemerkungen))
                        {
                            <div>
                                <MudText Typo="Typo.subtitle2">Bemerkungen</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary" Style="white-space:pre-line;">@_taskforce.Bemerkungen</MudText>
                            </div>
                        }
                        @if (string.IsNullOrWhiteSpace(_taskforce.Zweck) && string.IsNullOrWhiteSpace(_taskforce.Bemerkungen))
                        {
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">Keine weiteren Stammdaten erfasst.</MudText>
                        }
                    </MudStack>
                </MudTabPanel>
                <MudTabPanel Text="Zugeteilte Agents" Icon="@Icons.Material.Filled.ManageAccounts">
                    <TaskforceAgentePanel TaskforceId="@_taskforce.Id" User="_user" Changed="LeitungAktualisierenAsync" />
                </MudTabPanel>
                <MudTabPanel Text="Chat" Icon="@Icons.Material.Filled.Forum">
                    <TaskforceChatPanel TaskforceId="@_taskforce.Id" User="_user" />
                </MudTabPanel>
                <MudTabPanel Text="Beziehungen" Icon="@Icons.Material.Filled.Hub">
                    <TaskforceBeziehungenPanel TaskforceId="@_taskforce.Id" User="_user" />
                </MudTabPanel>
                <MudTabPanel Text="Quellen" Icon="@Icons.Material.Filled.AttachFile">
                    <QuellenPanel EntitaetTyp="@nameof(Taskforce)" EntitaetId="@_taskforce.Id" User="_user" />
                </MudTabPanel>
                <MudTabPanel Text="Kommentare" Icon="@Icons.Material.Filled.Comment">
                    <KommentarPanel EntitaetTyp="@nameof(Taskforce)" EntitaetId="@_taskforce.Id" User="_user" />
                </MudTabPanel>
                <MudTabPanel Text="Historie" Icon="@Icons.Material.Filled.History">
                    <TaskforceHistorieTimeline TaskforceId="@_taskforce.Id" IstFuehrung="_user.IstFuehrung()" @key="_historieKey" />
                </MudTabPanel>
            </MudTabs>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public string Id { get; set; } = default!;
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _laden = true;
    private Taskforce? _taskforce;
    private List<(string Codename, TaskforceRolle Rolle)> _leitung = new();
    private ClaimsPrincipal _user = default!;
    private Guid _historieKey = Guid.NewGuid();
    private string? _geladeneId;

    // Aktiver Tab wird in der URL (?tab=…) gehalten – Reihenfolge muss den MudTabPanels entsprechen.
    private int _aktiverTab;
    private static readonly string[] _tabs =
    {
        "stammdaten", "agents", "chat", "beziehungen", "quellen", "kommentare", "historie",
    };

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
    }

    // Diese Seite wird bei Navigation /taskforces/{A} → /taskforces/{B} WIEDERVERWENDET (gleiche Komponente);
    // OnInitializedAsync läuft dann NICHT erneut. Daher hier auf den Id-Wechsel reagieren – sonst bliebe die alte
    // Akte stehen. Das kurze _laden=true mountet den Tab-Baum (samt Kind-Panels) frisch. Tab-/Query-Wechsel: Id
    // bleibt gleich → kein Neuladen.
    protected override async Task OnParametersSetAsync()
    {
        if (_geladeneId == Id)
        {
            return;
        }
        _geladeneId = Id;
        _laden = true;
        _taskforce = null;
        _aktiverTab = TabUrlState.Read(Nav, _tabs);
        await LadenAsync();
        if (_taskforce is not null)
        {
            await ZugriffsLog.LogAnsichtAsync(nameof(Taskforce), _taskforce.Id);
        }
    }

    private async Task LadenAsync()
    {
        // Kein _laden = true beim Neuladen: sonst entfernt das @if (_laden) die MudTabs aus dem
        // Render-Baum, ein frisch gemountetes MudTabs springt auf den ersten Tab.
        _taskforce = await TaskforceService.GetDetailAsync(Id, _user.IstFuehrung());
        if (_taskforce is not null)
        {
            await LeitungLadenAsync();
        }
        _laden = false;
    }

    private async Task LeitungLadenAsync()
    {
        if (_taskforce is null)
        {
            return;
        }
        var leitung = await TaskforceService.GetLeitungAsync(_taskforce.Id);
        _leitung = leitung.Select(a => (a.Agent?.Codename ?? "?", a.Rolle)).ToList();
    }

    private async Task LeitungAktualisierenAsync()
    {
        await LeitungLadenAsync();
        StateHasChanged();
    }

    private async Task StatusSetzenAsync(TaskforceStatus neu)
    {
        if (_taskforce is null)
        {
            return;
        }
        try
        {
            await TaskforceService.GenehmigungSetzenAsync(_taskforce.Id, neu, _user);
            Snackbar.Add($"Status gesetzt: {TaskforceStatusAnzeige.Name(neu)}.", Severity.Success);
            await LadenAsync();
            _historieKey = Guid.NewGuid();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task LoeschenAsync()
    {
        if (_taskforce is null)
        {
            return;
        }
        var ok = await BestaetigenDialog.ZeigenAsync(DialogService, "Taskforce löschen?",
            "Die Taskforce wird in den Papierkorb verschoben und kann von der Führung wiederhergestellt werden.");
        if (!ok)
        {
            return;
        }
        await TaskforceService.LoeschenAsync(_taskforce.Id, _user);
        Snackbar.Add("Taskforce in den Papierkorb verschoben.", Severity.Success);
        Nav.NavigateTo("/taskforces");
    }
}
