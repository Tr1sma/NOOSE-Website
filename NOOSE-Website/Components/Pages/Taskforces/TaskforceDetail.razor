@page "/taskforces/{Id}"
@inject ITaskforceService TaskforceService
@inject IAccessLogService AccessLog
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IPartnerVisibilityPolicyService PartnerPolicy

<PageTitle>@(_taskforce?.Name ?? "Taskforce") · NOOSE</PageTitle>

@if (_load)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_taskforce is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
        Taskforce nicht gefunden oder nicht zugänglich (ggf. Verschlusssache).
    </MudAlert>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/taskforces" aria-label="Zurück" />
        <MudSpacer />
        <MudTooltip Text="Druckansicht – Akte drucken / als PDF speichern">
            <MudIconButton Icon="@Icons.Material.Filled.Print" Color="Color.Default"
                           Href="@($"/taskforces/{Id}/druck")" Target="_blank"
                           aria-label="Druckansicht öffnen" />
        </MudTooltip>
        @if (!_isPartner)
        {
            <FollowButton EntityType="@nameof(Taskforce)" EntityId="@_taskforce.Id" User="_user" />
            <JobCreateButton EntityType="@nameof(Taskforce)" EntityId="@_taskforce.Id" />
        }
        <AuthorizeView Policy="@Policies.WriteAccess" Context="freigabe">
            <PartnerShareButton EntityType="@nameof(Taskforce)" EntityId="@_taskforce.Id" />
        </AuthorizeView>
        <AuthorizeView Policy="@Policies.Leadership">
            <MudMenu Label="Genehmigung" StartIcon="@Icons.Material.Filled.Gavel" EndIcon="@Icons.Material.Filled.ArrowDropDown"
                     Variant="Variant.Outlined" Color="Color.Secondary">
                <MudMenuItem Disabled="@(_taskforce.Status == TaskforceStatus.Approved)" OnClick="@(() => StatusSetAsync(TaskforceStatus.Approved))">Genehmigen</MudMenuItem>
                <MudMenuItem Disabled="@(_taskforce.Status == TaskforceStatus.Rejected)" OnClick="@(() => StatusSetAsync(TaskforceStatus.Rejected))">Ablehnen</MudMenuItem>
                <MudMenuItem Disabled="@(_taskforce.Status == TaskforceStatus.Resolved)" OnClick="@(() => StatusSetAsync(TaskforceStatus.Resolved))">Auflösen</MudMenuItem>
            </MudMenu>
        </AuthorizeView>
        <AuthorizeView Policy="@Policies.WriteAccess" Context="schreib">
            <MudButton Href="@($"/taskforces/{_taskforce.Id}/bearbeiten")" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit">Bearbeiten</MudButton>
        </AuthorizeView>
        <AuthorizeView Policy="@Policies.Leadership">
            <MudButton Color="Color.Error" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Delete" OnClick="DeleteAsync">Löschen</MudButton>
        </AuthorizeView>
    </MudStack>

    @if (!_isPartner)
    {
        <MudPaper Class="pa-2 mb-4" Elevation="1">
            <TagChips EntityType="@nameof(Taskforce)" EntityId="@_taskforce.Id" User="_user" />
        </MudPaper>
    }

    <MudGrid>
        <MudItem xs="12" md="4" lg="3">
            <div class="akte-steckkarte">
                <TaskforceCard Taskforce="_taskforce" Lead="_lead" User="_user" Changed="LoadAsync" />
            </div>
        </MudItem>

        <MudItem xs="12" md="8" lg="9">
            @if (_renderTabs.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    Für Ihren Zugang sind in dieser Akte keine Bereiche freigegeben.
                </MudAlert>
            }
            else
            {
            <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" TabPanelsClass="pa-4"
                     @bind-ActivePanelIndex="_activeTab"
                     @bind-ActivePanelIndex:after="@(() => TabUrlState.WriteAsync(JS, Nav, _renderTabs, _activeTab))">
                @if (TabOn("stammdaten"))
                {
                <MudTabPanel Text="Stammdaten" Icon="@Icons.Material.Filled.Info">
                    <MudStack Spacing="3">
                        @if (!string.IsNullOrWhiteSpace(_taskforce.Purpose))
                        {
                            <div>
                                <MudText Typo="Typo.subtitle2">Sinn / Zweck</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary" Style="white-space:pre-line;">@_taskforce.Purpose</MudText>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(_taskforce.Remarks))
                        {
                            <div>
                                <MudText Typo="Typo.subtitle2">Bemerkungen</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary" Style="white-space:pre-line;">@_taskforce.Remarks</MudText>
                            </div>
                        }
                        @if (string.IsNullOrWhiteSpace(_taskforce.Purpose) && string.IsNullOrWhiteSpace(_taskforce.Remarks))
                        {
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">Keine weiteren Stammdaten erfasst.</MudText>
                        }
                    </MudStack>
                </MudTabPanel>
                }
                @* assigned NOOSE agents: internal only *@
                @if (!_isPartner)
                {
                <MudTabPanel Text="Zugeteilte Agents" Icon="@Icons.Material.Filled.ManageAccounts">
                    <TaskforceAgentsPanel TaskforceId="@_taskforce.Id" User="_user" Changed="LeadRefreshAsync" />
                </MudTabPanel>
                }
                @if (TabOn("chat"))
                {
                <MudTabPanel Text="Chat" Icon="@Icons.Material.Filled.Forum">
                    <TaskforceChatPanel TaskforceId="@_taskforce.Id" User="_user" />
                </MudTabPanel>
                }
                @if (TabOn("beziehungen"))
                {
                <MudTabPanel Text="Beziehungen" Icon="@Icons.Material.Filled.Hub">
                    <TaskforceRelationsPanel TaskforceId="@_taskforce.Id" User="_user" />
                </MudTabPanel>
                }
                @if (TabOn("quellen"))
                {
                <MudTabPanel Text="Quellen" Icon="@Icons.Material.Filled.AttachFile">
                    <SourcesPanel EntityType="@nameof(Taskforce)" EntityId="@_taskforce.Id" User="_user" />
                </MudTabPanel>
                }
                @if (TabOn("wiedervorlagen"))
                {
                <MudTabPanel Text="Wiedervorlagen" Icon="@Icons.Material.Filled.EventRepeat">
                    <FollowupPanel EntityType="@nameof(Taskforce)" EntityId="@_taskforce.Id" User="_user" />
                </MudTabPanel>
                }
                @if (TabOn("kommentare"))
                {
                <MudTabPanel Text="Kommentare" Icon="@Icons.Material.Filled.Comment">
                    <CommentPanel EntityType="@nameof(Taskforce)" EntityId="@_taskforce.Id" User="_user" />
                </MudTabPanel>
                }
                @if (TabOn("zusatzfelder"))
                {
                <MudTabPanel Text="Zusatzfelder" Icon="@Icons.Material.Filled.Tune">
                    <CustomFieldsPanel EntityType="@nameof(Taskforce)" EntityId="@_taskforce.Id" User="_user" />
                </MudTabPanel>
                }
                @if (TabOn("historie"))
                {
                <MudTabPanel Text="Zeitstrahl" Icon="@Icons.Material.Filled.Timeline">
                    <TimelinePanel EntityType="@nameof(Taskforce)" EntityId="@_taskforce.Id" User="_user" @key="_historyKey" />
                </MudTabPanel>
                }
            </MudTabs>
            }
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public string Id { get; set; } = default!;
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _load = true;
    private bool _isPartner;
    private Taskforce? _taskforce;
    private List<(string Codename, TaskforceRole Role)> _lead = new();
    private ClaimsPrincipal _user = default!;
    private Guid _historyKey = Guid.NewGuid();
    private string? _loadedId;

    // Active tab persisted in URL; order must match the MudTabPanels
    private int _activeTab;
    private static readonly string[] _tabs =
    {
        "stammdaten", "agents", "chat", "beziehungen", "quellen", "wiedervorlagen", "kommentare", "zusatzfelder", "historie",
    };

    // assigned-agents tab exposes internal codenames; hidden from partners regardless of tab config
    private static readonly HashSet<string> _internalOnlyTabs = new() { "agents" };

    // partner tab gating: null = no restriction (internal/unconfigured/individually released)
    private IReadOnlySet<string>? _visibleTabs;
    private List<string> _renderTabs = new();
    private bool TabOn(string slug) => _visibleTabs is null || _visibleTabs.Contains(slug);
    private void RebuildRenderTabs() => _renderTabs = _tabs.Where(s => (!_internalOnlyTabs.Contains(s) || !_isPartner) && TabOn(s)).ToList();

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        _isPartner = _user.IsPartner();
    }

    // Component is reused across ids; react to id changes here since OnInitialized won't rerun
    protected override async Task OnParametersSetAsync()
    {
        if (_loadedId == Id)
        {
            return;
        }
        _loadedId = Id;
        _load = true;
        _taskforce = null;
        await LoadAsync();
        _activeTab = TabUrlState.Read(Nav, _renderTabs);
        if (_taskforce is not null)
        {
            await AccessLog.LogViewAsync(nameof(Taskforce), _taskforce.Id);
        }
    }

    private async Task LoadAsync()
    {
        // Don't set _load on reload: it would remount MudTabs and jump to the first tab
        _taskforce = await TaskforceService.GetDetailAsync(Id, _user.MayAllTaskforcesSee(), _user.GetAgentId(),
            partnerAgency: _user.GetPartnerAgency(), partnerAgentId: _user.GetAgentId());
        if (_taskforce is not null && !_isPartner)
        {
            // partners: skip lead fan-out (internal codenames)
            await LeadLoadAsync();
        }
        _visibleTabs = _isPartner && _taskforce is not null
            ? await PartnerPolicy.GetVisibleTabsAsync(_user, nameof(Taskforce), _taskforce.Id)
            : null;
        RebuildRenderTabs();
        _load = false;
    }

    private async Task LeadLoadAsync()
    {
        if (_taskforce is null)
        {
            return;
        }
        var lead = await TaskforceService.GetLeadAsync(_taskforce.Id);
        _lead = lead.Select(a => (a.Agent?.Codename ?? "?", a.Role)).ToList();
    }

    private async Task LeadRefreshAsync()
    {
        await LeadLoadAsync();
        StateHasChanged();
    }

    private async Task StatusSetAsync(TaskforceStatus @new)
    {
        if (_taskforce is null)
        {
            return;
        }
        try
        {
            await TaskforceService.ApprovalSetAsync(_taskforce.Id, @new, _user);
            Snackbar.Add($"Status gesetzt: {TaskforceStatusDisplay.Name(@new)}.", Severity.Success);
            await LoadAsync();
            _historyKey = Guid.NewGuid();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task DeleteAsync()
    {
        if (_taskforce is null)
        {
            return;
        }
        var ok = await ConfirmDialog.ShowAsync(DialogService, "Taskforce löschen?",
            "Die Taskforce wird in den Papierkorb verschoben und kann von der Führung wiederhergestellt werden.");
        if (!ok)
        {
            return;
        }
        await TaskforceService.DeleteAsync(_taskforce.Id, _user);
        Snackbar.Add("Taskforce in den Papierkorb verschoben.", Severity.Success);
        Nav.NavigateTo("/taskforces");
    }
}
