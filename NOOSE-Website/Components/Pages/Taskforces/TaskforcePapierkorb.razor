@page "/taskforces/papierkorb"
@attribute [Authorize(Policy = Policies.FuehrungSeite)]
@inject ITaskforceService TaskforceService
@inject ISnackbar Snackbar

<PageTitle>Papierkorb – Taskforces · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/taskforces" aria-label="Zurück" />
    <MudIcon Icon="@Icons.Material.Filled.Delete" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h4">Papierkorb – Taskforces</MudText>
</MudStack>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-6">
    Gelöschte Taskforces. Die Führung kann sie wiederherstellen; sie erscheinen dann wieder in der Liste.
</MudText>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_taskforces.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">Der Papierkorb ist leer.</MudAlert>
}
else
{
    <MudTable Items="_taskforces" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="2" Dense="true">
        <HeaderContent>
            <MudTh><MudTableSortLabel T="Taskforce" SortBy="@(x => x.Aktenzeichen)">Aktenzeichen</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="Taskforce" SortBy="@(x => x.Name)">Name</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="Taskforce" SortBy="@(x => x.GeloeschtAm)" InitialDirection="SortDirection.Descending">Gelöscht am</MudTableSortLabel></MudTh>
            <MudTh Style="text-align:right;">Aktion</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Aktenzeichen"><MudText Typo="Typo.body2">@context.Aktenzeichen</MudText></MudTd>
            <MudTd DataLabel="Name"><MudText Typo="Typo.body2">@context.Name</MudText></MudTd>
            <MudTd DataLabel="Gelöscht am">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    @(context.GeloeschtAm?.ToLocalTime().ToString("dd.MM.yyyy HH:mm") ?? "—")
                </MudText>
            </MudTd>
            <MudTd DataLabel="Aktion" Style="text-align:right;">
                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success"
                           StartIcon="@Icons.Material.Filled.Restore"
                           OnClick="@(() => WiederherstellenAsync(context))">Wiederherstellen</MudButton>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _laden = true;
    private List<Taskforce> _taskforces = new();

    protected override Task OnInitializedAsync() => LadenAsync();

    private async Task LadenAsync()
    {
        _laden = true;
        _taskforces = await TaskforceService.GetPapierkorbAsync();
        _laden = false;
    }

    private async Task WiederherstellenAsync(Taskforce taskforce)
    {
        var user = (await AuthStateTask).User;
        try
        {
            await TaskforceService.WiederherstellenAsync(taskforce.Id, user);
            Snackbar.Add($"Taskforce {taskforce.Aktenzeichen} wiederhergestellt.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        await LadenAsync();
    }
}
