@page "/taskforces/neu"
@inject ITaskforceService TaskforceService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Neue Taskforce · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/taskforces" aria-label="Zurück" />
    <MudIcon Icon="@Icons.Material.Filled.Groups2" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h4">Neue Taskforce anlegen</MudText>
</MudStack>

<MudForm @ref="_form">
    <TaskforceForm Input="_input" IsLeadership="_isLeadership" />
</MudForm>
<MudText Typo="Typo.caption" Class="mud-text-secondary mt-2">
    Du wirst automatisch als Chefermittler (Leitung) zugeteilt. Die Taskforce startet als „Beantragt"; die Führung genehmigt sie.
</MudText>

<MudStack Row="true" Spacing="2" Class="mt-4">
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveAsync" Disabled="_saves">Anlegen</MudButton>
    <MudButton Variant="Variant.Text" Href="/taskforces">Abbrechen</MudButton>
</MudStack>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private MudForm _form = default!;
    private readonly TaskforceInput _input = new();
    private ClaimsPrincipal _user = default!;
    private bool _isLeadership;
    private bool _saves;

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        _isLeadership = _user.IsLeadership();
    }

    private async Task SaveAsync()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid)
        {
            return;
        }

        _saves = true;
        try
        {
            var taskforce = await TaskforceService.CreateAsync(_input, _user);
            Snackbar.Add($"Taskforce {taskforce.CaseNumber} angelegt.", Severity.Success);
            Nav.NavigateTo($"/taskforces/{taskforce.Id}");
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
            _saves = false;
        }
    }
}
