@* Druckansicht der Taskforce-Akte (Phase 7): komplette Akte als strukturiertes Dokument. *@
@page "/taskforces/{Id}/druck"
@layout DruckLayout
@inject ITaskforceService TaskforceService
@inject IVerknuepfungService VerknuepfungService
@inject IKommentarService KommentarService
@inject IZugriffsLogService ZugriffsLog

<PageTitle>@(_taskforce is null ? "Druckansicht" : $"Taskforce-Akte {_taskforce.Aktenzeichen}") · NOOSE</PageTitle>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_taskforce is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">Diese Akte existiert nicht (mehr) oder ist nicht sichtbar.</MudAlert>
}
else
{
    <DruckRahmen Titel="@($"Taskforce-Akte {_taskforce.Aktenzeichen}")" ZurueckHref="@($"/taskforces/{Id}")"
                 GedrucktVon="@_druckVon" IstVerschlusssache="_taskforce.IstVerschlusssache">
        <section>
            <h2>Stammdaten</h2>
            <table class="druck-felder">
                <tbody>
                    <tr><th>Name</th><td>@_taskforce.Name</td></tr>
                    <tr><th>Aktenzeichen</th><td>@_taskforce.Aktenzeichen</td></tr>
                    <tr><th>Status</th><td>@TaskforceStatusAnzeige.Name(_taskforce.Status)</td></tr>
                    <tr><th>Geltungsbereich</th><td>@TaskforceGeltungsbereichAnzeige.Name(_taskforce.Geltungsbereich)</td></tr>
                    @if (!string.IsNullOrWhiteSpace(_taskforce.Zweck))
                    {
                        <tr><th>Zweck</th><td class="druck-mehrzeilig">@_taskforce.Zweck</td></tr>
                    }
                    @if (!string.IsNullOrWhiteSpace(_taskforce.Bemerkungen))
                    {
                        <tr><th>Bemerkungen</th><td class="druck-mehrzeilig">@_taskforce.Bemerkungen</td></tr>
                    }
                    <tr><th>Zuletzt aktualisiert</th><td>@((_taskforce.GeaendertAm ?? _taskforce.ErstelltAm).ToLocalTime().ToString("dd.MM.yyyy HH:mm"))</td></tr>
                </tbody>
            </table>
        </section>

        @if (_taskforce.Agenten.Count > 0)
        {
            <section>
                <h2>Besetzung (@_taskforce.Agenten.Count)</h2>
                <table class="druck-tabelle">
                    <thead><tr><th>Agent</th><th>Rolle</th></tr></thead>
                    <tbody>
                        @foreach (var a in _taskforce.Agenten)
                        {
                            <tr>
                                <td>@(a.Agent?.Codename ?? "—")</td>
                                <td>@TaskforceRolleAnzeige.Name(a.Rolle)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>
        }

        <DruckVerknuepfungen Eintraege="_verknuepfungen" />
        <DruckKommentare Eintraege="_kommentare" />
    </DruckRahmen>
}

@code {
    [Parameter] public string Id { get; set; } = string.Empty;
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _laden = true;
    private string? _druckVon;
    private Taskforce? _taskforce;
    private List<VerknuepfungAnzeige> _verknuepfungen = new();
    private List<Kommentar> _kommentare = new();

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthStateTask).User;
        _druckVon = user.GetCodename();

        // Sichtbarkeit wie auf der Detailseite: Führung/Aufsicht sehen alles, sonst nur als Mitglied.
        _taskforce = await TaskforceService.GetDetailAsync(Id, user.DarfAlleTaskforcesSehen(), user.GetAgentId());
        if (_taskforce is not null)
        {
            _verknuepfungen = await VerknuepfungService.GetFuerAkteAsync(nameof(Taskforce), Id, user.DarfAlleTaskforcesSehen(), user.GetAgentId());
            _kommentare = await KommentarService.GetFuerAkteAsync(nameof(Taskforce), Id, user.IstFuehrung());
            await ZugriffsLog.LogAnsichtAsync(nameof(Taskforce), Id);
        }
        _laden = false;
    }
}
