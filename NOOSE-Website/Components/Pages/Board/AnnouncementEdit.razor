@page "/brett/{Id}/bearbeiten"
@inject IAnnouncementService BoardService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Ankündigung bearbeiten · NOOSE</PageTitle>

@if (_load)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_noAccess)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
        Diese Ankündigung darf nur ihr Verfasser oder die Führung bearbeiten.
        <MudButton Href="@($"/brett/{Id}")" Variant="Variant.Text" Color="Color.Primary" Class="ml-2">Zur Ankündigung</MudButton>
    </MudAlert>
}
else if (_input is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">Ankündigung nicht gefunden.</MudAlert>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="@($"/brett/{Id}")" aria-label="Zurück" />
        <MudIcon Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Large" />
        <MudText Typo="Typo.h4">Ankündigung bearbeiten</MudText>
    </MudStack>

    <MudForm @ref="_form">
        <AnnouncementForm Input="_input" ShowBroadcastOptions="false" IsLeadership="_isLeadership" />
    </MudForm>
    <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2">
        Hinweis: Zielgruppe, Glocken-Push und Quittierung werden beim Anlegen festgelegt und sind hier nicht änderbar.
    </MudText>

    <MudStack Row="true" Spacing="2" Class="mt-4">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveAsync" Disabled="_saves">Speichern</MudButton>
        <MudButton Variant="Variant.Text" Href="@($"/brett/{Id}")">Abbrechen</MudButton>
    </MudStack>
}

@code {
    [Parameter] public string Id { get; set; } = default!;
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private MudForm _form = default!;
    private AnnouncementInput? _input;
    private ClaimsPrincipal _user = default!;
    private bool _isLeadership;
    private bool _load = true;
    private bool _noAccess;
    private bool _saves;
    private string? _loadedId;

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        _isLeadership = _user.IsLeadership();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_loadedId == Id)
        {
            return;
        }
        _loadedId = Id;
        _load = true;
        _input = null;
        _noAccess = false;

        var detail = await BoardService.GetDetailAsync(Id, _user);
        if (detail is not null)
        {
            // mirror server-side edit gate so no unauthorized form appears
            if (!detail.Row.MayManage)
            {
                _noAccess = true;
            }
            else
            {
                _input = new AnnouncementInput
                {
                    Title = detail.Row.Title,
                    Content = detail.Row.Content,
                    Important = detail.Row.Important,
                };
            }
        }
        _load = false;
    }

    private async Task SaveAsync()
    {
        if (_input is null || _saves)
        {
            return;
        }
        await _form.ValidateAsync();
        if (!_form.IsValid)
        {
            return;
        }

        _saves = true;
        try
        {
            await BoardService.RefreshAsync(Id, _input, _user);
            Snackbar.Add("Änderungen gespeichert.", Severity.Success);
            Nav.NavigateTo($"/brett/{Id}");
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
            _saves = false;
        }
    }
}
