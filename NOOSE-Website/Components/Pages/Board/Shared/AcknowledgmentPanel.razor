@* Acknowledgment list for managers only; codenames, never real names. *@

<MudStack Spacing="2">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
        <MudIcon Icon="@Icons.Material.Filled.FactCheck" Color="Color.Primary" />
        <MudText Typo="Typo.subtitle1">Quittierungen</MudText>
        <MudSpacer />
        <MudText Typo="Typo.body2" Class="mud-text-secondary">@_acknowledged von @Acknowledgments.Count quittiert</MudText>
    </MudStack>

    @if (Acknowledgments.Count == 0)
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">Kein quittierungspflichtiger Empfänger.</MudText>
    }
    else
    {
        <MudList T="string" Dense="true">
            @foreach (var q in Acknowledgments)
            {
                <MudListItem T="string"
                             Icon="@(q.AcknowledgedAt is null ? Icons.Material.Filled.RadioButtonUnchecked : Icons.Material.Filled.CheckCircle)"
                             IconColor="@(q.AcknowledgedAt is null ? Color.Default : Color.Success)">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudText Typo="Typo.body2">@q.Codename</MudText>
                        <MudSpacer />
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                            @(q.AcknowledgedAt is { } z ? z.ToLocalTime().ToString("dd.MM.yyyy HH:mm") : "offen")
                        </MudText>
                    </MudStack>
                </MudListItem>
            }
        </MudList>
    }
</MudStack>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<AcknowledgmentRow> Acknowledgments { get; set; } = Array.Empty<AcknowledgmentRow>();

    private int _acknowledged => Acknowledgments.Count(q => q.AcknowledgedAt is not null);
}
