@page "/parteien/{Id}/bearbeiten"
@inject IParteiService ParteiService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Partei bearbeiten · NOOSE</PageTitle>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_eingabe is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
        Partei nicht gefunden oder nicht zugänglich.
    </MudAlert>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="@($"/parteien/{Id}")" aria-label="Zurück" />
        <MudIcon Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Large" />
        <MudText Typo="Typo.h4">Partei bearbeiten</MudText>
    </MudStack>

    <MudForm @ref="_form">
        <ParteiForm Eingabe="_eingabe" ZeigeEinstufung="false" IstFuehrung="_istFuehrung" />
    </MudForm>
    <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2">
        Hinweis: Die Einstufung wird in der Akte unter „Einstufung" geändert (mit Verlauf und Rang-Prüfung).
    </MudText>

    <MudStack Row="true" Spacing="2" Class="mt-4">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SpeichernAsync" Disabled="_speichert">Speichern</MudButton>
        <MudButton Variant="Variant.Text" Href="@($"/parteien/{Id}")">Abbrechen</MudButton>
    </MudStack>
}

@code {
    [Parameter] public string Id { get; set; } = default!;
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private MudForm _form = default!;
    private ParteiEingabe? _eingabe;
    private ClaimsPrincipal _user = default!;
    private bool _istFuehrung;
    private bool _laden = true;
    private bool _speichert;
    private string? _geladeneId;

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        _istFuehrung = _user.IstFuehrung();
    }

    // Diese Seite wird bei /parteien/{A}/bearbeiten → /parteien/{B}/bearbeiten WIEDERVERWENDET (gleiche Komponente);
    // OnInitializedAsync läuft dann NICHT erneut. Daher das id-abhängige Laden hier mit Guard – sonst bliebe das alte
    // Formular stehen. Das kurze _laden=true mountet das Formular frisch.
    protected override async Task OnParametersSetAsync()
    {
        if (_geladeneId == Id)
        {
            return;
        }
        _geladeneId = Id;
        _laden = true;
        _eingabe = null;
        var p = await ParteiService.GetDetailAsync(Id, _user.DarfVerschlusssacheLesen());
        if (p is not null)
        {
            _eingabe = new ParteiEingabe
            {
                Name = p.Name,
                Beschreibung = p.Beschreibung,
                Ziele = p.Ziele,
                Bemerkungen = p.Bemerkungen,
                Einstufung = p.Einstufung,
                IstVerschlusssache = p.IstVerschlusssache,
            };
        }
        _laden = false;
    }

    private async Task SpeichernAsync()
    {
        if (_eingabe is null)
        {
            return;
        }
        await _form.ValidateAsync();
        if (!_form.IsValid)
        {
            return;
        }

        _speichert = true;
        try
        {
            await ParteiService.AktualisierenAsync(Id, _eingabe, _user);
            Snackbar.Add("Änderungen gespeichert.", Severity.Success);
            Nav.NavigateTo($"/parteien/{Id}");
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
            _speichert = false;
        }
    }
}
