@* Dialog zum Hinzufügen/Bearbeiten einer Partei-Mitgliedschaft: Person + Rolle + Leitungs-Flag. *@
@inject IPersonService PersonService
@inject ISteckbriefVorschlagService VorschlagService

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3" Style="min-width:360px;">
            @if (IstBearbeiten)
            {
                <MudField Label="Person" Variant="Variant.Outlined">@PersonNameVorhanden</MudField>
            }
            else
            {
                <MudRadioGroup T="bool" @bind-Value="_modusNeu">
                    <MudRadio T="bool" Value="false" Color="Color.Primary" Dense="true">Bestehende Person</MudRadio>
                    <MudRadio T="bool" Value="true" Color="Color.Primary" Dense="true">Neue Person anlegen</MudRadio>
                </MudRadioGroup>
                @if (_modusNeu)
                {
                    <MudTextField @bind-Value="_neuerName" Label="Name der neuen Person" Variant="Variant.Outlined" Immediate="true"
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.PersonAddAlt1"
                                  HelperText="Es wird automatisch eine neue Akte angelegt (Aktenzeichen wird vergeben)." />
                }
                else
                {
                    <MudAutocomplete T="Person" Label="Person" @bind-Value="_person"
                                     SearchFunc="@SuchePersonen" ToStringFunc="@(p => p?.Name ?? string.Empty)"
                                     Variant="Variant.Outlined" Clearable="true" CoerceText="false" CoerceValue="false"
                                     ResetValueOnEmptyText="true" MinCharacters="0" Immediate="true"
                                     Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.PersonSearch"
                                     HelperText="Person der Partei zuordnen.">
                        <ItemTemplate Context="p">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.Badge" Size="Size.Small" Color="Color.Primary" />
                                <MudText Typo="Typo.body2">@p.Name</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@p.Aktenzeichen</MudText>
                            </MudStack>
                        </ItemTemplate>
                    </MudAutocomplete>
                }
            }

            @* Wie das Waffen-/Art-Feld: Autocomplete mit Vorschlägen aus dem gemeinsamen Katalog; freie Eingabe erlaubt.
               Ein neu eingetippter Wert (z. B. „Vorsitz") wird beim Speichern gemerkt und steht künftig zur Auswahl. *@
            <MudAutocomplete T="string" @bind-Value="_rolle" Label="Rolle (optional)"
                             SearchFunc="@RolleSuchen" Variant="Variant.Outlined"
                             CoerceText="false" CoerceValue="true" ResetValueOnEmptyText="false"
                             MinCharacters="0" Immediate="true" MaxItems="20" Clearable="true"
                             Placeholder="z. B. Vorsitz, Sprecher" />
            <MudSwitch T="bool" @bind-Value="_istLeitung" Color="Color.Primary" Label="Gehört zur Leitung" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Abbrechen">Abbrechen</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Speichern" Disabled="@(!KannSpeichern)">
            @(IstBearbeiten ? "Speichern" : "Hinzufügen")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public bool IstFuehrung { get; set; }
    [Parameter] public IReadOnlyList<string> AusschlussPersonIds { get; set; } = Array.Empty<string>();

    // Bearbeiten-Modus (Person fix): wird durch einen gesetzten Namen signalisiert.
    [Parameter] public string? PersonNameVorhanden { get; set; }
    [Parameter] public string? RolleVorhanden { get; set; }
    [Parameter] public bool IstLeitungVorhanden { get; set; }

    private bool IstBearbeiten => PersonNameVorhanden is not null;

    private Person? _person;
    private bool _modusNeu;
    private string? _neuerName;
    private string? _rolle;
    private bool _istLeitung;
    private IReadOnlyList<string> _rollenVorschlaege = Array.Empty<string>();

    // Speichern erst möglich, wenn eine Person gewählt (oder ein neuer Name eingegeben) ist – Button sonst deaktiviert.
    private bool KannSpeichern => IstBearbeiten || (_modusNeu ? !string.IsNullOrWhiteSpace(_neuerName) : _person is not null);

    protected override async Task OnInitializedAsync()
    {
        _rollenVorschlaege = await VorschlagService.GetAsync(VorschlagTyp.Parteirolle);
        if (IstBearbeiten)
        {
            _rolle = RolleVorhanden;
            _istLeitung = IstLeitungVorhanden;
        }
    }

    private Task<IEnumerable<string>> RolleSuchen(string value, CancellationToken token)
    {
        IEnumerable<string> treffer = string.IsNullOrWhiteSpace(value)
            ? _rollenVorschlaege
            : _rollenVorschlaege.Where(v => v.Contains(value.Trim(), StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(treffer);
    }

    private async Task<IEnumerable<Person>> SuchePersonen(string value, CancellationToken token)
    {
        var treffer = await PersonService.SucheAsync(value, IstFuehrung, 20, token);
        return treffer.Where(p => !AusschlussPersonIds.Contains(p.Id));
    }

    private void Speichern()
    {
        string personId = string.Empty;
        string? neuerName = null;
        string? anzeigeName = PersonNameVorhanden;
        if (!IstBearbeiten)
        {
            if (_modusNeu)
            {
                if (string.IsNullOrWhiteSpace(_neuerName))
                {
                    return;
                }
                neuerName = _neuerName.Trim();
                anzeigeName = neuerName;
            }
            else
            {
                if (_person is null)
                {
                    return;
                }
                personId = _person.Id;
                anzeigeName = _person.Name;
            }
        }
        MudDialog.Close(DialogResult.Ok(new ParteiMitgliedEingabe
        {
            PersonId = personId,
            NeuePersonName = neuerName,
            Rolle = _rolle,
            IstLeitung = _istLeitung,
            PersonName = anzeigeName,
        }));
    }

    private void Abbrechen() => MudDialog.Cancel();

    public static async Task<ParteiMitgliedEingabe?> ZeigenAsync(IDialogService dialog, bool istFuehrung, IReadOnlyList<string> ausschlussPersonIds)
    {
        var parameters = new DialogParameters<ParteiMitgliedDialog>
        {
            { x => x.IstFuehrung, istFuehrung },
            { x => x.AusschlussPersonIds, ausschlussPersonIds },
        };
        var referenz = await dialog.ShowAsync<ParteiMitgliedDialog>("Mitglied hinzufügen", parameters);
        var ergebnis = await referenz.Result;
        return ergebnis is { Canceled: false, Data: ParteiMitgliedEingabe e } ? e : null;
    }

    public static async Task<ParteiMitgliedEingabe?> ZeigenZumBearbeitenAsync(IDialogService dialog, string personName, string? rolle, bool istLeitung)
    {
        var parameters = new DialogParameters<ParteiMitgliedDialog>
        {
            { x => x.PersonNameVorhanden, personName },
            { x => x.RolleVorhanden, rolle },
            { x => x.IstLeitungVorhanden, istLeitung },
        };
        var referenz = await dialog.ShowAsync<ParteiMitgliedDialog>("Mitgliedschaft bearbeiten", parameters);
        var ergebnis = await referenz.Result;
        return ergebnis is { Canceled: false, Data: ParteiMitgliedEingabe e } ? e : null;
    }
}
