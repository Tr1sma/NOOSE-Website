@page "/parteien"
@inject IParteiService ParteiService
@inject IAktualitaetService Aktualitaet
@inject NavigationManager Nav

<PageTitle>Parteien · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
    <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h4">Parteien</MudText>
    <MudSpacer />
    <AuthorizeView Policy="@Policies.Fuehrung">
        <MudButton Href="/parteien/papierkorb" Variant="Variant.Text" Color="Color.Default" StartIcon="@Icons.Material.Filled.Delete">Papierkorb</MudButton>
    </AuthorizeView>
    <AuthorizeView Policy="@Policies.Schreibrecht" Context="schreib">
        <MudButton Href="/parteien/neu" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add">Neue Partei</MudButton>
    </AuthorizeView>
</MudStack>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-6">
    Politische Organisationen mit Leitung, Mitgliedern, Einstufung und zugeteilten Special Agents.
</MudText>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudDataGrid T="ParteiZeile" Items="_zeilen" Hover="true" Filterable="false" SortMode="SortMode.Multiple"
                 QuickFilter="Filter" Elevation="2" RowClick="@(args => Oeffnen(args.Item))" Dense="true">
        <ToolBarContent>
            <MudTextField @bind-Value="_suche" Placeholder="Suchen (Name, Aktenzeichen)…" Immediate="true"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" />
        </ToolBarContent>
        <Columns>
            <PropertyColumn Property="x => x.Aktenzeichen" Title="Aktenzeichen" />
            <TemplateColumn Title="Name" SortBy="x => x.Name">
                <CellTemplate>
                    @* Echter Link: Mittelklick/Strg+Klick öffnet die Akte im neuen Tab; tastatur-/screenreader-erreichbar. *@
                    <MudLink Href="@($"/parteien/{context.Item.Id}")" @onclick:stopPropagation="true">@context.Item.Name</MudLink>
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.Mitgliederzahl" Title="Mitglieder" />
            <TemplateColumn Title="Einstufung" SortBy="x => x.Einstufung">
                <CellTemplate>
                    <EinstufungBadge Wert="context.Item.Einstufung" />
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Verschluss" SortBy="x => x.IstVerschlusssache">
                <CellTemplate>
                    @if (context.Item.IstVerschlusssache)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Warning" Size="Size.Small" Title="Verschlusssache" />
                    }
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Aktualität" SortBy="x => x.Stufe">
                <CellTemplate>
                    <AktualitaetsAmpel Stufe="context.Item.Stufe" ReferenzdatumUtc="context.Item.AktualisiertUtc" />
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.Aktualisiert" Title="Zuletzt" Format="dd.MM.yyyy HH:mm" />
        </Columns>
        <NoRecordsContent>
            <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-6">
                <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Color="Color.Default" Size="Size.Large" />
                <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Parteien – lege die erste an.</MudText>
                <AuthorizeView Policy="@Policies.Schreibrecht" Context="schreib">
                    <MudButton Href="/parteien/neu" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add">Neue Partei</MudButton>
                </AuthorizeView>
            </MudStack>
        </NoRecordsContent>
        <PagerContent>
            <MudDataGridPager T="ParteiZeile" />
        </PagerContent>
    </MudDataGrid>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _laden = true;
    private string _suche = string.Empty;
    private List<ParteiZeile> _zeilen = new();

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthStateTask).User;
        var darfVsLesen = user.DarfVerschlusssacheLesen();
        var parteien = await ParteiService.GetListeAsync(darfVsLesen);
        var (warnungTage, veraltetTage) = await Aktualitaet.GetSchwelleAsync(nameof(Partei));
        var jetzt = DateTime.UtcNow;
        _zeilen = parteien.Select(p =>
        {
            var referenzUtc = p.GeaendertAm ?? p.ErstelltAm;
            return new ParteiZeile
            {
                Id = p.Id,
                Aktenzeichen = p.Aktenzeichen,
                Name = p.Name,
                // Wie in der Detailansicht zählen: nur Mitglieder mit sichtbarer (nicht gelöschter, ggf. nicht-VS) Akte.
                Mitgliederzahl = p.Mitglieder.Count(m => m.Person is not null && (darfVsLesen || !m.Person.IstVerschlusssache)),
                Einstufung = p.Einstufung,
                IstVerschlusssache = p.IstVerschlusssache,
                AktualisiertUtc = referenzUtc,
                Aktualisiert = referenzUtc.ToLocalTime(),
                Stufe = AktualitaetsBewertung.Stufe(warnungTage, veraltetTage, referenzUtc, jetzt),
            };
        }).ToList();
        _laden = false;
    }

    private bool Filter(ParteiZeile z)
    {
        if (string.IsNullOrWhiteSpace(_suche))
        {
            return true;
        }
        var s = _suche.Trim();
        return z.Name.Contains(s, StringComparison.OrdinalIgnoreCase)
            || z.Aktenzeichen.Contains(s, StringComparison.OrdinalIgnoreCase);
    }

    private void Oeffnen(ParteiZeile z) => Nav.NavigateTo($"/parteien/{z.Id}");

    private sealed class ParteiZeile
    {
        public string Id { get; set; } = string.Empty;
        public string Aktenzeichen { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public int Mitgliederzahl { get; set; }
        public Einstufung Einstufung { get; set; }
        public bool IstVerschlusssache { get; set; }
        public DateTime AktualisiertUtc { get; set; }
        public DateTime Aktualisiert { get; set; }
        public AktualitaetsStufe Stufe { get; set; }
    }
}
