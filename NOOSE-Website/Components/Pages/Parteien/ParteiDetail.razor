@page "/parteien/{Id}"
@inject IParteiService ParteiService
@inject IZugriffsLogService ZugriffsLog
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>@(_partei?.Name ?? "Partei") · NOOSE</PageTitle>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_partei is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
        Partei nicht gefunden oder nicht zugänglich (ggf. Verschlusssache).
    </MudAlert>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/parteien" aria-label="Zurück" />
        <MudSpacer />
        <FolgenButton EntitaetTyp="@nameof(Partei)" EntitaetId="@_partei.Id" User="_user" />
        <MudButton Href="@($"/parteien/{_partei.Id}/bearbeiten")" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit">Bearbeiten</MudButton>
        <AuthorizeView Policy="@Policies.Fuehrung">
            <MudButton Color="Color.Error" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Delete" OnClick="LoeschenAsync">Löschen</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-2 mb-4" Elevation="1">
        <TagChips EntitaetTyp="@nameof(Partei)" EntitaetId="@_partei.Id" User="_user" />
    </MudPaper>

    <MudGrid>
        <MudItem xs="12" md="4" lg="3">
            <div class="akte-steckkarte">
                <Parteikarte Partei="_partei" Mitgliederzahl="_mitgliederzahl" Ermittlungsleiter="_ermittlungsleiter" />
            </div>
        </MudItem>

        <MudItem xs="12" md="8" lg="9">
            <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" TabPanelsClass="pa-4"
                     @bind-ActivePanelIndex="_aktiverTab"
                     @bind-ActivePanelIndex:after="@(() => TabUrlState.Write(Nav, _tabs, _aktiverTab))">
                <MudTabPanel Text="Stammdaten" Icon="@Icons.Material.Filled.Info">
                    <MudStack Spacing="3">
                        @if (!string.IsNullOrWhiteSpace(_partei.Ziele))
                        {
                            <div>
                                <MudText Typo="Typo.subtitle2">Ziele</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary">@_partei.Ziele</MudText>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(_partei.Beschreibung))
                        {
                            <div>
                                <MudText Typo="Typo.subtitle2">Beschreibung</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary">@_partei.Beschreibung</MudText>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(_partei.Bemerkungen))
                        {
                            <div>
                                <MudText Typo="Typo.subtitle2">Bemerkungen</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary" Style="white-space:pre-line;">@_partei.Bemerkungen</MudText>
                            </div>
                        }
                        @if (string.IsNullOrWhiteSpace(_partei.Ziele) && string.IsNullOrWhiteSpace(_partei.Beschreibung) && string.IsNullOrWhiteSpace(_partei.Bemerkungen))
                        {
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">Keine weiteren Stammdaten erfasst.</MudText>
                        }
                    </MudStack>
                </MudTabPanel>
                <MudTabPanel Text="Mitglieder" Icon="@Icons.Material.Filled.Group">
                    <ParteiMitgliederPanel ParteiId="@_partei.Id" User="_user" Changed="MitgliederGeaendertAsync" />
                </MudTabPanel>
                <MudTabPanel Text="Zugeteilte Agents" Icon="@Icons.Material.Filled.ManageAccounts">
                    <ParteiAgentePanel ParteiId="@_partei.Id" User="_user" Changed="ErmittlungsleiterAktualisierenAsync" />
                </MudTabPanel>
                <MudTabPanel Text="Einstufung" Icon="@Icons.Material.Filled.Shield">
                    <EinstufungPanel Aktuell="_partei.Einstufung" Verlauf="_einstufungVerlauf" User="_user" OnSetzen="EinstufungSetzenAsync"
                                     EntitaetTyp="@nameof(Partei)" EntitaetId="@_partei.Id" ZielBezeichnung="@($"{_partei.Name} ({_partei.Aktenzeichen})")" />
                </MudTabPanel>
                <MudTabPanel Text="Doks" Icon="@Icons.Material.Filled.Description">
                    <OrgDoksPanel OrgTyp="@nameof(Partei)" OrgId="@_partei.Id" User="_user" />
                </MudTabPanel>
                <MudTabPanel Text="Beziehungen" Icon="@Icons.Material.Filled.Hub">
                    <OrgBeziehungenPanel EntitaetTyp="@nameof(Partei)" EntitaetId="@_partei.Id" User="_user" />
                </MudTabPanel>
                <MudTabPanel Text="Quellen" Icon="@Icons.Material.Filled.AttachFile">
                    <QuellenPanel EntitaetTyp="@nameof(Partei)" EntitaetId="@_partei.Id" User="_user" />
                </MudTabPanel>
                <MudTabPanel Text="Kommentare" Icon="@Icons.Material.Filled.Comment">
                    <KommentarPanel EntitaetTyp="@nameof(Partei)" EntitaetId="@_partei.Id" User="_user" />
                </MudTabPanel>
                <MudTabPanel Text="Historie" Icon="@Icons.Material.Filled.History">
                    <ParteiHistorieTimeline ParteiId="@_partei.Id" IstFuehrung="_user.IstFuehrung()" @key="_historieKey" />
                </MudTabPanel>
            </MudTabs>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public string Id { get; set; } = default!;
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _laden = true;
    private Partei? _partei;
    private int _mitgliederzahl;
    private List<string> _ermittlungsleiter = new();
    private List<EinstufungVerlauf> _einstufungVerlauf = new();
    private ClaimsPrincipal _user = default!;
    private Guid _historieKey = Guid.NewGuid();
    private string? _geladeneId;

    // Aktiver Tab wird in der URL (?tab=…) gehalten – Reihenfolge muss den MudTabPanels entsprechen.
    private int _aktiverTab;
    private static readonly string[] _tabs =
    {
        "stammdaten", "mitglieder", "agents", "einstufung", "doks",
        "beziehungen", "quellen", "kommentare", "historie",
    };

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
    }

    // Diese Seite wird bei Navigation /parteien/{A} → /parteien/{B} WIEDERVERWENDET (gleiche Komponente);
    // OnInitializedAsync läuft dann NICHT erneut. Daher hier auf den Id-Wechsel reagieren – sonst bliebe die alte
    // Akte stehen. Das kurze _laden=true mountet den Tab-Baum (samt Kind-Panels) frisch. Tab-/Query-Wechsel: Id
    // bleibt gleich → kein Neuladen.
    protected override async Task OnParametersSetAsync()
    {
        if (_geladeneId == Id)
        {
            return;
        }
        _geladeneId = Id;
        _laden = true;
        _partei = null;
        _aktiverTab = TabUrlState.Read(Nav, _tabs);
        await LadenAsync();
        if (_partei is not null)
        {
            await ZugriffsLog.LogAnsichtAsync(nameof(Partei), _partei.Id);
        }
    }

    private async Task LadenAsync()
    {
        // Kein _laden = true beim Neuladen: sonst entfernt das @if (_laden) die MudTabs aus dem
        // Render-Baum, ein frisch gemountetes MudTabs springt auf den ersten Tab. Der erste Aufruf
        // zeigt den Ladebalken weiterhin über den Feld-Initialwert (_laden = true).
        _partei = await ParteiService.GetDetailAsync(Id, _user.IstFuehrung());
        if (_partei is not null)
        {
            _einstufungVerlauf = await ParteiService.GetEinstufungVerlaufAsync(_partei.Id, _user.IstFuehrung());
            _mitgliederzahl = (await ParteiService.GetMitgliederAsync(_partei.Id, _user.IstFuehrung())).Count;
            await ErmittlungsleiterLadenAsync();
        }
        _laden = false;
    }

    private async Task ErmittlungsleiterLadenAsync()
    {
        if (_partei is null)
        {
            return;
        }
        var el = await ParteiService.GetErmittlungsleiterAsync(_partei.Id);
        _ermittlungsleiter = el.Select(a => a.Agent?.Codename ?? "?").ToList();
    }

    private async Task ErmittlungsleiterAktualisierenAsync()
    {
        await ErmittlungsleiterLadenAsync();
        StateHasChanged();
    }

    private async Task NeuLadenAsync()
    {
        await LadenAsync();
        _historieKey = Guid.NewGuid();
        StateHasChanged();
    }

    private async Task MitgliederGeaendertAsync()
    {
        if (_partei is not null)
        {
            _mitgliederzahl = (await ParteiService.GetMitgliederAsync(_partei.Id, _user.IstFuehrung())).Count;
            StateHasChanged();
        }
    }

    private async Task EinstufungSetzenAsync((Einstufung Neu, string? Begruendung) eingabe)
    {
        if (_partei is null)
        {
            return;
        }
        await ParteiService.EinstufungSetzenAsync(_partei.Id, eingabe.Neu, eingabe.Begruendung, _user);
        await NeuLadenAsync();
    }

    private async Task LoeschenAsync()
    {
        if (_partei is null)
        {
            return;
        }
        var ok = await BestaetigenDialog.ZeigenAsync(DialogService, "Partei löschen?",
            "Die Partei wird in den Papierkorb verschoben und kann von der Führung wiederhergestellt werden.");
        if (!ok)
        {
            return;
        }
        await ParteiService.LoeschenAsync(_partei.Id, _user);
        Snackbar.Add("Partei in den Papierkorb verschoben.", Severity.Success);
        Nav.NavigateTo("/parteien");
    }
}
