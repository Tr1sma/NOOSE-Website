@page "/parteien/neu"
@inject IParteiService ParteiService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Neue Partei · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/parteien" aria-label="Zurück" />
    <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h4">Neue Partei anlegen</MudText>
</MudStack>

<MudForm @ref="_form">
    <ParteiForm Eingabe="_eingabe" ZeigeEinstufung="true" DarfHoechste="_darfHoechste"
                ZeigeMitglieder="true" IstFuehrung="_istFuehrung" />
</MudForm>

<MudStack Row="true" Spacing="2" Class="mt-4">
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SpeichernAsync" Disabled="_speichert">Anlegen</MudButton>
    <MudButton Variant="Variant.Text" Href="/parteien">Abbrechen</MudButton>
</MudStack>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private MudForm _form = default!;
    private readonly ParteiEingabe _eingabe = new();
    private ClaimsPrincipal _user = default!;
    private bool _darfHoechste;
    private bool _istFuehrung;
    private bool _speichert;

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        _darfHoechste = _user.DarfHoechsteEinstufung();
        _istFuehrung = _user.IstFuehrung();
    }

    private async Task SpeichernAsync()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid)
        {
            return;
        }

        _speichert = true;
        try
        {
            var partei = await ParteiService.ErstellenAsync(_eingabe, _user);
            Snackbar.Add($"Partei {partei.Aktenzeichen} angelegt.", Severity.Success);
            Nav.NavigateTo($"/parteien/{partei.Id}");
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
            _speichert = false;
        }
    }
}
