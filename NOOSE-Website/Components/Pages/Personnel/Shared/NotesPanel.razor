@* Commendation or disciplinary notes; add/delete is leadership-only. *@
@inject IPersonnelFileService PersonnelFileService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudStack Spacing="3">
    <MudText Typo="Typo.subtitle1">@Title (@_notes.Count)</MudText>

    <AuthorizeView Policy="@Policies.Leadership">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Start">
            <MudTextField @bind-Value="_newText" Placeholder="@($"{Title}: neuer Eintrag …")" Lines="2"
                          Variant="Variant.Outlined" Immediate="true" Class="flex-grow-1" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="AddAsync" Disabled="@(_saves || string.IsNullOrWhiteSpace(_newText))">Hinzufügen</MudButton>
        </MudStack>
    </AuthorizeView>

    @if (_load)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_notes.Count == 0)
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">Keine Einträge.</MudText>
    }
    else
    {
        @foreach (var v in _notes)
        {
            <MudPaper Class="pa-3" Elevation="1">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                    <div>
                        <MudText Typo="Typo.body2" Style="white-space:pre-wrap;">@v.Text</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                            @(string.IsNullOrWhiteSpace(v.AuthorName) ? "—" : v.AuthorName) · @v.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                        </MudText>
                    </div>
                    <AuthorizeView Policy="@Policies.Leadership">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                       OnClick="@(() => DeleteAsync(v))" aria-label="Eintrag löschen" />
                    </AuthorizeView>
                </MudStack>
            </MudPaper>
        }
    }
</MudStack>

@code {
    [Parameter, EditorRequired] public string AgentId { get; set; } = default!;
    [Parameter, EditorRequired] public AgentNoteKind Kind { get; set; }
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _load = true;
    private bool _saves;
    private string _newText = string.Empty;
    private ClaimsPrincipal _user = default!;
    private List<AgentNote> _notes = new();

    private string Title => Kind == AgentNoteKind.Commendation ? "Belobigungen" : "Disziplinarisches";

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _load = true;
        _notes = await PersonnelFileService.GetNotesAsync(AgentId, Kind);
        _load = false;
    }

    private async Task AddAsync()
    {
        if (string.IsNullOrWhiteSpace(_newText) || _saves)
        {
            return;
        }
        _saves = true;
        try
        {
            await PersonnelFileService.NoteCreateAsync(AgentId, Kind, _newText, _user);
            _newText = string.Empty;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        _saves = false;
    }

    private async Task DeleteAsync(AgentNote v)
    {
        var ok = await ConfirmDialog.ShowAsync(DialogService, "Eintrag löschen?", "Der Eintrag wird entfernt.");
        if (!ok)
        {
            return;
        }
        try
        {
            await PersonnelFileService.NoteDeleteAsync(v.Id, _user);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
