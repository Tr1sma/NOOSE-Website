<MudDialog>
    <DialogContent>
        <MudStack Spacing="3" Style="min-width:360px;">
            <MudText Typo="Typo.body2" Class="mud-text-secondary">Beförderungsantrag für <b>@Codename</b> (aktuell: @RankDisplay.Name(Current)).</MudText>
            <MudSelect T="Rank" @bind-Value="_target" Label="Ziel-Dienstgrad" Variant="Variant.Outlined">
                @foreach (var d in RankDisplay.All)
                {
                    <MudSelectItem Value="d">@RankDisplay.Name(d)</MudSelectItem>
                }
            </MudSelect>
            <MudTextField @bind-Value="_justification" Label="Begründung" Lines="3" Variant="Variant.Outlined"
                          HelperText="Wird im Posteingang für die Entscheidung angezeigt." />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Abbrechen</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save">Beantragen</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string Codename { get; set; } = string.Empty;
    [Parameter] public Rank Current { get; set; } = Rank.JuniorAgent;

    private Rank _target;
    private string? _justification;

    protected override void OnInitialized() => _target = Current;

    private void Save() => MudDialog.Close(DialogResult.Ok(new Choice(_target, _justification)));
    private void Cancel() => MudDialog.Cancel();

    public record Choice(Rank TargetRank, string? Justification);

    public static async Task<Choice?> ShowAsync(IDialogService dialog, string codename, Rank current)
    {
        var parameters = new DialogParameters<PromotionDialog>
        {
            { x => x.Codename, codename },
            { x => x.Current, current },
        };
        var reference = await dialog.ShowAsync<PromotionDialog>("Beförderung beantragen", parameters);
        var result = await reference.Result;
        return result is { Canceled: false, Data: Choice choice } ? choice : null;
    }
}
