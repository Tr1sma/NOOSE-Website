@page "/personal"
@inject IAgentManagementService AgentService
@inject NavigationManager Nav

<PageTitle>Personal · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
    <MudIcon Icon="@Icons.Material.Filled.Badge" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h4">Personal</MudText>
</MudStack>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-6">
    Personalakten aller NOOSE-Agenten: Dienstgrad-Verlauf, Belobigungen, Disziplinarisches und Beförderungen.
</MudText>

@if (_load)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="false"
             @bind-ActivePanelIndex="_tab" Class="mb-3">
        <MudTabPanel Icon="@Icons.Material.Filled.Badge" IconColor="Color.Primary"
                     Text="@($"NOOSE ({CountInternal})")" />
        <MudTabPanel Icon="@Icons.Material.Filled.Handshake" IconColor="Color.Info"
                     Text="@($"Partner ({CountPartner})")" />
    </MudTabs>

    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-3" Wrap="Wrap.Wrap">
        <MudTextField @bind-Value="_search" Placeholder="Suchen (Codename, Dienstnummer)…" Immediate="true"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Variant="Variant.Outlined" Margin="Margin.Dense" Class="flex-grow-1" Style="min-width:220px;" />
        @if (_tab == 1)
        {
            <MudSelect T="PartnerAgency?" Value="_agencyFilter" ValueChanged="@(v => _agencyFilter = v)"
                       Label="Behörde" Clearable="true" Dense="true" Margin="Margin.Dense" Variant="Variant.Outlined"
                       Style="min-width:160px;">
                <MudSelectItem T="PartnerAgency?" Value="@((PartnerAgency?)null)">Alle Behörden</MudSelectItem>
                @foreach (var ag in PartnerAgencyDisplay.All)
                {
                    <MudSelectItem T="PartnerAgency?" Value="@ag">@PartnerAgencyDisplay.Name(ag)</MudSelectItem>
                }
            </MudSelect>
            <MudSelect T="PartnerRank?" Value="_rankFilter" ValueChanged="@(v => _rankFilter = v)"
                       Label="Rang" Clearable="true" Dense="true" Margin="Margin.Dense" Variant="Variant.Outlined"
                       Style="min-width:160px;">
                <MudSelectItem T="PartnerRank?" Value="@((PartnerRank?)null)">Alle Ränge</MudSelectItem>
                @foreach (var pr in PartnerRankDisplay.All)
                {
                    <MudSelectItem T="PartnerRank?" Value="@pr">@pr</MudSelectItem>
                }
            </MudSelect>
        }
    </MudStack>

    <MudTable Items="_filtered" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="2" Dense="true"
              OnRowClick="@((TableRowClickEventArgs<Agent> e) => Open(e.Item))" T="Agent">
        <HeaderContent>
            <MudTh><MudTableSortLabel T="Agent" SortBy="@(x => x.Codename)">Codename</MudTableSortLabel></MudTh>
            @if (_mayRealName)
            {
                <MudTh><MudTableSortLabel T="Agent" SortBy="@(x => x.RealName)">Klarname</MudTableSortLabel></MudTh>
            }
            @if (_tab == 1)
            {
                <MudTh><MudTableSortLabel T="Agent" SortBy="@(x => x.PartnerAgency)">Behörde</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="Agent" SortBy="@(x => x.PartnerRank)">Partner-Rang</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="Agent" SortBy="@(x => StatusName(x.Status))">Status</MudTableSortLabel></MudTh>
            }
            else
            {
                <MudTh><MudTableSortLabel T="Agent" SortBy="@(x => x.Rank)">Dienstgrad</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="Agent" SortBy="@(x => StatusName(x.Status))">Status</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="Agent" SortBy="@(x => x.IsTRU)">TRU</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="Agent" SortBy="@(x => x.IsHRB)">HRB</MudTableSortLabel></MudTh>
            }
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Codename">
                <MudLink Href="@($"/personal/{context.Id}")" @onclick:stopPropagation="true">
                    @(string.IsNullOrWhiteSpace(context.Codename) ? "Unbenannter Agent" : context.Codename)
                </MudLink>
            </MudTd>
            @if (_mayRealName)
            {
                <MudTd DataLabel="Klarname"><MudText Typo="Typo.body2" Class="mud-text-secondary">@(context.RealName ?? "—")</MudText></MudTd>
            }
            @if (_tab == 1)
            {
                <MudTd DataLabel="Behörde">@PartnerAgencyDisplay.Name(context.PartnerAgency)</MudTd>
                <MudTd DataLabel="Partner-Rang">@PartnerRankDisplay.Full(context.PartnerAgency, context.PartnerRank)</MudTd>
                <MudTd DataLabel="Status">@StatusName(context.Status)</MudTd>
            }
            else
            {
                <MudTd DataLabel="Dienstgrad">@RankDisplay.Name(context.Rank)</MudTd>
                <MudTd DataLabel="Status">@StatusName(context.Status)</MudTd>
                <MudTd DataLabel="TRU">@(context.IsTRU ? "TRU" : "")</MudTd>
                <MudTd DataLabel="HRB">@(context.IsHRB ? "HRB" : "")</MudTd>
            }
        </RowTemplate>
        <NoRecordsContent>
            <MudText Typo="Typo.body2" Class="mud-text-secondary pa-4">Keine Agenten gefunden.</MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _load = true;
    private bool _mayRealName;
    private string _search = string.Empty;
    private int _tab;
    private PartnerAgency? _agencyFilter;
    private PartnerRank? _rankFilter;
    private List<Agent> _agents = new();

    private IEnumerable<Agent> _filtered
    {
        get
        {
            var query = _agents.Where(a => _tab == 1 ? a.PartnerAgency != null : a.PartnerAgency == null);
            if (_tab == 1)
            {
                if (_agencyFilter is { } agency)
                {
                    query = query.Where(a => a.PartnerAgency == agency);
                }
                if (_rankFilter is { } rank)
                {
                    query = query.Where(a => a.PartnerRank == rank);
                }
            }
            if (!string.IsNullOrWhiteSpace(_search))
            {
                var s = _search.Trim();
                query = query.Where(a => (a.Codename ?? string.Empty).Contains(s, StringComparison.OrdinalIgnoreCase)
                                       || (a.BadgeNumber ?? string.Empty).Contains(s, StringComparison.OrdinalIgnoreCase)
                                       || (_mayRealName && (a.RealName ?? string.Empty).Contains(s, StringComparison.OrdinalIgnoreCase)));
            }
            return query;
        }
    }

    private int CountInternal => _agents.Count(a => a.PartnerAgency == null);
    private int CountPartner => _agents.Count(a => a.PartnerAgency != null);

    protected override async Task OnInitializedAsync()
    {
        _mayRealName = (await AuthStateTask).User.MayRealNameSee();
        // TeamLeads invisible in RP; blocked accounts hidden too
        _agents = (await AgentService.GetAllAsync())
            .Where(a => !a.IsTeamLead && a.Status != AgentStatus.Blocked)
            .ToList();
        _load = false;
    }

    private void Open(Agent? a)
    {
        if (a is not null)
        {
            Nav.NavigateTo($"/personal/{a.Id}");
        }
    }

    private static string StatusName(AgentStatus s) => s switch
    {
        AgentStatus.Active => "Aktiv",
        AgentStatus.Pending => "Ausstehend",
        AgentStatus.Blocked => "Gesperrt",
        _ => "—",
    };
}
