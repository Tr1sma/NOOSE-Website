@* Druckansicht der Fraktionsakte (Phase 7): komplette Akte als strukturiertes Dokument. *@
@page "/fraktionen/{Id}/druck"
@layout DruckLayout
@inject IFraktionService FraktionService
@inject IVerknuepfungService VerknuepfungService
@inject IKommentarService KommentarService
@inject IZugriffsLogService ZugriffsLog

<PageTitle>@(_fraktion is null ? "Druckansicht" : $"Fraktionsakte {_fraktion.Aktenzeichen}") · NOOSE</PageTitle>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_fraktion is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">Diese Akte existiert nicht (mehr) oder ist nicht sichtbar.</MudAlert>
}
else
{
    <DruckRahmen Titel="@($"Fraktionsakte {_fraktion.Aktenzeichen}")" ZurueckHref="@($"/fraktionen/{Id}")"
                 GedrucktVon="@_druckVon" IstVerschlusssache="_fraktion.IstVerschlusssache">
        <section>
            <h2>Stammdaten</h2>
            <table class="druck-felder">
                <tbody>
                    <tr><th>Name</th><td>@_fraktion.Name</td></tr>
                    <tr><th>Aktenzeichen</th><td>@_fraktion.Aktenzeichen</td></tr>
                    @if (!string.IsNullOrWhiteSpace(_fraktion.Art))
                    {
                        <tr><th>Art</th><td>@_fraktion.Art</td></tr>
                    }
                    <tr><th>Einstufung</th><td>@EinstufungAnzeige.Name(_fraktion.Einstufung)</td></tr>
                    <tr><th>Gefährdung</th><td>@GefaehrdungAnzeigeText()</td></tr>
                    @if (_fraktion.IstStaatsfraktion)
                    {
                        <tr><th>Staatsfraktion</th><td>Ja</td></tr>
                    }
                    @if (_fraktion.GeschaetzteMitgliederzahl is { } anzahl)
                    {
                        <tr><th>Geschätzte Mitgliederzahl</th><td>@anzahl</td></tr>
                    }
                    @if (!string.IsNullOrWhiteSpace(_fraktion.Funk))
                    {
                        <tr><th>Funk</th><td>@_fraktion.Funk</td></tr>
                    }
                    @if (!string.IsNullOrWhiteSpace(_fraktion.Darkchat))
                    {
                        <tr><th>Darkchat</th><td>@_fraktion.Darkchat</td></tr>
                    }
                    @if (!string.IsNullOrWhiteSpace(_fraktion.Anwesen))
                    {
                        <tr><th>Anwesen</th><td class="druck-mehrzeilig">@_fraktion.Anwesen</td></tr>
                    }
                    @if (!string.IsNullOrWhiteSpace(_fraktion.Erkennungsfarbe))
                    {
                        <tr><th>Erkennungsfarbe</th><td>@_fraktion.Erkennungsfarbe</td></tr>
                    }
                    @if (!string.IsNullOrWhiteSpace(_fraktion.Ziele))
                    {
                        <tr><th>Ziele</th><td class="druck-mehrzeilig">@_fraktion.Ziele</td></tr>
                    }
                    @if (!string.IsNullOrWhiteSpace(_fraktion.Beschreibung))
                    {
                        <tr><th>Beschreibung</th><td class="druck-mehrzeilig">@_fraktion.Beschreibung</td></tr>
                    }
                    <tr><th>Zuletzt aktualisiert</th><td>@((_fraktion.GeaendertAm ?? _fraktion.ErstelltAm).ToLocalTime().ToString("dd.MM.yyyy HH:mm"))</td></tr>
                </tbody>
            </table>
        </section>

        @if (_fraktion.Raenge.Count > 0)
        {
            <section>
                <h2>Rangstruktur</h2>
                <table class="druck-tabelle">
                    <thead><tr><th>Stufe</th><th>Bezeichnung</th></tr></thead>
                    <tbody>
                        @foreach (var r in _fraktion.Raenge.OrderBy(r => r.Reihenfolge))
                        {
                            <tr><td>@r.Reihenfolge</td><td>@r.Bezeichnung</td></tr>
                        }
                    </tbody>
                </table>
            </section>
        }

        @if (_mitglieder.Count > 0)
        {
            <section>
                <h2>Mitglieder (@_mitglieder.Count)</h2>
                <table class="druck-tabelle">
                    <thead><tr><th>Name</th><th>Rang</th><th>Seit</th></tr></thead>
                    <tbody>
                        @foreach (var m in _mitglieder)
                        {
                            <tr>
                                <td>@(m.Person?.Name ?? "—")@(m.IstLeitung ? " (Leitung)" : "")</td>
                                <td>@(string.IsNullOrWhiteSpace(m.Rang) ? "—" : m.Rang)</td>
                                <td>@m.ErstelltAm.ToLocalTime().ToString("dd.MM.yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>
        }

        @if (_agenten.Count > 0)
        {
            <section>
                <h2>Zugeteilte Agenten</h2>
                <table class="druck-tabelle">
                    <thead><tr><th>Agent</th><th>Funktion</th><th>Seit</th></tr></thead>
                    <tbody>
                        @foreach (var a in _agenten)
                        {
                            <tr>
                                <td>@(a.Agent?.Codename ?? "—")</td>
                                <td>@(a.IstErmittlungsleiter ? "Ermittlungsleiter" : "Zugeteilt")</td>
                                <td>@a.ErstelltAm.ToLocalTime().ToString("dd.MM.yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>
        }

        @if (_fraktion.Waffenbestand.Count > 0)
        {
            <section>
                <h2>Waffenbestand</h2>
                <table class="druck-tabelle">
                    <thead><tr><th>Bezeichnung</th><th>Menge</th></tr></thead>
                    <tbody>
                        @foreach (var w in _fraktion.Waffenbestand)
                        {
                            <tr><td>@w.Bezeichnung</td><td>@(string.IsNullOrWhiteSpace(w.Menge) ? "—" : w.Menge)</td></tr>
                        }
                    </tbody>
                </table>
            </section>
        }

        @if (_fraktion.Lagerbestand.Count > 0)
        {
            <section>
                <h2>Lagerbestand</h2>
                <table class="druck-tabelle">
                    <thead><tr><th>Bezeichnung</th><th>Menge</th></tr></thead>
                    <tbody>
                        @foreach (var l in _fraktion.Lagerbestand)
                        {
                            <tr><td>@l.Bezeichnung</td><td>@(string.IsNullOrWhiteSpace(l.Menge) ? "—" : l.Menge)</td></tr>
                        }
                    </tbody>
                </table>
            </section>
        }

        @if (_fraktion.Drogenrouten.Count > 0)
        {
            <section>
                <h2>Drogenrouten</h2>
                <table class="druck-tabelle">
                    <thead><tr><th>Bezeichnung</th><th>Notiz</th></tr></thead>
                    <tbody>
                        @foreach (var d in _fraktion.Drogenrouten)
                        {
                            <tr><td>@d.Bezeichnung</td><td>@(string.IsNullOrWhiteSpace(d.Notiz) ? "—" : d.Notiz)</td></tr>
                        }
                    </tbody>
                </table>
            </section>
        }

        @if (_aktivitaeten.Count > 0)
        {
            <section>
                <h2>Aktivitäten</h2>
                @foreach (var a in _aktivitaeten)
                {
                    <div class="druck-eintrag">
                        <div class="druck-eintrag-kopf">
                            <b>@a.Zeitpunkt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</b> · @a.Titel
                            @if (!string.IsNullOrWhiteSpace(a.Art))
                            {
                                <text> · @a.Art</text>
                            }
                            @if (!string.IsNullOrWhiteSpace(a.Ort))
                            {
                                <text> · @a.Ort</text>
                            }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(a.Beschreibung))
                        {
                            <div class="druck-mehrzeilig">@a.Beschreibung</div>
                        }
                    </div>
                }
            </section>
        }

        <DruckEinstufungVerlauf Eintraege="_einstufungVerlauf" />
        <DruckVerknuepfungen Eintraege="_verknuepfungen" />
        <DruckKommentare Eintraege="_kommentare" />
    </DruckRahmen>
}

@code {
    [Parameter] public string Id { get; set; } = string.Empty;
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _laden = true;
    private string? _druckVon;
    private Fraktion? _fraktion;
    private List<FraktionMitglied> _mitglieder = new();
    private List<FraktionAgent> _agenten = new();
    private List<FraktionAktivitaet> _aktivitaeten = new();
    private List<EinstufungVerlauf> _einstufungVerlauf = new();
    private List<VerknuepfungAnzeige> _verknuepfungen = new();
    private List<Kommentar> _kommentare = new();

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthStateTask).User;
        var istFuehrung = user.IstFuehrung();
        _druckVon = user.GetCodename();

        _fraktion = await FraktionService.GetDetailAsync(Id, istFuehrung);
        if (_fraktion is not null)
        {
            _mitglieder = await FraktionService.GetMitgliederAsync(Id, istFuehrung);
            _agenten = await FraktionService.GetAgentenAsync(Id);
            _aktivitaeten = await FraktionService.GetAktivitaetenAsync(Id, istFuehrung);
            _einstufungVerlauf = await FraktionService.GetEinstufungVerlaufAsync(Id, istFuehrung);
            _verknuepfungen = await VerknuepfungService.GetFuerAkteAsync(nameof(Fraktion), Id, istFuehrung, user.GetAgentId());
            _kommentare = await KommentarService.GetFuerAkteAsync(nameof(Fraktion), Id, istFuehrung);
            await ZugriffsLog.LogAnsichtAsync(nameof(Fraktion), Id);
        }
        _laden = false;
    }

    /// <summary>Gefährdungsstufe inkl. Score-Zahl und Konfidenz (sofern berechnet) für die Druckansicht.</summary>
    private string GefaehrdungAnzeigeText()
    {
        if (_fraktion is null)
        {
            return "—";
        }
        if (_fraktion.IstStaatsfraktion)
        {
            return "Ausgenommen (Staatsfraktion)";
        }
        var stufe = GefaehrdungsStufeLogic.Name(GefaehrdungsStufeLogic.Aus(_fraktion.BedrohungsScore));
        if (_fraktion.BedrohungsScore is not { } score)
        {
            return stufe;
        }
        var konfidenz = _fraktion.BedrohungsKonfidenz is { } k ? $" · Konfidenz {k} %" : "";
        return $"{stufe} (Score {score}{konfidenz})";
    }
}
