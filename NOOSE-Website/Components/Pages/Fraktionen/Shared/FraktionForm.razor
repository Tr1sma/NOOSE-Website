@* Gemeinsames Formular für Anlegen/Bearbeiten einer Fraktion: Stammdaten + strukturierte Listen
   (Ränge, Waffen-/Lagerbestand). Bindet direkt an das übergebene FraktionEingabe. Beim Anlegen können
   bereits Mitglieder erfasst werden (ZeigeMitglieder); im Bearbeiten laufen sie über den Akten-Tab. *@
@using MudBlazor.Utilities
@inject ISteckbriefVorschlagService VorschlagService
@inject IDialogService DialogService

<MudGrid>
    <MudItem xs="12" md="8">
        <MudTextField @bind-Value="Eingabe.Name" Label="Name" Required="true" RequiredError="Name ist erforderlich"
                      Variant="Variant.Outlined" />
    </MudItem>
    <MudItem xs="12" md="4">
        @* Wie das Waffen-Feld: Autocomplete mit Vorschlägen aus dem gemeinsamen Katalog; freie Eingabe erlaubt. *@
        <MudAutocomplete T="string" @bind-Value="Eingabe.Art" Label="Art (z. B. Gang, Konzern)"
                         SearchFunc="@ArtSuchen" Variant="Variant.Outlined"
                         CoerceText="false" CoerceValue="true" ResetValueOnEmptyText="false"
                         MinCharacters="0" Immediate="true" MaxItems="20" Clearable="true"
                         Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Category" />
    </MudItem>

    <MudItem xs="12" md="4">
        <MudTextField @bind-Value="Eingabe.Funk" Label="Funk" Variant="Variant.Outlined" />
    </MudItem>
    <MudItem xs="12" md="4">
        <MudTextField @bind-Value="Eingabe.Darkchat" Label="Darkchat" Variant="Variant.Outlined" />
    </MudItem>
    <MudItem xs="12" md="4">
        <MudTextField @bind-Value="Eingabe.Ausstellungszeiten" Label="Ausstellungszeiten" Variant="Variant.Outlined" />
    </MudItem>

    <MudItem xs="12" md="4">
        <MudNumericField @bind-Value="Eingabe.GeschaetzteMitgliederzahl" Label="Geschätzte Mitgliederzahl"
                         Variant="Variant.Outlined" Min="0" HelperText="Für den Erfassungsfortschritt (x/y)" Clearable="true" />
    </MudItem>

    <MudItem xs="12" md="6">
        <MudColorPicker Label="Erkennungsfarbe (optional)" Value="_farbe" ValueChanged="FarbeGesetzt"
                        Variant="Variant.Outlined" Placeholder="z. B. #1E88E5" Clearable="true" />
    </MudItem>
    <MudItem xs="12" md="6" Class="d-flex flex-column justify-center">
        <MudSwitch T="bool" @bind-Value="Eingabe.IstVerschlusssache" Color="Color.Warning"
                   Label="Verschlusssache (nur Führung sichtbar)" />
        @if (Eingabe.IstVerschlusssache && !IstFuehrung)
        {
            <MudText Typo="Typo.caption" Color="Color.Warning">
                Achtung: Du verlierst als Nicht-Führung nach dem Speichern selbst den Zugriff auf diese Akte.
            </MudText>
        }
        <MudSwitch T="bool" @bind-Value="Eingabe.IstStaatsfraktion" Color="Color.Info"
                   Label="Staatsfraktion (wird nie als veraltet markiert)" />
    </MudItem>

    @if (ZeigeEinstufung)
    {
        <MudItem xs="12" md="6">
            <MudSelect T="Einstufung" @bind-Value="Eingabe.Einstufung" Label="Einstufung" Variant="Variant.Outlined">
                @foreach (var e in EinstufungAnzeige.Alle)
                {
                    <MudSelectItem Value="e" Disabled="@(e == Einstufung.GesichertStaatsgefaehrdend && !DarfHoechste)">
                        @EinstufungAnzeige.Name(e)
                    </MudSelectItem>
                }
            </MudSelect>
        </MudItem>
    }

    <MudItem xs="12">
        <MudTextField @bind-Value="Eingabe.Anwesen" Label="Anwesen" Lines="2" Variant="Variant.Outlined"
                      HelperText="Sitz/Anwesen der Fraktion – Adresse und Notizen (optional)." />
    </MudItem>
    <MudItem xs="12">
        <MudTextField @bind-Value="Eingabe.Ziele" Label="Ziele" Lines="2" Variant="Variant.Outlined" />
    </MudItem>
    <MudItem xs="12">
        <MudTextField @bind-Value="Eingabe.Beschreibung" Label="Beschreibung" Lines="3" Variant="Variant.Outlined" />
    </MudItem>
</MudGrid>

<MudDivider Class="my-4" />
<MudGrid>
    @* Ränge als einfache Zeilen (Reihenfolge = Listenreihenfolge). *@
    <MudItem xs="12" md="6">
        <MudStack Spacing="1">
            <MudText Typo="Typo.subtitle2">Ränge</MudText>
            @foreach (var r in Eingabe.Raenge)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudTextField @bind-Value="r.Bezeichnung" Placeholder="Rang-Bezeichnung" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                   OnClick="@(() => Eingabe.Raenge.Remove(r))" aria-label="Entfernen" />
                </MudStack>
            }
            <MudButton StartIcon="@Icons.Material.Filled.Add" Size="Size.Small" OnClick="@(() => Eingabe.Raenge.Add(new()))">Rang hinzufügen</MudButton>
        </MudStack>

        <div class="mt-4">
            <SteckbriefMehrfachFeld TItem="BestandEingabe" Titel="Waffenbestand" Items="Eingabe.Waffenbestand"
                                    Typ="VorschlagTyp.Waffe" ZeigeZusatz="true"
                                    HauptPlaceholder="Waffe" ZusatzPlaceholder="Menge (optional)" />
        </div>
    </MudItem>

    <MudItem xs="12" md="6">
        <SteckbriefMehrfachFeld TItem="BestandEingabe" Titel="Lagerbestand" Items="Eingabe.Lagerbestand"
                                Typ="VorschlagTyp.Lagerbestand" ZeigeZusatz="true"
                                HauptPlaceholder="Gegenstand" ZusatzPlaceholder="Menge (optional)" />

        <div class="mt-4">
            <SteckbriefMehrfachFeld TItem="BestandEingabe" Titel="Drogenrouten" Items="Eingabe.Drogenrouten"
                                    Typ="VorschlagTyp.Drogenroute" ZeigeZusatz="true"
                                    HauptPlaceholder="Route" ZusatzPlaceholder="Notiz (optional)" />
        </div>
    </MudItem>
</MudGrid>

@if (ZeigeMitglieder)
{
    <MudDivider Class="my-4" />
    <MudStack Spacing="2">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudText Typo="Typo.h6">Mitglieder</MudText>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd" OnClick="MitgliedHinzufuegenAsync">
                Mitglied hinzufügen
            </MudButton>
        </MudStack>
        @if (Eingabe.Mitglieder.Count == 0)
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Mitglieder – optional. Können auch später in der Akte ergänzt werden.</MudText>
        }
        else
        {
            @foreach (var m in Eingabe.Mitglieder)
            {
                <MudPaper Class="pa-2" Elevation="1">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Badge" Color="Color.Primary" Size="Size.Small" />
                            <MudText Typo="Typo.body2"><b>@m.PersonName</b></MudText>
                            @if (m.IstLeitung)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled" Icon="@Icons.Material.Filled.Star">Leitung</MudChip>
                            }
                            @if (!string.IsNullOrWhiteSpace(m.Rang))
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">@m.Rang</MudChip>
                            }
                        </MudStack>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                       OnClick="@(() => Eingabe.Mitglieder.Remove(m))" aria-label="Mitglied entfernen" />
                    </MudStack>
                </MudPaper>
            }
        }
    </MudStack>
}

@code {
    [Parameter, EditorRequired] public FraktionEingabe Eingabe { get; set; } = default!;
    /// <summary>Einstufung im Formular zeigen (nur beim Anlegen; im Bearbeiten läuft sie über den Tab „Einstufung").</summary>
    [Parameter] public bool ZeigeEinstufung { get; set; }
    [Parameter] public bool DarfHoechste { get; set; }
    /// <summary>Ob der aktuelle Nutzer der Führung angehört (Verschlusssache-Warnung + Mitglieder-Suche).</summary>
    [Parameter] public bool IstFuehrung { get; set; }
    /// <summary>Mitglieder-Sektion zeigen (nur beim Anlegen; im Bearbeiten über den Tab „Mitglieder").</summary>
    [Parameter] public bool ZeigeMitglieder { get; set; }

    private MudColor? _farbe;
    private IReadOnlyList<string> _artVorschlaege = Array.Empty<string>();

    protected override async Task OnInitializedAsync()
        => _artVorschlaege = await VorschlagService.GetAsync(VorschlagTyp.Art);

    protected override void OnParametersSet()
        => _farbe = string.IsNullOrWhiteSpace(Eingabe.Erkennungsfarbe) ? null : new MudColor(Eingabe.Erkennungsfarbe);

    private Task<IEnumerable<string>> ArtSuchen(string value, CancellationToken token)
    {
        IEnumerable<string> treffer = string.IsNullOrWhiteSpace(value)
            ? _artVorschlaege
            : _artVorschlaege.Where(v => v.Contains(value.Trim(), StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(treffer);
    }

    private void FarbeGesetzt(MudColor? farbe)
    {
        _farbe = farbe;
        Eingabe.Erkennungsfarbe = farbe is null ? null : farbe.ToString(MudColorOutputFormats.Hex);
    }

    private async Task MitgliedHinzufuegenAsync()
    {
        var ausschluss = Eingabe.Mitglieder.Select(m => m.PersonId).ToList();
        // Ränge stehen erst nach dem Speichern als Akte; beim Anlegen die im Formular erfassten Bezeichnungen anbieten.
        var raenge = Eingabe.Raenge.Where(r => !string.IsNullOrWhiteSpace(r.Bezeichnung)).Select(r => r.Bezeichnung).ToList();
        var neu = await MitgliedDialog.ZeigenAsync(DialogService, IstFuehrung, raenge, ausschluss);
        if (neu is null)
        {
            return;
        }
        // Doppelte vermeiden: gleiche bestehende Person oder gleicher neuer Name.
        var schonVorhanden =
            (!string.IsNullOrWhiteSpace(neu.PersonId) && Eingabe.Mitglieder.Any(m => m.PersonId == neu.PersonId))
            || (!string.IsNullOrWhiteSpace(neu.NeuePersonName)
                && Eingabe.Mitglieder.Any(m => string.Equals(m.NeuePersonName, neu.NeuePersonName, StringComparison.OrdinalIgnoreCase)));
        if (!schonVorhanden)
        {
            Eingabe.Mitglieder.Add(neu);
        }
    }
}
