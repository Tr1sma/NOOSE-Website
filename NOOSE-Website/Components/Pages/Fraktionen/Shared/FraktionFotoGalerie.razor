@* Foto-Galerie einer Fraktion: Mehrfach-Upload, geschützte Anzeige, Löschen, Titelbild markieren. *@
@inject IFraktionService FraktionService
@inject IFraktionFotoStorageService FileStorage
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudText Typo="Typo.subtitle1">Foto-Galerie (@_fotos.Count)</MudText>
        @if (_darfSchreiben)
        {
            <MudFileUpload T="IReadOnlyList<IBrowserFile>" FilesChanged="HochladenAsync" Accept="image/*" MaximumFileCount="20">
                <CustomContent>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Upload"
                               OnClick="@context.OpenFilePickerAsync" Disabled="_laden">
                        Fotos hochladen
                    </MudButton>
                </CustomContent>
                <SelectedTemplate />
            </MudFileUpload>
        }
    </MudStack>

    @if (_laden)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }

    @if (_fotos.Count == 0)
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Fotos.</MudText>
    }
    else
    {
        <div class="d-flex flex-wrap gap-3">
            @foreach (var foto in _fotos)
            {
                <MudPaper Class="pa-1" Elevation="2" Style="width:160px;">
                    <div style="position:relative;">
                        <MudImage Src="@($"/dateien/fraktionen/foto/{foto.Id}")" Alt="@foto.OriginalName"
                                  Height="120" Width="150" ObjectFit="ObjectFit.Cover" Class="rounded" />
                        @if (foto.IstTitelbild)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled"
                                     Icon="@Icons.Material.Filled.Star"
                                     Style="position:absolute;top:4px;left:4px;margin:0;">Titelbild</MudChip>
                        }
                    </div>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="px-1">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="max-width:80px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                            @foto.OriginalName
                        </MudText>
                        @if (_darfSchreiben)
                        {
                            <MudStack Row="true" Spacing="0" AlignItems="AlignItems.Center">
                                @if (!foto.IstTitelbild)
                                {
                                    <MudIconButton Icon="@Icons.Material.Outlined.StarBorder" Color="Color.Primary" Size="Size.Small"
                                                   OnClick="@(() => AlsTitelbildAsync(foto))" aria-label="Als Titelbild setzen" />
                                }
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                               OnClick="@(() => EntfernenAsync(foto))" aria-label="Foto löschen" />
                            </MudStack>
                        }
                    </MudStack>
                </MudPaper>
            }
        </div>
    }
</MudStack>

@code {
    [Parameter, EditorRequired] public string FraktionId { get; set; } = default!;
    [Parameter, EditorRequired] public ClaimsPrincipal User { get; set; } = default!;
    [Parameter] public EventCallback Changed { get; set; }

    private List<FraktionFoto> _fotos = new();
    private bool _laden;
    private bool _darfSchreiben;

    protected override async Task OnInitializedAsync()
    {
        _darfSchreiben = User.DarfSchreiben();
        await LadenAsync();
    }

    private async Task LadenAsync()
    {
        _fotos = await FraktionService.GetFotosAsync(FraktionId);
    }

    private async Task HochladenAsync(IReadOnlyList<IBrowserFile> dateien)
    {
        _laden = true;
        try
        {
            var hochgeladen = 0;
            foreach (var datei in dateien)
            {
                if (!FileStorage.IstErlaubterTyp(datei.ContentType))
                {
                    Snackbar.Add($"'{datei.Name}': Dateityp nicht erlaubt (nur Bilder).", Severity.Warning);
                    continue;
                }
                if (datei.Size > FileStorage.MaxBytes)
                {
                    Snackbar.Add($"'{datei.Name}': zu groß (max. {FileStorage.MaxBytes / (1024 * 1024)} MB).", Severity.Warning);
                    continue;
                }
                await using var stream = datei.OpenReadStream(FileStorage.MaxBytes);
                await FraktionService.FotoHinzufuegenAsync(FraktionId, stream, datei.Name, datei.ContentType, datei.Size, User);
                hochgeladen++;
            }

            // Nur melden/neu laden, wenn tatsächlich mindestens ein Foto gespeichert wurde.
            if (hochgeladen > 0)
            {
                Snackbar.Add(hochgeladen == 1 ? "Foto hochgeladen." : $"{hochgeladen} Fotos hochgeladen.", Severity.Success);
                await LadenAsync();
                await Changed.InvokeAsync();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Upload fehlgeschlagen: {ex.Message}", Severity.Error);
        }
        finally
        {
            _laden = false;
        }
    }

    private async Task AlsTitelbildAsync(FraktionFoto foto)
    {
        try
        {
            await FraktionService.AlsTitelbildSetzenAsync(foto.Id, User);
            Snackbar.Add("Als Titelbild gesetzt.", Severity.Success);
            await LadenAsync();
            await Changed.InvokeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task EntfernenAsync(FraktionFoto foto)
    {
        var ok = await BestaetigenDialog.ZeigenAsync(DialogService, "Foto löschen?",
            $"'{foto.OriginalName}' wird dauerhaft gelöscht.");
        if (!ok)
        {
            return;
        }
        try
        {
            await FraktionService.FotoEntfernenAsync(foto.Id, User);
            Snackbar.Add("Foto gelöscht.", Severity.Success);
            await LadenAsync();
            await Changed.InvokeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
