@* Aktivitäten-Zeitstrahl einer Fraktion: Aktionen (z. B. Raub/Geiselnahme) chronologisch, mit Dokument-/Quellen-Verknüpfung je Eintrag. *@
@inject IFraktionService FraktionService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudText Typo="Typo.subtitle1">Aktivitäten (@_aktivitaeten.Count)</MudText>
        @if (_darfSchreiben)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="HinzufuegenAsync">
                Aktivität hinzufügen
            </MudButton>
        }
    </MudStack>

    @if (_laden)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_aktivitaeten.Count == 0)
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Aktivitäten erfasst.</MudText>
    }
    else
    {
        <MudTimeline TimelinePosition="TimelinePosition.Start">
            @foreach (var a in _aktivitaeten)
            {
                <MudTimelineItem Color="@Farbe(a.Art)" Size="Size.Small">
                    <MudStack Spacing="1">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudText Typo="Typo.body1"><b>@a.Titel</b></MudText>
                                @if (!string.IsNullOrWhiteSpace(a.Art))
                                {
                                    <MudChip T="string" Size="Size.Small" Color="@Farbe(a.Art)" Variant="Variant.Outlined">@a.Art</MudChip>
                                }
                            </MudStack>
                            @if (_darfSchreiben)
                            {
                                <MudStack Row="true" Spacing="0">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Default" Size="Size.Small"
                                                   OnClick="@(() => BearbeitenAsync(a))" aria-label="Aktivität bearbeiten" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                                   OnClick="@(() => EntfernenAsync(a))" aria-label="Aktivität löschen" />
                                </MudStack>
                            }
                        </MudStack>

                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="flex-wrap">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mud-text-secondary" />
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@a.Zeitpunkt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</MudText>
                            </MudStack>
                            @if (!string.IsNullOrWhiteSpace(a.Ort))
                            {
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Small" Class="mud-text-secondary" />
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@a.Ort</MudText>
                                </MudStack>
                            }
                        </MudStack>

                        @if (!string.IsNullOrWhiteSpace(a.Beschreibung))
                        {
                            <MudText Typo="Typo.body2" Style="white-space:pre-wrap;">@a.Beschreibung</MudText>
                        }

                        @* Dokumente/Anhänge je Aktivität – generische Quellen-Engine; nur laden, wenn aufgeklappt. *@
                        <MudExpansionPanels Elevation="0" Dense="true" Class="mt-1">
                            <MudExpansionPanel Text="Quellen &amp; Anhänge" Icon="@Icons.Material.Filled.AttachFile"
                                               Expanded="@_offen.Contains(a.Id)" ExpandedChanged="@(v => Umschalten(a.Id, v))">
                                @if (_offen.Contains(a.Id))
                                {
                                    <QuellenPanel EntitaetTyp="@nameof(FraktionAktivitaet)" EntitaetId="@a.Id" User="User" />
                                }
                            </MudExpansionPanel>
                        </MudExpansionPanels>
                    </MudStack>
                </MudTimelineItem>
            }
        </MudTimeline>
    }
</MudStack>

@code {
    [Parameter, EditorRequired] public string FraktionId { get; set; } = default!;
    [Parameter, EditorRequired] public ClaimsPrincipal User { get; set; } = default!;

    private bool _laden = true;
    private bool _darfSchreiben;
    private List<FraktionAktivitaet> _aktivitaeten = new();
    private List<string> _arten = new();
    private readonly HashSet<string> _offen = new();

    protected override async Task OnInitializedAsync()
    {
        _darfSchreiben = User.DarfSchreiben();
        await LadenAsync();
    }

    private async Task LadenAsync()
    {
        _laden = true;
        _aktivitaeten = await FraktionService.GetAktivitaetenAsync(FraktionId, User.IstFuehrung());
        _arten = await FraktionService.GetAktivitaetArtenAsync();
        _laden = false;
    }

    private async Task HinzufuegenAsync()
    {
        var eingabe = await AktivitaetDialog.ZeigenAsync(DialogService, _arten);
        if (eingabe is null)
        {
            return;
        }
        try
        {
            await FraktionService.AktivitaetHinzufuegenAsync(FraktionId, eingabe, User);
            Snackbar.Add("Aktivität hinzugefügt.", Severity.Success);
            await LadenAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task BearbeitenAsync(FraktionAktivitaet a)
    {
        // Vorhandene Werte mit lokalem Zeitpunkt in den Dialog geben (der Dienst speichert wieder als UTC).
        var vorhanden = new AktivitaetEingabe
        {
            Titel = a.Titel,
            Art = a.Art,
            Zeitpunkt = a.Zeitpunkt.ToLocalTime(),
            Ort = a.Ort,
            Beschreibung = a.Beschreibung,
        };
        var eingabe = await AktivitaetDialog.ZeigenAsync(DialogService, _arten, vorhanden);
        if (eingabe is null)
        {
            return;
        }
        try
        {
            await FraktionService.AktivitaetAendernAsync(a.Id, eingabe, User);
            Snackbar.Add("Aktivität aktualisiert.", Severity.Success);
            await LadenAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task EntfernenAsync(FraktionAktivitaet a)
    {
        var ok = await BestaetigenDialog.ZeigenAsync(DialogService, "Aktivität löschen?",
            $"„{a.Titel}“ wird in den Papierkorb verschoben.");
        if (!ok)
        {
            return;
        }
        try
        {
            await FraktionService.AktivitaetEntfernenAsync(a.Id, User);
            _offen.Remove(a.Id);
            Snackbar.Add("Aktivität gelöscht.", Severity.Success);
            await LadenAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private void Umschalten(string id, bool offen)
    {
        if (offen)
        {
            _offen.Add(id);
        }
        else
        {
            _offen.Remove(id);
        }
    }

    // Deterministische Farbe je Art (gleiche Art → gleiche Farbe im Zeitstrahl); ohne Art neutral.
    private static readonly Color[] _palette =
    {
        Color.Primary, Color.Secondary, Color.Info, Color.Success, Color.Warning, Color.Error, Color.Tertiary,
    };

    private static Color Farbe(string? art)
    {
        if (string.IsNullOrWhiteSpace(art))
        {
            return Color.Default;
        }
        var h = 0;
        foreach (var c in art)
        {
            h = (h * 31 + c) & 0x7fffffff;
        }
        return _palette[h % _palette.Length];
    }
}
