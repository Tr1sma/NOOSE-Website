@* Gefährdungs-Panel: Bedrohungs-Score einer Fraktion mit Konfidenz und nachvollziehbarer Aufschlüsselung (Phase 8/Block D). *@
@using System.Text.Json

<MudStack Spacing="4">
    @if (_detail?.Ausgenommen is { } ausnahme)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            Vom Bedrohungs-Score ausgenommen (@ausnahme).
        </MudAlert>
    }
    else if (Score is null && _detail is null)
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">
            Noch nicht berechnet – wird beim nächsten Schreibvorgang oder dem täglichen Lauf gesetzt.
        </MudText>
    }
    else
    {
        var stufe = GefaehrdungsStufeLogic.Aus(Score);
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4" Class="flex-wrap">
            <div>
                <MudText Typo="Typo.h3">@(Score?.ToString() ?? "—")</MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">von 100</MudText>
            </div>
            <MudChip T="string" Color="@StufeFarbe(stufe)" Variant="Variant.Filled" Size="Size.Large">
                @GefaehrdungsStufeLogic.Name(stufe)
            </MudChip>
            @if (Konfidenz is { } k)
            {
                <MudTooltip Text="Daten-Konfidenz: wie gut die Fraktion erfasst ist. Niedrige Konfidenz senkt den Score nie – sie markiert Nacherfassungsbedarf.">
                    <MudChip T="string" Color="@KonfidenzFarbe(k)" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.FactCheck">
                        Konfidenz @k&nbsp;%
                    </MudChip>
                </MudTooltip>
            }
        </MudStack>

        @if (_detail is not null)
        {
            @if (!string.IsNullOrWhiteSpace(_detail.BandHinweis))
            {
                <MudText Typo="Typo.body2" Class="mud-text-secondary">@_detail.BandHinweis</MudText>
            }
            @if (!string.IsNullOrWhiteSpace(_detail.TriageHinweis))
            {
                <MudAlert Severity="@(_detail.TriageFlag ? Severity.Warning : Severity.Info)" Variant="Variant.Outlined" Dense="true">
                    @_detail.TriageHinweis
                </MudAlert>
            }

            <MudStack Spacing="3">
                @foreach (var t in _detail.Teilscores)
                {
                    <div>
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.subtitle2">@t.Name</MudText>
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">+@t.Punkte.ToString("0.#") / @t.Cap.ToString("0")</MudText>
                        </MudStack>
                        <MudProgressLinear Color="Color.Primary" Rounded="true" Value="@Anteil(t)" Class="my-1" />
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@string.Join(" · ", t.Treiber)</MudText>
                    </div>
                }
            </MudStack>

            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                Inhalt @_detail.Inhalt.ToString("0") / 100 · Einstufung @_detail.EinstufungName (Band ab @_detail.Sockel)
            </MudText>
            @if (_detail.BerechnetAmUtc != default)
            {
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    Zuletzt berechnet: @_detail.BerechnetAmUtc.ToLocalTime().ToString("g")
                </MudText>
            }
        }
    }
</MudStack>

@code {
    [Parameter] public int? Score { get; set; }
    [Parameter] public int? Konfidenz { get; set; }
    [Parameter] public string? DetailJson { get; set; }

    private BedrohungsScoreDetail? _detail;
    private string? _geparstesJson;

    protected override void OnParametersSet()
    {
        if (_geparstesJson == DetailJson)
        {
            return;
        }
        _geparstesJson = DetailJson;
        _detail = null;
        if (!string.IsNullOrWhiteSpace(DetailJson))
        {
            try
            {
                _detail = JsonSerializer.Deserialize<BedrohungsScoreDetail>(DetailJson, BedrohungsScoreService.JsonOptions);
            }
            catch (JsonException)
            {
                _detail = null; // defekter Altbestand → wie „nicht berechnet" behandeln
            }
        }
    }

    private static double Anteil(BedrohungsTeilscore t) => t.Cap <= 0 ? 0 : Math.Clamp(t.Punkte / t.Cap * 100, 0, 100);

    private static Color StufeFarbe(GefaehrdungsStufe s) => s switch
    {
        GefaehrdungsStufe.Kritisch => Color.Error,
        GefaehrdungsStufe.Hoch => Color.Error,
        GefaehrdungsStufe.Mittel => Color.Warning,
        GefaehrdungsStufe.Niedrig => Color.Info,
        _ => Color.Default,
    };

    private static Color KonfidenzFarbe(int k) => k >= 67 ? Color.Success : k >= 34 ? Color.Warning : Color.Error;
}
