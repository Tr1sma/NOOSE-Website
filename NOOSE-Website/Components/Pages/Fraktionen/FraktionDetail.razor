@page "/fraktionen/{Id}"
@inject IFraktionService FraktionService
@inject IZugriffsLogService ZugriffsLog
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>@(_fraktion?.Name ?? "Fraktion") · NOOSE</PageTitle>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_fraktion is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
        Fraktion nicht gefunden oder nicht zugänglich (ggf. Verschlusssache).
    </MudAlert>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/fraktionen" aria-label="Zurück" />
        <MudSpacer />
        <FolgenButton EntitaetTyp="@nameof(Fraktion)" EntitaetId="@_fraktion.Id" User="_user" />
        <AufgabeErstellenButton EntitaetTyp="@nameof(Fraktion)" EntitaetId="@_fraktion.Id" />
        <MudButton Href="@($"/fraktionen/{_fraktion.Id}/bearbeiten")" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit">Bearbeiten</MudButton>
        <AuthorizeView Policy="@Policies.Fuehrung">
            <MudButton Color="Color.Error" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Delete" OnClick="LoeschenAsync">Löschen</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-2 mb-4" Elevation="1">
        <TagChips EntitaetTyp="@nameof(Fraktion)" EntitaetId="@_fraktion.Id" User="_user" />
    </MudPaper>

    <MudGrid>
        <MudItem xs="12" md="4" lg="3">
            <div class="akte-steckkarte">
                <Fraktionskarte Fraktion="_fraktion" Mitgliederzahl="_mitgliederzahl" Ermittlungsleiter="_ermittlungsleiter" />
            </div>
        </MudItem>

        <MudItem xs="12" md="8" lg="9">
            <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" TabPanelsClass="pa-4"
                     @bind-ActivePanelIndex="_aktiverTab"
                     @bind-ActivePanelIndex:after="@(() => TabUrlState.Write(Nav, _tabs, _aktiverTab))">
                <MudTabPanel Text="Stammdaten" Icon="@Icons.Material.Filled.Info">
                    <MudStack Spacing="3">
                        <MudStack Row="true" Spacing="6" Class="flex-wrap">
                            @foreach (var (label, wert) in Stammdaten())
                            {
                                <div>
                                    <MudText Typo="Typo.subtitle2">@label</MudText>
                                    <MudText Typo="Typo.body2" Class="mud-text-secondary">@wert</MudText>
                                </div>
                            }
                        </MudStack>
                        @if (!string.IsNullOrWhiteSpace(_fraktion.Anwesen))
                        {
                            <div>
                                <MudText Typo="Typo.subtitle2">Anwesen</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary" Style="white-space:pre-line;">@_fraktion.Anwesen</MudText>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(_fraktion.Ziele))
                        {
                            <div>
                                <MudText Typo="Typo.subtitle2">Ziele</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary">@_fraktion.Ziele</MudText>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(_fraktion.Beschreibung))
                        {
                            <div>
                                <MudText Typo="Typo.subtitle2">Beschreibung</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary">@_fraktion.Beschreibung</MudText>
                            </div>
                        }
                        <SteckbriefListe Titel="Ränge" Werte="@_fraktion.Raenge.OrderBy(r => r.Reihenfolge).Select(r => r.Bezeichnung)" />
                    </MudStack>
                </MudTabPanel>
                <MudTabPanel Text="Mitglieder" Icon="@Icons.Material.Filled.Groups">
                    <MitgliederPanel FraktionId="@_fraktion.Id" User="_user" Raenge="_raenge" Changed="MitgliederGeaendertAsync" />
                </MudTabPanel>
                <MudTabPanel Text="Zugeteilte Agents" Icon="@Icons.Material.Filled.ManageAccounts">
                    <FraktionAgentePanel FraktionId="@_fraktion.Id" User="_user" Changed="ErmittlungsleiterAktualisierenAsync" />
                </MudTabPanel>
                <MudTabPanel Text="Bestände" Icon="@Icons.Material.Filled.Inventory2">
                    <MudStack Spacing="3">
                        <SteckbriefListe Titel="Waffenbestand" Werte="BestandTexte(_fraktion.Waffenbestand.Select(w => (w.Bezeichnung, w.Menge)))" />
                        <SteckbriefListe Titel="Lagerbestand" Werte="BestandTexte(_fraktion.Lagerbestand.Select(l => (l.Bezeichnung, l.Menge)))" />
                    </MudStack>
                </MudTabPanel>
                <MudTabPanel Text="Einstufung" Icon="@Icons.Material.Filled.Shield">
                    <EinstufungPanel Aktuell="_fraktion.Einstufung" Verlauf="_einstufungVerlauf" User="_user" OnSetzen="EinstufungSetzenAsync"
                                     EntitaetTyp="@nameof(Fraktion)" EntitaetId="@_fraktion.Id" ZielBezeichnung="@($"{_fraktion.Name} ({_fraktion.Aktenzeichen})")" />
                </MudTabPanel>
                <MudTabPanel Text="Doks" Icon="@Icons.Material.Filled.Description">
                    <OrgDoksPanel OrgTyp="@nameof(Fraktion)" OrgId="@_fraktion.Id" User="_user" />
                </MudTabPanel>
                <MudTabPanel Text="Beziehungen" Icon="@Icons.Material.Filled.Hub">
                    <OrgBeziehungenPanel EntitaetTyp="@nameof(Fraktion)" EntitaetId="@_fraktion.Id" User="_user" />
                </MudTabPanel>
                <MudTabPanel Text="Quellen" Icon="@Icons.Material.Filled.AttachFile">
                    <QuellenPanel EntitaetTyp="@nameof(Fraktion)" EntitaetId="@_fraktion.Id" User="_user" />
                </MudTabPanel>
                <MudTabPanel Text="Wiedervorlagen" Icon="@Icons.Material.Filled.EventRepeat">
                    <WiedervorlagePanel EntitaetTyp="@nameof(Fraktion)" EntitaetId="@_fraktion.Id" User="_user" />
                </MudTabPanel>
                <MudTabPanel Text="Kommentare" Icon="@Icons.Material.Filled.Comment">
                    <KommentarPanel EntitaetTyp="@nameof(Fraktion)" EntitaetId="@_fraktion.Id" User="_user" />
                </MudTabPanel>
                <MudTabPanel Text="Zusatzfelder" Icon="@Icons.Material.Filled.Tune">
                    <CustomFelderPanel EntitaetTyp="@nameof(Fraktion)" EntitaetId="@_fraktion.Id" User="_user" />
                </MudTabPanel>
                <MudTabPanel Text="Historie" Icon="@Icons.Material.Filled.History">
                    <FraktionHistorieTimeline FraktionId="@_fraktion.Id" IstFuehrung="_user.IstFuehrung()" @key="_historieKey" />
                </MudTabPanel>
            </MudTabs>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public string Id { get; set; } = default!;
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _laden = true;
    private Fraktion? _fraktion;
    private int _mitgliederzahl;
    private List<string> _ermittlungsleiter = new();
    private List<string> _raenge = new();
    private List<EinstufungVerlauf> _einstufungVerlauf = new();
    private ClaimsPrincipal _user = default!;
    private Guid _historieKey = Guid.NewGuid();
    private string? _geladeneId;

    // Aktiver Tab wird in der URL (?tab=…) gehalten – Reihenfolge muss den MudTabPanels entsprechen.
    private int _aktiverTab;
    private static readonly string[] _tabs =
    {
        "stammdaten", "mitglieder", "agents", "bestaende", "einstufung", "doks",
        "beziehungen", "quellen", "wiedervorlagen", "kommentare", "zusatzfelder", "historie",
    };

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
    }

    // Diese Seite wird bei Navigation /fraktionen/{A} → /fraktionen/{B} WIEDERVERWENDET (gleiche Komponente);
    // OnInitializedAsync läuft dann NICHT erneut. Daher hier auf den Id-Wechsel reagieren – sonst bliebe die alte
    // Akte stehen. Das kurze _laden=true mountet den Tab-Baum (samt Kind-Panels) frisch. Tab-/Query-Wechsel: Id
    // bleibt gleich → kein Neuladen.
    protected override async Task OnParametersSetAsync()
    {
        if (_geladeneId == Id)
        {
            return;
        }
        _geladeneId = Id;
        _laden = true;
        _fraktion = null;
        _aktiverTab = TabUrlState.Read(Nav, _tabs);
        await LadenAsync();
        if (_fraktion is not null)
        {
            await ZugriffsLog.LogAnsichtAsync(nameof(Fraktion), _fraktion.Id);
        }
    }

    private async Task LadenAsync()
    {
        // Kein _laden = true beim Neuladen: sonst entfernt das @if (_laden) die MudTabs aus dem
        // Render-Baum, ein frisch gemountetes MudTabs springt auf den ersten Tab. Der erste Aufruf
        // zeigt den Ladebalken weiterhin über den Feld-Initialwert (_laden = true).
        _fraktion = await FraktionService.GetDetailAsync(Id, _user.IstFuehrung());
        if (_fraktion is not null)
        {
            _raenge = _fraktion.Raenge.OrderBy(r => r.Reihenfolge).Select(r => r.Bezeichnung).ToList();
            _einstufungVerlauf = await FraktionService.GetEinstufungVerlaufAsync(_fraktion.Id, _user.IstFuehrung());
            _mitgliederzahl = (await FraktionService.GetMitgliederAsync(_fraktion.Id, _user.IstFuehrung())).Count;
            await ErmittlungsleiterLadenAsync();
        }
        _laden = false;
    }

    private async Task ErmittlungsleiterLadenAsync()
    {
        if (_fraktion is null)
        {
            return;
        }
        var el = await FraktionService.GetErmittlungsleiterAsync(_fraktion.Id);
        _ermittlungsleiter = el.Select(a => a.Agent?.Codename ?? "?").ToList();
    }

    private async Task ErmittlungsleiterAktualisierenAsync()
    {
        await ErmittlungsleiterLadenAsync();
        StateHasChanged();
    }

    private async Task NeuLadenAsync()
    {
        await LadenAsync();
        _historieKey = Guid.NewGuid();
        StateHasChanged();
    }

    private async Task MitgliederGeaendertAsync()
    {
        if (_fraktion is not null)
        {
            _mitgliederzahl = (await FraktionService.GetMitgliederAsync(_fraktion.Id, _user.IstFuehrung())).Count;
            StateHasChanged();
        }
    }

    private async Task EinstufungSetzenAsync((Einstufung Neu, string? Begruendung) eingabe)
    {
        if (_fraktion is null)
        {
            return;
        }
        await FraktionService.EinstufungSetzenAsync(_fraktion.Id, eingabe.Neu, eingabe.Begruendung, _user);
        await NeuLadenAsync();
    }

    private async Task LoeschenAsync()
    {
        if (_fraktion is null)
        {
            return;
        }
        var ok = await BestaetigenDialog.ZeigenAsync(DialogService, "Fraktion löschen?",
            "Die Fraktion wird in den Papierkorb verschoben und kann von der Führung wiederhergestellt werden.");
        if (!ok)
        {
            return;
        }
        await FraktionService.LoeschenAsync(_fraktion.Id, _user);
        Snackbar.Add("Fraktion in den Papierkorb verschoben.", Severity.Success);
        Nav.NavigateTo("/fraktionen");
    }

    private IEnumerable<(string Label, string Wert)> Stammdaten()
    {
        yield return ("Art", _fraktion!.Art ?? "—");
        yield return ("Funk", _fraktion.Funk ?? "—");
        yield return ("Darkchat", _fraktion.Darkchat ?? "—");
        yield return ("Ausstellungszeiten", _fraktion.Ausstellungszeiten ?? "—");
    }

    private static IEnumerable<string> BestandTexte(IEnumerable<(string Bezeichnung, string? Menge)> items)
        => items.Select(i => string.IsNullOrWhiteSpace(i.Menge) ? i.Bezeichnung : $"{i.Bezeichnung} · {i.Menge}");
}
