@* Shared create/edit appointment form; date+time merge into local RP time, service stores UTC. *@
@inject IAgentManagementService AgentService

<MudGrid>
    <MudItem xs="12" md="8">
        <MudTextField @bind-Value="Input.Title" Label="Titel" Required="true" RequiredError="Titel ist erforderlich"
                      Variant="Variant.Outlined" />
    </MudItem>
    <MudItem xs="12" md="4">
        <MudSelect T="AppointmentCategory" @bind-Value="Input.Category" Label="Kategorie" Variant="Variant.Outlined">
            @foreach (var k in AppointmentCategoryDisplay.All)
            {
                <MudSelectItem Value="k">@AppointmentCategoryDisplay.Name(k)</MudSelectItem>
            }
        </MudSelect>
    </MudItem>

    <MudItem xs="12" md="4">
        <MudSelect T="AppointmentStatus" @bind-Value="Input.Status" Label="Status" Variant="Variant.Outlined">
            @foreach (var s in AppointmentStatusDisplay.All)
            {
                <MudSelectItem Value="s">@AppointmentStatusDisplay.Name(s)</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
    <MudItem xs="12" md="8">
        <MudTextField @bind-Value="Input.Location" Label="Ort (optional)" Variant="Variant.Outlined" />
    </MudItem>

    <MudItem xs="12">
        <MudSwitch T="bool" Value="Input.AllDay" ValueChanged="AllDayModified" Color="Color.Primary" Label="Ganztägig" />
    </MudItem>

    <MudItem xs="12" md="@(Input.AllDay ? 12 : 6)">
        <MudDatePicker @bind-Date="_startDate" @bind-Date:after="Sync" Label="Beginn (Datum)" Required="true"
                       RequiredError="Beginn ist erforderlich" Variant="Variant.Outlined" Editable="true" DateFormat="dd.MM.yyyy" />
    </MudItem>
    @if (!Input.AllDay)
    {
        <MudItem xs="12" md="6">
            <MudTimePicker @bind-Time="_startTime" @bind-Time:after="Sync" Label="Beginn (Uhrzeit)" Variant="Variant.Outlined" Editable="true" />
        </MudItem>
    }

    <MudItem xs="12" md="@(Input.AllDay ? 12 : 6)">
        <MudDatePicker @bind-Date="_endDate" @bind-Date:after="Sync" Label="Ende (Datum, optional)" Variant="Variant.Outlined"
                       Clearable="true" Editable="true" DateFormat="dd.MM.yyyy" />
    </MudItem>
    @if (!Input.AllDay)
    {
        <MudItem xs="12" md="6">
            <MudTimePicker @bind-Time="_endTime" @bind-Time:after="Sync" Label="Ende (Uhrzeit, optional)" Variant="Variant.Outlined" Clearable="true" Editable="true" />
        </MudItem>
    }

    <MudItem xs="12" md="6">
        <MudSelect T="AppointmentVisibilityLevel" @bind-Value="Input.Visibility" Label="Sichtbarkeit" Variant="Variant.Outlined"
                   AdornmentIcon="@AppointmentVisibilityLevelDisplay.Icon(Input.Visibility)" Adornment="Adornment.Start"
                   HelperText="@AppointmentVisibilityLevelDisplay.Help(Input.Visibility)">
            @foreach (var s in AppointmentVisibilityLevelDisplay.All)
            {
                <MudSelectItem Value="s">@AppointmentVisibilityLevelDisplay.Name(s)</MudSelectItem>
            }
        </MudSelect>
    </MudItem>

    @if (ShowAssignment)
    {
        <MudItem xs="12">
            <MudSelect T="string" Label="Teilnehmer (optional)" MultiSelection="true"
                       SelectedValues="AgentIds" SelectedValuesChanged="OnAgentsChanged"
                       MultiSelectionTextFunc="@DisplaySelection" Variant="Variant.Outlined"
                       Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.ManageAccounts"
                       HelperText="Teilnehmer erhalten eine Benachrichtigung.">
                @foreach (var a in _agents)
                {
                    <MudSelectItem T="string" Value="@a.Id">@a.Codename (@RankDisplay.Name(a.Rank))</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
    }

    <MudItem xs="12">
        <MudTextField @bind-Value="Input.Description" Label="Beschreibung (optional)" Lines="4" Variant="Variant.Outlined"
                      HelperText="Worum geht es bei diesem Termin?" />
    </MudItem>
</MudGrid>

@code {
    [Parameter, EditorRequired] public AppointmentInput Input { get; set; } = default!;

    /// <summary>Show multi-assignment (create only).</summary>
    [Parameter] public bool ShowAssignment { get; set; }

    /// <summary>Selected agent ids, two-way bound.</summary>
    [Parameter] public IReadOnlyCollection<string> AgentIds { get; set; } = Array.Empty<string>();
    [Parameter] public EventCallback<IReadOnlyCollection<string>> AgentIdsChanged { get; set; }

    private List<Agent> _agents = new();
    private DateTime? _startDate;
    private TimeSpan? _startTime;
    private DateTime? _endDate;
    private TimeSpan? _endTime;

    protected override async Task OnInitializedAsync()
    {
        if (ShowAssignment)
        {
            _agents = await AgentService.GetSelectableAsync();
        }
        if (Input.Start is { } b)
        {
            _startDate = b.Date;
            _startTime = b.TimeOfDay;
        }
        if (Input.End is { } e)
        {
            _endDate = e.Date;
            _endTime = e.TimeOfDay;
        }
    }

    private void AllDayModified(bool value)
    {
        Input.AllDay = value;
        if (value)
        {
            _startTime = null;
            _endTime = null;
        }
        Sync();
    }

    // Merge date + time; missing time defaults to 00:00
    private void Sync()
    {
        Input.Start = Combo(_startDate, _startTime);
        Input.End = Combo(_endDate, _endTime);
    }

    private static DateTime? Combo(DateTime? date, TimeSpan? time)
        => date is { } d ? d.Date + (time ?? TimeSpan.Zero) : null;

    private async Task OnAgentsChanged(IReadOnlyCollection<string> values)
    {
        AgentIds = values;
        await AgentIdsChanged.InvokeAsync(values);
    }

    private string DisplaySelection(IReadOnlyList<string> ids)
    {
        var names = _agents.Where(a => ids.Contains(a.Id)).Select(a => a.Codename).ToList();
        return names.Count == 0 ? string.Empty : string.Join(", ", names);
    }
}
