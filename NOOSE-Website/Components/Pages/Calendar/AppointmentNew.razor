@page "/kalender/neu"
@inject IAppointmentService AppointmentService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Neuer Termin · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/kalender" aria-label="Zurück" />
    <MudIcon Icon="@Icons.Material.Filled.EventNote" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h4">Neuen Termin anlegen</MudText>
</MudStack>

<MudForm @ref="_form">
    <AppointmentForm Input="_input" ShowAssignment="true" @bind-AgentIds="_agentIds" />
</MudForm>

<MudStack Row="true" Spacing="2" Class="mt-4">
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveAsync" Disabled="_saves">Anlegen</MudButton>
    <MudButton Variant="Variant.Text" Href="/kalender">Abbrechen</MudButton>
</MudStack>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private MudForm _form = default!;
    private readonly AppointmentInput _input = new();
    private IReadOnlyCollection<string> _agentIds = new HashSet<string>();
    private ClaimsPrincipal _user = default!;
    private bool _saves;

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        // Bequeme Vorbelegung: nächste volle Stunde (lokale RP-Zeit).
        var now = DateTime.Now;
        _input.Start = new DateTime(now.Year, now.Month, now.Day, now.Hour, 0, 0).AddHours(1);
    }

    private async Task SaveAsync()
    {
        if (_saves)
        {
            return;
        }
        await _form.ValidateAsync();
        if (!_form.IsValid)
        {
            return;
        }

        _saves = true;
        try
        {
            var appointment = await AppointmentService.CreateAsync(_input, _agentIds.ToList(), _user);
            Snackbar.Add($"Termin {appointment.CaseNumber} angelegt.", Severity.Success);
            Nav.NavigateTo($"/kalender/{appointment.Id}");
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
            _saves = false;
        }
    }
}
