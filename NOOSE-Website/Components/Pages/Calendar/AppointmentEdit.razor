@page "/kalender/{Id}/bearbeiten"
@inject IAppointmentService AppointmentService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Termin bearbeiten · NOOSE</PageTitle>

@if (_load)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_noAccess)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
        Diesen Termin darf nur sein Ersteller oder die Führung bearbeiten.
        <MudButton Href="@($"/kalender/{Id}")" Variant="Variant.Text" Color="Color.Primary" Class="ml-2">Zum Termin</MudButton>
    </MudAlert>
}
else if (_input is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
        Termin nicht gefunden.
    </MudAlert>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="@($"/kalender/{Id}")" aria-label="Zurück" />
        <MudIcon Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Large" />
        <MudText Typo="Typo.h4">Termin bearbeiten</MudText>
    </MudStack>

    <MudForm @ref="_form">
        <AppointmentForm Input="_input" ShowAssignment="false" @key="Id" />
    </MudForm>
    <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2">
        Hinweis: Teilnehmer werden im Termin unter „Teilnehmer" verwaltet.
    </MudText>

    <MudStack Row="true" Spacing="2" Class="mt-4">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveAsync" Disabled="_saves">Speichern</MudButton>
        <MudButton Variant="Variant.Text" Href="@($"/kalender/{Id}")">Abbrechen</MudButton>
    </MudStack>
}

@code {
    [Parameter] public string Id { get; set; } = default!;
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private MudForm _form = default!;
    private AppointmentInput? _input;
    private ClaimsPrincipal _user = default!;
    private bool _load = true;
    private bool _noAccess;
    private bool _saves;
    private string? _loadedId;

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_loadedId == Id)
        {
            return;
        }
        _loadedId = Id;
        _load = true;
        _input = null;
        _noAccess = false;
        var t = await AppointmentService.GetDetailAsync(Id, _user);
        if (t is not null)
        {
            // Mirror the server-side creator/leadership write gate in the UI
            if (!_user.IsLeadership() && t.CreatedById != _user.GetAgentId())
            {
                _noAccess = true;
            }
            else
            {
                _input = new AppointmentInput
                {
                    Title = t.Title,
                    Category = t.Category,
                    Status = t.Status,
                    Location = t.Location,
                    Start = UtcByLocal(t.Start),
                    End = t.End is { } e ? UtcByLocal(e) : null,
                    AllDay = t.AllDay,
                    Description = t.Description,
                    Visibility = t.Visibility,
                };
            }
        }
        _load = false;
    }

    private async Task SaveAsync()
    {
        if (_input is null || _saves)
        {
            return;
        }
        await _form.ValidateAsync();
        if (!_form.IsValid)
        {
            return;
        }

        _saves = true;
        try
        {
            await AppointmentService.RefreshAsync(Id, _input, _user);
            Snackbar.Add("Änderungen gespeichert.", Severity.Success);
            Nav.NavigateTo($"/kalender/{Id}");
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
            _saves = false;
        }
    }

    private static DateTime UtcByLocal(DateTime utc)
        => DateTime.SpecifyKind(utc, DateTimeKind.Utc).ToLocalTime();
}
