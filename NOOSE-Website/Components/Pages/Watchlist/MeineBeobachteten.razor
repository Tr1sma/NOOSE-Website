@page "/watchlist"
@inject IWatchlistService WatchlistService
@inject ISnackbar Snackbar

<PageTitle>Beobachtete Akten · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
    <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Warning" Size="Size.Large" />
    <MudText Typo="Typo.h4">Beobachtete Akten</MudText>
</MudStack>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_akten.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
        Du folgst noch keiner Akte. Öffne eine Akte und klicke auf „Folgen", um bei Änderungen benachrichtigt zu werden.
    </MudAlert>
}
else
{
    <MudStack Spacing="2">
        @foreach (var a in _akten)
        {
            <MudPaper Class="pa-3" Elevation="1">
                <div class="d-flex align-center" style="gap:.75rem">
                    <MudIcon Icon="@TypIcon(a.Typ)" Color="Color.Primary" />
                    <div class="flex-grow-1">
                        @if (a.Zugaenglich && !string.IsNullOrEmpty(a.Href))
                        {
                            <MudLink Href="@a.Href" Typo="Typo.body1">@a.Anzeige</MudLink>
                        }
                        else
                        {
                            <MudText Typo="Typo.body1" Class="mud-text-secondary">@a.Anzeige</MudText>
                        }
                        <MudText Typo="Typo.caption" Class="mud-text-secondary d-block">
                            @TypName(a.Typ) · folgt seit @a.ErstelltAm.ToLocalTime().ToString("dd.MM.yyyy")
                        </MudText>
                    </div>
                    <MudTooltip Text="Nicht mehr folgen">
                        <MudIconButton Icon="@Icons.Material.Filled.Star" Color="Color.Warning"
                                       aria-label="Nicht mehr folgen" Disabled="_busy"
                                       OnClick="@(() => EntfolgenAsync(a))" />
                    </MudTooltip>
                </div>
            </MudPaper>
        }
    </MudStack>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _laden = true;
    private bool _busy;
    private List<GefolgteAkte> _akten = new();
    private ClaimsPrincipal _user = default!;

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        await LadenAsync();
    }

    private async Task LadenAsync()
    {
        _laden = true;
        _akten = await WatchlistService.GetGefolgteAufgeloestAsync(_user);
        _laden = false;
    }

    private async Task EntfolgenAsync(GefolgteAkte a)
    {
        if (_busy)
        {
            return;
        }
        _busy = true;
        try
        {
            await WatchlistService.EntfolgenAsync(a.Typ, a.Id, _user);
            _akten.Remove(a);
            Snackbar.Add("Du folgst dieser Akte nicht mehr.", Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private static string TypIcon(string typ) => typ switch
    {
        nameof(Person) => Icons.Material.Filled.Badge,
        nameof(Fraktion) => Icons.Material.Filled.Groups,
        nameof(Personengruppe) => Icons.Material.Filled.Diversity3,
        nameof(Partei) => Icons.Material.Filled.AccountBalance,
        nameof(Operation) => Icons.Material.Filled.Radar,
        nameof(Vorgang) => Icons.Material.Filled.FolderSpecial,
        nameof(Taskforce) => Icons.Material.Filled.Groups2,
        nameof(Agent) => Icons.Material.Filled.People,
        _ => Icons.Material.Filled.Article,
    };

    private static string TypName(string typ) => typ switch
    {
        nameof(Person) => "Person",
        nameof(Fraktion) => "Fraktion",
        nameof(Personengruppe) => "Personengruppe",
        nameof(Partei) => "Partei",
        nameof(Operation) => "Operation",
        nameof(Vorgang) => "Vorgang",
        nameof(Taskforce) => "Taskforce",
        nameof(Agent) => "Personalakte",
        _ => typ,
    };
}
