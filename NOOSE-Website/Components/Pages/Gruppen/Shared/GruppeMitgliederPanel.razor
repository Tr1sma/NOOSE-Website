@* Mitglieder einer Personengruppe: Liste (Leitung zuerst), Hinzufügen/Bearbeiten/Entfernen mit Rolle + Leitung. *@
@inject IPersonengruppeService GruppeService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudText Typo="Typo.subtitle1">Mitglieder (@_mitglieder.Count)</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd" OnClick="HinzufuegenAsync">
            Mitglied hinzufügen
        </MudButton>
    </MudStack>

    @if (_laden)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_mitglieder.Count == 0)
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Mitglieder erfasst.</MudText>
    }
    else
    {
        @foreach (var m in _mitglieder)
        {
            <MudPaper Class="pa-3" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Badge" Color="Color.Primary" Size="Size.Small" />
                        <MudLink Href="@($"/personen/{m.PersonId}")" Typo="Typo.body2"><b>@m.Person?.Name</b></MudLink>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@m.Person?.Aktenzeichen</MudText>
                        @if (m.IstLeitung)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled" Icon="@Icons.Material.Filled.Star">Leitung</MudChip>
                        }
                        @if (!string.IsNullOrWhiteSpace(m.Rolle))
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">@m.Rolle</MudChip>
                        }
                    </MudStack>
                    <MudStack Row="true" Spacing="0">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Default" Size="Size.Small"
                                       OnClick="@(() => BearbeitenAsync(m))" aria-label="Mitgliedschaft bearbeiten" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                       OnClick="@(() => EntfernenAsync(m))" aria-label="Mitglied entfernen" />
                    </MudStack>
                </MudStack>
            </MudPaper>
        }
    }
</MudStack>

@code {
    [Parameter, EditorRequired] public string GruppeId { get; set; } = default!;
    [Parameter, EditorRequired] public ClaimsPrincipal User { get; set; } = default!;
    /// <summary>Wird nach Änderungen ausgelöst (damit die Steckkarte den Fortschritt aktualisiert).</summary>
    [Parameter] public EventCallback Changed { get; set; }

    private bool _laden = true;
    private List<PersonengruppeMitglied> _mitglieder = new();

    protected override async Task OnInitializedAsync() => await LadenAsync();

    private async Task LadenAsync()
    {
        _laden = true;
        _mitglieder = await GruppeService.GetMitgliederAsync(GruppeId, User.IstFuehrung());
        _laden = false;
    }

    private async Task HinzufuegenAsync()
    {
        var ausschluss = _mitglieder.Select(m => m.PersonId).ToList();
        var eingabe = await GruppeMitgliedDialog.ZeigenAsync(DialogService, User.IstFuehrung(), ausschluss);
        if (eingabe is null)
        {
            return;
        }
        try
        {
            await GruppeService.MitgliedHinzufuegenAsync(GruppeId, eingabe, User);
            Snackbar.Add("Mitglied hinzugefügt.", Severity.Success);
            await LadenAsync();
            await Changed.InvokeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task BearbeitenAsync(PersonengruppeMitglied m)
    {
        var eingabe = await GruppeMitgliedDialog.ZeigenZumBearbeitenAsync(DialogService, m.Person?.Name ?? "—", m.Rolle, m.IstLeitung);
        if (eingabe is null)
        {
            return;
        }
        try
        {
            await GruppeService.MitgliedAendernAsync(m.Id, eingabe.Rolle, eingabe.IstLeitung, User);
            Snackbar.Add("Mitgliedschaft aktualisiert.", Severity.Success);
            await LadenAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task EntfernenAsync(PersonengruppeMitglied m)
    {
        var ok = await BestaetigenDialog.ZeigenAsync(DialogService, "Mitglied entfernen?",
            $"„{m.Person?.Name}“ wird aus der Gruppe entfernt.", "Entfernen");
        if (!ok)
        {
            return;
        }
        await GruppeService.MitgliedEntfernenAsync(m.Id, User);
        Snackbar.Add("Mitglied entfernt.", Severity.Success);
        await LadenAsync();
        await Changed.InvokeAsync();
    }
}
