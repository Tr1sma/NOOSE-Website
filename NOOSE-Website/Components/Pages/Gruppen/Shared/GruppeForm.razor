@* Gemeinsames Formular für Anlegen/Bearbeiten einer Personengruppe. Beim Anlegen können bereits Mitglieder
   erfasst werden (ZeigeMitglieder); zugeteilte Agents laufen weiterhin nur über die Akte. *@
@inject IDialogService DialogService

<MudGrid>
    <MudItem xs="12" md="8">
        <MudTextField @bind-Value="Eingabe.Name" Label="Name" Required="true" RequiredError="Name ist erforderlich"
                      Variant="Variant.Outlined" />
    </MudItem>
    <MudItem xs="12" md="4">
        <MudNumericField @bind-Value="Eingabe.GeschaetzteMitgliederzahl" Label="Geschätzte Mitgliederzahl"
                         Variant="Variant.Outlined" Min="0" HelperText="Für den Erfassungsfortschritt (x/y)" Clearable="true" />
    </MudItem>

    @if (ZeigeEinstufung)
    {
        <MudItem xs="12" md="6">
            <MudSelect T="Einstufung" @bind-Value="Eingabe.Einstufung" Label="Einstufung" Variant="Variant.Outlined">
                @foreach (var e in EinstufungAnzeige.Alle)
                {
                    <MudSelectItem Value="e" Disabled="@(e == Einstufung.GesichertStaatsgefaehrdend && !DarfHoechste)">
                        @EinstufungAnzeige.Name(e)
                    </MudSelectItem>
                }
            </MudSelect>
        </MudItem>
    }
    <MudItem xs="12" md="6" Class="d-flex flex-column justify-center">
        <MudSwitch T="bool" @bind-Value="Eingabe.IstVerschlusssache" Color="Color.Warning"
                   Label="Verschlusssache (nur Führung sichtbar)" />
        @if (Eingabe.IstVerschlusssache && !IstFuehrung)
        {
            <MudText Typo="Typo.caption" Color="Color.Warning">
                Achtung: Du verlierst als Nicht-Führung nach dem Speichern selbst den Zugriff auf diese Akte.
            </MudText>
        }
    </MudItem>

    <MudItem xs="12">
        <MudTextField @bind-Value="Eingabe.Ziele" Label="Ziele" Lines="2" Variant="Variant.Outlined" />
    </MudItem>
    <MudItem xs="12">
        <MudTextField @bind-Value="Eingabe.Beschreibung" Label="Beschreibung" Lines="3" Variant="Variant.Outlined" />
    </MudItem>
</MudGrid>

@if (ZeigeMitglieder)
{
    <MudDivider Class="my-4" />
    <MudStack Spacing="2">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudText Typo="Typo.h6">Mitglieder</MudText>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd" OnClick="MitgliedHinzufuegenAsync">
                Mitglied hinzufügen
            </MudButton>
        </MudStack>
        @if (Eingabe.Mitglieder.Count == 0)
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Mitglieder – optional. Können auch später in der Akte ergänzt werden.</MudText>
        }
        else
        {
            @foreach (var m in Eingabe.Mitglieder)
            {
                <MudPaper Class="pa-2" Elevation="1">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Badge" Color="Color.Primary" Size="Size.Small" />
                            <MudText Typo="Typo.body2"><b>@m.PersonName</b></MudText>
                            @if (m.IstLeitung)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled" Icon="@Icons.Material.Filled.Star">Leitung</MudChip>
                            }
                            @if (!string.IsNullOrWhiteSpace(m.Rolle))
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">@m.Rolle</MudChip>
                            }
                        </MudStack>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                       OnClick="@(() => Eingabe.Mitglieder.Remove(m))" aria-label="Mitglied entfernen" />
                    </MudStack>
                </MudPaper>
            }
        }
    </MudStack>
}

@code {
    [Parameter, EditorRequired] public PersonengruppeEingabe Eingabe { get; set; } = default!;
    /// <summary>Einstufung im Formular zeigen (nur beim Anlegen; im Bearbeiten über den Tab „Einstufung").</summary>
    [Parameter] public bool ZeigeEinstufung { get; set; }
    [Parameter] public bool DarfHoechste { get; set; }
    /// <summary>Mitglieder-Sektion zeigen (nur beim Anlegen; im Bearbeiten über den Tab „Mitglieder").</summary>
    [Parameter] public bool ZeigeMitglieder { get; set; }
    [Parameter] public bool IstFuehrung { get; set; }

    private async Task MitgliedHinzufuegenAsync()
    {
        var ausschluss = Eingabe.Mitglieder.Select(m => m.PersonId).ToList();
        var neu = await GruppeMitgliedDialog.ZeigenAsync(DialogService, IstFuehrung, ausschluss);
        if (neu is null)
        {
            return;
        }
        // Doppelte vermeiden: gleiche bestehende Person oder gleicher neuer Name (Akte würde sonst doppelt entstehen).
        var schonVorhanden =
            (!string.IsNullOrWhiteSpace(neu.PersonId) && Eingabe.Mitglieder.Any(m => m.PersonId == neu.PersonId))
            || (!string.IsNullOrWhiteSpace(neu.NeuePersonName)
                && Eingabe.Mitglieder.Any(m => string.Equals(m.NeuePersonName, neu.NeuePersonName, StringComparison.OrdinalIgnoreCase)));
        if (!schonVorhanden)
        {
            Eingabe.Mitglieder.Add(neu);
        }
    }
}
