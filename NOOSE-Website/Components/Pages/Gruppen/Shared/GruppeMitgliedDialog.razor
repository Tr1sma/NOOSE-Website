@* Dialog zum Hinzufügen/Bearbeiten einer Gruppen-Mitgliedschaft: Person + Rolle + Leitungs-Flag. *@
@inject IPersonService PersonService

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3" Style="min-width:360px;">
            @if (IstBearbeiten)
            {
                <MudField Label="Person" Variant="Variant.Outlined">@PersonNameVorhanden</MudField>
            }
            else
            {
                <MudAutocomplete T="Person" Label="Person" @bind-Value="_person"
                                 SearchFunc="@SuchePersonen" ToStringFunc="@(p => p?.Name ?? string.Empty)"
                                 Variant="Variant.Outlined" Clearable="true" CoerceText="false" CoerceValue="false"
                                 ResetValueOnEmptyText="true" MinCharacters="0" Immediate="true"
                                 Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.PersonSearch"
                                 HelperText="Person der Gruppe zuordnen.">
                    <ItemTemplate Context="p">
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                            <MudIcon Icon="@Icons.Material.Filled.Badge" Size="Size.Small" Color="Color.Primary" />
                            <MudText Typo="Typo.body2">@p.Name</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@p.Aktenzeichen</MudText>
                        </MudStack>
                    </ItemTemplate>
                </MudAutocomplete>
            }

            <MudTextField @bind-Value="_rolle" Label="Rolle (optional)" Variant="Variant.Outlined"
                          Placeholder="z. B. Anführer, Kurier" />
            <MudSwitch T="bool" @bind-Value="_istLeitung" Color="Color.Primary" Label="Gehört zur Leitung" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Abbrechen">Abbrechen</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Speichern">
            @(IstBearbeiten ? "Speichern" : "Hinzufügen")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public bool IstFuehrung { get; set; }
    [Parameter] public IReadOnlyList<string> AusschlussPersonIds { get; set; } = Array.Empty<string>();

    // Bearbeiten-Modus (Person fix): wird durch einen gesetzten Namen signalisiert.
    [Parameter] public string? PersonNameVorhanden { get; set; }
    [Parameter] public string? RolleVorhanden { get; set; }
    [Parameter] public bool IstLeitungVorhanden { get; set; }

    private bool IstBearbeiten => PersonNameVorhanden is not null;

    private Person? _person;
    private string? _rolle;
    private bool _istLeitung;

    protected override void OnInitialized()
    {
        if (IstBearbeiten)
        {
            _rolle = RolleVorhanden;
            _istLeitung = IstLeitungVorhanden;
        }
    }

    private async Task<IEnumerable<Person>> SuchePersonen(string value, CancellationToken token)
    {
        var treffer = await PersonService.SucheAsync(value, IstFuehrung, 20, token);
        return treffer.Where(p => !AusschlussPersonIds.Contains(p.Id));
    }

    private void Speichern()
    {
        if (!IstBearbeiten && _person is null)
        {
            return;
        }
        MudDialog.Close(DialogResult.Ok(new GruppeMitgliedEingabe
        {
            PersonId = IstBearbeiten ? string.Empty : _person!.Id,
            Rolle = _rolle,
            IstLeitung = _istLeitung,
        }));
    }

    private void Abbrechen() => MudDialog.Cancel();

    public static async Task<GruppeMitgliedEingabe?> ZeigenAsync(IDialogService dialog, bool istFuehrung, IReadOnlyList<string> ausschlussPersonIds)
    {
        var parameters = new DialogParameters<GruppeMitgliedDialog>
        {
            { x => x.IstFuehrung, istFuehrung },
            { x => x.AusschlussPersonIds, ausschlussPersonIds },
        };
        var referenz = await dialog.ShowAsync<GruppeMitgliedDialog>("Mitglied hinzufügen", parameters);
        var ergebnis = await referenz.Result;
        return ergebnis is { Canceled: false, Data: GruppeMitgliedEingabe e } ? e : null;
    }

    public static async Task<GruppeMitgliedEingabe?> ZeigenZumBearbeitenAsync(IDialogService dialog, string personName, string? rolle, bool istLeitung)
    {
        var parameters = new DialogParameters<GruppeMitgliedDialog>
        {
            { x => x.PersonNameVorhanden, personName },
            { x => x.RolleVorhanden, rolle },
            { x => x.IstLeitungVorhanden, istLeitung },
        };
        var referenz = await dialog.ShowAsync<GruppeMitgliedDialog>("Mitgliedschaft bearbeiten", parameters);
        var ergebnis = await referenz.Result;
        return ergebnis is { Canceled: false, Data: GruppeMitgliedEingabe e } ? e : null;
    }
}
