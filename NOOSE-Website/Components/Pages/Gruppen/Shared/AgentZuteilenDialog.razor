@* Dialog zum Zuteilen eines NOOSE-Agents zu einer Personengruppe. *@
@inject IAgentVerwaltungService AgentService

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3" Style="min-width:360px;">
            <MudAutocomplete T="Agent" Label="Agent" @bind-Value="_agent" AutoFocus="true"
                             SearchFunc="@SucheAgenten" ToStringFunc="@(a => a is null ? string.Empty : a.Codename)"
                             Variant="Variant.Outlined" Clearable="true" CoerceText="false" CoerceValue="false"
                             ResetValueOnEmptyText="true" MinCharacters="0" Immediate="true"
                             Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.ManageAccounts"
                             HelperText="Aktiven Agent der Gruppe zuteilen.">
                <ItemTemplate Context="a">
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Color="Color.Primary" />
                        <MudText Typo="Typo.body2">@a.Codename</MudText>
                        @if (DarfKlarname && !string.IsNullOrWhiteSpace(a.Klarname))
                        {
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">(@a.Klarname)</MudText>
                        }
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@DienstgradAnzeige.Name(a.Dienstgrad)</MudText>
                    </MudStack>
                </ItemTemplate>
            </MudAutocomplete>

            @if (DarfErmittlungsleiterSetzen)
            {
                <MudCheckBox @bind-Value="_alsErmittlungsleiter" Color="Color.Primary" Dense="true"
                             Label="@LeitungLabel" />
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Abbrechen">Abbrechen</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Speichern" Disabled="@(_agent is null)">Zuteilen</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public IReadOnlyList<string> AusschlussAgentIds { get; set; } = Array.Empty<string>();

    /// <summary>Wer den Klarnamen sehen darf (Führungsebene/Admin), darf auch danach suchen und sieht ihn in der Liste –
    /// sonst wäre die Suche ein Orakel auf das Geheimfeld. Vom Aufrufer über <c>User.DarfKlarnameSehen()</c> setzen.</summary>
    [Parameter] public bool DarfKlarname { get; set; }

    /// <summary>Nur die Führung darf das Ermittlungsleiter-Flag vergeben; steuert die Sichtbarkeit der Checkbox.
    /// Vom Aufrufer über <c>User.IstFuehrung()</c> setzen.</summary>
    [Parameter] public bool DarfErmittlungsleiterSetzen { get; set; }

    /// <summary>Beschriftung der Leitungs-Checkbox (modulabhängig, z. B. „Als Fallführer zuteilen").</summary>
    [Parameter] public string LeitungLabel { get; set; } = "Als Ermittlungsleiter zuteilen";

    private Agent? _agent;
    private bool _alsErmittlungsleiter;
    private List<Agent> _alle = new();

    protected override async Task OnInitializedAsync()
    {
        var alle = await AgentService.GetAlleAsync();
        _alle = alle.Where(a => a.Status == AgentStatus.Aktiv && !AusschlussAgentIds.Contains(a.Id)).ToList();
    }

    private Task<IEnumerable<Agent>> SucheAgenten(string value, CancellationToken token)
    {
        var suche = value.Trim();
        IEnumerable<Agent> treffer = string.IsNullOrWhiteSpace(value)
            ? _alle
            : _alle.Where(a => a.Codename.Contains(suche, StringComparison.OrdinalIgnoreCase)
                            || (DarfKlarname && (a.Klarname ?? string.Empty).Contains(suche, StringComparison.OrdinalIgnoreCase)));
        return Task.FromResult(treffer);
    }

    private void Speichern()
    {
        if (_agent is null)
        {
            return;
        }
        MudDialog.Close(DialogResult.Ok(new Wahl(_agent.Id, DarfErmittlungsleiterSetzen && _alsErmittlungsleiter)));
    }

    private void Abbrechen() => MudDialog.Cancel();

    /// <summary>Auswahl des Dialogs: zuzuteilender Agent + ob er gleich als Ermittlungsleiter markiert werden soll.</summary>
    public record Wahl(string AgentId, bool AlsErmittlungsleiter);

    /// <summary>Zeigt den Dialog; liefert die Auswahl oder null bei Abbruch.</summary>
    public static async Task<Wahl?> ZeigenAsync(IDialogService dialog, IReadOnlyList<string> ausschlussAgentIds,
        bool darfKlarname, bool darfErmittlungsleiterSetzen, string? leitungLabel = null)
    {
        var parameters = new DialogParameters<AgentZuteilenDialog>
        {
            { x => x.AusschlussAgentIds, ausschlussAgentIds },
            { x => x.DarfKlarname, darfKlarname },
            { x => x.DarfErmittlungsleiterSetzen, darfErmittlungsleiterSetzen },
        };
        if (leitungLabel is not null)
        {
            parameters.Add(x => x.LeitungLabel, leitungLabel);
        }
        var referenz = await dialog.ShowAsync<AgentZuteilenDialog>("Agent zuteilen", parameters);
        var ergebnis = await referenz.Result;
        return ergebnis is { Canceled: false, Data: Wahl wahl } ? wahl : null;
    }
}
