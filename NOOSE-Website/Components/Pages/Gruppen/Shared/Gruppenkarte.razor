@* Identitäts-/Steckkarte der Personengruppe: Name, Einstufung, Erfassungsfortschritt x/y. *@
<MudPaper Class="pa-4" Elevation="2">
    <MudStack Spacing="3">
        <MudStack AlignItems="AlignItems.Center" Class="py-2">
            <MudAvatar Color="Color.Primary" Rounded="true" Style="height:120px;width:120px;">
                <MudIcon Icon="@Icons.Material.Filled.Diversity3" Style="font-size:3rem;" />
            </MudAvatar>
        </MudStack>

        <div>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudText Typo="Typo.h5">@Gruppe.Name</MudText>
                @if (Gruppe.IstVerschlusssache)
                {
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Warning" Size="Size.Small" Title="Verschlusssache" />
                }
            </MudStack>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">@Gruppe.Aktenzeichen</MudText>
        </div>

        <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Filled"
                 Icon="@ArtIcon(Gruppe.Art)" Class="align-self-start">
            @GruppenArtAnzeige.Name(Gruppe.Art)
        </MudChip>

        <EinstufungBadge Wert="Gruppe.Einstufung" />

        <ErmittlungsleiterAnzeige Namen="Ermittlungsleiter" />

        <MudDivider />

        @* Erfassungsfortschritt x/y *@
        <div>
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudText Typo="Typo.subtitle2">Erfassungsfortschritt</MudText>
                <MudText Typo="Typo.body2">@Fortschritt.Erfasst / @(Fortschritt.Geschaetzt?.ToString() ?? "?")</MudText>
            </MudStack>
            @if (Fortschritt.Geschaetzt is > 0)
            {
                <MudProgressLinear Color="Color.Primary" Value="@Prozent()" Class="mt-1" Rounded="true" Size="Size.Medium" />
            }
            else
            {
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    @Fortschritt.Erfasst Mitglied(er) erfasst – keine geschätzte Gesamtgröße hinterlegt.
                </MudText>
            }
        </div>

        <MudDivider />

        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <AktualitaetsAmpel AktenTyp="@nameof(Personengruppe)" ReferenzdatumUtc="@(Gruppe.GeaendertAm ?? Gruppe.ErstelltAm)" />
            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                Zuletzt aktualisiert: @((Gruppe.GeaendertAm ?? Gruppe.ErstelltAm).ToLocalTime().ToString("dd.MM.yyyy HH:mm"))
            </MudText>
        </MudStack>
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired] public Personengruppe Gruppe { get; set; } = default!;
    [Parameter, EditorRequired] public PersonengruppeFortschritt Fortschritt { get; set; } = default!;

    /// <summary>Codenames der Ermittlungsleiter (für die prominente Anzeige links in der Steckkarte).</summary>
    [Parameter] public IReadOnlyList<string> Ermittlungsleiter { get; set; } = Array.Empty<string>();

    private double Prozent()
    {
        if (Fortschritt.Geschaetzt is not > 0)
        {
            return 0;
        }
        var p = (double)Fortschritt.Erfasst / Fortschritt.Geschaetzt.Value * 100;
        return Math.Clamp(p, 0, 100);
    }

    private static string ArtIcon(GruppenArt art) => art switch
    {
        GruppenArt.Persoenlichkeit => Icons.Material.Filled.Star,
        GruppenArt.PersonOfInterest => Icons.Material.Filled.PersonSearch,
        _ => Icons.Material.Filled.Diversity3,
    };
}
