@page "/personengruppen"
@inject IPersonengruppeService GruppeService
@inject IAktualitaetService Aktualitaet
@inject NavigationManager Nav

<PageTitle>Personengruppen · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
    <MudIcon Icon="@Icons.Material.Filled.Diversity3" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h4">Personengruppen</MudText>
    <MudSpacer />
    <AuthorizeView Policy="@Policies.Fuehrung">
        <MudButton Href="/personengruppen/papierkorb" Variant="Variant.Text" Color="Color.Default" StartIcon="@Icons.Material.Filled.Delete">Papierkorb</MudButton>
    </AuthorizeView>
    <AuthorizeView Policy="@Policies.Schreibrecht" Context="schreib">
        <MudButton Href="/personengruppen/neu" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add">Neue Gruppe</MudButton>
    </AuthorizeView>
</MudStack>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-6">
    Lose Zusammenschlüsse von Personen mit Einstufung, zugeteilten Agents und Erfassungsfortschritt.
</MudText>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudDataGrid T="GruppeZeile" Items="_zeilen" Hover="true" Filterable="false" SortMode="SortMode.Multiple"
                 QuickFilter="Filter" Elevation="2" RowClick="@(args => Oeffnen(args.Item))" Dense="true">
        <ToolBarContent>
            <MudTextField @bind-Value="_suche" Placeholder="Suchen (Name, Aktenzeichen)…" Immediate="true"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" />
            <MudSpacer />
            <MudSelect T="GruppenArt?" @bind-Value="_artFilter" Clearable="true" Dense="true" Margin="Margin.Dense"
                       Label="Kategorie" Variant="Variant.Outlined" Class="mt-0" Style="max-width:240px;">
                @foreach (var a in GruppenArtAnzeige.Alle)
                {
                    <MudSelectItem T="GruppenArt?" Value="@((GruppenArt?)a)">@GruppenArtAnzeige.Name(a)</MudSelectItem>
                }
            </MudSelect>
        </ToolBarContent>
        <Columns>
            <PropertyColumn Property="x => x.Aktenzeichen" Title="Aktenzeichen" />
            <TemplateColumn Sortable="true" Title="Name" SortBy="x => x.Name">
                <CellTemplate>
                    @* Echter Link: Mittelklick/Strg+Klick öffnet die Akte im neuen Tab; tastatur-/screenreader-erreichbar. *@
                    <MudLink Href="@($"/personengruppen/{context.Item.Id}")" @onclick:stopPropagation="true">@context.Item.Name</MudLink>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Sortable="true" Title="Kategorie" SortBy="x => x.Art">
                <CellTemplate>
                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined">@GruppenArtAnzeige.Name(context.Item.Art)</MudChip>
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.Mitgliederzahl" Title="Mitglieder" />
            <TemplateColumn Sortable="true" Title="Einstufung" SortBy="x => x.Einstufung">
                <CellTemplate>
                    <EinstufungBadge Wert="context.Item.Einstufung" />
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Sortable="true" Title="Verschluss" SortBy="x => x.IstVerschlusssache">
                <CellTemplate>
                    @if (context.Item.IstVerschlusssache)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Warning" Size="Size.Small" Title="Verschlusssache" />
                    }
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Sortable="true" Title="Aktualität" SortBy="x => x.Stufe">
                <CellTemplate>
                    <AktualitaetsAmpel Stufe="context.Item.Stufe" ReferenzdatumUtc="context.Item.AktualisiertUtc" />
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.Aktualisiert" Title="Zuletzt" Format="dd.MM.yyyy HH:mm" />
        </Columns>
        <NoRecordsContent>
            <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-6">
                <MudIcon Icon="@Icons.Material.Filled.Diversity3" Color="Color.Default" Size="Size.Large" />
                <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Personengruppen – lege die erste an.</MudText>
                <AuthorizeView Policy="@Policies.Schreibrecht" Context="schreib">
                    <MudButton Href="/personengruppen/neu" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add">Neue Gruppe</MudButton>
                </AuthorizeView>
            </MudStack>
        </NoRecordsContent>
        <PagerContent>
            <MudDataGridPager T="GruppeZeile" />
        </PagerContent>
    </MudDataGrid>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _laden = true;
    private string _suche = string.Empty;
    private GruppenArt? _artFilter;
    private List<GruppeZeile> _zeilen = new();

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthStateTask).User;
        var darfVsLesen = user.DarfVerschlusssacheLesen();
        var gruppen = await GruppeService.GetListeAsync(darfVsLesen);
        var (warnungTage, veraltetTage) = await Aktualitaet.GetSchwelleAsync(nameof(Personengruppe));
        var jetzt = DateTime.UtcNow;
        _zeilen = gruppen.Select(g =>
        {
            var referenzUtc = g.GeaendertAm ?? g.ErstelltAm;
            return new GruppeZeile
            {
                Id = g.Id,
                Aktenzeichen = g.Aktenzeichen,
                Name = g.Name,
                // Wie in der Detailansicht zählen: nur Mitglieder mit sichtbarer (nicht gelöschter, ggf. nicht-VS) Akte.
                Mitgliederzahl = g.Mitglieder.Count(m => m.Person is not null && (darfVsLesen || !m.Person.IstVerschlusssache)),
                Art = g.Art,
                Einstufung = g.Einstufung,
                IstVerschlusssache = g.IstVerschlusssache,
                AktualisiertUtc = referenzUtc,
                Aktualisiert = referenzUtc.ToLocalTime(),
                Stufe = AktualitaetsBewertung.Stufe(warnungTage, veraltetTage, referenzUtc, jetzt),
            };
        }).ToList();
        _laden = false;
    }

    private bool Filter(GruppeZeile z)
    {
        if (_artFilter is not null && z.Art != _artFilter)
        {
            return false;
        }
        if (string.IsNullOrWhiteSpace(_suche))
        {
            return true;
        }
        var s = _suche.Trim();
        return z.Name.Contains(s, StringComparison.OrdinalIgnoreCase)
            || z.Aktenzeichen.Contains(s, StringComparison.OrdinalIgnoreCase);
    }

    private void Oeffnen(GruppeZeile z) => Nav.NavigateTo($"/personengruppen/{z.Id}");

    private sealed class GruppeZeile
    {
        public string Id { get; set; } = string.Empty;
        public string Aktenzeichen { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public int Mitgliederzahl { get; set; }
        public GruppenArt Art { get; set; }
        public Einstufung Einstufung { get; set; }
        public bool IstVerschlusssache { get; set; }
        public DateTime AktualisiertUtc { get; set; }
        public DateTime Aktualisiert { get; set; }
        public AktualitaetsStufe Stufe { get; set; }
    }
}
