@page "/organigramm"
@inject IOrganigrammService OrganigrammService

<PageTitle>Organigramm · NOOSE</PageTitle>

<MudStack Spacing="4">
    @* ---- Kopfzeile ---- *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="flex-wrap">
        <MudIcon Icon="@Icons.Material.Filled.AccountTree" Color="Color.Primary" Size="Size.Large" />
        <div>
            <MudText Typo="Typo.h5">Organigramm</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">NOOSE-Struktur: Dienstgrade, TRU und Taskforce-Besetzung.</MudText>
        </div>
    </MudStack>

    @if (_laden)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_daten is not null)
    {
        @* ---- Dienstgrad-Hierarchie als Org-Chart (Director oben → Junior unten) ---- *@
        @if (_daten.Raenge.Count == 0)
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary">Keine aktiven Agenten erfasst.</MudText>
        }
        else
        {
            <div class="org-scroll">
                <div class="org">
                    <div class="org-node org-root">N.O.O.S.E.</div>
                    @foreach (var rang in _daten.Raenge)
                    {
                        <div class="org-link"></div>
                        <div class="org-tier">
                            <div class="org-node org-rank">
                                @DienstgradAnzeige.Name(rang.Dienstgrad)<span class="org-count">@rang.Agenten.Count</span>
                            </div>
                            <ul class="org-leaves">
                                @foreach (var a in rang.Agenten)
                                {
                                    <li class="org-leaf">
                                        <a class="org-card" href="@($"/personal/{a.Id}")">
                                            <span class="org-card-avatar">@Initialen(a.Codename)</span>
                                            <span class="org-card-name">@(string.IsNullOrWhiteSpace(a.Codename) ? "Unbenannt" : a.Codename)</span>
                                            @if (_darfKlarname && !string.IsNullOrWhiteSpace(a.Klarname))
                                            {
                                                <span class="org-card-sub">@a.Klarname</span>
                                            }
                                            @if (a.IstTRU)
                                            {
                                                <span class="org-card-badge">TRU</span>
                                            }
                                        </a>
                                    </li>
                                }
                            </ul>
                        </div>
                    }
                </div>
            </div>
        }

        @* ---- TRU ---- *@
        @if (_daten.Tru.Count > 0)
        {
            <MudDivider />
            <MudStack Spacing="2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="flex-wrap">
                    <MudIcon Icon="@Icons.Material.Filled.LocalPolice" Color="Color.Warning" />
                    <MudText Typo="Typo.h6">Tactical Response Unit (TRU)</MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">· @_daten.Tru.Count rangübergreifend</MudText>
                </MudStack>
                <MudGrid Spacing="2">
                    @foreach (var a in _daten.Tru)
                    {
                        <MudItem xs="12" sm="6" md="4" lg="3">
                            <AgentKachel Agent="a" DarfKlarname="_darfKlarname" />
                        </MudItem>
                    }
                </MudGrid>
            </MudStack>
        }

        @* ---- Taskforce-Besetzung ---- *@
        <MudDivider />
        <MudStack Spacing="2">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Groups2" Color="Color.Primary" />
                <MudText Typo="Typo.h6">Taskforces</MudText>
            </MudStack>
            @if (_daten.Taskforces.Count == 0)
            {
                <MudText Typo="Typo.body2" Class="mud-text-secondary">@_taskforceLeerText</MudText>
            }
            else
            {
                @foreach (var tf in _daten.Taskforces)
                {
                    <MudPaper Class="pa-3" Elevation="1">
                        <MudStack Spacing="2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="flex-wrap">
                                <MudLink Href="@($"/taskforces/{tf.Taskforce.Id}")" Typo="Typo.subtitle1"><b>@tf.Taskforce.Name</b></MudLink>
                                <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Text">@tf.Taskforce.Aktenzeichen</MudChip>
                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">@TaskforceGeltungsbereichAnzeige.Name(tf.Taskforce.Geltungsbereich)</MudChip>
                            </MudStack>
                            @if (tf.Mitglieder.Count == 0)
                            {
                                <MudText Typo="Typo.body2" Class="mud-text-secondary">Keine Mitglieder.</MudText>
                            }
                            else
                            {
                                <MudGrid Spacing="2">
                                    @foreach (var m in tf.Mitglieder)
                                    {
                                        <MudItem xs="12" sm="6" md="4" lg="3">
                                            <AgentKachel Agent="m.Agent!" DarfKlarname="_darfKlarname"
                                                         RolleText="@(TaskforceRolleAnzeige.IstLeitung(m.Rolle) ? TaskforceRolleAnzeige.Name(m.Rolle) : null)"
                                                         IstLeitung="@TaskforceRolleAnzeige.IstLeitung(m.Rolle)" />
                                        </MudItem>
                                    }
                                </MudGrid>
                            }
                        </MudStack>
                    </MudPaper>
                }
            }
        </MudStack>
    }
</MudStack>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _laden = true;
    private bool _darfKlarname;
    private OrganigrammDaten? _daten;
    private string _taskforceLeerText = "Keine genehmigten Taskforces vorhanden.";

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthStateTask).User;
        _darfKlarname = user.DarfKlarnameSehen();
        _taskforceLeerText = user.IstFuehrung()
            ? "Keine genehmigten Taskforces vorhanden."
            : "Dir sind keine genehmigten Taskforces zugeteilt.";
        _daten = await OrganigrammService.GetAsync(user);
        _laden = false;
    }

    // Initialen aus dem Codename (1–2 Buchstaben) für den Avatar.
    private static string Initialen(string? codename)
    {
        if (string.IsNullOrWhiteSpace(codename))
        {
            return "?";
        }
        var teile = codename.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (teile.Length >= 2)
        {
            return string.Concat(char.ToUpperInvariant(teile[0][0]), char.ToUpperInvariant(teile[1][0]));
        }
        var wort = teile[0];
        return wort.Length >= 2 ? wort[..2].ToUpperInvariant() : wort[..1].ToUpperInvariant();
    }
}
