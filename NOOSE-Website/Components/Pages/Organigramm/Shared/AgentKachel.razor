@* Wiederverwendbare Agenten-Karte für das Organigramm: Initialen-Avatar, Codename (Link zur Personalakte),
   Klarname nur für Führung, optional Dienstgrad-/Rollen-Chip + TRU-/HRB-Badge. *@

<MudPaper Class="pa-3" Elevation="1" Style="height:100%;">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
        <MudAvatar Color="@(IstLeitung ? Color.Warning : Color.Primary)" Rounded="true">@Initialen(Agent.Codename)</MudAvatar>
        <MudStack Spacing="0" Style="min-width:0;">
            <MudLink Href="@($"/personal/{Agent.Id}")" Typo="Typo.body1">
                <b>@(string.IsNullOrWhiteSpace(Agent.Codename) ? "Unbenannter Agent" : Agent.Codename)</b>
            </MudLink>
            @if (DarfKlarname && !string.IsNullOrWhiteSpace(Agent.Klarname))
            {
                <MudText Typo="Typo.caption" Class="mud-text-secondary">@Agent.Klarname</MudText>
            }
            <MudStack Row="true" Spacing="1" Class="flex-wrap mt-1" AlignItems="AlignItems.Center">
                @if (ZeigeDienstgrad)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined"
                             Icon="@Icons.Material.Filled.MilitaryTech">@DienstgradAnzeige.Name(Agent.Dienstgrad)</MudChip>
                }
                @if (Agent.IstTRU)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">TRU</MudChip>
                }
                @if (Agent.IstHRB)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">HRB</MudChip>
                }
                @if (!string.IsNullOrWhiteSpace(RolleText))
                {
                    <MudChip T="string" Size="Size.Small" Color="@(IstLeitung ? Color.Warning : Color.Default)"
                             Variant="@(IstLeitung ? Variant.Filled : Variant.Outlined)"
                             Icon="@(IstLeitung ? Icons.Material.Filled.LocalPolice : null)">@RolleText</MudChip>
                }
            </MudStack>
        </MudStack>
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired] public Agent Agent { get; set; } = default!;
    [Parameter] public bool DarfKlarname { get; set; }
    [Parameter] public bool ZeigeDienstgrad { get; set; } = true;
    [Parameter] public string? RolleText { get; set; }
    [Parameter] public bool IstLeitung { get; set; }

    // Initialen aus dem Codename (1–2 Buchstaben) – ohne externe Avatar-Bilder.
    private static string Initialen(string? codename)
    {
        if (string.IsNullOrWhiteSpace(codename))
        {
            return "?";
        }
        var teile = codename.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (teile.Length >= 2)
        {
            return string.Concat(char.ToUpperInvariant(teile[0][0]), char.ToUpperInvariant(teile[1][0]));
        }
        var wort = teile[0];
        return wort.Length >= 2 ? wort[..2].ToUpperInvariant() : wort[..1].ToUpperInvariant();
    }
}
