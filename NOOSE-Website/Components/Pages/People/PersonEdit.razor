@page "/personen/{Id}/bearbeiten"
@inject IPersonService PersonService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Akte bearbeiten · NOOSE</PageTitle>

@if (_load)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_input is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
        Akte nicht gefunden oder nicht zugänglich.
    </MudAlert>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="@($"/personen/{Id}")" aria-label="Zurück" />
        <MudIcon Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Large" />
        <MudText Typo="Typo.h4">Akte bearbeiten</MudText>
    </MudStack>

    <MudForm @ref="_form">
        <MudGrid>
            <MudItem xs="12" md="8">
                <MudTextField @bind-Value="_input.Name" Label="Name" Required="true" RequiredError="Name ist erforderlich"
                              Variant="Variant.Outlined" AutoFocus="true" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudSelect T="LifeStatus" @bind-Value="_input.LifeStatus" Label="Lebensstatus" Variant="Variant.Outlined">
                    @foreach (var s in LifeStatusDisplay.All)
                    {
                        <MudSelectItem Value="s">@LifeStatusDisplay.Name(s)</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_input.Description" Label="Beschreibung" Lines="3" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" md="6" Class="d-flex flex-column justify-center">
                <MudSwitch T="bool" @bind-Value="_input.IsClassified" Color="Color.Warning" Label="Verschlusssache (nur Führung sichtbar)" />
                @if (_input.IsClassified && !_isLeadership)
                {
                    <MudText Typo="Typo.caption" Color="Color.Warning">
                        Achtung: Du verlierst als Nicht-Führung nach dem Speichern selbst den Zugriff auf diese Akte.
                    </MudText>
                }
            </MudItem>
        </MudGrid>
        <MudText Typo="Typo.caption" Class="mud-text-secondary">
            Hinweis: Die Einstufung wird in der Akte unter „Einstufung" geändert (mit Verlauf und Rang-Prüfung).
        </MudText>

        <MudDivider Class="my-4" />
        <MudText Typo="Typo.h6" Class="mb-2">Steckbrief</MudText>
        <ProfileForm Input="_input" />
    </MudForm>

    <MudStack Row="true" Spacing="2" Class="mt-4">
        <AuthorizeView Policy="@Policies.WriteAccess">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveAsync" Disabled="_saves">Speichern</MudButton>
        </AuthorizeView>
        <MudButton Variant="Variant.Text" Href="@($"/personen/{Id}")">Abbrechen</MudButton>
    </MudStack>
}

@code {
    [Parameter] public string Id { get; set; } = default!;
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private MudForm _form = default!;
    private PersonInput? _input;
    private ClaimsPrincipal _user = default!;
    private bool _isLeadership;
    private bool _load = true;
    private bool _saves;
    private string? _loadedId;

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        _isLeadership = _user.IsLeadership();
    }

    // Diese Seite wird bei /personen/{A}/bearbeiten → /personen/{B}/bearbeiten WIEDERVERWENDET (gleiche Komponente);
    // OnInitializedAsync läuft dann NICHT erneut. Daher das id-abhängige Laden hier mit Guard – sonst bliebe das alte
    // Formular stehen. Das kurze _laden=true mountet das Formular frisch.
    protected override async Task OnParametersSetAsync()
    {
        if (_loadedId == Id)
        {
            return;
        }
        _loadedId = Id;
        _load = true;
        _input = null;
        var p = await PersonService.GetDetailAsync(Id, _user.MayClassifiedRead());
        if (p is not null)
        {
            _input = new PersonInput
            {
                Name = p.Name,
                Description = p.Description,
                // Effektiven Status vorbefüllen: eine Person, deren 20-Min-Tot-Fenster abgelaufen ist, gilt
                // als „Lebend" – so startet eine harmlose Bearbeitung kein neues Tot-Fenster.
                LifeStatus = LifeStatusLogic.Effective(p.LifeStatus, p.DeadUntil, DateTime.UtcNow),
                Classification = p.Classification,
                IsClassified = p.IsClassified,
                Aliases = p.Aliases.Select(a => new AliasInput { AliasName = a.AliasName }).ToList(),
                PhoneNumbers = p.PhoneNumbers.Select(t => new PhoneInput { Number = t.Number, Designation = t.Designation }).ToList(),
                Vehicles = p.Vehicles.Select(f => new VehicleInput { Designation = f.Designation, LicensePlate = f.LicensePlate }).ToList(),
                Locations = p.Locations.Select(o => new LocationInput { Text = o.Text, Note = o.Note }).ToList(),
                Weapons = p.Weapons.Select(w => new WeaponInput { Text = w.Text }).ToList(),
            };
        }
        _load = false;
    }

    private async Task SaveAsync()
    {
        if (_input is null)
        {
            return;
        }
        await _form.ValidateAsync();
        if (!_form.IsValid)
        {
            return;
        }

        _saves = true;
        try
        {
            await PersonService.RefreshAsync(Id, _input, _user);
            Snackbar.Add("Änderungen gespeichert.", Severity.Success);
            Nav.NavigateTo($"/personen/{Id}");
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
            _saves = false;
        }
    }
}
