@* Druckansicht der Personenakte (Phase 7): rendert die komplette Akte als sauber strukturiertes
   Dokument (Stammdaten, Steckbrief, Zugehörigkeiten, Beziehungen, Doks, Observationen,
   Einstufungs-Verlauf, Verknüpfungen, Vermerke) – ohne Tabs/Navigation. Öffnet sich aus der
   Akte heraus in einem neuen Tab und startet den Browser-Druckdialog automatisch
   („Als PDF speichern" = PDF-Export). *@
@page "/personen/{Id}/druck"
@layout PrintLayout
@inject IPersonService PersonService
@inject IPersonDocService DocService
@inject IObservationService ObservationService
@inject IRelationService RelationService
@inject ILinkService LinkService
@inject ICommentService CommentService
@inject IAccessLogService AccessLog
@inject IJSRuntime JS

<PageTitle>@(_person is null ? "Druckansicht" : $"Personenakte {_person.CaseNumber}") · NOOSE</PageTitle>

@if (_load)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_person is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">Diese Akte existiert nicht (mehr) oder ist nicht sichtbar.</MudAlert>
}
else
{
    <div class="no-print druck-aktionen">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Print" OnClick="Print">
            Drucken / als PDF speichern
        </MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Default" StartIcon="@Icons.Material.Filled.ArrowBack"
                   Href="@($"/personen/{Id}")">Zurück zur Akte</MudButton>
    </div>

    <div class="druck-dokument">
        @* ---- Dokumentkopf ---- *@
        <header class="druck-kopf">
            <div class="druck-behoerde">N.O.O.S.E. · National Office of Security Enforcement</div>
            <h1>Personenakte @_person.CaseNumber</h1>
            <div class="druck-meta">
                Gedruckt am @DateTime.Now.ToString("dd.MM.yyyy HH:mm")
                @if (!string.IsNullOrWhiteSpace(_printBy))
                {
                    <text> · von @_printBy</text>
                }
                @if (_person.IsClassified)
                {
                    <span class="druck-vs">VERSCHLUSSSACHE – NUR FÜR DIE FÜHRUNG</span>
                }
            </div>
        </header>

        @* ---- Stammdaten ---- *@
        <section>
            <h2>Stammdaten</h2>
            <table class="druck-felder">
                <tbody>
                    <tr><th>Name</th><td>@_person.Name</td></tr>
                    <tr><th>Aktenzeichen</th><td>@_person.CaseNumber</td></tr>
                    <tr><th>Lebensstatus</th><td>@LifeStatusDisplay.Name(LifeStatusLogic.Effective(_person.LifeStatus, _person.DeadUntil, DateTime.UtcNow))</td></tr>
                    <tr><th>Einstufung</th><td>@ClassificationDisplay.Name(_person.Classification)</td></tr>
                    @if (!string.IsNullOrWhiteSpace(_person.Description))
                    {
                        <tr><th>Beschreibung</th><td class="druck-mehrzeilig">@_person.Description</td></tr>
                    }
                    <tr><th>Zuletzt aktualisiert</th><td>@((_person.ModifiedAt ?? _person.CreatedAt).ToLocalTime().ToString("dd.MM.yyyy HH:mm"))</td></tr>
                </tbody>
            </table>
        </section>

        @* ---- Steckbrief ---- *@
        @if (_person.Aliases.Count > 0 || _person.PhoneNumbers.Count > 0 || _person.Vehicles.Count > 0
             || _person.Locations.Count > 0 || _person.Weapons.Count > 0)
        {
            <section>
                <h2>Steckbrief</h2>
                <table class="druck-felder">
                    <tbody>
                        @if (_person.Aliases.Count > 0)
                        {
                            <tr><th>Aliase</th><td>@string.Join(", ", _person.Aliases.Select(a => a.AliasName))</td></tr>
                        }
                        @if (_person.PhoneNumbers.Count > 0)
                        {
                            <tr><th>Telefonnummern</th><td>@string.Join(", ", _person.PhoneNumbers.Select(t => string.IsNullOrWhiteSpace(t.Designation) ? t.Number : $"{t.Number} ({t.Designation})"))</td></tr>
                        }
                        @if (_person.Vehicles.Count > 0)
                        {
                            <tr><th>Fahrzeuge</th><td>@string.Join(", ", _person.Vehicles.Select(f => string.IsNullOrWhiteSpace(f.LicensePlate) ? f.Designation : $"{f.Designation} ({f.LicensePlate})"))</td></tr>
                        }
                        @if (_person.Locations.Count > 0)
                        {
                            <tr><th>Orte</th><td>@string.Join("; ", _person.Locations.Select(o => string.IsNullOrWhiteSpace(o.Note) ? o.Text : $"{o.Text} – {o.Note}"))</td></tr>
                        }
                        @if (_person.Weapons.Count > 0)
                        {
                            <tr><th>Waffen</th><td>@string.Join(", ", _person.Weapons.Select(w => w.Text))</td></tr>
                        }
                    </tbody>
                </table>
            </section>
        }

        @* ---- Zugehörigkeiten ---- *@
        @if (_affiliations.Count > 0)
        {
            <section>
                <h2>Zugehörigkeiten</h2>
                <table class="druck-tabelle">
                    <thead>
                        <tr><th>Organisation</th><th>Aktenzeichen</th><th>Rolle</th><th>Beitritt</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var z in _affiliations)
                        {
                            <tr>
                                <td>@z.Name@(z.IsLead ? " (Leitung)" : "")</td>
                                <td>@z.CaseNumber</td>
                                <td>@(string.IsNullOrWhiteSpace(z.Role) ? "—" : z.Role)</td>
                                <td>@z.JoinedAt.ToLocalTime().ToString("dd.MM.yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>
        }

        @* ---- Beziehungen ---- *@
        @if (_relations.Count > 0)
        {
            <section>
                <h2>Beziehungen</h2>
                <table class="druck-tabelle">
                    <thead>
                        <tr><th>Person</th><th>Aktenzeichen</th><th>Art</th><th>Notiz</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var b in _relations)
                        {
                            <tr>
                                <td>@b.OtherPersonName</td>
                                <td>@b.OtherPersonCaseNumber</td>
                                <td>@RelationTypeDisplay.Name(b.Type)</td>
                                <td>@(string.IsNullOrWhiteSpace(b.Note) ? "—" : b.Note)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>
        }

        @* ---- Doks (Verhöre/Maßnahmen) ---- *@
        @if (_docs.Count > 0)
        {
            <section>
                <h2>Doks (Verhöre &amp; Maßnahmen)</h2>
                @foreach (var d in _docs)
                {
                    <div class="druck-eintrag">
                        <div class="druck-eintrag-kopf">
                            <b>@d.Doc.Timestamp.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</b>
                            · Beendigung: @MeasureOutcomeDisplay.Name(d.Doc.Outcome)
                            @if (d.Doc.TruthSerum)
                            {
                                <text> · Wahrheitsserum</text>
                            }
                            @if (d.Doc.MemoryDeleted)
                            {
                                <text> · Gedächtnis gelöscht</text>
                            }
                        </div>
                        <table class="druck-felder">
                            <tbody>
                                @if (!string.IsNullOrWhiteSpace(d.OrgName) || !string.IsNullOrWhiteSpace(d.Doc.Faction))
                                {
                                    <tr><th>Fraktion/Gruppe</th><td>@(d.OrgName ?? d.Doc.Faction)</td></tr>
                                }
                                @if (!string.IsNullOrWhiteSpace(d.Doc.Reason))
                                {
                                    <tr><th>Grund</th><td class="druck-mehrzeilig">@d.Doc.Reason</td></tr>
                                }
                                @if (!string.IsNullOrWhiteSpace(d.Doc.ReceivedInformation))
                                {
                                    <tr><th>Erhaltene Informationen</th><td class="druck-mehrzeilig">@d.Doc.ReceivedInformation</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </section>
        }

        @* ---- Observationen ---- *@
        @if (_observations.Count > 0)
        {
            <section>
                <h2>Observationen</h2>
                @foreach (var o in _observations)
                {
                    <div class="druck-eintrag">
                        <div class="druck-eintrag-kopf">
                            <b>@o.Obs.Start.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</b>
                            @if (o.Obs.End is { } end)
                            {
                                <text> – @end.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</text>
                            }
                            @if (!string.IsNullOrWhiteSpace(o.AgentCodename))
                            {
                                <text> · Agent: @o.AgentCodename</text>
                            }
                        </div>
                        <table class="druck-felder">
                            <tbody>
                                @if (!string.IsNullOrWhiteSpace(o.Obs.Location))
                                {
                                    <tr><th>Ort</th><td>@o.Obs.Location</td></tr>
                                }
                                @if (!string.IsNullOrWhiteSpace(o.Obs.Sighting))
                                {
                                    <tr><th>Beobachtung</th><td class="druck-mehrzeilig">@o.Obs.Sighting</td></tr>
                                }
                                @if (!string.IsNullOrWhiteSpace(o.Obs.Result))
                                {
                                    <tr><th>Ergebnis</th><td class="druck-mehrzeilig">@o.Obs.Result</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </section>
        }

        @* ---- Einstufungs-Verlauf ---- *@
        @if (_classificationHistory.Count > 0)
        {
            <section>
                <h2>Einstufungs-Verlauf</h2>
                <table class="druck-tabelle">
                    <thead>
                        <tr><th>Zeitpunkt</th><th>Einstufung</th><th>Begründung</th><th>Agent</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var e in _classificationHistory)
                        {
                            <tr>
                                <td>@e.Timestamp.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                <td>@ClassificationDisplay.Name(e.Value)</td>
                                <td>@(string.IsNullOrWhiteSpace(e.Justification) ? "—" : e.Justification)</td>
                                <td>@(e.AgentName ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>
        }

        @* ---- Verknüpfte Akten ---- *@
        @if (_links.Count > 0)
        {
            <section>
                <h2>Verknüpfte Akten</h2>
                <table class="druck-tabelle">
                    <thead>
                        <tr><th>Typ</th><th>Akte</th><th>Bezeichnung</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var v in _links)
                        {
                            <tr>
                                <td>@v.OtherType</td>
                                <td>@v.OtherDesignation</td>
                                <td>@(string.IsNullOrWhiteSpace(v.Label) ? "—" : v.Label)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>
        }

        @* ---- Vermerke/Kommentare ---- *@
        @if (_comments.Count > 0)
        {
            <section>
                <h2>Vermerke</h2>
                @foreach (var k in _comments)
                {
                    <div class="druck-eintrag">
                        <div class="druck-eintrag-kopf">
                            <b>@k.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</b>
                            @if (!string.IsNullOrWhiteSpace(k.AuthorName))
                            {
                                <text> · @k.AuthorName</text>
                            }
                        </div>
                        <div class="druck-mehrzeilig">@k.Text</div>
                    </div>
                }
            </section>
        }

        <footer class="druck-fusszeile">
            NOOSE-interne Akte · @_person.CaseNumber · Weitergabe nur nach Freigabe durch die Führung.
        </footer>
    </div>
}

@code {
    [Parameter] public string Id { get; set; } = string.Empty;
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _load = true;
    private bool _printTriggered;
    private string? _printBy;
    private Person? _person;
    private List<PersonAffiliation> _affiliations = new();
    private List<RelationDisplay> _relations = new();
    private List<PersonDocDisplay> _docs = new();
    private List<ObservationDisplay> _observations = new();
    private List<ClassificationHistory> _classificationHistory = new();
    private List<LinkDisplay> _links = new();
    private List<Comment> _comments = new();

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthStateTask).User;
        var isLeadership = user.IsLeadership();
        _printBy = user.GetCodename();

        _person = await PersonService.GetDetailAsync(Id, user.MayClassifiedRead());
        if (_person is not null)
        {
            _affiliations = await PersonService.GetAffiliationsAsync(Id, isLeadership);
            _relations = await RelationService.GetForPersonAsync(Id, isLeadership);
            _docs = await DocService.GetForPersonAsync(Id, isLeadership);
            _observations = await ObservationService.GetForPersonAsync(Id, isLeadership);
            _classificationHistory = await PersonService.GetClassificationHistoryAsync(Id, isLeadership);
            _links = await LinkService.GetForRecordAsync(nameof(Person), Id, isLeadership, user.GetAgentId());
            _comments = await CommentService.GetForRecordAsync(nameof(Person), Id, isLeadership);

            // Druckansicht zählt als Akteneinsicht.
            await AccessLog.LogViewAsync(nameof(Person), Id);
        }
        _load = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Druckdialog automatisch öffnen, sobald das Dokument fertig gerendert ist (nur einmal).
        // Bricht der Nutzer ab, bleibt die Vorschau mit dem Drucken-Knopf stehen.
        if (!_load && _person is not null && !_printTriggered)
        {
            _printTriggered = true;
            try
            {
                await JS.InvokeVoidAsync("window.print");
            }
            catch (JSException)
            {
                // Manche Browser blockieren programmatisches Drucken – der Knopf bleibt als Fallback.
            }
        }
    }

    private async Task Print() => await JS.InvokeVoidAsync("window.print");
}
