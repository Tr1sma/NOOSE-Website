@* Zeigt einen benannten Steckbrief-Abschnitt als Label + Chips. Ist die Liste leer, wird nichts gerendert. *@
@{
    var list = Values.Where(w => !string.IsNullOrWhiteSpace(w)).ToList();
}
@if (list.Count > 0)
{
    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="flex-wrap">
        <MudText Typo="Typo.body2" Class="mud-text-secondary" Style="min-width:120px;">@Title</MudText>
        <MudStack Row="true" Spacing="1" Class="flex-wrap">
            @foreach (var w in list)
            {
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">@w</MudChip>
            }
        </MudStack>
    </MudStack>
}

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter, EditorRequired] public IEnumerable<string> Values { get; set; } = Enumerable.Empty<string>();
}
