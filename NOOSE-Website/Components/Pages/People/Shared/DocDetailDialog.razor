@* Detailansicht eines Personen-Doks (lesen + bearbeiten). Öffnet sich per Klick aus der Übersicht und der Akte. *@
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject IPersonDocService DocService
@inject IFactionService FactionService
@inject IPersonGroupService GroupService
@inject IPersonService PersonService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">
            <MudText Typo="Typo.body2">
                <b>@Doc.Timestamp.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</b> · @MeasureOutcomeDisplay.Name(Doc.Outcome)
            </MudText>
            @if (Doc.Person is not null)
            {
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    Person: @Doc.Person.Name (@Doc.Person.CaseNumber)
                </MudText>
            }
            @if (!string.IsNullOrWhiteSpace(Doc.Reason))
            {
                <MudText Typo="Typo.body2"><b>Grund:</b> @Doc.Reason</MudText>
            }
            @* Verknüpfte Fraktion/Gruppe als Link; sonst Freitext-Fallback. *@
            @if (OrgRoute is not null)
            {
                <MudText Typo="Typo.body2"><b>Fraktion:</b> <MudLink Href="@OrgRoute">@OrgName</MudLink></MudText>
            }
            else if (!string.IsNullOrWhiteSpace(Doc.Faction))
            {
                <MudText Typo="Typo.body2"><b>Fraktion:</b> @Doc.Faction</MudText>
            }
            @if (!string.IsNullOrWhiteSpace(Doc.ReceivedInformation))
            {
                <div>
                    <MudText Typo="Typo.subtitle2">Erhaltene Informationen</MudText>
                    <MudText Typo="Typo.body2">@Doc.ReceivedInformation</MudText>
                </div>
            }
            @if (Doc.TruthSerum || Doc.MemoryDeleted)
            {
                <MudStack Row="true" Spacing="2" Class="flex-wrap">
                    @if (Doc.TruthSerum)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Icon="@Icons.Material.Filled.Science">Wahrheitsserum</MudChip>
                    }
                    @if (Doc.MemoryDeleted)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Icon="@Icons.Material.Filled.Psychology">Gedächtnisverlust</MudChip>
                    }
                </MudStack>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton StartIcon="@Icons.Material.Filled.Edit" OnClick="EditAsync">Bearbeiten</MudButton>
        @if (ShowToRecord)
        {
            <MudButton StartIcon="@Icons.Material.Filled.Badge" OnClick="ToRecord">Zur Akte</MudButton>
        }
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Close">Schließen</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter, EditorRequired] public PersonDoc Doc { get; set; } = default!;
    [Parameter, EditorRequired] public ClaimsPrincipal User { get; set; } = default!;
    [Parameter] public bool ShowToRecord { get; set; } = true;

    @* Aufgelöste Anzeigedaten der verknüpften Org (Verschlusssache-gefiltert); null → Freitext-Fallback. *@
    [Parameter] public string? OrgName { get; set; }
    [Parameter] public string? OrgCaseNumber { get; set; }
    [Parameter] public string? OrgRoute { get; set; }

    private void Close() => MudDialog.Close();

    private void ToRecord()
    {
        MudDialog.Close();
        Nav.NavigateTo($"/personen/{Doc.PersonId}");
    }

    private async Task EditAsync()
    {
        var input = await DocDialog.ShowToEditAsync(DialogService, Doc, User.IsLeadership(), OrgName, OrgCaseNumber);
        if (input is null)
        {
            return;
        }
        try
        {
            await DocService.RefreshAsync(Doc.Id, input, User);
            Snackbar.Add("Dok aktualisiert.", Severity.Success);
            // Optional: Person zugleich als Mitglied der verknüpften Akte eintragen.
            await DocMembership.EnterAsync(FactionService, GroupService, PersonService, Snackbar, Doc.PersonId, input, User);
            // Detail schließen und dem Aufrufer „geändert" melden → Liste neu laden.
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    /// <summary>
    /// Zeigt die Dok-Detailansicht an und liefert true, wenn das Dok darin bearbeitet wurde
    /// (damit der Aufrufer seine Liste neu laden kann).
    /// </summary>
    public static async Task<bool> ShowAsync(IDialogService dialog, PersonDocDisplay display, ClaimsPrincipal user, bool showToRecord = true)
    {
        var doc = display.Doc;
        var parameters = new DialogParameters<DocDetailDialog>
        {
            { x => x.Doc, doc },
            { x => x.User, user },
            { x => x.ShowToRecord, showToRecord },
            { x => x.OrgName, display.OrgName },
            { x => x.OrgCaseNumber, display.OrgCaseNumber },
            { x => x.OrgRoute, display.OrgRoute },
        };
        var title = doc.Person is not null ? $"Dok · {doc.Person.Name}" : "Dok";
        var reference = await dialog.ShowAsync<DocDetailDialog>(title, parameters);
        var result = await reference.Result;
        return result is { Canceled: false, Data: bool modified } && modified;
    }
}
