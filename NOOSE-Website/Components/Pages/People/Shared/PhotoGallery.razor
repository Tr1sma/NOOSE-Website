@* Person photo gallery: multi-upload, protected display, delete. *@
@inject IPersonService PersonService
@inject IFileStorageService FileStorage
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IPartnerShareService PartnerShareService

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudText Typo="Typo.subtitle1">Foto-Galerie (@Photos.Count)</MudText>
        @if (_mayWrite)
        {
            <MudFileUpload T="IReadOnlyList<IBrowserFile>" FilesChanged="UploadAsync" Accept="image/*" MaximumFileCount="20">
                <CustomContent>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Upload"
                               OnClick="@context.OpenFilePickerAsync" Disabled="_load">
                        Fotos hochladen
                    </MudButton>
                </CustomContent>
                <SelectedTemplate />
            </MudFileUpload>
        }
    </MudStack>

    @if (_load)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }

    @if (Photos.Count == 0)
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Fotos.</MudText>
    }
    else
    {
        <div class="d-flex flex-wrap gap-3">
            @foreach (var photo in Photos)
            {
                <MudPaper Class="pa-1" Elevation="2" Style="width:160px;">
                    <div @onclick="@(() => OpenLightboxAsync(photo))" style="cursor:pointer;">
                        <MudImage Src="@($"/dateien/personen/foto/{photo.Id}")" Alt="@photo.OriginalName"
                                  Height="120" Width="150" ObjectFit="ObjectFit.Cover" Class="rounded"
                                  Style="@($"object-position:{photo.FocalPointX}% {photo.FocalPointY}%")" />
                    </div>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="px-1">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="max-width:110px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                            @photo.OriginalName
                        </MudText>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="0">
                            <PartnerChildShareButton Show="_canShareChildren" ChildType="@nameof(PersonPhoto)" ChildId="@photo.Id" />
                            @if (_mayWrite)
                            {
                                <MudIconButton Icon="@Icons.Material.Outlined.CropFree" Color="Color.Default" Size="Size.Small"
                                               OnClick="@(() => EditFocalPointAsync(photo))" aria-label="Bildausschnitt festlegen" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                               OnClick="@(() => RemoveAsync(photo))" aria-label="Foto löschen" />
                            }
                        </MudStack>
                    </MudStack>
                </MudPaper>
            }
        </div>
    }
</MudStack>

@code {
    [Parameter, EditorRequired] public string PersonId { get; set; } = default!;
    [Parameter, EditorRequired] public List<PersonPhoto> Photos { get; set; } = default!;
    [Parameter, EditorRequired] public ClaimsPrincipal User { get; set; } = default!;
    [Parameter] public EventCallback Changed { get; set; }

    private bool _load;
    private bool _mayWrite;
    private bool _canShareChildren;

    protected override async Task OnInitializedAsync()
    {
        _mayWrite = User.MayWrite();
        // leadership: per-item release only matters when the record is shell-released
        if (User.IsLeadership())
        {
            _canShareChildren = (await PartnerShareService.GetForRecordAsync(nameof(Person), PersonId))
                .Any(s => s.Released && !s.IncludesChildren);
        }
    }

    private async Task OpenLightboxAsync(PersonPhoto photo)
    {
        var images = Photos
            .Select(p => new ImageLightbox.LightboxImage($"/dateien/personen/foto/{p.Id}", p.OriginalName))
            .ToList();
        var start = Photos.IndexOf(photo);
        await ImageLightbox.ShowAsync(DialogService, images, Math.Max(0, start));
    }

    private async Task UploadAsync(IReadOnlyList<IBrowserFile> files)
    {
        _load = true;
        try
        {
            var uploaded = 0;
            foreach (var file in files)
            {
                if (!FileStorage.IsAllowedType(file.ContentType))
                {
                    Snackbar.Add($"'{file.Name}': Dateityp nicht erlaubt (nur Bilder).", Severity.Warning);
                    continue;
                }
                if (file.Size > FileStorage.MaxBytes)
                {
                    Snackbar.Add($"'{file.Name}': zu groß (max. {FileStorage.MaxBytes / (1024 * 1024)} MB).", Severity.Warning);
                    continue;
                }
                await using var stream = file.OpenReadStream(FileStorage.MaxBytes);
                await PersonService.PhotoAddAsync(PersonId, stream, file.Name, file.ContentType, file.Size, User);
                uploaded++;
            }

            if (uploaded > 0)
            {
                Snackbar.Add(uploaded == 1 ? "Foto hochgeladen." : $"{uploaded} Fotos hochgeladen.", Severity.Success);
                await Changed.InvokeAsync();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Upload fehlgeschlagen: {ex.Message}", Severity.Error);
        }
        finally
        {
            _load = false;
        }
    }

    private async Task EditFocalPointAsync(PersonPhoto photo)
    {
        var saved = await FocalPointDialog.ShowAsync(DialogService,
            $"/dateien/personen/foto/{photo.Id}", photo.Id, photo.FocalPointX, photo.FocalPointY);
        if (saved)
        {
            await Changed.InvokeAsync();
        }
    }

    private async Task RemoveAsync(PersonPhoto photo)
    {
        var ok = await ConfirmDialog.ShowAsync(DialogService, "Foto löschen?",
            $"'{photo.OriginalName}' wird dauerhaft gelöscht.");
        if (!ok)
        {
            return;
        }
        try
        {
            await PersonService.PhotoRemoveAsync(photo.Id, User);
            Snackbar.Add("Foto gelöscht.", Severity.Success);
            await Changed.InvokeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
