@* Detailansicht einer Observation (lesen + bearbeiten). Öffnet sich per Klick aus der Übersicht und der Akte. *@
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject IObservationService ObservationService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">
            <MudText Typo="Typo.body2">
                <b>@Obs.Start.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</b>
                @if (Obs.End is { } end)
                {
                    <span> – @end.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                }
            </MudText>
            @if (Obs.Person is not null)
            {
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    Person: @Obs.Person.Name (@Obs.Person.CaseNumber)
                </MudText>
            }
            @if (!string.IsNullOrWhiteSpace(AgentCodename))
            {
                <MudText Typo="Typo.body2"><b>Beobachtender Agent:</b> @AgentCodename</MudText>
            }
            @if (!string.IsNullOrWhiteSpace(Obs.Location))
            {
                <MudText Typo="Typo.body2"><b>Ort:</b> @Obs.Location</MudText>
            }
            @* Verknüpfte Fraktion/Gruppe als Link. *@
            @if (OrgRoute is not null)
            {
                <MudText Typo="Typo.body2"><b>Verknüpft:</b> <MudLink Href="@OrgRoute">@OrgName</MudLink></MudText>
            }
            @if (!string.IsNullOrWhiteSpace(Obs.Sighting))
            {
                <div>
                    <MudText Typo="Typo.subtitle2">Beobachtung</MudText>
                    <MudText Typo="Typo.body2">@Obs.Sighting</MudText>
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(Obs.Result))
            {
                <div>
                    <MudText Typo="Typo.subtitle2">Ergebnis / Folgerung</MudText>
                    <MudText Typo="Typo.body2">@Obs.Result</MudText>
                </div>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton StartIcon="@Icons.Material.Filled.Edit" OnClick="EditAsync">Bearbeiten</MudButton>
        @if (ShowToRecord)
        {
            <MudButton StartIcon="@Icons.Material.Filled.Badge" OnClick="ToRecord">Zur Akte</MudButton>
        }
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Close">Schließen</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter, EditorRequired] public Observation Obs { get; set; } = default!;
    [Parameter, EditorRequired] public ClaimsPrincipal User { get; set; } = default!;
    [Parameter] public bool ShowToRecord { get; set; } = true;

    [Parameter] public string? AgentCodename { get; set; }

    @* Aufgelöste Anzeigedaten der verknüpften Org (Verschlusssache-gefiltert); null → keine Verknüpfung. *@
    [Parameter] public string? OrgName { get; set; }
    [Parameter] public string? OrgCaseNumber { get; set; }
    [Parameter] public string? OrgRoute { get; set; }

    private void Close() => MudDialog.Close();

    private void ToRecord()
    {
        MudDialog.Close();
        Nav.NavigateTo($"/personen/{Obs.PersonId}");
    }

    private async Task EditAsync()
    {
        var input = await ObservationDialog.ShowToEditAsync(DialogService, Obs, User.IsLeadership(), OrgName, OrgCaseNumber);
        if (input is null)
        {
            return;
        }
        try
        {
            await ObservationService.RefreshAsync(Obs.Id, input, User);
            Snackbar.Add("Observation aktualisiert.", Severity.Success);
            // Detail schließen und dem Aufrufer „geändert" melden → Liste neu laden.
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    /// <summary>
    /// Zeigt die Observations-Detailansicht an und liefert true, wenn der Eintrag darin bearbeitet wurde
    /// (damit der Aufrufer seine Liste neu laden kann).
    /// </summary>
    public static async Task<bool> ShowAsync(IDialogService dialog, ObservationDisplay display, ClaimsPrincipal user, bool showToRecord = true)
    {
        var obs = display.Obs;
        var parameters = new DialogParameters<ObservationDetailDialog>
        {
            { x => x.Obs, obs },
            { x => x.User, user },
            { x => x.ShowToRecord, showToRecord },
            { x => x.AgentCodename, display.AgentCodename },
            { x => x.OrgName, display.OrgName },
            { x => x.OrgCaseNumber, display.OrgCaseNumber },
            { x => x.OrgRoute, display.OrgRoute },
        };
        var title = obs.Person is not null ? $"Observation · {obs.Person.Name}" : "Observation";
        var reference = await dialog.ShowAsync<ObservationDetailDialog>(title, parameters);
        var result = await reference.Result;
        return result is { Canceled: false, Data: bool modified } && modified;
    }
}
