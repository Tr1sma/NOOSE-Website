@page "/personen"
@inject IPersonService PersonService
@inject IRecencyService Recency
@inject IDialogService DialogService
@inject NavigationManager Nav

<PageTitle>Personen-Akten · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
    <MudIcon Icon="@Icons.Material.Filled.Badge" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h4">Personen-Akten</MudText>
    <MudSpacer />
    <AuthorizeView Policy="@Policies.Leadership">
        <MudButton Variant="Variant.Text" Color="Color.Default" StartIcon="@Icons.Material.Filled.CallMerge"
                   OnClick="MergeAsync">Zusammenführen</MudButton>
        <MudButton Href="/personen/papierkorb" Variant="Variant.Text" Color="Color.Default" StartIcon="@Icons.Material.Filled.Delete">Papierkorb</MudButton>
    </AuthorizeView>
    <AuthorizeView Policy="@Policies.WriteAccess" Context="schreib">
        <MudButton Href="/personen/neu" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd">Neue Person</MudButton>
    </AuthorizeView>
</MudStack>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-6">
    Zentrale Personenakten des Nachrichtendienstes. Klicke eine Akte an, um Steckbrief, Doks,
    Einstufung, Fotos und Historie zu sehen.
</MudText>

@if (_load)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudDataGrid T="PersonRow" Items="_rows" Hover="true" Filterable="false" SortMode="SortMode.Multiple"
                 QuickFilter="Filter" Elevation="2" RowClick="@(args => Open(args.Item))" Dense="true">
        <ToolBarContent>
            <MudTextField @bind-Value="_search" Placeholder="Suchen (Name, Aktenzeichen, Alias)…" Immediate="true"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" />
        </ToolBarContent>
        <Columns>
            <PropertyColumn Property="x => x.CaseNumber" Title="Aktenzeichen" />
            <TemplateColumn Sortable="true" Title="Name" SortBy="x => x.Name">
                <CellTemplate>
                    @* Real link: middle/ctrl-click opens record in new tab; keyboard/screenreader-reachable. *@
                    <MudLink Href="@($"/personen/{context.Item.Id}")" @onclick:stopPropagation="true">@context.Item.Name</MudLink>
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.Aliases" Title="Aliase" />
            <TemplateColumn Sortable="true" Title="Lebensstatus" SortBy="x => x.EffectiveLifeStatus">
                <CellTemplate>
                    <LifeStatusBadge Status="context.Item.LifeStatusRaw" DeadUntil="context.Item.DeadUntil" />
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Sortable="true" Title="Einstufung" SortBy="x => x.Classification">
                <CellTemplate>
                    <ClassificationBadge Value="context.Item.Classification" />
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Sortable="true" Title="Gefährdung" SortBy="x => x.ThreatScore ?? -1" InitialDirection="SortDirection.Descending">
                <CellTemplate>
                    @if (context.Item.ThreatScore is { } gscore)
                    {
                        <MudTooltip Text="@($"Bedrohungs-Score {gscore}/100" + (context.Item.ThreatConfidence is { } gk ? $" · Konfidenz {gk} %" : ""))">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="@DangerColour(context.Item.Hazard)">
                                @HazardLevelLogic.Name(context.Item.Hazard)
                            </MudChip>
                        </MudTooltip>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">—</MudText>
                    }
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Sortable="true" Title="Verschluss" SortBy="x => x.IsClassified">
                <CellTemplate>
                    @if (context.Item.IsClassified)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Lock">@DocumentClassificationDisplay.ChipLabel(context.Item.SecrecyLevel)</MudChip>
                    }
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Sortable="true" Title="Aktualität" SortBy="x => x.Level">
                <CellTemplate>
                    <RecencyIndicator Level="context.Item.Level" ReferenceDateUtc="context.Item.RefreshedUtc" />
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.Refreshed" Title="Zuletzt" Format="dd.MM.yyyy HH:mm" />
        </Columns>
        <NoRecordsContent>
            <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-6">
                <MudIcon Icon="@Icons.Material.Filled.Badge" Color="Color.Default" Size="Size.Large" />
                <AuthorizeView Policy="@Policies.PartnerView" Context="partnerEmpty">
                    <Authorized>
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">Für Ihre Behörde wurde noch keine Personen-Akte freigegeben.</MudText>
                    </Authorized>
                    <NotAuthorized>
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Personen-Akten – lege die erste an.</MudText>
                    </NotAuthorized>
                </AuthorizeView>
                <AuthorizeView Policy="@Policies.WriteAccess" Context="schreib">
                    <MudButton Href="/personen/neu" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd">Neue Person</MudButton>
                </AuthorizeView>
            </MudStack>
        </NoRecordsContent>
        <PagerContent>
            <MudDataGridPager T="PersonRow" />
        </PagerContent>
    </MudDataGrid>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _load = true;
    private string _search = string.Empty;
    private List<PersonRow> _rows = new();

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthStateTask).User;
        var people = await PersonService.GetListAsync(ViewerScope.From(user));
        var settings = await Recency.GetSettingsAsync(nameof(Person));
        var now = DateTime.UtcNow;
        _rows = people.Select(p =>
        {
            var referenceUtc = p.ModifiedAt ?? p.CreatedAt;
            return new PersonRow
            {
                Id = p.Id,
                CaseNumber = p.CaseNumber,
                Name = p.Name,
                Aliases = string.Join(", ", p.Aliases.Select(a => a.AliasName)),
                LifeStatusRaw = p.LifeStatus,
                DeadUntil = p.DeadUntil,
                EffectiveLifeStatus = LifeStatusDisplay.Name(LifeStatusLogic.Effective(p.LifeStatus, p.DeadUntil, now)),
                Classification = p.Classification,
                ThreatScore = p.ThreatScore,
                ThreatConfidence = p.ThreatConfidence,
                Hazard = HazardLevelLogic.From(p.ThreatScore),
                IsClassified = p.IsClassified,
                SecrecyLevel = p.SecrecyLevel,
                RefreshedUtc = referenceUtc,
                Refreshed = referenceUtc.ToLocalTime(),
                Level = settings.AgingDisabled || p.AgingDisabled ? RecencyLevel.Fresh : RecencyAssessment.Level(settings.WarningDays, settings.StaleDays, referenceUtc, now),
            };
        }).ToList();
        _load = false;
    }

    private bool Filter(PersonRow z)
    {
        if (string.IsNullOrWhiteSpace(_search))
        {
            return true;
        }
        var s = _search.Trim();
        return z.Name.Contains(s, StringComparison.OrdinalIgnoreCase)
            || z.CaseNumber.Contains(s, StringComparison.OrdinalIgnoreCase)
            || z.Aliases.Contains(s, StringComparison.OrdinalIgnoreCase);
    }

    private void Open(PersonRow z) => Nav.NavigateTo($"/personen/{z.Id}");

    private static Color DangerColour(HazardLevel s) => s switch
    {
        HazardLevel.Critical => Color.Error,
        HazardLevel.High => Color.Error,
        HazardLevel.Medium => Color.Warning,
        HazardLevel.Low => Color.Info,
        _ => Color.Default,
    };

    private async Task MergeAsync()
    {
        var targetId = await PersonMergeDialog.ShowAsync(DialogService);
        if (targetId is not null)
        {
            Nav.NavigateTo($"/personen/{targetId}");
        }
    }

    private sealed class PersonRow
    {
        public string Id { get; set; } = string.Empty;
        public string CaseNumber { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string Aliases { get; set; } = string.Empty;
        public LifeStatus LifeStatusRaw { get; set; }
        public DateTime? DeadUntil { get; set; }
        public string EffectiveLifeStatus { get; set; } = string.Empty;
        public Classification Classification { get; set; }
        public int? ThreatScore { get; set; }
        public int? ThreatConfidence { get; set; }
        public HazardLevel Hazard { get; set; }
        public bool IsClassified { get; set; }
        public DocumentClassification SecrecyLevel { get; set; }
        public DateTime RefreshedUtc { get; set; }
        public DateTime Refreshed { get; set; }
        public RecencyLevel Level { get; set; }
    }
}
