@* Zentrale Dokumenten-Bibliothek: durchsuchbare Liste aller (für den Aufrufer sichtbaren) Dokumente. *@
@page "/dokumente"
@inject IDokumentService DokumentService
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Dokumente · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
    <MudIcon Icon="@Icons.Material.Filled.MenuBook" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h4">Dokumente</MudText>
    <MudSpacer />
    <AuthorizeView Policy="@Policies.Schreibrecht" Context="schreib">
        <MudButton Href="/dokumente/neu" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add">Neues Dokument</MudButton>
    </AuthorizeView>
</MudStack>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-6">
    Zentrale Bibliothek formatierter Dokumente und hochgeladener Dateien (Formulare, SOPs, Vorlagen).
    Ein Dokument kann an beliebig viele Akten als Quelle angehängt werden. Verschlusssachen sind nur
    der Führung sichtbar.
</MudText>

<MudTabs Elevation="0" Rounded="true" Class="mb-3">
<MudTabPanel Icon="@Icons.Material.Filled.Article" Text="Dokumente">

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    @if (_angepinnt.Count > 0)
    {
        <MudPaper Class="pa-3 mb-4" Elevation="2">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-2">
                <MudIcon Icon="@Icons.Material.Filled.PushPin" Color="Color.Primary" Size="Size.Small" />
                <MudText Typo="Typo.subtitle2">Angepinnt</MudText>
            </MudStack>
            <MudStack Spacing="1">
                @foreach (var p in _angepinnt)
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Article" Color="Color.Default" Size="Size.Small" />
                        <MudLink Href="@($"/dokumente/{p.Id}")">@p.Titel</MudLink>
                        @if (!string.IsNullOrWhiteSpace(p.Kategorie))
                        {
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@p.Kategorie</MudText>
                        }
                        @if (p.IstVerschlusssache)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Warning" Size="Size.Small" Title="Verschlusssache" />
                        }
                        <MudSpacer />
                        @if (_istFuehrung)
                        {
                            <MudTooltip Text="Lösen">
                                <MudIconButton Icon="@Icons.Material.Filled.PushPin" Color="Color.Primary" Size="Size.Small"
                                               OnClick="() => PinSetzen(p, false)" aria-label="Anpinnen lösen" />
                            </MudTooltip>
                        }
                    </MudStack>
                }
            </MudStack>
        </MudPaper>
    }

    <MudDataGrid T="DokumentListeItem" Items="_zeilen" Hover="true" Filterable="false" SortMode="SortMode.Multiple"
                 QuickFilter="Filter" Elevation="2" RowClick="@(args => Oeffnen(args.Item))" Dense="true">
        <ToolBarContent>
            <MudTextField @bind-Value="_suche" Placeholder="Suchen (Titel, Kategorie)…" Immediate="true"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" />
        </ToolBarContent>
        <Columns>
            @if (_istFuehrung)
            {
                <TemplateColumn Title="" Sortable="false">
                    <CellTemplate>
                        @* span stoppt die Klick-Propagation, damit der Pin-Klick nicht zusätzlich die Zeile öffnet. *@
                        <span @onclick:stopPropagation="true">
                            <MudTooltip Text="Anpinnen">
                                <MudIconButton Icon="@Icons.Material.Outlined.PushPin" Color="Color.Default" Size="Size.Small"
                                               OnClick="@(() => PinSetzen(context.Item, true))"
                                               aria-label="Dokument anpinnen" />
                            </MudTooltip>
                        </span>
                    </CellTemplate>
                </TemplateColumn>
            }
            <TemplateColumn Title="Titel" SortBy="x => x.Titel">
                <CellTemplate>
                    @* Echter Link: Mittelklick/Strg+Klick öffnet im neuen Tab; tastatur-/screenreader-erreichbar. *@
                    <MudLink Href="@($"/dokumente/{context.Item.Id}")" @onclick:stopPropagation="true">@context.Item.Titel</MudLink>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Kategorie" SortBy="x => x.Kategorie">
                <CellTemplate>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">@(string.IsNullOrWhiteSpace(context.Item.Kategorie) ? "—" : context.Item.Kategorie)</MudText>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Verschluss" Sortable="false">
                <CellTemplate>
                    @if (context.Item.IstVerschlusssache)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Warning" Size="Size.Small" Title="Verschlusssache" />
                    }
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.Aktualisiert" Title="Zuletzt" Format="dd.MM.yyyy HH:mm" />
        </Columns>
        <NoRecordsContent>
            <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-6">
                <MudIcon Icon="@Icons.Material.Filled.MenuBook" Color="Color.Default" Size="Size.Large" />
                <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Dokumente – lege das erste an.</MudText>
                <AuthorizeView Policy="@Policies.Schreibrecht" Context="schreib">
                    <MudButton Href="/dokumente/neu" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add">Neues Dokument</MudButton>
                </AuthorizeView>
            </MudStack>
        </NoRecordsContent>
        <PagerContent>
            <MudDataGridPager T="DokumentListeItem" />
        </PagerContent>
    </MudDataGrid>
}

</MudTabPanel>
<MudTabPanel Icon="@Icons.Material.Filled.FolderOpen" Text="Dateien">
    @* Datei-Bibliothek (Phase 7): hochgeladene Formulare/SOPs/Vorlagen. *@
    <BibliothekPanel />
</MudTabPanel>
</MudTabs>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _laden = true;
    private bool _istFuehrung;
    private string _suche = string.Empty;
    private ClaimsPrincipal _user = default!;
    private List<DokumentListeItem> _zeilen = new();      // Nicht angepinnte – im Grid darunter.
    private List<DokumentListeItem> _angepinnt = new();   // Angepinnte – im Block oben.

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        _istFuehrung = _user.IstFuehrung();
        await LadenAsync();
    }

    private async Task LadenAsync()
    {
        var alle = await DokumentService.GetListeAsync(_user.DarfVerschlusssacheLesen());
        _angepinnt = alle.Where(d => d.Angepinnt).ToList();
        _zeilen = alle.Where(d => !d.Angepinnt).ToList();
        _laden = false;
    }

    private async Task PinSetzen(DokumentListeItem item, bool angepinnt)
    {
        try
        {
            await DokumentService.AnpinnenSetzenAsync(item.Id, angepinnt, _user);
            await LadenAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private bool Filter(DokumentListeItem z)
    {
        if (string.IsNullOrWhiteSpace(_suche))
        {
            return true;
        }
        var s = _suche.Trim();
        return z.Titel.Contains(s, StringComparison.OrdinalIgnoreCase)
            || (z.Kategorie?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false);
    }

    private void Oeffnen(DokumentListeItem z) => Nav.NavigateTo($"/dokumente/{z.Id}");
}
