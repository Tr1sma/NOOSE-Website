@* Volltext-WYSIWYG-Editor zum Erstellen/Bearbeiten eines Bibliotheks-Dokuments. Optional: aus einer
   Akte heraus gestartet (?entitaetTyp=…&entitaetId=…&attach=1) → das Dokument wird beim Speichern als
   Quelle an die Akte gehängt. Optional: Vorlage vorausgewählt (?vorlageId=…). *@
@page "/dokumente/neu"
@page "/dokumente/{Id}/bearbeiten"
@inject IDokumentService DokumentService
@inject IDokumentVorlageService VorlageService
@inject IPlatzhalterService Platzhalter
@inject IQuelleService QuelleService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>@(_bearbeiten ? "Dokument bearbeiten" : "Neues Dokument") · NOOSE</PageTitle>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_bearbeiten && !_gefunden)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">Dokument nicht gefunden oder nicht zugänglich.</MudAlert>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="Abbrechen" aria-label="Zurück" />
        <MudIcon Icon="@Icons.Material.Filled.Article" Color="Color.Primary" Size="Size.Large" />
        <MudText Typo="Typo.h4">@(_bearbeiten ? "Dokument bearbeiten" : "Neues Dokument")</MudText>
        <MudSpacer />
        <MudButton OnClick="Abbrechen" Variant="Variant.Text" Color="Color.Default">Abbrechen</MudButton>
        <MudButton OnClick="SpeichernAsync" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" Disabled="_speichert">Speichern</MudButton>
    </MudStack>

    <MudPaper Class="pa-4" Elevation="2">
        <MudStack Spacing="3">
            <MudGrid>
                <MudItem xs="12" md="7">
                    <MudTextField @bind-Value="_titel" Label="Titel" Variant="Variant.Outlined" Required="true"
                                  RequiredError="Titel ist erforderlich" AutoFocus="true" />
                </MudItem>
                <MudItem xs="12" md="5">
                    <MudTextField @bind-Value="_kategorie" Label="Kategorie (optional)" Variant="Variant.Outlined"
                                  Placeholder="z. B. SOP, Formular, Vermerk" />
                </MudItem>
            </MudGrid>

            @if (!_bearbeiten && _vorlagen.Count > 0)
            {
                <MudSelect T="string" Label="Vorlage übernehmen (optional)" Value="_gewaehlteVorlageId"
                           ValueChanged="VorlageAnwendenAsync" Variant="Variant.Outlined" Clearable="true"
                           Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Dvr"
                           HelperText="Füllt den Editor mit dem Vorlagen-Text vor und ersetzt Platzhalter aus dem Kontext.">
                    @foreach (var v in _vorlagen)
                    {
                        <MudSelectItem T="string" Value="@v.Id">@v.Name</MudSelectItem>
                    }
                </MudSelect>
            }

            @if (_istFuehrung)
            {
                <MudSwitch @bind-Value="_istVs" Color="Color.Warning" Label="Verschlusssache (nur für die Führung sichtbar)" />
            }

            <RichTextEditor @ref="_editor" Value="@_inhaltHtml" />
        </MudStack>
    </MudPaper>
}

@code {
    [Parameter] public string? Id { get; set; }
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private RichTextEditor _editor = default!;
    private ClaimsPrincipal _user = default!;

    private bool _laden = true;
    private bool _bearbeiten;
    private bool _gefunden;
    private bool _istFuehrung;
    private bool _speichert;

    private string _titel = string.Empty;
    private string? _kategorie;
    private bool _istVs;
    private string? _inhaltHtml;

    private List<DokumentVorlage> _vorlagen = new();
    private string? _gewaehlteVorlageId;

    // Akten-Kontext (aus der Quellen-Ansicht heraus gestartet).
    private string? _entitaetTyp;
    private string? _entitaetId;
    private bool _attach;

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        _istFuehrung = _user.IstFuehrung();
        _bearbeiten = !string.IsNullOrEmpty(Id);

        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(Nav.ToAbsoluteUri(Nav.Uri).Query);
        _entitaetTyp = query.TryGetValue("entitaetTyp", out var et) ? et.ToString() : null;
        _entitaetId = query.TryGetValue("entitaetId", out var ei) ? ei.ToString() : null;
        _attach = query.TryGetValue("attach", out var at) && at == "1";
        var vorlageId = query.TryGetValue("vorlageId", out var vid) ? vid.ToString() : null;

        if (_bearbeiten)
        {
            var dokument = await DokumentService.GetAsync(Id!, _istFuehrung);
            if (dokument is not null)
            {
                _gefunden = true;
                _titel = dokument.Titel;
                _kategorie = dokument.Kategorie;
                _istVs = dokument.IstVerschlusssache;
                _inhaltHtml = dokument.InhaltHtml;
            }
        }
        else
        {
            _vorlagen = await VorlageService.GetAktiveAsync();
            // Vorab gewählte Vorlage (Platzhalter direkt in den Initial-Inhalt einsetzen, da der Editor
            // den Wert nur beim Initialisieren liest).
            if (!string.IsNullOrEmpty(vorlageId))
            {
                var vorlage = _vorlagen.FirstOrDefault(v => v.Id == vorlageId);
                if (vorlage is not null)
                {
                    _gewaehlteVorlageId = vorlage.Id;
                    _inhaltHtml = await Platzhalter.AnwendenAsync(vorlage.InhaltHtml, _entitaetTyp, _entitaetId, _user);
                    if (string.IsNullOrWhiteSpace(_titel))
                    {
                        _titel = vorlage.Name;
                    }
                }
            }
        }

        _laden = false;
    }

    private async Task VorlageAnwendenAsync(string? vorlageId)
    {
        _gewaehlteVorlageId = vorlageId;
        if (string.IsNullOrEmpty(vorlageId))
        {
            return;
        }
        var vorlage = _vorlagen.FirstOrDefault(v => v.Id == vorlageId);
        if (vorlage is null)
        {
            return;
        }
        var html = await Platzhalter.AnwendenAsync(vorlage.InhaltHtml, _entitaetTyp, _entitaetId, _user);
        await _editor.SetHtmlAsync(html);
        if (string.IsNullOrWhiteSpace(_titel))
        {
            _titel = vorlage.Name;
        }
    }

    private async Task SpeichernAsync()
    {
        var titel = _titel?.Trim() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(titel))
        {
            Snackbar.Add("Bitte einen Titel angeben.", Severity.Warning);
            return;
        }

        _speichert = true;
        try
        {
            var html = await _editor.GetHtmlAsync();
            var eingabe = new DokumentEingabe
            {
                Titel = titel,
                Kategorie = _kategorie,
                InhaltHtml = html,
                IstVerschlusssache = _istVs,
            };

            string id;
            if (_bearbeiten)
            {
                await DokumentService.AktualisierenAsync(Id!, eingabe, _user);
                id = Id!;
            }
            else
            {
                var dokument = await DokumentService.ErstellenAsync(eingabe, _user);
                id = dokument.Id;

                // Beim Anlegen aus einer Akte heraus: direkt als Dokument-Quelle anhängen.
                if (HatAktenKontext())
                {
                    await QuelleService.ErstellenAsync(_entitaetTyp!, _entitaetId!, new QuelleEingabe
                    {
                        Typ = QuelleTyp.Dokument,
                        Titel = titel,
                        ZielTyp = nameof(Dokument),
                        ZielId = id,
                    }, _user);
                }
            }

            Snackbar.Add("Dokument gespeichert.", Severity.Success);
            Nav.NavigateTo(ZielNachSpeichern(id));
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _speichert = false;
        }
    }

    private void Abbrechen()
    {
        if (HatAktenKontext())
        {
            Nav.NavigateTo($"{SuchNavigation.Route(_entitaetTyp!, _entitaetId!)}?tab=quellen");
        }
        else if (_bearbeiten)
        {
            Nav.NavigateTo($"/dokumente/{Id}");
        }
        else
        {
            Nav.NavigateTo("/dokumente");
        }
    }

    private bool HatAktenKontext()
        => _attach && !string.IsNullOrWhiteSpace(_entitaetTyp) && !string.IsNullOrWhiteSpace(_entitaetId);

    private string ZielNachSpeichern(string id)
        => HatAktenKontext()
            ? $"{SuchNavigation.Route(_entitaetTyp!, _entitaetId!)}?tab=quellen"
            : $"/dokumente/{id}";
}
