@* Upload-/Bearbeiten-Dialog der Datei-Bibliothek (Phase 7). Beim Bearbeiten (Vorbelegung gesetzt)
   wird keine neue Datei gewählt, nur Titel/Kategorie/Verschlusssache geändert. *@
@inject IBibliothekStorageService Storage

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            @if (!IstBearbeitung)
            {
                <MudFileUpload T="IBrowserFile" FilesChanged="DateiGewaehlt">
                    <CustomContent>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.UploadFile"
                                   OnClick="@context.OpenFilePickerAsync">
                            @(_datei is null ? "Datei wählen…" : _datei.Name)
                        </MudButton>
                    </CustomContent>
                </MudFileUpload>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    Erlaubt: PDF, Bilder, Office-Dokumente, Text, ZIP – max. @(Storage.MaxBytes / (1024 * 1024)) MB.
                </MudText>
                @if (_warnung is not null)
                {
                    <MudAlert Severity="Severity.Warning" Dense="true">@_warnung</MudAlert>
                }
            }
            <MudTextField @bind-Value="_titel" Label="Titel" Variant="Variant.Outlined" Required="true"
                          RequiredError="Titel ist erforderlich" />
            <MudTextField @bind-Value="_kategorie" Label="Kategorie (optional)" Variant="Variant.Outlined"
                          Placeholder="z. B. Formular, SOP, Vorlage" />
            @if (DarfVerschluss)
            {
                <MudSwitch T="bool" @bind-Value="_istVerschlusssache" Color="Color.Warning"
                           Label="Verschlusssache (nur Führung sichtbar)" />
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Abbrechen">Abbrechen</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Speichern"
                   Disabled="@(string.IsNullOrWhiteSpace(_titel) || (!IstBearbeitung && _datei is null))">
            Speichern
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public bool DarfVerschluss { get; set; }
    [Parameter] public BibliothekDatei? Vorbelegung { get; set; }

    private bool IstBearbeitung => Vorbelegung is not null;

    private IBrowserFile? _datei;
    private string? _warnung;
    private string _titel = string.Empty;
    private string? _kategorie;
    private bool _istVerschlusssache;

    protected override void OnParametersSet()
    {
        if (Vorbelegung is not null && string.IsNullOrEmpty(_titel))
        {
            _titel = Vorbelegung.Titel;
            _kategorie = Vorbelegung.Kategorie;
            _istVerschlusssache = Vorbelegung.IstVerschlusssache;
        }
    }

    private void DateiGewaehlt(IBrowserFile? datei)
    {
        _warnung = null;
        if (datei is null)
        {
            _datei = null;
            return;
        }
        if (datei.Size > Storage.MaxBytes)
        {
            _warnung = $"Die Datei ist zu groß (max. {Storage.MaxBytes / (1024 * 1024)} MB).";
            return;
        }
        if (!Storage.IstErlaubterTyp(datei.ContentType))
        {
            _warnung = "Dieser Dateityp ist nicht erlaubt.";
            return;
        }
        _datei = datei;
        if (string.IsNullOrWhiteSpace(_titel))
        {
            // Titel aus dem Dateinamen vorbelegen (ohne Endung).
            _titel = Path.GetFileNameWithoutExtension(datei.Name);
        }
    }

    private void Abbrechen() => MudDialog.Cancel();

    private void Speichern()
        => MudDialog.Close(DialogResult.Ok(new Ergebnis(_titel.Trim(), _kategorie, _istVerschlusssache, _datei)));

    /// <summary>Dialog-Ergebnis: Metadaten + (nur beim Upload) die gewählte Datei.</summary>
    public sealed record Ergebnis(string Titel, string? Kategorie, bool IstVerschlusssache, IBrowserFile? Datei);

    /// <summary>Zeigt den Dialog; liefert das Ergebnis oder <c>null</c> bei Abbruch.</summary>
    public static async Task<Ergebnis?> ZeigenAsync(IDialogService dialog, string titel, bool darfVerschluss, BibliothekDatei? vorbelegung = null)
    {
        var parameters = new DialogParameters<BibliothekDateiDialog>
        {
            { x => x.DarfVerschluss, darfVerschluss },
            { x => x.Vorbelegung, vorbelegung },
        };
        var referenz = await dialog.ShowAsync<BibliothekDateiDialog>(titel, parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true });
        var ergebnis = await referenz.Result;
        return ergebnis is { Canceled: false, Data: Ergebnis e } ? e : null;
    }
}
