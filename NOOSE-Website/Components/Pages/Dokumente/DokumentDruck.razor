@* Druckansicht eines Bibliotheks-Dokuments (Phase 7): Metadaten + formatierter Inhalt. *@
@page "/dokumente/{Id}/druck"
@layout DruckLayout
@inject IDokumentService DokumentService
@inject IZugriffsLogService ZugriffsLog

<PageTitle>@(_dokument is null ? "Druckansicht" : _dokument.Titel) · NOOSE</PageTitle>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_dokument is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">Dieses Dokument existiert nicht (mehr) oder ist nicht sichtbar.</MudAlert>
}
else
{
    <DruckRahmen Titel="@_dokument.Titel" ZurueckHref="@($"/dokumente/{Id}")"
                 GedrucktVon="@_druckVon" IstVerschlusssache="_dokument.IstVerschlusssache"
                 Fusszeile="NOOSE-internes Dokument · Weitergabe nur nach Freigabe durch die Führung.">
        <section>
            <h2>Dokumentdaten</h2>
            <table class="druck-felder">
                <tbody>
                    @if (!string.IsNullOrWhiteSpace(_dokument.Kategorie))
                    {
                        <tr><th>Kategorie</th><td>@_dokument.Kategorie</td></tr>
                    }
                    <tr><th>Erstellt</th><td>@_dokument.ErstelltAm.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td></tr>
                    @if (_dokument.GeaendertAm is { } geaendert)
                    {
                        <tr><th>Geändert</th><td>@geaendert.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td></tr>
                    }
                </tbody>
            </table>
        </section>

        <section>
            <h2>Inhalt</h2>
            @* Serverseitig bereinigtes HTML (HtmlBereinigung) – sicher als MarkupString renderbar. *@
            <div class="dokument-html">@((MarkupString)_dokument.InhaltHtml)</div>
        </section>

        @if (_anhaenge.Count > 0)
        {
            <section>
                <h2>Angehängt an</h2>
                <table class="druck-tabelle">
                    <thead><tr><th>Typ</th><th>Akte</th></tr></thead>
                    <tbody>
                        @foreach (var a in _anhaenge)
                        {
                            <tr><td>@a.EntitaetTyp</td><td>@a.Anzeige</td></tr>
                        }
                    </tbody>
                </table>
            </section>
        }
    </DruckRahmen>
}

@code {
    [Parameter] public string Id { get; set; } = string.Empty;
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _laden = true;
    private string? _druckVon;
    private Dokument? _dokument;
    private List<DokumentAnhang> _anhaenge = new();

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthStateTask).User;
        var istFuehrung = user.IstFuehrung();
        _druckVon = user.GetCodename();

        _dokument = await DokumentService.GetAsync(Id, istFuehrung);
        if (_dokument is not null)
        {
            _anhaenge = await DokumentService.GetAnhaengeAsync(Id, istFuehrung, user.GetAgentId());
            await ZugriffsLog.LogAnsichtAsync(nameof(Dokument), Id);
        }
        _laden = false;
    }
}
