@page "/fraktionen/{Id}"
@inject IFactionService FactionService
@inject IAccessLogService AccessLog
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IPartnerVisibilityPolicyService PartnerPolicy

<PageTitle>@(_faction?.Name ?? "Fraktion") · NOOSE</PageTitle>

@if (_load)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_faction is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
        Fraktion nicht gefunden oder nicht zugänglich (ggf. Verschlusssache).
    </MudAlert>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/fraktionen" aria-label="Zurück" />
        <MudSpacer />
        <MudTooltip Text="Druckansicht – Akte drucken / als PDF speichern">
            <MudIconButton Icon="@Icons.Material.Filled.Print" Color="Color.Default"
                           Href="@($"/fraktionen/{Id}/druck")" Target="_blank"
                           aria-label="Druckansicht öffnen" />
        </MudTooltip>
        @if (!_isPartner)
        {
            <FollowButton EntityType="@nameof(Faction)" EntityId="@_faction.Id" User="_user" />
            <JobCreateButton EntityType="@nameof(Faction)" EntityId="@_faction.Id" />
        }
        <AuthorizeView Policy="@Policies.WriteAccess" Context="freigabe">
            <PartnerShareButton EntityType="@nameof(Faction)" EntityId="@_faction.Id" />
        </AuthorizeView>
        <AuthorizeView Policy="@Policies.WriteAccess" Context="schreib">
            <MudButton Href="@($"/fraktionen/{_faction.Id}/bearbeiten")" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit">Bearbeiten</MudButton>
        </AuthorizeView>
        <AuthorizeView Policy="@Policies.Leadership">
            <MudButton Color="Color.Error" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Delete" OnClick="DeleteAsync">Löschen</MudButton>
        </AuthorizeView>
    </MudStack>

    @if (!_isPartner)
    {
        <MudPaper Class="pa-2 mb-4" Elevation="1">
            <TagChips EntityType="@nameof(Faction)" EntityId="@_faction.Id" User="_user" />
        </MudPaper>
    }

    <MudGrid>
        <MudItem xs="12" md="4" lg="3">
            <div class="akte-steckkarte">
                <FactionCard Faction="_faction" MemberCount="_memberCount" InvestigationLead="_investigationLead"
                                TitleImagePhotoId="@(_faction.Photos.FirstOrDefault(x => x.IsTitleImage)?.Id)" />
            </div>
        </MudItem>

        <MudItem xs="12" md="8" lg="9">
            @if (_renderTabs.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    Für Ihren Zugang sind in dieser Akte keine Bereiche freigegeben.
                </MudAlert>
            }
            else
            {
            <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" TabPanelsClass="pa-4"
                     @bind-ActivePanelIndex="_activeTab"
                     @bind-ActivePanelIndex:after="@(() => TabUrlState.WriteAsync(JS, Nav, _renderTabs, _activeTab))">
                @if (TabOn("stammdaten"))
                {
                <MudTabPanel Text="Stammdaten" Icon="@Icons.Material.Filled.Info">
                    <MudStack Spacing="3">
                        <MudStack Row="true" Spacing="6" Class="flex-wrap">
                            @foreach (var (label, value) in MasterData())
                            {
                                <div>
                                    <MudText Typo="Typo.subtitle2">@label</MudText>
                                    <MudText Typo="Typo.body2" Class="mud-text-secondary">@value</MudText>
                                </div>
                            }
                        </MudStack>
                        @if (!string.IsNullOrWhiteSpace(_faction.Estate))
                        {
                            <div>
                                <MudText Typo="Typo.subtitle2">Anwesen</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary" Style="white-space:pre-line;">@_faction.Estate</MudText>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(_faction.Targets))
                        {
                            <div>
                                <MudText Typo="Typo.subtitle2">Ziele</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary">@_faction.Targets</MudText>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(_faction.Description))
                        {
                            <div>
                                <MudText Typo="Typo.subtitle2">Beschreibung</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary">@_faction.Description</MudText>
                            </div>
                        }
                        <ProfileList Title="Ränge" Values="@_faction.Ranks.OrderBy(r => r.Order).Select(r => r.Designation)" />
                    </MudStack>
                </MudTabPanel>
                }
                @if (TabOn("mitglieder"))
                {
                <MudTabPanel Text="Mitglieder" Icon="@Icons.Material.Filled.Groups">
                    <MembersPanel FactionId="@_faction.Id" User="_user" Ranks="_ranks" Changed="MembersModifiedAsync" />
                </MudTabPanel>
                }
                @* assigned NOOSE agents: internal only *@
                @if (!_isPartner)
                {
                <MudTabPanel Text="Zugeteilte Agents" Icon="@Icons.Material.Filled.ManageAccounts">
                    <FactionAgentsPanel FactionId="@_faction.Id" User="_user" Changed="InvestigationLeadRefreshAsync" />
                </MudTabPanel>
                }
                @if (TabOn("bestaende"))
                {
                <MudTabPanel Text="Bestände" Icon="@Icons.Material.Filled.Inventory2">
                    <MudStack Spacing="3">
                        <ProfileList Title="WeaponStock" Values="StockTexts(_faction.WeaponStock.Select(w => (w.Designation, w.Quantity)))" />
                        <ProfileList Title="Inventory" Values="StockTexts(_faction.Inventory.Select(l => (l.Designation, l.Quantity)))" />
                        <ProfileList Title="DrugRoutes" Values="StockTexts(_faction.DrugRoutes.Select(d => (d.Designation, d.Note)))" />
                    </MudStack>
                </MudTabPanel>
                }
                @if (TabOn("aktivitaeten"))
                {
                <MudTabPanel Text="Aktivitäten" Icon="@Icons.Material.Filled.Timeline">
                    <ActivitiesPanel FactionId="@_faction.Id" User="_user" />
                </MudTabPanel>
                }
                @* partner-safe child service *@
                @if (TabOn("fotos"))
                {
                <MudTabPanel Text="Fotos" Icon="@Icons.Material.Filled.PhotoLibrary">
                    <FactionPhotoGallery FactionId="@_faction.Id" User="_user" Changed="PhotosModifiedAsync" />
                </MudTabPanel>
                }
                @if (TabOn("einstufung"))
                {
                <MudTabPanel Text="Einstufung" Icon="@Icons.Material.Filled.Shield">
                    <ClassificationPanel Current="_faction.Classification" History="_classificationHistory" User="_user" OnSet="ClassificationSetAsync"
                                     EntityType="@nameof(Faction)" EntityId="@_faction.Id" TargetDesignation="@($"{_faction.Name} ({_faction.CaseNumber})")" />
                </MudTabPanel>
                }
                @if (TabOn("gefaehrdung"))
                {
                <MudTabPanel Text="Gefährdung" Icon="@Icons.Material.Filled.Warning">
                    <HazardPanel Score="_faction.ThreatScore" Confidence="_faction.ThreatConfidence"
                                      DetailJson="@_faction.ThreatDetailJson" />
                </MudTabPanel>
                }
                @if (TabOn("doks"))
                {
                <MudTabPanel Text="Doks" Icon="@Icons.Material.Filled.Description">
                    <OrgDocsPanel OrgType="@nameof(Faction)" OrgId="@_faction.Id" User="_user" />
                </MudTabPanel>
                }
                @* partner-safe child services *@
                @if (TabOn("beziehungen"))
                {
                <MudTabPanel Text="Beziehungen" Icon="@Icons.Material.Filled.Hub">
                    <OrgRelationsPanel EntityType="@nameof(Faction)" EntityId="@_faction.Id" User="_user" />
                </MudTabPanel>
                }
                @if (TabOn("quellen"))
                {
                <MudTabPanel Text="Quellen" Icon="@Icons.Material.Filled.AttachFile">
                    <SourcesPanel EntityType="@nameof(Faction)" EntityId="@_faction.Id" User="_user" />
                </MudTabPanel>
                }
                @if (TabOn("wiedervorlagen"))
                {
                <MudTabPanel Text="Wiedervorlagen" Icon="@Icons.Material.Filled.EventRepeat">
                    <FollowupPanel EntityType="@nameof(Faction)" EntityId="@_faction.Id" User="_user" />
                </MudTabPanel>
                }
                @if (TabOn("kommentare"))
                {
                <MudTabPanel Text="Kommentare" Icon="@Icons.Material.Filled.Comment">
                    <CommentPanel EntityType="@nameof(Faction)" EntityId="@_faction.Id" User="_user" />
                </MudTabPanel>
                }
                @if (TabOn("zusatzfelder"))
                {
                <MudTabPanel Text="Zusatzfelder" Icon="@Icons.Material.Filled.Tune">
                    <CustomFieldsPanel EntityType="@nameof(Faction)" EntityId="@_faction.Id" User="_user" />
                </MudTabPanel>
                }
                @* partner-safe: timeline filters cross-refs for partners *@
                @if (TabOn("historie"))
                {
                <MudTabPanel Text="Zeitstrahl" Icon="@Icons.Material.Filled.Timeline">
                    <TimelinePanel EntityType="@nameof(Faction)" EntityId="@_faction.Id" User="_user" @key="_historyKey" />
                </MudTabPanel>
                }
            </MudTabs>
            }
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public string Id { get; set; } = default!;
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _load = true;
    private bool _isPartner;
    private Faction? _faction;
    private int _memberCount;
    private List<string> _investigationLead = new();
    private List<string> _ranks = new();
    private List<ClassificationHistory> _classificationHistory = new();
    private ClaimsPrincipal _user = default!;
    private Guid _historyKey = Guid.NewGuid();
    private string? _loadedId;

    // order must match MudTabPanels
    private int _activeTab;
    private static readonly string[] _tabs =
    {
        "stammdaten", "mitglieder", "agents", "bestaende", "aktivitaeten", "fotos", "einstufung", "gefaehrdung", "doks",
        "beziehungen", "quellen", "wiedervorlagen", "kommentare", "zusatzfelder", "historie",
    };

    // partner tab gating: null = no restriction (internal/unconfigured/individually released)
    private IReadOnlySet<string>? _visibleTabs;
    private List<string> _renderTabs = new();
    private bool TabOn(string slug) => _visibleTabs is null || _visibleTabs.Contains(slug);
    private void RebuildRenderTabs() => _renderTabs = _tabs.Where(s => (s != "agents" || !_isPartner) && TabOn(s)).ToList();

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        _isPartner = _user.IsPartner();
    }

    // Page is reused across /fraktionen/{A}→{B}, so OnInitializedAsync won't re-run; react to Id change here.
    protected override async Task OnParametersSetAsync()
    {
        if (_loadedId == Id)
        {
            return;
        }
        _loadedId = Id;
        _load = true;
        _faction = null;
        await LoadAsync();
        _activeTab = TabUrlState.Read(Nav, _renderTabs);
        if (_faction is not null)
        {
            await AccessLog.LogViewAsync(nameof(Faction), _faction.Id);
        }
    }

    private async Task LoadAsync()
    {
        // Don't set _load=true on reload: remounting MudTabs would jump to the first tab.
        var scope = ViewerScope.From(_user);
        _faction = await FactionService.GetDetailAsync(Id, scope);
        if (_faction is not null)
        {
            _ranks = _faction.Ranks.OrderBy(r => r.Order).Select(r => r.Designation).ToList();
            _classificationHistory = await FactionService.GetClassificationHistoryAsync(_faction.Id, scope);
            _memberCount = (await FactionService.GetMembersAsync(_faction.Id, scope)).Count;
            // partners: skip agent fan-out
            if (!_isPartner)
            {
                await InvestigationLeadLoadAsync();
            }
        }
        _visibleTabs = _isPartner && _faction is not null
            ? await PartnerPolicy.GetVisibleTabsAsync(_user, nameof(Faction), _faction.Id)
            : null;
        RebuildRenderTabs();
        _load = false;
    }

    private async Task InvestigationLeadLoadAsync()
    {
        if (_faction is null)
        {
            return;
        }
        var el = await FactionService.GetInvestigationLeadAsync(_faction.Id);
        _investigationLead = el.Select(a => a.Agent?.Codename ?? "?").ToList();
    }

    private async Task InvestigationLeadRefreshAsync()
    {
        await InvestigationLeadLoadAsync();
        StateHasChanged();
    }

    private async Task NewLoadAsync()
    {
        await LoadAsync();
        _historyKey = Guid.NewGuid();
        StateHasChanged();
    }

    private async Task MembersModifiedAsync()
    {
        if (_faction is not null)
        {
            _memberCount = (await FactionService.GetMembersAsync(_faction.Id, ViewerScope.From(_user))).Count;
            StateHasChanged();
        }
    }

    private async Task PhotosModifiedAsync()
    {
        if (_faction is not null)
        {
            // refresh title image banner
            _faction.Photos = await FactionService.GetPhotosAsync(_faction.Id);
            StateHasChanged();
        }
    }

    private async Task ClassificationSetAsync((Classification New, string? Justification) input)
    {
        if (_faction is null)
        {
            return;
        }
        await FactionService.ClassificationSetAsync(_faction.Id, input.New, input.Justification, _user);
        await NewLoadAsync();
    }

    private async Task DeleteAsync()
    {
        if (_faction is null)
        {
            return;
        }
        var ok = await ConfirmDialog.ShowAsync(DialogService, "Fraktion löschen?",
            "Die Fraktion wird in den Papierkorb verschoben und kann von der Führung wiederhergestellt werden.");
        if (!ok)
        {
            return;
        }
        await FactionService.DeleteAsync(_faction.Id, _user);
        Snackbar.Add("Fraktion in den Papierkorb verschoben.", Severity.Success);
        Nav.NavigateTo("/fraktionen");
    }

    private IEnumerable<(string Label, string Value)> MasterData()
    {
        yield return ("Art", _faction!.Kind ?? "—");
        yield return ("Funk", _faction.Radio ?? "—");
        yield return ("Darkchat", _faction.Darkchat ?? "—");
        yield return ("Aufstellungszeiten", _faction.IssuingTimes ?? "—");
    }

    private static IEnumerable<string> StockTexts(IEnumerable<(string Designation, string? Quantity)> items)
        => items.Select(i => string.IsNullOrWhiteSpace(i.Quantity) ? i.Designation : $"{i.Designation} · {i.Quantity}");
}
