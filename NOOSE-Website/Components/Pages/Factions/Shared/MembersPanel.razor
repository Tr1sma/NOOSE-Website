@* Mitglieder einer Fraktion: Liste (Leitung zuerst), Hinzufügen/Bearbeiten/Entfernen mit Rang + Leitung. *@
@inject IFactionService FactionService
@inject IPersonService PersonService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudText Typo="Typo.subtitle1">Mitglieder (@_members.Count)</MudText>
        @if (_mayWrite)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd" OnClick="AddAsync">
                Mitglied hinzufügen
            </MudButton>
        }
    </MudStack>

    @if (_load)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_members.Count == 0)
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Mitglieder erfasst.</MudText>
    }
    else
    {
        @foreach (var m in _members)
        {
            <MudPaper Class="pa-3" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Badge" Color="Color.Primary" Size="Size.Small" />
                        <MudLink Href="@($"/personen/{m.PersonId}")" Typo="Typo.body2"><b>@m.Person?.Name</b></MudLink>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@m.Person?.CaseNumber</MudText>
                        @if (m.IsLead)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled" Icon="@Icons.Material.Filled.Star">Leitung</MudChip>
                        }
                        @if (!string.IsNullOrWhiteSpace(m.Rank))
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">@m.Rank</MudChip>
                        }
                    </MudStack>
                    @if (_mayWrite)
                    {
                        <MudStack Row="true" Spacing="0">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Default" Size="Size.Small"
                                           OnClick="@(() => EditAsync(m))" aria-label="Mitgliedschaft bearbeiten" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                           OnClick="@(() => RemoveAsync(m))" aria-label="Mitglied entfernen" />
                        </MudStack>
                    }
                </MudStack>
            </MudPaper>
        }
    }
</MudStack>

@code {
    [Parameter, EditorRequired] public string FactionId { get; set; } = default!;
    [Parameter, EditorRequired] public ClaimsPrincipal User { get; set; } = default!;
    /// <summary>Ränge der Fraktion (für den Rang-Auswahl-Dialog).</summary>
    [Parameter] public IReadOnlyList<string> Ranks { get; set; } = Array.Empty<string>();
    /// <summary>Wird nach Änderungen ausgelöst (damit die Steckkarte die Mitgliederzahl aktualisiert).</summary>
    [Parameter] public EventCallback Changed { get; set; }

    private bool _load = true;
    private bool _mayWrite;
    private List<FactionMember> _members = new();

    protected override async Task OnInitializedAsync()
    {
        _mayWrite = User.MayWrite();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _load = true;
        _members = await FactionService.GetMembersAsync(FactionId, ViewerScope.From(User));
        _load = false;
    }

    private async Task AddAsync()
    {
        var exclusion = _members.Select(m => m.PersonId).ToList();
        var input = await MemberDialog.ShowAsync(DialogService, User.IsLeadership(), Ranks, exclusion);
        if (input is null)
        {
            return;
        }
        // Beim Anlegen einer neuen Person vor gleichnamigen Dubletten warnen.
        if (!await DuplicateCheck.MayNewRecordCreateAsync(DialogService, PersonService, input.NewPersonName, User.IsLeadership()))
        {
            return;
        }
        try
        {
            await FactionService.MemberAddAsync(FactionId, input, User);
            Snackbar.Add("Mitglied hinzugefügt.", Severity.Success);
            await LoadAsync();
            await Changed.InvokeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task EditAsync(FactionMember m)
    {
        var input = await MemberDialog.ShowToEditAsync(DialogService, Ranks, m.Person?.Name ?? "—", m.Rank, m.IsLead);
        if (input is null)
        {
            return;
        }
        try
        {
            await FactionService.MemberChangeAsync(m.Id, input.Rank, input.IsLead, User);
            Snackbar.Add("Mitgliedschaft aktualisiert.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task RemoveAsync(FactionMember m)
    {
        var ok = await ConfirmDialog.ShowAsync(DialogService, "Mitglied entfernen?",
            $"„{m.Person?.Name}“ wird aus der Fraktion entfernt.", "Entfernen");
        if (!ok)
        {
            return;
        }
        await FactionService.MemberRemoveAsync(m.Id, User);
        Snackbar.Add("Mitglied entfernt.", Severity.Success);
        await LoadAsync();
        await Changed.InvokeAsync();
    }
}
