@inject IFactionService FactionService
@inject IFactionPhotoStorageService FileStorage
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IPartnerShareService PartnerShareService

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudText Typo="Typo.subtitle1">Foto-Galerie (@_photos.Count)</MudText>
        @if (_mayWrite)
        {
            <MudFileUpload T="IReadOnlyList<IBrowserFile>" FilesChanged="UploadAsync" Accept="image/*" MaximumFileCount="20">
                <CustomContent>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Upload"
                               OnClick="@context.OpenFilePickerAsync" Disabled="_load">
                        Fotos hochladen
                    </MudButton>
                </CustomContent>
                <SelectedTemplate />
            </MudFileUpload>
        }
    </MudStack>

    @if (_load)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }

    @if (_photos.Count == 0)
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Fotos.</MudText>
    }
    else
    {
        <div class="d-flex flex-wrap gap-3">
            @foreach (var photo in _photos)
            {
                <MudPaper Class="pa-1" Elevation="2" Style="width:160px;">
                    <div @onclick="@(() => OpenLightboxAsync(photo))" style="position:relative;cursor:pointer;">
                        <MudImage Src="@($"/dateien/fraktionen/foto/{photo.Id}")" Alt="@photo.OriginalName"
                                  Height="120" Width="150" ObjectFit="ObjectFit.Cover" Class="rounded" />
                        @if (photo.IsTitleImage)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled"
                                     Icon="@Icons.Material.Filled.Star"
                                     Style="position:absolute;top:4px;left:4px;margin:0;">Titelbild</MudChip>
                        }
                    </div>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="px-1">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="max-width:80px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                            @photo.OriginalName
                        </MudText>
                        <MudStack Row="true" Spacing="0" AlignItems="AlignItems.Center">
                            <PartnerChildShareButton Show="_canShareChildren" ChildType="@nameof(FactionPhoto)" ChildId="@photo.Id" />
                            @if (_mayWrite)
                            {
                                @if (!photo.IsTitleImage)
                                {
                                    <MudIconButton Icon="@Icons.Material.Outlined.StarBorder" Color="Color.Primary" Size="Size.Small"
                                                   OnClick="@(() => AsTitleImageAsync(photo))" aria-label="Als Titelbild setzen" />
                                }
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                               OnClick="@(() => RemoveAsync(photo))" aria-label="Foto löschen" />
                            }
                        </MudStack>
                    </MudStack>
                </MudPaper>
            }
        </div>
    }
</MudStack>

@code {
    [Parameter, EditorRequired] public string FactionId { get; set; } = default!;
    [Parameter, EditorRequired] public ClaimsPrincipal User { get; set; } = default!;
    [Parameter] public EventCallback Changed { get; set; }

    private List<FactionPhoto> _photos = new();
    private bool _load;
    private bool _mayWrite;
    private bool _canShareChildren;

    protected override async Task OnInitializedAsync()
    {
        _mayWrite = User.MayWrite();
        // leadership: per-item release only matters when the record is shell-released
        if (User.IsLeadership())
        {
            _canShareChildren = (await PartnerShareService.GetForRecordAsync(nameof(Faction), FactionId))
                .Any(s => s.Released && !s.IncludesChildren);
        }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _photos = await FactionService.GetPhotosAsync(FactionId);
    }

    private async Task OpenLightboxAsync(FactionPhoto photo)
    {
        var images = _photos
            .Select(p => new ImageLightbox.LightboxImage($"/dateien/fraktionen/foto/{p.Id}", p.OriginalName))
            .ToList();
        var start = _photos.IndexOf(photo);
        await ImageLightbox.ShowAsync(DialogService, images, Math.Max(0, start));
    }

    private async Task UploadAsync(IReadOnlyList<IBrowserFile> files)
    {
        _load = true;
        try
        {
            var uploaded = 0;
            foreach (var file in files)
            {
                if (!FileStorage.IsAllowedType(file.ContentType))
                {
                    Snackbar.Add($"'{file.Name}': Dateityp nicht erlaubt (nur Bilder).", Severity.Warning);
                    continue;
                }
                if (file.Size > FileStorage.MaxBytes)
                {
                    Snackbar.Add($"'{file.Name}': zu groß (max. {FileStorage.MaxBytes / (1024 * 1024)} MB).", Severity.Warning);
                    continue;
                }
                await using var stream = file.OpenReadStream(FileStorage.MaxBytes);
                await FactionService.PhotoAddAsync(FactionId, stream, file.Name, file.ContentType, file.Size, User);
                uploaded++;
            }

            if (uploaded > 0)
            {
                Snackbar.Add(uploaded == 1 ? "Foto hochgeladen." : $"{uploaded} Fotos hochgeladen.", Severity.Success);
                await LoadAsync();
                await Changed.InvokeAsync();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Upload fehlgeschlagen: {ex.Message}", Severity.Error);
        }
        finally
        {
            _load = false;
        }
    }

    private async Task AsTitleImageAsync(FactionPhoto photo)
    {
        try
        {
            await FactionService.AsTitleImageSetAsync(photo.Id, User);
            Snackbar.Add("Als Titelbild gesetzt.", Severity.Success);
            await LoadAsync();
            await Changed.InvokeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task RemoveAsync(FactionPhoto photo)
    {
        var ok = await ConfirmDialog.ShowAsync(DialogService, "Foto löschen?",
            $"'{photo.OriginalName}' wird dauerhaft gelöscht.");
        if (!ok)
        {
            return;
        }
        try
        {
            await FactionService.PhotoRemoveAsync(photo.Id, User);
            Snackbar.Add("Foto gelöscht.", Severity.Success);
            await LoadAsync();
            await Changed.InvokeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
