@* Aktivitäten-Zeitstrahl einer Fraktion: Aktionen (z. B. Raub/Geiselnahme) chronologisch, mit Dokument-/Quellen-Verknüpfung je Eintrag. *@
@inject IFactionService FactionService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudText Typo="Typo.subtitle1">Aktivitäten (@_activities.Count)</MudText>
        @if (_mayWrite)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="AddAsync">
                Aktivität hinzufügen
            </MudButton>
        }
    </MudStack>

    @if (_load)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_activities.Count == 0)
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Aktivitäten erfasst.</MudText>
    }
    else
    {
        <MudTimeline TimelinePosition="TimelinePosition.Start">
            @foreach (var a in _activities)
            {
                <MudTimelineItem Color="@Colour(a.Kind)" Size="Size.Small">
                    <MudStack Spacing="1">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudText Typo="Typo.body1"><b>@a.Title</b></MudText>
                                @if (!string.IsNullOrWhiteSpace(a.Kind))
                                {
                                    <MudChip T="string" Size="Size.Small" Color="@Colour(a.Kind)" Variant="Variant.Outlined">@a.Kind</MudChip>
                                }
                            </MudStack>
                            @if (_mayWrite)
                            {
                                <MudStack Row="true" Spacing="0">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Default" Size="Size.Small"
                                                   OnClick="@(() => EditAsync(a))" aria-label="Aktivität bearbeiten" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                                   OnClick="@(() => RemoveAsync(a))" aria-label="Aktivität löschen" />
                                </MudStack>
                            }
                        </MudStack>

                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="flex-wrap">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mud-text-secondary" />
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@a.Timestamp.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</MudText>
                            </MudStack>
                            @if (!string.IsNullOrWhiteSpace(a.Location))
                            {
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Small" Class="mud-text-secondary" />
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@a.Location</MudText>
                                </MudStack>
                            }
                        </MudStack>

                        @if (!string.IsNullOrWhiteSpace(a.Description))
                        {
                            <MudText Typo="Typo.body2" Style="white-space:pre-wrap;">@a.Description</MudText>
                        }

                        @* Dokumente/Anhänge je Aktivität – generische Quellen-Engine; nur laden, wenn aufgeklappt. *@
                        <MudExpansionPanels Elevation="0" Dense="true" Class="mt-1">
                            <MudExpansionPanel Text="Quellen &amp; Anhänge" Icon="@Icons.Material.Filled.AttachFile"
                                               Expanded="@_open.Contains(a.Id)" ExpandedChanged="@(v => Toggle(a.Id, v))">
                                @if (_open.Contains(a.Id))
                                {
                                    <SourcesPanel EntityType="@nameof(FactionActivity)" EntityId="@a.Id" User="User" />
                                }
                            </MudExpansionPanel>
                        </MudExpansionPanels>
                    </MudStack>
                </MudTimelineItem>
            }
        </MudTimeline>
    }
</MudStack>

@code {
    [Parameter, EditorRequired] public string FactionId { get; set; } = default!;
    [Parameter, EditorRequired] public ClaimsPrincipal User { get; set; } = default!;

    private bool _load = true;
    private bool _mayWrite;
    private List<FactionActivity> _activities = new();
    private List<string> _kinds = new();
    private readonly HashSet<string> _open = new();

    protected override async Task OnInitializedAsync()
    {
        _mayWrite = User.MayWrite();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _load = true;
        _activities = await FactionService.GetActivitiesAsync(FactionId, ViewerScope.From(User));
        _kinds = await FactionService.GetActivityKindsAsync();
        _load = false;
    }

    private async Task AddAsync()
    {
        var input = await ActivityDialog.ShowAsync(DialogService, _kinds);
        if (input is null)
        {
            return;
        }
        try
        {
            await FactionService.ActivityAddAsync(FactionId, input, User);
            Snackbar.Add("Aktivität hinzugefügt.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task EditAsync(FactionActivity a)
    {
        // Vorhandene Werte mit lokalem Zeitpunkt in den Dialog geben (der Dienst speichert wieder als UTC).
        var exists = new ActivityInput
        {
            Title = a.Title,
            Kind = a.Kind,
            Timestamp = a.Timestamp.ToLocalTime(),
            Location = a.Location,
            Description = a.Description,
        };
        var input = await ActivityDialog.ShowAsync(DialogService, _kinds, exists);
        if (input is null)
        {
            return;
        }
        try
        {
            await FactionService.ActivityChangeAsync(a.Id, input, User);
            Snackbar.Add("Aktivität aktualisiert.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task RemoveAsync(FactionActivity a)
    {
        var ok = await ConfirmDialog.ShowAsync(DialogService, "Aktivität löschen?",
            $"„{a.Title}“ wird in den Papierkorb verschoben.");
        if (!ok)
        {
            return;
        }
        try
        {
            await FactionService.ActivityRemoveAsync(a.Id, User);
            _open.Remove(a.Id);
            Snackbar.Add("Aktivität gelöscht.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private void Toggle(string id, bool open)
    {
        if (open)
        {
            _open.Add(id);
        }
        else
        {
            _open.Remove(id);
        }
    }

    // Deterministische Farbe je Art (gleiche Art → gleiche Farbe im Zeitstrahl); ohne Art neutral.
    private static readonly Color[] _palette =
    {
        Color.Primary, Color.Secondary, Color.Info, Color.Success, Color.Warning, Color.Error, Color.Tertiary,
    };

    private static Color Colour(string? kind)
    {
        if (string.IsNullOrWhiteSpace(kind))
        {
            return Color.Default;
        }
        var h = 0;
        foreach (var c in kind)
        {
            h = (h * 31 + c) & 0x7fffffff;
        }
        return _palette[h % _palette.Length];
    }
}
