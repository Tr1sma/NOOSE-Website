@inject IPersonService PersonService

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3" Style="min-width:360px;">
            @if (IsEdit)
            {
                <MudField Label="Person" Variant="Variant.Outlined">@PersonNameExists</MudField>
            }
            else
            {
                <MudRadioGroup T="bool" @bind-Value="_modeNew">
                    <MudRadio T="bool" Value="false" Color="Color.Primary" Dense="true">Bestehende Person</MudRadio>
                    <MudRadio T="bool" Value="true" Color="Color.Primary" Dense="true">Neue Person anlegen</MudRadio>
                </MudRadioGroup>
                @if (_modeNew)
                {
                    <MudTextField @bind-Value="_newName" Label="Name der neuen Person" Variant="Variant.Outlined" Immediate="true"
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.PersonAddAlt1"
                                  HelperText="Es wird automatisch eine neue Akte angelegt (Aktenzeichen wird vergeben)." />
                }
                else
                {
                    <MudAutocomplete T="Person" Label="Person" @bind-Value="_person"
                                     SearchFunc="@SearchPeople" ToStringFunc="@(p => p?.Name ?? string.Empty)"
                                     Variant="Variant.Outlined" Clearable="true" CoerceText="false" CoerceValue="false"
                                     ResetValueOnEmptyText="true" MinCharacters="0" Immediate="true"
                                     Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.PersonSearch"
                                     HelperText="Person der Fraktion zuordnen.">
                        <ItemTemplate Context="p">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.Badge" Size="Size.Small" Color="Color.Primary" />
                                <MudText Typo="Typo.body2">@p.Name</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@p.CaseNumber</MudText>
                            </MudStack>
                        </ItemTemplate>
                    </MudAutocomplete>
                }
            }

            @if (Ranks.Count > 0)
            {
                <MudSelect T="string" @bind-Value="_rank" Label="Rang (optional)" Variant="Variant.Outlined" Clearable="true" Dense="true">
                    @foreach (var r in Ranks)
                    {
                        <MudSelectItem Value="r">@r</MudSelectItem>
                    }
                </MudSelect>
            }
            else
            {
                <MudTextField @bind-Value="_rank" Label="Rang (optional)" Variant="Variant.Outlined"
                              HelperText="Tipp: Ränge können in der Fraktion gepflegt werden." />
            }

            <MudSwitch T="bool" @bind-Value="_isLead" Color="Color.Primary" Label="Gehört zur Leaderschaft" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Abbrechen</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save" Disabled="@(!CanSave)">
            @(IsEdit ? "Speichern" : "Hinzufügen")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public bool IsLeadership { get; set; }
    [Parameter] public IReadOnlyList<string> Ranks { get; set; } = Array.Empty<string>();
    [Parameter] public IReadOnlyList<string> ExclusionPersonIds { get; set; } = Array.Empty<string>();

    // edit mode (person fixed): signalled by a set name
    [Parameter] public string? PersonNameExists { get; set; }
    [Parameter] public string? RankExists { get; set; }
    [Parameter] public bool IsLeadExists { get; set; }

    private bool IsEdit => PersonNameExists is not null;

    private Person? _person;
    private bool _modeNew;
    private string? _newName;
    private string? _rank;
    private bool _isLead;

    private bool CanSave => IsEdit || (_modeNew ? !string.IsNullOrWhiteSpace(_newName) : _person is not null);

    protected override void OnInitialized()
    {
        if (IsEdit)
        {
            _rank = RankExists;
            _isLead = IsLeadExists;
        }
    }

    private async Task<IEnumerable<Person>> SearchPeople(string value, CancellationToken token)
    {
        var hit = await PersonService.SearchAsync(value, IsLeadership, 20, token);
        return hit.Where(p => !ExclusionPersonIds.Contains(p.Id));
    }

    private void Save()
    {
        string personId = string.Empty;
        string? newName = null;
        string? displayName = PersonNameExists;
        if (!IsEdit)
        {
            if (_modeNew)
            {
                if (string.IsNullOrWhiteSpace(_newName))
                {
                    return;
                }
                newName = _newName.Trim();
                displayName = newName;
            }
            else
            {
                if (_person is null)
                {
                    return;
                }
                personId = _person.Id;
                displayName = _person.Name;
            }
        }
        MudDialog.Close(DialogResult.Ok(new MemberInput
        {
            PersonId = personId,
            NewPersonName = newName,
            PersonName = displayName,
            Rank = _rank,
            IsLead = _isLead,
        }));
    }

    private void Cancel() => MudDialog.Cancel();

    /// <summary>Shows the add-member dialog; returns the input or null if cancelled.</summary>
    public static async Task<MemberInput?> ShowAsync(IDialogService dialog, bool isLeadership,
        IReadOnlyList<string> ranks, IReadOnlyList<string> exclusionPersonIds)
    {
        var parameters = new DialogParameters<MemberDialog>
        {
            { x => x.IsLeadership, isLeadership },
            { x => x.Ranks, ranks },
            { x => x.ExclusionPersonIds, exclusionPersonIds },
        };
        var reference = await dialog.ShowAsync<MemberDialog>("Mitglied hinzufügen", parameters);
        var result = await reference.Result;
        return result is { Canceled: false, Data: MemberInput e } ? e : null;
    }

    /// <summary>Shows the dialog to change an existing member's rank/lead (person fixed).</summary>
    public static async Task<MemberInput?> ShowToEditAsync(IDialogService dialog,
        IReadOnlyList<string> ranks, string personName, string? rank, bool isLead)
    {
        var parameters = new DialogParameters<MemberDialog>
        {
            { x => x.Ranks, ranks },
            { x => x.PersonNameExists, personName },
            { x => x.RankExists, rank },
            { x => x.IsLeadExists, isLead },
        };
        var reference = await dialog.ShowAsync<MemberDialog>("Mitgliedschaft bearbeiten", parameters);
        var result = await reference.Result;
        return result is { Canceled: false, Data: MemberInput e } ? e : null;
    }
}
