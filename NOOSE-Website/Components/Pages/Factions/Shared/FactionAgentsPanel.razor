@* Name deliberately prefixed to avoid a tag-resolution collision with the groups component (both Shared folders are global @using). *@
@inject IFactionService FactionService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudText Typo="Typo.subtitle1">Zugeteilte Agents (@_agents.Count)</MudText>
        @if (_canManage)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.GroupAdd" OnClick="AllocateAsync">
                Agent zuteilen
            </MudButton>
        }
    </MudStack>

    @if (_load)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_agents.Count == 0)
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Agents zugeteilt.</MudText>
    }
    else
    {
        @foreach (var a in _agents)
        {
            <MudPaper Class="pa-3" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@(a.IsInvestigationLead ? Icons.Material.Filled.LocalPolice : Icons.Material.Filled.Person)"
                                 Color="@(a.IsInvestigationLead ? Color.Warning : Color.Primary)" Size="Size.Small" />
                        <MudText Typo="Typo.body2"><b>@a.Agent?.Codename</b></MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">@RankDisplay.Name(a.Agent?.Rank)</MudChip>
                        @if (a.IsInvestigationLead)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled" Icon="@Icons.Material.Filled.LocalPolice">Ermittlungsleiter</MudChip>
                        }
                    </MudStack>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="0">
                        @if (_mayWrite && _isLeadership)
                        {
                            <MudIconButton Icon="@(a.IsInvestigationLead ? Icons.Material.Filled.Star : Icons.Material.Outlined.StarBorder)"
                                           Color="@(a.IsInvestigationLead ? Color.Warning : Color.Default)" Size="Size.Small"
                                           OnClick="@(() => InvestigationLeadToggleAsync(a))"
                                           aria-label="@(a.IsInvestigationLead ? "Ermittlungsleiter-Markierung entfernen" : "Als Ermittlungsleiter markieren")" />
                        }
                        @if (_canManage)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                           OnClick="@(() => RemoveAsync(a))" aria-label="Agent entfernen" />
                        }
                    </MudStack>
                </MudStack>
            </MudPaper>
        }
    }
</MudStack>

@code {
    [Parameter, EditorRequired] public string FactionId { get; set; } = default!;
    [Parameter, EditorRequired] public ClaimsPrincipal User { get; set; } = default!;

    [Parameter] public EventCallback Changed { get; set; }

    private bool _load = true;
    private bool _mayWrite;
    private bool _isLeadership;
    private bool _canManage;
    private List<FactionAgent> _agents = new();

    protected override async Task OnInitializedAsync()
    {
        _mayWrite = User.MayWrite();
        _isLeadership = User.IsLeadership();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _load = true;
        _agents = await FactionService.GetAgentsAsync(FactionId);
        // leadership or this record's investigation lead may manage
        var myId = User.GetAgentId();
        _canManage = _isLeadership || _agents.Any(a => a.AgentId == myId && a.IsInvestigationLead);
        // read-only supervisors get no mutation controls
        _canManage = _canManage && _mayWrite;
        _load = false;
    }

    private async Task AllocateAsync()
    {
        var exclusion = _agents.Select(a => a.AgentId).ToList();
        var choice = await AgentAllocateDialog.ShowAsync(DialogService, exclusion, User.MayRealNameSee(), _isLeadership);
        if (choice is null)
        {
            return;
        }
        try
        {
            await FactionService.AgentAllocateAsync(FactionId, choice.AgentId, choice.AsInvestigationLead, User);
            Snackbar.Add("Agent zugeteilt.", Severity.Success);
            await LoadAsync();
            await Changed.InvokeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task InvestigationLeadToggleAsync(FactionAgent a)
    {
        try
        {
            await FactionService.InvestigationLeadSetAsync(a.Id, !a.IsInvestigationLead, User);
            Snackbar.Add(a.IsInvestigationLead ? "Ermittlungsleiter-Markierung entfernt." : "Als Ermittlungsleiter markiert.", Severity.Success);
            await LoadAsync();
            await Changed.InvokeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task RemoveAsync(FactionAgent a)
    {
        var ok = await ConfirmDialog.ShowAsync(DialogService, "Zuteilung aufheben?",
            $"„{a.Agent?.Codename}“ wird der Fraktion nicht mehr zugeteilt.", "Entfernen");
        if (!ok)
        {
            return;
        }
        try
        {
            await FactionService.AgentRemoveAsync(a.Id, User);
            Snackbar.Add("Zuteilung aufgehoben.", Severity.Success);
            await LoadAsync();
            await Changed.InvokeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
