@* Druckansicht der Fraktionsakte (Phase 7): komplette Akte als strukturiertes Dokument. *@
@page "/fraktionen/{Id}/druck"
@layout PrintLayout
@inject IFactionService FactionService
@inject ILinkService LinkService
@inject ICommentService CommentService
@inject IAccessLogService AccessLog

<PageTitle>@(_faction is null ? "Druckansicht" : $"Fraktionsakte {_faction.CaseNumber}") · NOOSE</PageTitle>

@if (_load)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_faction is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">Diese Akte existiert nicht (mehr) oder ist nicht sichtbar.</MudAlert>
}
else
{
    <PrintFrame Title="@($"Fraktionsakte {_faction.CaseNumber}")" BackHref="@($"/fraktionen/{Id}")"
                 PrintedBy="@_printBy" IsClassified="_faction.IsClassified">
        <section>
            <h2>Stammdaten</h2>
            <table class="druck-felder">
                <tbody>
                    <tr><th>Name</th><td>@_faction.Name</td></tr>
                    <tr><th>Aktenzeichen</th><td>@_faction.CaseNumber</td></tr>
                    @if (!string.IsNullOrWhiteSpace(_faction.Kind))
                    {
                        <tr><th>Art</th><td>@_faction.Kind</td></tr>
                    }
                    <tr><th>Einstufung</th><td>@ClassificationDisplay.Name(_faction.Classification)</td></tr>
                    <tr><th>Gefährdung</th><td>@HazardDisplayText()</td></tr>
                    @if (_faction.IsStateFaction)
                    {
                        <tr><th>Staatsfraktion</th><td>Ja</td></tr>
                    }
                    @if (_faction.EstimatedMemberCount is { } count)
                    {
                        <tr><th>Geschätzte Mitgliederzahl</th><td>@count</td></tr>
                    }
                    @if (!string.IsNullOrWhiteSpace(_faction.Radio))
                    {
                        <tr><th>Funk</th><td>@_faction.Radio</td></tr>
                    }
                    @if (!string.IsNullOrWhiteSpace(_faction.Darkchat))
                    {
                        <tr><th>Darkchat</th><td>@_faction.Darkchat</td></tr>
                    }
                    @if (!string.IsNullOrWhiteSpace(_faction.Estate))
                    {
                        <tr><th>Anwesen</th><td class="druck-mehrzeilig">@_faction.Estate</td></tr>
                    }
                    @if (!string.IsNullOrWhiteSpace(_faction.RecognitionColor))
                    {
                        <tr><th>Erkennungsfarbe</th><td>@_faction.RecognitionColor</td></tr>
                    }
                    @if (!string.IsNullOrWhiteSpace(_faction.Targets))
                    {
                        <tr><th>Ziele</th><td class="druck-mehrzeilig">@_faction.Targets</td></tr>
                    }
                    @if (!string.IsNullOrWhiteSpace(_faction.Description))
                    {
                        <tr><th>Beschreibung</th><td class="druck-mehrzeilig">@_faction.Description</td></tr>
                    }
                    <tr><th>Zuletzt aktualisiert</th><td>@((_faction.ModifiedAt ?? _faction.CreatedAt).ToLocalTime().ToString("dd.MM.yyyy HH:mm"))</td></tr>
                </tbody>
            </table>
        </section>

        @if (_faction.Ranks.Count > 0)
        {
            <section>
                <h2>Rangstruktur</h2>
                <table class="druck-tabelle">
                    <thead><tr><th>Stufe</th><th>Bezeichnung</th></tr></thead>
                    <tbody>
                        @foreach (var r in _faction.Ranks.OrderBy(r => r.Order))
                        {
                            <tr><td>@r.Order</td><td>@r.Designation</td></tr>
                        }
                    </tbody>
                </table>
            </section>
        }

        @if (_members.Count > 0)
        {
            <section>
                <h2>Mitglieder (@_members.Count)</h2>
                <table class="druck-tabelle">
                    <thead><tr><th>Name</th><th>Rang</th><th>Seit</th></tr></thead>
                    <tbody>
                        @foreach (var m in _members)
                        {
                            <tr>
                                <td>@(m.Person?.Name ?? "—")@(m.IsLead ? " (Leitung)" : "")</td>
                                <td>@(string.IsNullOrWhiteSpace(m.Rank) ? "—" : m.Rank)</td>
                                <td>@m.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>
        }

        @if (_agents.Count > 0)
        {
            <section>
                <h2>Zugeteilte Agenten</h2>
                <table class="druck-tabelle">
                    <thead><tr><th>Agent</th><th>Funktion</th><th>Seit</th></tr></thead>
                    <tbody>
                        @foreach (var a in _agents)
                        {
                            <tr>
                                <td>@(a.Agent?.Codename ?? "—")</td>
                                <td>@(a.IsInvestigationLead ? "Ermittlungsleiter" : "Zugeteilt")</td>
                                <td>@a.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>
        }

        @if (_faction.WeaponStock.Count > 0)
        {
            <section>
                <h2>Waffenbestand</h2>
                <table class="druck-tabelle">
                    <thead><tr><th>Bezeichnung</th><th>Menge</th></tr></thead>
                    <tbody>
                        @foreach (var w in _faction.WeaponStock)
                        {
                            <tr><td>@w.Designation</td><td>@(string.IsNullOrWhiteSpace(w.Quantity) ? "—" : w.Quantity)</td></tr>
                        }
                    </tbody>
                </table>
            </section>
        }

        @if (_faction.Inventory.Count > 0)
        {
            <section>
                <h2>Lagerbestand</h2>
                <table class="druck-tabelle">
                    <thead><tr><th>Bezeichnung</th><th>Menge</th></tr></thead>
                    <tbody>
                        @foreach (var l in _faction.Inventory)
                        {
                            <tr><td>@l.Designation</td><td>@(string.IsNullOrWhiteSpace(l.Quantity) ? "—" : l.Quantity)</td></tr>
                        }
                    </tbody>
                </table>
            </section>
        }

        @if (_faction.DrugRoutes.Count > 0)
        {
            <section>
                <h2>Drogenrouten</h2>
                <table class="druck-tabelle">
                    <thead><tr><th>Bezeichnung</th><th>Notiz</th></tr></thead>
                    <tbody>
                        @foreach (var d in _faction.DrugRoutes)
                        {
                            <tr><td>@d.Designation</td><td>@(string.IsNullOrWhiteSpace(d.Note) ? "—" : d.Note)</td></tr>
                        }
                    </tbody>
                </table>
            </section>
        }

        @if (_activities.Count > 0)
        {
            <section>
                <h2>Aktivitäten</h2>
                @foreach (var a in _activities)
                {
                    <div class="druck-eintrag">
                        <div class="druck-eintrag-kopf">
                            <b>@a.Timestamp.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</b> · @a.Title
                            @if (!string.IsNullOrWhiteSpace(a.Kind))
                            {
                                <text> · @a.Kind</text>
                            }
                            @if (!string.IsNullOrWhiteSpace(a.Location))
                            {
                                <text> · @a.Location</text>
                            }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(a.Description))
                        {
                            <div class="druck-mehrzeilig">@a.Description</div>
                        }
                    </div>
                }
            </section>
        }

        <PrintClassificationHistory Entries="_classificationHistory" />
        <PrintLinks Entries="_links" />
        <PrintComments Entries="_comments" />
    </PrintFrame>
}

@code {
    [Parameter] public string Id { get; set; } = string.Empty;
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _load = true;
    private string? _printBy;
    private Faction? _faction;
    private List<FactionMember> _members = new();
    private List<FactionAgent> _agents = new();
    private List<FactionActivity> _activities = new();
    private List<ClassificationHistory> _classificationHistory = new();
    private List<LinkDisplay> _links = new();
    private List<Comment> _comments = new();

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthStateTask).User;
        var isLeadership = user.IsLeadership();
        _printBy = user.GetCodename();

        _faction = await FactionService.GetDetailAsync(Id, isLeadership);
        if (_faction is not null)
        {
            _members = await FactionService.GetMembersAsync(Id, isLeadership);
            _agents = await FactionService.GetAgentsAsync(Id);
            _activities = await FactionService.GetActivitiesAsync(Id, isLeadership);
            _classificationHistory = await FactionService.GetClassificationHistoryAsync(Id, isLeadership);
            _links = await LinkService.GetForRecordAsync(nameof(Faction), Id, isLeadership, user.GetAgentId());
            _comments = await CommentService.GetForRecordAsync(nameof(Faction), Id, isLeadership);
            await AccessLog.LogViewAsync(nameof(Faction), Id);
        }
        _load = false;
    }

    /// <summary>Gefährdungsstufe inkl. Score-Zahl und Konfidenz (sofern berechnet) für die Druckansicht.</summary>
    private string HazardDisplayText()
    {
        if (_faction is null)
        {
            return "—";
        }
        if (_faction.IsStateFaction)
        {
            return "Ausgenommen (Staatsfraktion)";
        }
        var level = HazardLevelLogic.Name(HazardLevelLogic.From(_faction.ThreatScore));
        if (_faction.ThreatScore is not { } score)
        {
            return level;
        }
        var confidence = _faction.ThreatConfidence is { } k ? $" · Konfidenz {k} %" : "";
        return $"{level} (Score {score}{confidence})";
    }
}
