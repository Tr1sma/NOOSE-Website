@page "/aufgaben/{Id}/bearbeiten"
@inject IAufgabeService AufgabeService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Aufgabe bearbeiten · NOOSE</PageTitle>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_keinZugriff)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
        Diese Aufgabe darf nur ihr Ersteller oder die Führung bearbeiten.
        <MudButton Href="@($"/aufgaben/{Id}")" Variant="Variant.Text" Color="Color.Primary" Class="ml-2">Zur Aufgabe</MudButton>
    </MudAlert>
}
else if (_eingabe is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
        Aufgabe nicht gefunden.
    </MudAlert>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="@($"/aufgaben/{Id}")" aria-label="Zurück" />
        <MudIcon Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Large" />
        <MudText Typo="Typo.h4">Aufgabe bearbeiten</MudText>
    </MudStack>

    <MudForm @ref="_form">
        <AufgabeForm Eingabe="_eingabe" ZeigeZuweisung="false" />
    </MudForm>
    <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2">
        Hinweis: Zuweisungen werden in der Aufgabe unter „Beteiligte" verwaltet.
    </MudText>

    <MudStack Row="true" Spacing="2" Class="mt-4">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SpeichernAsync" Disabled="_speichert">Speichern</MudButton>
        <MudButton Variant="Variant.Text" Href="@($"/aufgaben/{Id}")">Abbrechen</MudButton>
    </MudStack>
}

@code {
    [Parameter] public string Id { get; set; } = default!;
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private MudForm _form = default!;
    private AufgabeEingabe? _eingabe;
    private ClaimsPrincipal _user = default!;
    private bool _laden = true;
    private bool _keinZugriff;
    private bool _speichert;
    private string? _geladeneId;

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_geladeneId == Id)
        {
            return;
        }
        _geladeneId = Id;
        _laden = true;
        _eingabe = null;
        _keinZugriff = false;
        var a = await AufgabeService.GetDetailAsync(Id);
        if (a is not null)
        {
            // Bearbeiten ist Ersteller/Führung vorbehalten – serverseitig in AktualisierenAsync erzwungen, hier
            // proaktiv in der UI gespiegelt, damit kein nicht-berechtigtes Formular angezeigt wird.
            if (!_user.IstFuehrung() && a.ErstelltVonId != _user.GetAgentId())
            {
                _keinZugriff = true;
            }
            else
            {
                _eingabe = new AufgabeEingabe
                {
                    Titel = a.Titel,
                    Beschreibung = a.Beschreibung,
                    Status = a.Status,
                    Prioritaet = a.Prioritaet,
                    Faelligkeit = a.Faelligkeit,
                };
            }
        }
        _laden = false;
    }

    private async Task SpeichernAsync()
    {
        if (_eingabe is null || _speichert)
        {
            return;
        }
        await _form.ValidateAsync();
        if (!_form.IsValid)
        {
            return;
        }

        _speichert = true;
        try
        {
            await AufgabeService.AktualisierenAsync(Id, _eingabe, _user);
            Snackbar.Add("Änderungen gespeichert.", Severity.Success);
            Nav.NavigateTo($"/aufgaben/{Id}");
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
            _speichert = false;
        }
    }
}
