@* Der Aufgabe zugewiesene NOOSE-Agents: Liste + Zuweisen/Entfernen. Verwalten darf der Ersteller oder die
   Führung (über das Flag <see cref="KannVerwalten"/>). Komponentenname bewusst „AufgabeAgentePanel" wegen der
   global per @using sichtbaren Shared-Ordner. *@
@inject IAufgabeService AufgabeService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudText Typo="Typo.subtitle1">Zugewiesene Agents (@_agenten.Count)</MudText>
        @if (KannVerwalten)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.GroupAdd" OnClick="ZuweisenAsync">
                Agent zuweisen
            </MudButton>
        }
    </MudStack>

    @if (_laden)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_agenten.Count == 0)
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch niemandem zugewiesen.</MudText>
    }
    else
    {
        @foreach (var a in _agenten)
        {
            <MudPaper Class="pa-3" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Primary" Size="Size.Small" />
                        <MudText Typo="Typo.body2"><b>@a.Agent?.Codename</b></MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">@DienstgradAnzeige.Name(a.Agent?.Dienstgrad)</MudChip>
                    </MudStack>
                    @if (KannVerwalten)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                       OnClick="@(() => EntfernenAsync(a))" aria-label="Zuweisung aufheben" />
                    }
                </MudStack>
            </MudPaper>
        }
    }
</MudStack>

@code {
    [Parameter, EditorRequired] public string AufgabeId { get; set; } = default!;
    [Parameter, EditorRequired] public ClaimsPrincipal User { get; set; } = default!;

    /// <summary>Darf der Aufrufer zuweisen/entfernen (Ersteller oder Führung)? Vom Detail berechnet.</summary>
    [Parameter] public bool KannVerwalten { get; set; }

    /// <summary>Wird nach jeder Änderung der Zuweisungen ausgelöst (Karte aktualisieren).</summary>
    [Parameter] public EventCallback Changed { get; set; }

    private bool _laden = true;
    private List<AufgabeZuweisung> _agenten = new();

    protected override async Task OnInitializedAsync() => await LadenAsync();

    private async Task LadenAsync()
    {
        _laden = true;
        _agenten = await AufgabeService.GetZuweisungenAsync(AufgabeId);
        _laden = false;
    }

    private async Task ZuweisenAsync()
    {
        var ausschluss = _agenten.Select(a => a.AgentId).ToList();
        var wahl = await AgentZuteilenDialog.ZeigenAsync(DialogService, ausschluss, User.DarfKlarnameSehen(), false);
        if (wahl is null)
        {
            return;
        }
        try
        {
            await AufgabeService.AgentZuweisenAsync(AufgabeId, wahl.AgentId, User);
            Snackbar.Add("Agent zugewiesen.", Severity.Success);
            await LadenAsync();
            await Changed.InvokeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task EntfernenAsync(AufgabeZuweisung a)
    {
        var ok = await BestaetigenDialog.ZeigenAsync(DialogService, "Zuweisung aufheben?",
            $"„{a.Agent?.Codename}“ ist dieser Aufgabe nicht mehr zugewiesen.", "Entfernen");
        if (!ok)
        {
            return;
        }
        try
        {
            await AufgabeService.AgentEntfernenAsync(a.Id, User);
            Snackbar.Add("Zuweisung aufgehoben.", Severity.Success);
            await LadenAsync();
            await Changed.InvokeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
