@* Farbiger Status-Chip einer Aufgabe (Offen/In Bearbeitung/Erledigt/Abgebrochen). Zentralisiert
   Beschriftung und Farbgebung für Liste, Karte und Detailseite. *@
<MudChip T="string" Size="@Size" Variant="Variant.Filled" Color="@Farbe(Status)" Icon="@Symbol(Status)">
    @AufgabeStatusAnzeige.Name(Status)
</MudChip>

@code {
    [Parameter, EditorRequired] public AufgabeStatus Status { get; set; }
    [Parameter] public Size Size { get; set; } = Size.Small;

    private static Color Farbe(AufgabeStatus status) => status switch
    {
        AufgabeStatus.Offen => Color.Info,
        AufgabeStatus.InBearbeitung => Color.Warning,
        AufgabeStatus.Erledigt => Color.Success,
        AufgabeStatus.Abgebrochen => Color.Dark,
        _ => Color.Default,
    };

    private static string Symbol(AufgabeStatus status) => status switch
    {
        AufgabeStatus.Offen => Icons.Material.Filled.RadioButtonUnchecked,
        AufgabeStatus.InBearbeitung => Icons.Material.Filled.Autorenew,
        AufgabeStatus.Erledigt => Icons.Material.Filled.CheckCircle,
        AufgabeStatus.Abgebrochen => Icons.Material.Filled.Cancel,
        _ => Icons.Material.Filled.HelpOutline,
    };
}
