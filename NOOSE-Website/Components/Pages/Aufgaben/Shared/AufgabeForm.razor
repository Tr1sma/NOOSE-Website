@* Gemeinsames Formular für Anlegen/Bearbeiten einer Aufgabe. Beim Anlegen kann zusätzlich eine
   Mehrfach-Zuweisung an aktive Agenten erfolgen (nur Codename – kein Klarname-Leck). Beim Bearbeiten
   werden Zuweisungen über das Beteiligte-Panel der Detailseite verwaltet. *@
@inject IAgentVerwaltungService AgentService

<MudGrid>
    <MudItem xs="12">
        <MudTextField @bind-Value="Eingabe.Titel" Label="Titel" Required="true" RequiredError="Titel ist erforderlich"
                      Variant="Variant.Outlined" />
    </MudItem>

    <MudItem xs="12" md="4">
        <MudSelect T="AufgabeStatus" @bind-Value="Eingabe.Status" Label="Status" Variant="Variant.Outlined">
            @foreach (var s in AufgabeStatusAnzeige.Alle)
            {
                <MudSelectItem Value="s">@AufgabeStatusAnzeige.Name(s)</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
    <MudItem xs="12" md="4">
        <MudSelect T="AufgabePrioritaet" @bind-Value="Eingabe.Prioritaet" Label="Priorität" Variant="Variant.Outlined">
            @foreach (var p in AufgabePrioritaetAnzeige.Alle)
            {
                <MudSelectItem Value="p">@AufgabePrioritaetAnzeige.Name(p)</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
    <MudItem xs="12" md="4">
        <MudDatePicker @bind-Date="Eingabe.Faelligkeit" Label="Fälligkeit (optional)" Variant="Variant.Outlined"
                       Clearable="true" Editable="true" />
    </MudItem>

    @if (ZeigeZuweisung)
    {
        <MudItem xs="12">
            <MudSelect T="string" Label="Zuweisen an (optional)" MultiSelection="true"
                       SelectedValues="AgentIds" SelectedValuesChanged="OnAgentsChanged"
                       MultiSelectionTextFunc="@AnzeigeAuswahl" Variant="Variant.Outlined"
                       Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.ManageAccounts"
                       HelperText="Zugewiesene Agenten erhalten eine Benachrichtigung.">
                @foreach (var a in _agenten)
                {
                    <MudSelectItem T="string" Value="@a.Id">@a.Codename (@DienstgradAnzeige.Name(a.Dienstgrad))</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
    }

    <MudItem xs="12">
        <MudTextField @bind-Value="Eingabe.Beschreibung" Label="Beschreibung (optional)" Lines="4" Variant="Variant.Outlined"
                      HelperText="Worum geht es bei dieser Aufgabe?" />
    </MudItem>
</MudGrid>

@code {
    [Parameter, EditorRequired] public AufgabeEingabe Eingabe { get; set; } = default!;

    /// <summary>Mehrfach-Zuweisung anzeigen (nur beim Anlegen).</summary>
    [Parameter] public bool ZeigeZuweisung { get; set; }

    /// <summary>Gewählte Agent-Ids (zweiweg-gebunden über <c>@bind-AgentIds</c>).</summary>
    [Parameter] public IReadOnlyCollection<string> AgentIds { get; set; } = Array.Empty<string>();
    [Parameter] public EventCallback<IReadOnlyCollection<string>> AgentIdsChanged { get; set; }

    private List<Agent> _agenten = new();

    protected override async Task OnInitializedAsync()
    {
        if (ZeigeZuweisung)
        {
            // GetAuswaehlbareAsync: nur aktive Agenten ohne TeamLeitung-Marker, bereits nach Codename sortiert.
            _agenten = await AgentService.GetAuswaehlbareAsync();
        }
    }

    private async Task OnAgentsChanged(IReadOnlyCollection<string> werte)
    {
        AgentIds = werte;
        await AgentIdsChanged.InvokeAsync(werte);
    }

    private string AnzeigeAuswahl(IReadOnlyList<string> ids)
    {
        var namen = _agenten.Where(a => ids.Contains(a.Id)).Select(a => a.Codename).ToList();
        return namen.Count == 0 ? string.Empty : string.Join(", ", namen);
    }
}
