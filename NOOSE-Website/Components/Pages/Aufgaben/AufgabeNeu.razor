@page "/aufgaben/neu"
@inject IAufgabeService AufgabeService
@inject IVerknuepfungService VerknuepfungService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Neue Aufgabe · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/aufgaben" aria-label="Zurück" />
    <MudIcon Icon="@Icons.Material.Filled.AssignmentTurnedIn" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h4">Neue Aufgabe anlegen</MudText>
</MudStack>

<MudForm @ref="_form">
    <AufgabeForm Eingabe="_eingabe" ZeigeZuweisung="true" @bind-AgentIds="_agentIds" />
</MudForm>

@* Bezug / Verknüpfungen: hier schon beim Anlegen Akten verknüpfen, auf die sich die Aufgabe bezieht. *@
<MudPaper Class="pa-4 mt-4" Elevation="1">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
        <MudText Typo="Typo.subtitle1">Bezug / Verknüpfte Akten (optional)</MudText>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AddLink" OnClick="BezugHinzufuegenAsync">
            Akte verknüpfen
        </MudButton>
    </MudStack>
    @if (_bezuege.Count == 0)
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">
            Verknüpfe z. B. die Person, Operation oder den Vorgang, auf die sich die Aufgabe bezieht.
        </MudText>
    }
    else
    {
        <div class="d-flex flex-wrap" style="gap:.5rem;">
            @foreach (var b in _bezuege)
            {
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Icon="@TypIcon(b.ZielTyp)"
                         OnClose="@(() => BezugEntfernen(b))">
                    @TypAnzeige(b.ZielTyp): @(b.Anzeige ?? b.ZielId)
                </MudChip>
            }
        </div>
    }
</MudPaper>

<MudStack Row="true" Spacing="2" Class="mt-4">
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SpeichernAsync" Disabled="_speichert">Anlegen</MudButton>
    <MudButton Variant="Variant.Text" Href="/aufgaben">Abbrechen</MudButton>
</MudStack>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    [SupplyParameterFromQuery(Name = "bezugTyp")] public string? BezugTyp { get; set; }
    [SupplyParameterFromQuery(Name = "bezugId")] public string? BezugId { get; set; }

    private MudForm _form = default!;
    private readonly AufgabeEingabe _eingabe = new();
    private IReadOnlyCollection<string> _agentIds = new HashSet<string>();
    private readonly List<VerknuepfungEingabe> _bezuege = new();
    private ClaimsPrincipal _user = default!;
    private bool _speichert;

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;

        // Vom „Aufgabe erstellen"-Button einer Akte vorausgefüllt: als Bezug vormerken (nur wenn zugänglich).
        if (!string.IsNullOrWhiteSpace(BezugTyp) && !string.IsNullOrWhiteSpace(BezugId))
        {
            var name = await AufgabeService.BezugAnzeigeAsync(BezugTyp, BezugId, _user);
            if (name is not null)
            {
                _bezuege.Add(new VerknuepfungEingabe { ZielTyp = BezugTyp, ZielId = BezugId, Anzeige = name });
            }
        }
    }

    private async Task BezugHinzufuegenAsync()
    {
        var wahl = await VerknuepfungDialog.ZeigenAsync(DialogService, _user.IstFuehrung());
        if (wahl is null)
        {
            return;
        }
        // Dubletten vermeiden (gleiches Ziel nicht doppelt verknüpfen).
        if (_bezuege.Any(b => b.ZielTyp == wahl.ZielTyp && b.ZielId == wahl.ZielId))
        {
            return;
        }
        _bezuege.Add(wahl);
    }

    private void BezugEntfernen(VerknuepfungEingabe b) => _bezuege.Remove(b);

    private async Task SpeichernAsync()
    {
        if (_speichert)
        {
            return;
        }
        await _form.ValidateAsync();
        if (!_form.IsValid)
        {
            return;
        }

        _speichert = true;
        try
        {
            var aufgabe = await AufgabeService.ErstellenAsync(_eingabe, _agentIds.ToList(), _user);

            // Gewählte Bezüge verknüpfen – ein Fehler einzelner Verknüpfungen bricht das Anlegen nicht ab;
            // die konkreten Fehlertexte werden gesammelt und angezeigt.
            var fehler = new List<string>();
            foreach (var b in _bezuege)
            {
                try
                {
                    await VerknuepfungService.ErstellenAsync(nameof(Aufgabe), aufgabe.Id, b.ZielTyp, b.ZielId, b.Label, _user, VerknuepfungArt.Standard);
                }
                catch (Exception ex)
                {
                    fehler.Add($"{TypAnzeige(b.ZielTyp)} ({b.Anzeige ?? b.ZielId}): {ex.Message}");
                }
            }

            if (fehler.Count > 0)
            {
                Snackbar.Add($"Aufgabe {aufgabe.Aktenzeichen} angelegt, aber {fehler.Count} Verknüpfung(en) schlugen fehl: {string.Join("; ", fehler)}", Severity.Warning);
            }
            else
            {
                Snackbar.Add($"Aufgabe {aufgabe.Aktenzeichen} angelegt.", Severity.Success);
            }
            Nav.NavigateTo($"/aufgaben/{aufgabe.Id}");
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _speichert = false;
        }
    }

    private static string TypAnzeige(string typ) => typ switch
    {
        nameof(Person) => "Person",
        nameof(Fraktion) => "Fraktion",
        nameof(Personengruppe) => "Personengruppe",
        nameof(Partei) => "Partei",
        nameof(Operation) => "Operation",
        nameof(Vorgang) => "Vorgang",
        nameof(Taskforce) => "Taskforce",
        nameof(Agent) => "Personalakte",
        nameof(PersonDok) => "Personen-Dok",
        nameof(Observation) => "Observation",
        nameof(Aufgabe) => "Aufgabe",
        _ => "Akte",
    };

    private static string TypIcon(string typ) => typ switch
    {
        nameof(Person) => Icons.Material.Filled.Badge,
        nameof(Fraktion) => Icons.Material.Filled.Groups,
        nameof(Personengruppe) => Icons.Material.Filled.Diversity3,
        nameof(Partei) => Icons.Material.Filled.AccountBalance,
        nameof(Operation) => Icons.Material.Filled.Radar,
        nameof(Vorgang) => Icons.Material.Filled.FolderSpecial,
        nameof(Taskforce) => Icons.Material.Filled.Groups2,
        nameof(Agent) => Icons.Material.Filled.Person,
        nameof(PersonDok) => Icons.Material.Filled.Description,
        nameof(Observation) => Icons.Material.Filled.Visibility,
        nameof(Aufgabe) => Icons.Material.Filled.AssignmentTurnedIn,
        _ => Icons.Material.Filled.Hub,
    };
}
