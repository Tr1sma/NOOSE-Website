@* Einstufung anzeigen/ändern (mit Rang-Gate) und Verlauf als Zeitleiste. Akten-agnostisch:
   der Aufrufer reicht aktuelle Einstufung + Verlauf herein und behandelt das Setzen via OnSetzen.
   Reicht der Aufrufer EntitaetTyp/EntitaetId mit, kann ein Agent unterhalb Senior Special Agent die
   höchste Einstufung „Gesichert staatsgefährdend" per Hochstufungs-Antrag beantragen (Phase 5). *@
@inject ISnackbar Snackbar
@inject IAntragService AntragService

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
        <MudText Typo="Typo.subtitle1">Aktuelle Einstufung:</MudText>
        <EinstufungBadge Wert="Aktuell" />
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudText Typo="Typo.subtitle2" Class="mb-2">Einstufung ändern</MudText>
        <MudStack Spacing="2">
            <MudSelect T="Einstufung" @bind-Value="_neu" Label="Neue Einstufung" Variant="Variant.Outlined" Dense="true">
                @foreach (var e in EinstufungAnzeige.Alle)
                {
                    <MudSelectItem Value="e" Disabled="@(e == Einstufung.GesichertStaatsgefaehrdend && !_darfHoechste && !_kannBeantragen)">
                        @EinstufungAnzeige.Name(e)
                    </MudSelectItem>
                }
            </MudSelect>
            @if (!_darfHoechste && _kannBeantragen)
            {
                @if (_antragLaeuft)
                {
                    <MudAlert Severity="Severity.Info" Dense="true" Variant="Variant.Outlined">
                        Für diese Akte läuft bereits ein Hochstufungs-Antrag – er wartet auf die Entscheidung
                        eines Senior Special Agent.
                    </MudAlert>
                }
                else
                {
                    <MudAlert Severity="Severity.Info" Dense="true" Variant="Variant.Outlined">
                        „Gesichert staatsgefährdend“ kannst du nicht direkt setzen. Wähle die Stufe aus und stelle
                        mit Begründung einen Hochstufungs-Antrag; ein Senior Special Agent entscheidet darüber.
                    </MudAlert>
                }
            }
            else if (!_darfHoechste)
            {
                <MudAlert Severity="Severity.Info" Dense="true" Variant="Variant.Outlined">
                    „Gesichert staatsgefährdend“ kann erst ab Senior Special Agent direkt gesetzt werden.
                </MudAlert>
            }
            <MudTextField @bind-Value="_begruendung" Immediate="true" Lines="2" Variant="Variant.Outlined"
                          Label="@(_istBeantragen ? "Begründung (für den Antrag erforderlich)" : "Begründung (optional)")" />
            <div>
                @if (_istBeantragen)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Send"
                               OnClick="BeantragenAsync" Disabled="@(_antragLaeuft || string.IsNullOrWhiteSpace(_begruendung))">
                        Hochstufung beantragen</MudButton>
                    @if (_antragLaeuft)
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mt-1">
                            Es läuft bereits ein Antrag für diese Akte.
                        </MudText>
                    }
                    else if (string.IsNullOrWhiteSpace(_begruendung))
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mt-1">
                            Für den Antrag ist eine Begründung erforderlich.
                        </MudText>
                    }
                }
                else
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save"
                               OnClick="SetzenAsync" Disabled="@(_neu == Aktuell)">Einstufung speichern</MudButton>
                    @if (_neu == Aktuell)
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mt-1">
                            Wähle oben eine andere Einstufung, um sie zu speichern.
                        </MudText>
                    }
                }
            </div>
        </MudStack>
    </MudPaper>

    <MudText Typo="Typo.subtitle2">Verlauf</MudText>
    @if (Verlauf.Count == 0)
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Einstufungs-Änderungen.</MudText>
    }
    else
    {
        <MudTimeline TimelinePosition="TimelinePosition.Start">
            @foreach (var v in Verlauf.OrderByDescending(x => x.Zeitpunkt))
            {
                <MudTimelineItem Color="Color.Primary" Size="Size.Small">
                    <MudText Typo="Typo.body2"><b>@EinstufungAnzeige.Name(v.Wert)</b></MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                        @v.Zeitpunkt.ToLocalTime().ToString("dd.MM.yyyy HH:mm") · @(v.AgentName ?? "—")
                    </MudText>
                    @if (!string.IsNullOrWhiteSpace(v.Begruendung))
                    {
                        <MudText Typo="Typo.body2">@v.Begruendung</MudText>
                    }
                </MudTimelineItem>
            }
        </MudTimeline>
    }
</MudStack>

@code {
    [Parameter, EditorRequired] public Einstufung Aktuell { get; set; }
    [Parameter, EditorRequired] public IReadOnlyList<EinstufungVerlauf> Verlauf { get; set; } = Array.Empty<EinstufungVerlauf>();
    [Parameter, EditorRequired] public ClaimsPrincipal User { get; set; } = default!;
    /// <summary>Wird mit (neue Einstufung, Begründung) aufgerufen; der Aufrufer persistiert und lädt neu.</summary>
    [Parameter, EditorRequired] public EventCallback<(Einstufung Neu, string? Begruendung)> OnSetzen { get; set; }

    // Optionaler Akten-Bezug: ermöglicht den Hochstufungs-Antrag für Agenten unterhalb Senior Special Agent.
    [Parameter] public string? EntitaetTyp { get; set; }
    [Parameter] public string? EntitaetId { get; set; }
    /// <summary>Denormalisierte Bezeichnung der Akte (Name + Aktenzeichen) für den Antrag/Posteingang.</summary>
    [Parameter] public string? ZielBezeichnung { get; set; }

    private Einstufung _neu;
    private Einstufung _zuletztAktuell;
    private bool _initialisiert;
    private string? _begruendung;
    private bool _darfHoechste;
    private bool _kannBeantragen;
    private bool _antragLaeuft;

    // Beantragen statt direkt setzen: höchste Stufe gewählt, kein Senior-Recht, aber Akten-Bezug vorhanden.
    private bool _istBeantragen => _neu == Einstufung.GesichertStaatsgefaehrdend && !_darfHoechste && _kannBeantragen;

    protected override async Task OnInitializedAsync()
    {
        _kannBeantragen = !string.IsNullOrWhiteSpace(EntitaetTyp) && !string.IsNullOrWhiteSpace(EntitaetId);
        if (_kannBeantragen)
        {
            _antragLaeuft = await AntragService.HatOffenenAntragAsync(EntitaetTyp!, EntitaetId!);
        }
    }

    private async Task BeantragenAsync()
    {
        if (!_kannBeantragen || string.IsNullOrWhiteSpace(_begruendung))
        {
            return;
        }
        try
        {
            await AntragService.HochstufungBeantragenAsync(EntitaetTyp!, EntitaetId!, ZielBezeichnung ?? string.Empty, _neu, _begruendung!, User);
            _antragLaeuft = true;
            _begruendung = null;
            _neu = Aktuell;
            Snackbar.Add("Hochstufungs-Antrag gestellt. Ein Senior Special Agent entscheidet darüber.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    protected override void OnParametersSet()
    {
        _darfHoechste = User.DarfHoechsteEinstufung();
        // Auswahl an die aktuelle Einstufung angleichen – aber nur bei echter Änderung, damit
        // eine laufende Auswahl des Nutzers nicht durch Re-Renders des Elternteils zurückgesetzt wird.
        if (!_initialisiert || _zuletztAktuell != Aktuell)
        {
            _neu = Aktuell;
            _zuletztAktuell = Aktuell;
            _initialisiert = true;
        }
    }

    private async Task SetzenAsync()
    {
        try
        {
            await OnSetzen.InvokeAsync((_neu, _begruendung));
            Snackbar.Add($"Einstufung auf {EinstufungAnzeige.Name(_neu)} gesetzt.", Severity.Success);
            _begruendung = null;
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
