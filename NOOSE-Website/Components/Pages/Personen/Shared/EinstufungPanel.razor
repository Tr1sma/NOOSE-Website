@* Einstufung anzeigen/ändern (mit Rang-Gate) und Verlauf als Zeitleiste. Akten-agnostisch:
   der Aufrufer reicht aktuelle Einstufung + Verlauf herein und behandelt das Setzen via OnSetzen. *@
@inject ISnackbar Snackbar

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
        <MudText Typo="Typo.subtitle1">Aktuelle Einstufung:</MudText>
        <EinstufungBadge Wert="Aktuell" />
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudText Typo="Typo.subtitle2" Class="mb-2">Einstufung ändern</MudText>
        <MudStack Spacing="2">
            <MudSelect T="Einstufung" @bind-Value="_neu" Label="Neue Einstufung" Variant="Variant.Outlined" Dense="true">
                @foreach (var e in EinstufungAnzeige.Alle)
                {
                    <MudSelectItem Value="e" Disabled="@(e == Einstufung.GesichertStaatsgefaehrdend && !_darfHoechste)">
                        @EinstufungAnzeige.Name(e)
                    </MudSelectItem>
                }
            </MudSelect>
            @if (!_darfHoechste)
            {
                <MudAlert Severity="Severity.Info" Dense="true" Variant="Variant.Outlined">
                    „Gesichert staatsgefährdend" kann erst ab Senior Special Agent direkt gesetzt werden –
                    darunter per Antrag (kommt in Phase 5).
                </MudAlert>
            }
            <MudTextField @bind-Value="_begruendung" Label="Begründung (optional)" Lines="2" Variant="Variant.Outlined" />
            <div>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save"
                           OnClick="SetzenAsync" Disabled="@(_neu == Aktuell)">Einstufung speichern</MudButton>
            </div>
        </MudStack>
    </MudPaper>

    <MudText Typo="Typo.subtitle2">Verlauf</MudText>
    @if (Verlauf.Count == 0)
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Einstufungs-Änderungen.</MudText>
    }
    else
    {
        <MudTimeline TimelinePosition="TimelinePosition.Start">
            @foreach (var v in Verlauf.OrderByDescending(x => x.Zeitpunkt))
            {
                <MudTimelineItem Color="Color.Primary" Size="Size.Small">
                    <MudText Typo="Typo.body2"><b>@EinstufungAnzeige.Name(v.Wert)</b></MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                        @v.Zeitpunkt.ToLocalTime().ToString("dd.MM.yyyy HH:mm") · @(v.AgentName ?? "—")
                    </MudText>
                    @if (!string.IsNullOrWhiteSpace(v.Begruendung))
                    {
                        <MudText Typo="Typo.body2">@v.Begruendung</MudText>
                    }
                </MudTimelineItem>
            }
        </MudTimeline>
    }
</MudStack>

@code {
    [Parameter, EditorRequired] public Einstufung Aktuell { get; set; }
    [Parameter, EditorRequired] public IReadOnlyList<EinstufungVerlauf> Verlauf { get; set; } = Array.Empty<EinstufungVerlauf>();
    [Parameter, EditorRequired] public ClaimsPrincipal User { get; set; } = default!;
    /// <summary>Wird mit (neue Einstufung, Begründung) aufgerufen; der Aufrufer persistiert und lädt neu.</summary>
    [Parameter, EditorRequired] public EventCallback<(Einstufung Neu, string? Begruendung)> OnSetzen { get; set; }

    private Einstufung _neu;
    private Einstufung _zuletztAktuell;
    private bool _initialisiert;
    private string? _begruendung;
    private bool _darfHoechste;

    protected override void OnParametersSet()
    {
        _darfHoechste = User.DarfHoechsteEinstufung();
        // Auswahl an die aktuelle Einstufung angleichen – aber nur bei echter Änderung, damit
        // eine laufende Auswahl des Nutzers nicht durch Re-Renders des Elternteils zurückgesetzt wird.
        if (!_initialisiert || _zuletztAktuell != Aktuell)
        {
            _neu = Aktuell;
            _zuletztAktuell = Aktuell;
            _initialisiert = true;
        }
    }

    private async Task SetzenAsync()
    {
        try
        {
            await OnSetzen.InvokeAsync((_neu, _begruendung));
            Snackbar.Add($"Einstufung auf {EinstufungAnzeige.Name(_neu)} gesetzt.", Severity.Success);
            _begruendung = null;
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
