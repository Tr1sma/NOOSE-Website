@* Rück-Verknüpfungen einer Person: Fraktionen und Personengruppen, denen sie angehört.
   Hinzufügen/Entfernen direkt hier; eine Fraktions-Mitgliedschaft erzeugt automatisch
   „Fraktionskollege"-Verknüpfungen zu den übrigen Mitgliedern (siehe Tab „Verknüpfungen"). *@
@inject IPersonService PersonService
@inject IFraktionService FraktionService
@inject IPersonengruppeService GruppeService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudText Typo="Typo.subtitle1">Zugehörigkeit (@_zugehoerigkeiten.Count)</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="HinzufuegenAsync">
            Fraktion / Gruppe hinzufügen
        </MudButton>
    </MudStack>

    @if (_laden)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_zugehoerigkeiten.Count == 0)
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">Keine Fraktions- oder Gruppen-Zugehörigkeit erfasst.</MudText>
    }
    else
    {
        @foreach (var z in _zugehoerigkeiten)
        {
            <MudPaper Class="pa-3" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@TypIcon(z.Typ)" Color="Color.Primary" Size="Size.Small" />
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">@TypAnzeige(z.Typ)</MudChip>
                        <MudLink Href="@Route(z)" Typo="Typo.body2"><b>@z.Name</b></MudLink>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@z.Aktenzeichen</MudText>
                        @if (z.IstLeitung)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled" Icon="@Icons.Material.Filled.Star">Leitung</MudChip>
                        }
                        @if (!string.IsNullOrWhiteSpace(z.Rolle))
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">@z.Rolle</MudChip>
                        }
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">seit @z.BeitrittAm.ToLocalTime().ToString("dd.MM.yyyy")</MudText>
                    </MudStack>
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                   OnClick="@(() => EntfernenAsync(z))" aria-label="Zugehörigkeit entfernen" />
                </MudStack>
            </MudPaper>
        }
    }

    @* Mitgliedschafts-Verlauf: beendete Zugehörigkeiten mit Beitritts-/Austrittsdatum (nur lesbar). *@
    @if (!_laden && _ehemalige.Count > 0)
    {
        <MudDivider Class="my-2" />
        <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">Ehemalige Zugehörigkeiten (@_ehemalige.Count)</MudText>
        @foreach (var z in _ehemalige)
        {
            <MudPaper Class="pa-3" Outlined="true" Style="opacity:.7;">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@TypIcon(z.Typ)" Color="Color.Default" Size="Size.Small" />
                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">@TypAnzeige(z.Typ)</MudChip>
                    <MudLink Href="@Route(z)" Typo="Typo.body2">@z.Name</MudLink>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@z.Aktenzeichen</MudText>
                    @if (z.IstLeitung)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Star">Leitung</MudChip>
                    }
                    @if (!string.IsNullOrWhiteSpace(z.Rolle))
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">@z.Rolle</MudChip>
                    }
                    <MudSpacer />
                    <MudIcon Icon="@Icons.Material.Filled.DateRange" Size="Size.Small" Class="mud-text-secondary" />
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                        @z.BeitrittAm.ToLocalTime().ToString("dd.MM.yyyy") – @(z.BeendetAm?.ToLocalTime().ToString("dd.MM.yyyy"))
                    </MudText>
                </MudStack>
            </MudPaper>
        }
    }
</MudStack>

@code {
    [Parameter, EditorRequired] public string PersonId { get; set; } = default!;
    [Parameter, EditorRequired] public ClaimsPrincipal User { get; set; } = default!;

    @* Wird nach Hinzufügen/Entfernen ausgelöst, damit die Eltern-Akte (Übersichtskarte + Historie) aktualisiert. *@
    [Parameter] public EventCallback Changed { get; set; }

    private bool _laden = true;
    private List<PersonZugehoerigkeit> _zugehoerigkeiten = new();
    private List<PersonZugehoerigkeit> _ehemalige = new();

    protected override async Task OnInitializedAsync() => await LadenAsync();

    private async Task LadenAsync()
    {
        _laden = true;
        var istFuehrung = User.IstFuehrung();
        _zugehoerigkeiten = await PersonService.GetZugehoerigkeitenAsync(PersonId, istFuehrung);
        _ehemalige = await PersonService.GetEhemaligeZugehoerigkeitenAsync(PersonId, istFuehrung);
        _laden = false;
    }

    @* Nach einer Änderung: ist die Komponente in eine Akte eingebunden, benachrichtigt sie die Eltern – die
       re-keyen dieses Panel (frisches Neuladen) und aktualisieren die Übersichtskarte. Sonst lädt sie sich
       selbst neu (Standalone-Betrieb). Vermeidet Doppel-Laden über das Re-Key. *@
    private async Task AktualisierenAsync()
    {
        if (Changed.HasDelegate)
        {
            await Changed.InvokeAsync();
        }
        else
        {
            await LadenAsync();
        }
    }

    private async Task HinzufuegenAsync()
    {
        var fraktionIds = _zugehoerigkeiten.Where(z => z.Typ == nameof(Fraktion)).Select(z => z.Id).ToList();
        var gruppenIds = _zugehoerigkeiten.Where(z => z.Typ == nameof(Personengruppe)).Select(z => z.Id).ToList();
        var wahl = await ZugehoerigkeitDialog.ZeigenAsync(DialogService, User.IstFuehrung(), fraktionIds, gruppenIds);
        if (wahl is null)
        {
            return;
        }
        try
        {
            if (wahl.Typ == nameof(Fraktion))
            {
                await FraktionService.MitgliedHinzufuegenAsync(wahl.ZielId, new MitgliedEingabe { PersonId = PersonId }, User);
            }
            else
            {
                await GruppeService.MitgliedHinzufuegenAsync(wahl.ZielId, new GruppeMitgliedEingabe { PersonId = PersonId }, User);
            }
            Snackbar.Add("Zugehörigkeit hinzugefügt.", Severity.Success);
            await AktualisierenAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task EntfernenAsync(PersonZugehoerigkeit z)
    {
        var ok = await BestaetigenDialog.ZeigenAsync(DialogService, "Zugehörigkeit entfernen?",
            $"Die Mitgliedschaft in „{z.Name}“ wird entfernt.", "Entfernen");
        if (!ok)
        {
            return;
        }
        if (z.Typ == nameof(Fraktion))
        {
            await FraktionService.MitgliedEntfernenAsync(z.MitgliedId, User);
        }
        else
        {
            await GruppeService.MitgliedEntfernenAsync(z.MitgliedId, User);
        }
        Snackbar.Add("Zugehörigkeit entfernt.", Severity.Success);
        await AktualisierenAsync();
    }

    private static string Route(PersonZugehoerigkeit z)
        => z.Typ == nameof(Personengruppe) ? $"/personengruppen/{z.Id}" : $"/fraktionen/{z.Id}";

    private static string TypAnzeige(string typ)
        => typ == nameof(Personengruppe) ? "Gruppe" : "Fraktion";

    private static string TypIcon(string typ)
        => typ == nameof(Personengruppe) ? Icons.Material.Filled.Diversity3 : Icons.Material.Filled.Groups;
}
