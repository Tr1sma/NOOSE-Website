@* Zeigt den effektiven Lebensstatus farbig an. Bei laufendem Tot-Fenster mit Respawn-Countdown. *@
@{
    var jetzt = DateTime.UtcNow;
    var effektiv = LebensstatusLogic.Effektiv(Status, TotBis, jetzt);
    var imFenster = LebensstatusLogic.IstTotFenster(Status, TotBis, jetzt);
    var minuten = LebensstatusLogic.VerbleibendeMinuten(TotBis, jetzt);
}
<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
    <MudIcon Icon="@Icon(effektiv)" Color="@Farbe(effektiv)" Size="Size.Small" />
    <MudText Typo="Typo.body2" Color="@Farbe(effektiv)">
        @if (imFenster)
        {
            @($"Tot · respawnt in {minuten} Min")
        }
        else
        {
            @LebensstatusAnzeige.Name(effektiv)
        }
    </MudText>
</MudStack>

@code {
    [Parameter, EditorRequired] public Lebensstatus Status { get; set; }
    [Parameter] public DateTime? TotBis { get; set; }

    private static Color Farbe(Lebensstatus s) => s switch
    {
        Lebensstatus.Lebend => Color.Success,
        Lebensstatus.Tot => Color.Error,
        Lebensstatus.Fluechtig => Color.Warning,
        _ => Color.Default,
    };

    private static string Icon(Lebensstatus s) => s switch
    {
        Lebensstatus.Lebend => Icons.Material.Filled.Favorite,
        Lebensstatus.Tot => Icons.Material.Filled.HeartBroken,
        Lebensstatus.Fluechtig => Icons.Material.Filled.DirectionsRun,
        _ => Icons.Material.Filled.Help,
    };
}
