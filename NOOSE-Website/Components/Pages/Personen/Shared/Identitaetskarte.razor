@* Identitäts-/Steckkarte der Personen-Akte: Mugshot und Kerndaten auf einen Blick.
   Als Avatar dient das aktuellste hochgeladene Foto (neueste Aufnahme der Person). *@
@{
    var foto = Person.Fotos.OrderByDescending(f => f.ErstelltAm).FirstOrDefault();
}
<MudPaper Class="pa-4" Elevation="2">
    <MudStack Spacing="3">
        @* Mugshot bzw. Initialen-Platzhalter, falls noch kein Foto hinterlegt ist. *@
        @if (foto is not null)
        {
            <MudImage Src="@($"/dateien/personen/foto/{foto.Id}")" Alt="@Person.Name"
                      Height="220" ObjectFit="ObjectFit.Cover" Class="rounded" Style="width:100%;" />
        }
        else
        {
            <MudStack AlignItems="AlignItems.Center" Class="py-4">
                <MudAvatar Color="Color.Primary" Rounded="true" Style="height:140px;width:140px;font-size:3rem;">
                    @Initialen(Person.Name)
                </MudAvatar>
            </MudStack>
        }

        @* Name + Verschlusssache-Kennzeichnung *@
        <div>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudText Typo="Typo.h5">@Person.Name</MudText>
                @if (Person.IstVerschlusssache)
                {
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Warning" Size="Size.Small" Title="Verschlusssache" />
                }
            </MudStack>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">@Person.Aktenzeichen</MudText>
        </div>

        @* Status-Badges *@
        <MudStack Spacing="1">
            <LebensstatusBadge Status="Person.Lebensstatus" TotBis="Person.TotBis" />
            <EinstufungBadge Wert="Person.Einstufung" />
        </MudStack>

        <MudDivider />

        @* Meta + Kennzahlen aus den bereits geladenen Daten *@
        <MudText Typo="Typo.caption" Class="mud-text-secondary">
            Zuletzt aktualisiert: @((Person.GeaendertAm ?? Person.ErstelltAm).ToLocalTime().ToString("dd.MM.yyyy HH:mm"))
        </MudText>
        <MudStack Row="true" Spacing="4" Class="flex-wrap">
            @foreach (var (wert, label) in Kennzahlen())
            {
                <MudStack Spacing="0" AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.h6">@wert</MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@label</MudText>
                </MudStack>
            }
        </MudStack>
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired] public Person Person { get; set; } = default!;

    private IEnumerable<(int Wert, string Label)> Kennzahlen()
    {
        yield return (Person.Fotos.Count, "Fotos");
        yield return (Person.Aliase.Count, "Aliase");
        yield return (Person.Telefonnummern.Count, "Telefon");
    }

    private static string Initialen(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
        {
            return "?";
        }
        var teile = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        var buchstaben = teile.Take(2).Select(t => t[0]);
        return string.Concat(buchstaben).ToUpperInvariant();
    }
}
