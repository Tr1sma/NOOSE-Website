@* Editor für die Mehrfach-Felder des Steckbriefs. Bindet direkt an das übergebene PersonEingabe.
   Waffen/Fahrzeuge/Orte nutzen die Chip-Eingabe mit Katalog-Vorschlägen; Aliase/Telefon bleiben Zeilen. *@
<MudGrid>
    <MudItem xs="12" md="6">
        <MudStack Spacing="1">
            <MudText Typo="Typo.subtitle2">Aliase</MudText>
            @foreach (var a in Eingabe.Aliase)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudTextField @bind-Value="a.Aliasname" Placeholder="Aliasname" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                   OnClick="@(() => Eingabe.Aliase.Remove(a))" aria-label="Entfernen" />
                </MudStack>
            }
            <MudButton StartIcon="@Icons.Material.Filled.Add" Size="Size.Small" OnClick="@(() => Eingabe.Aliase.Add(new()))">Alias hinzufügen</MudButton>
        </MudStack>

        <MudStack Spacing="1" Class="mt-4">
            <MudText Typo="Typo.subtitle2">Telefonnummern</MudText>
            @foreach (var t in Eingabe.Telefonnummern)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudTextField @bind-Value="t.Nummer" Placeholder="Nummer" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    <MudTextField @bind-Value="t.Bezeichnung" Placeholder="Bezeichnung (optional)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                   OnClick="@(() => Eingabe.Telefonnummern.Remove(t))" aria-label="Entfernen" />
                </MudStack>
            }
            <MudButton StartIcon="@Icons.Material.Filled.Add" Size="Size.Small" OnClick="@(() => Eingabe.Telefonnummern.Add(new()))">Nummer hinzufügen</MudButton>
        </MudStack>

        <div class="mt-4">
            <SteckbriefMehrfachFeld TItem="WaffeEingabe" Titel="Waffen" Items="Eingabe.Waffen"
                                    Typ="VorschlagTyp.Waffe" HauptPlaceholder="Waffe" />
        </div>
    </MudItem>

    <MudItem xs="12" md="6">
        <SteckbriefMehrfachFeld TItem="FahrzeugEingabe" Titel="Fahrzeuge" Items="Eingabe.Fahrzeuge"
                                Typ="VorschlagTyp.Fahrzeug" ZeigeZusatz="true"
                                HauptPlaceholder="Fahrzeug" ZusatzPlaceholder="Kennzeichen (optional)" />

        <div class="mt-4">
            <SteckbriefMehrfachFeld TItem="OrtEingabe" Titel="Bekannte Orte" Items="Eingabe.Orte"
                                    Typ="VorschlagTyp.Ort" ZeigeZusatz="true"
                                    HauptPlaceholder="Ort" ZusatzPlaceholder="Notiz (optional)" />
        </div>
    </MudItem>
</MudGrid>

@code {
    [Parameter, EditorRequired] public PersonEingabe Eingabe { get; set; } = default!;
}
