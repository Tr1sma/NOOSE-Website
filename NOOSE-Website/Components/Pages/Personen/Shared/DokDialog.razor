@* Formular-Dialog zum Anlegen eines Personen-Doks. Liefert eine PersonDokEingabe zurück. *@
@inject IFraktionService FraktionService
@inject IPersonengruppeService GruppeService
<MudDialog>
    <DialogContent>
        <MudForm @ref="_form">
            <MudStack Spacing="3">
                <MudGrid>
                    <MudItem xs="7">
                        <MudDatePicker Label="Datum der Maßnahme" @bind-Date="_datum" Required="true"
                                       RequiredError="Datum ist erforderlich" />
                    </MudItem>
                    <MudItem xs="5">
                        <MudTimePicker Label="Uhrzeit" @bind-Time="_zeit" />
                    </MudItem>
                </MudGrid>
                <MudSelect T="MassnahmeAusgang" Label="Beendigung der Maßnahme" @bind-Value="_eingabe.Ausgang" Variant="Variant.Outlined">
                    @foreach (var a in MassnahmeAusgangAnzeige.Alle)
                    {
                        <MudSelectItem Value="a">@MassnahmeAusgangAnzeige.Name(a)</MudSelectItem>
                    }
                </MudSelect>
                @if (_eingabe.Ausgang == MassnahmeAusgang.Erschossen)
                {
                    <MudAlert Severity="Severity.Warning" Dense="true" Variant="Variant.Outlined">
                        Setzt den Lebensstatus für 20 Minuten auf „Tot" (Respawn-Zeit).
                    </MudAlert>
                }
                else if (_eingabe.Ausgang == MassnahmeAusgang.Spritze)
                {
                    <MudAlert Severity="Severity.Info" Dense="true" Variant="Variant.Outlined">
                        Amnestie-Spritze: Person lebt weiter, verliert aber ihre Erinnerung.
                    </MudAlert>
                }
                <MudTextField @bind-Value="_eingabe.Grund" Label="Grund" Lines="2" Variant="Variant.Outlined" />

                @* Fraktionszugehörigkeit: bevorzugt eine bestehende Akte verknüpfen, sonst Freitext. *@
                @if (_orgVerborgen)
                {
                    @* Verknüpfte Akte ist hier nicht auflösbar (Verschlusssache/gelöscht): Picker ausblenden,
                       damit eine harmlose Bearbeitung die bestehende Verknüpfung nicht still löscht. *@
                    <MudAlert Severity="Severity.Info" Dense="true" Variant="Variant.Outlined">
                        Verknüpfte Akte ist hier nicht sichtbar (Verschlusssache oder gelöscht) – sie bleibt beim Speichern erhalten.
                    </MudAlert>
                }
                else
                {
                    <MudRadioGroup T="string" @bind-Value="Typ">
                        <MudRadio T="string" Value="@nameof(Fraktion)" Color="Color.Primary" Dense="true">Fraktion</MudRadio>
                        <MudRadio T="string" Value="@nameof(Personengruppe)" Color="Color.Primary" Dense="true">Personengruppe</MudRadio>
                    </MudRadioGroup>
                    <MudAutocomplete T="ZugehoerigkeitDialog.AkteTreffer" Label="Fraktion / Gruppe (verknüpft)"
                                     @bind-Value="_ziel" SearchFunc="@Suchen" ToStringFunc="@(a => a?.Name ?? string.Empty)"
                                     Variant="Variant.Outlined" Clearable="true" CoerceText="false" CoerceValue="false"
                                     ResetValueOnEmptyText="true" MinCharacters="0" Immediate="true"
                                     Adornment="Adornment.Start" AdornmentIcon="@(IstFraktion ? Icons.Material.Filled.Groups : Icons.Material.Filled.Diversity3)"
                                     HelperText="Bestehende Akte verknüpfen – oder leer lassen und unten Freitext nutzen.">
                        <ItemTemplate Context="a">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@(IstFraktion ? Icons.Material.Filled.Groups : Icons.Material.Filled.Diversity3)" Size="Size.Small" Color="Color.Primary" />
                                <MudText Typo="Typo.body2">@a.Name</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@a.Aktenzeichen</MudText>
                            </MudStack>
                        </ItemTemplate>
                    </MudAutocomplete>
                    @if (_ziel is not null)
                    {
                        <MudCheckBox T="bool" @bind-Value="_alsMitglied" Color="Color.Primary" Dense="true"
                                     Label="Person als Mitglied dieser Akte eintragen" />
                    }
                }
                <MudTextField @bind-Value="_eingabe.Fraktion" Label="Fraktionszugehörigkeit (Freitext)" Variant="Variant.Outlined"
                              HelperText="Freitext-Fallback, wenn die Organisation nicht als Akte existiert." />
                <MudTextField @bind-Value="_eingabe.ErhalteneInformationen" Label="Erhaltene Informationen" Lines="3" Variant="Variant.Outlined" />
                <MudSwitch T="bool" @bind-Value="_eingabe.Wahrheitsserum" Color="Color.Primary" Label="Wahrheitsserum verabreicht" />
            </MudStack>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Abbrechen">Abbrechen</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Speichern">@(IstBearbeiten ? "Änderungen speichern" : "Dok speichern")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    /// <summary>Beim Bearbeiten gesetzt: vorhandene Werte zum Vorbefüllen. Null = Anlegen.</summary>
    [Parameter] public PersonDokEingabe? Vorhanden { get; set; }

    /// <summary>Steuert, ob auch Verschlusssachen in der Org-Suche erscheinen.</summary>
    [Parameter] public bool IstFuehrung { get; set; }

    /// <summary>Beim Bearbeiten: bereits aufgelöster Name/Aktenzeichen der verknüpften Org (zum Vorbefüllen der Suche).</summary>
    [Parameter] public string? VorhandenOrgName { get; set; }
    [Parameter] public string? VorhandenOrgAktenzeichen { get; set; }

    private bool IstBearbeiten => Vorhanden is not null;

    private MudForm _form = default!;
    private readonly PersonDokEingabe _eingabe = new();
    private DateTime? _datum = DateTime.Now;
    private TimeSpan? _zeit = DateTime.Now.TimeOfDay;

    private string _orgTyp = nameof(Fraktion);
    private string Typ
    {
        get => _orgTyp;
        // Typwechsel verwirft die bisherige Auswahl (Fraktion- und Gruppen-Treffer sind nicht austauschbar).
        set { if (_orgTyp != value) { _orgTyp = value; _ziel = null; } }
    }
    private bool IstFraktion => _orgTyp == nameof(Fraktion);
    private ZugehoerigkeitDialog.AkteTreffer? _ziel;
    private bool _alsMitglied;
    // True, wenn die bestehende Verknüpfung für den Nutzer nicht auflösbar ist (Verschlusssache/gelöscht) –
    // dann bleibt sie unverändert erhalten, statt durch das leere Picker-Feld gelöscht zu werden.
    private bool _orgVerborgen;

    private async Task<IEnumerable<ZugehoerigkeitDialog.AkteTreffer>> Suchen(string value, CancellationToken token)
    {
        if (IstFraktion)
        {
            var treffer = await FraktionService.SucheAsync(value, IstFuehrung, 20, token);
            return treffer.Select(f => new ZugehoerigkeitDialog.AkteTreffer(f.Id, f.Name, f.Aktenzeichen));
        }
        var gruppen = await GruppeService.SucheAsync(value, IstFuehrung, 20, token);
        return gruppen.Select(g => new ZugehoerigkeitDialog.AkteTreffer(g.Id, g.Name, g.Aktenzeichen));
    }

    protected override void OnInitialized()
    {
        if (Vorhanden is null)
        {
            return;
        }
        // Edit-Modus: Felder sowie Datum/Uhrzeit (in Ortszeit) aus den vorhandenen Werten übernehmen.
        _eingabe.Grund = Vorhanden.Grund;
        _eingabe.Fraktion = Vorhanden.Fraktion;
        _eingabe.ErhalteneInformationen = Vorhanden.ErhalteneInformationen;
        _eingabe.Wahrheitsserum = Vorhanden.Wahrheitsserum;
        _eingabe.Ausgang = Vorhanden.Ausgang;
        var lokal = Vorhanden.Zeitpunkt.ToLocalTime();
        _datum = lokal.Date;
        _zeit = lokal.TimeOfDay;
        // Verknüpfung vorbefüllen – der Name stammt aus der bereits aufgelösten Anzeige (kein Extra-Roundtrip).
        if (!string.IsNullOrWhiteSpace(Vorhanden.OrgId) && !string.IsNullOrWhiteSpace(Vorhanden.OrgTyp))
        {
            _orgTyp = Vorhanden.OrgTyp;
            if (!string.IsNullOrWhiteSpace(VorhandenOrgName))
            {
                _ziel = new ZugehoerigkeitDialog.AkteTreffer(Vorhanden.OrgId, VorhandenOrgName, VorhandenOrgAktenzeichen ?? string.Empty);
            }
            else
            {
                // Verknüpfte Akte ist nicht auflösbar (Verschlusssache/gelöscht) → erhalten, nicht still löschen.
                _orgVerborgen = true;
            }
        }
    }

    private async Task Speichern()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid)
        {
            return;
        }
        var datum = (_datum ?? DateTime.Now).Date;
        var zeit = _zeit ?? TimeSpan.Zero;
        // Eingabe ist Ortszeit → für die Speicherung nach UTC umrechnen.
        _eingabe.Zeitpunkt = DateTime.SpecifyKind(datum + zeit, DateTimeKind.Local).ToUniversalTime();
        if (_orgVerborgen)
        {
            // Nicht sichtbare Verknüpfung unverändert übernehmen (kein stilles Löschen durch das leere Feld).
            _eingabe.OrgId = Vorhanden!.OrgId;
            _eingabe.OrgTyp = Vorhanden.OrgTyp;
            _eingabe.AlsMitglied = false;
        }
        else
        {
            // Verknüpfung übernehmen; ohne Auswahl bleibt nur der Freitext.
            _eingabe.OrgId = _ziel?.Id;
            _eingabe.OrgTyp = _ziel is null ? null : _orgTyp;
            _eingabe.AlsMitglied = _ziel is not null && _alsMitglied;
        }
        MudDialog.Close(DialogResult.Ok(_eingabe));
    }

    private void Abbrechen() => MudDialog.Cancel();

    /// <summary>Zeigt den Dialog und liefert die Eingabe oder null bei Abbruch.</summary>
    public static async Task<PersonDokEingabe?> ZeigenAsync(IDialogService dialog, bool istFuehrung)
    {
        var parameters = new DialogParameters<DokDialog> { { x => x.IstFuehrung, istFuehrung } };
        var referenz = await dialog.ShowAsync<DokDialog>("Neues Dok", parameters);
        var ergebnis = await referenz.Result;
        return ergebnis is { Canceled: false, Data: PersonDokEingabe e } ? e : null;
    }

    /// <summary>Zeigt den Dialog im Bearbeiten-Modus (vorbefüllt) und liefert die geänderte Eingabe oder null bei Abbruch.</summary>
    public static async Task<PersonDokEingabe?> ZeigenZumBearbeitenAsync(IDialogService dialog, PersonDok dok, bool istFuehrung,
        string? orgName, string? orgAktenzeichen)
    {
        var vorhanden = new PersonDokEingabe
        {
            Zeitpunkt = dok.Zeitpunkt,
            Grund = dok.Grund,
            Fraktion = dok.Fraktion,
            OrgTyp = dok.OrgTyp,
            OrgId = dok.OrgId,
            ErhalteneInformationen = dok.ErhalteneInformationen,
            Wahrheitsserum = dok.Wahrheitsserum,
            Ausgang = dok.Ausgang,
        };
        var parameters = new DialogParameters<DokDialog>
        {
            { x => x.Vorhanden, vorhanden },
            { x => x.IstFuehrung, istFuehrung },
            { x => x.VorhandenOrgName, orgName },
            { x => x.VorhandenOrgAktenzeichen, orgAktenzeichen },
        };
        var referenz = await dialog.ShowAsync<DokDialog>("Dok bearbeiten", parameters);
        var ergebnis = await referenz.Result;
        return ergebnis is { Canceled: false, Data: PersonDokEingabe e } ? e : null;
    }
}
