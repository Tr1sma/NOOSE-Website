@* Generische Chip-Eingabe für ein Steckbrief-Mehrfachfeld (Waffe/Fahrzeug/Ort):
   vorhandene Werte als umbrechende Chips, Hinzufügen per Autocomplete mit Katalog-Vorschlägen
   (freie Eingabe neuer Werte möglich) plus optionalem Zusatzfeld (Kennzeichen/Notiz). *@
@typeparam TItem where TItem : ISteckbriefMehrfach, new()
@inject ISteckbriefVorschlagService VorschlagService

<MudStack Spacing="1">
    <MudText Typo="Typo.subtitle2">@Titel</MudText>

    @if (Items.Count > 0)
    {
        <MudStack Row="true" Spacing="1" Class="flex-wrap">
            @foreach (var item in Items)
            {
                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Default"
                         OnClose="@(() => Entfernen(item))">@ChipText(item)</MudChip>
            }
        </MudStack>
    }

    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="flex-wrap">
        <MudAutocomplete T="string" @bind-Value="_neuHaupt" @bind-Text="_neuHauptText"
                         SearchFunc="@Suchen" Placeholder="@HauptPlaceholder"
                         Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true"
                         CoerceText="false" CoerceValue="true" ResetValueOnEmptyText="false"
                         MinCharacters="0" Immediate="true" MaxItems="20" Clearable="true"
                         Class="flex-grow-1" Style="min-width:160px;"
                         Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" />
        @if (ZeigeZusatz)
        {
            <MudTextField @bind-Value="_neuZusatz" Placeholder="@ZusatzPlaceholder"
                          Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width:140px;" />
        }
        <MudButton StartIcon="@Icons.Material.Filled.Add" Size="Size.Small" Variant="Variant.Filled"
                   Color="Color.Primary" OnClick="Hinzufuegen"
                   Disabled="@string.IsNullOrWhiteSpace(_neuHauptText)">Hinzufügen</MudButton>
    </MudStack>
</MudStack>

@code {
    [Parameter, EditorRequired] public string Titel { get; set; } = string.Empty;
    [Parameter, EditorRequired] public List<TItem> Items { get; set; } = new();
    [Parameter, EditorRequired] public VorschlagTyp Typ { get; set; }
    [Parameter] public bool ZeigeZusatz { get; set; }
    [Parameter] public string? HauptPlaceholder { get; set; }
    [Parameter] public string? ZusatzPlaceholder { get; set; }

    private string? _neuHaupt;
    private string? _neuHauptText;
    private string? _neuZusatz;
    private IReadOnlyList<string> _vorschlaege = Array.Empty<string>();

    protected override async Task OnInitializedAsync()
        => _vorschlaege = await VorschlagService.GetAsync(Typ);

    private Task<IEnumerable<string>> Suchen(string value, CancellationToken token)
    {
        IEnumerable<string> treffer = string.IsNullOrWhiteSpace(value)
            ? _vorschlaege
            : _vorschlaege.Where(v => v.Contains(value.Trim(), StringComparison.OrdinalIgnoreCase));
        // Bereits erfasste Werte nicht erneut vorschlagen.
        return Task.FromResult(treffer.Where(v =>
            !Items.Any(i => string.Equals(i.Hauptwert, v, StringComparison.OrdinalIgnoreCase))));
    }

    private static string ChipText(TItem item)
        => string.IsNullOrWhiteSpace(item.Zusatz) ? item.Hauptwert : $"{item.Hauptwert} · {item.Zusatz}";

    private void Hinzufuegen()
    {
        // Maßgeblich ist der sichtbare Text (deckt Vorschlag-Auswahl und freie Eingabe gleichermaßen ab).
        var haupt = _neuHauptText?.Trim();
        if (string.IsNullOrWhiteSpace(haupt))
        {
            return;
        }
        // Duplikate (case-insensitiv) innerhalb derselben Person vermeiden.
        if (!Items.Any(i => string.Equals(i.Hauptwert, haupt, StringComparison.OrdinalIgnoreCase)))
        {
            var item = new TItem();
            item.Hauptwert = haupt;
            item.Zusatz = string.IsNullOrWhiteSpace(_neuZusatz) ? null : _neuZusatz.Trim();
            Items.Add(item);
        }
        _neuHaupt = null;
        _neuHauptText = null;
        _neuZusatz = null;
    }

    private void Entfernen(TItem item) => Items.Remove(item);
}
