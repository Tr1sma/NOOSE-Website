@* Formular-Dialog zum Anlegen/Bearbeiten einer Observation (Überwachungseintrag). Liefert eine ObservationEingabe zurück. *@
@inject IAgentVerwaltungService AgentService
@inject IFraktionService FraktionService
@inject IPersonengruppeService GruppeService

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form">
            <MudStack Spacing="3">
                @* Beginn des Beobachtungsfensters (Pflicht). *@
                <MudGrid>
                    <MudItem xs="7">
                        <MudDatePicker Label="Beginn (Datum)" @bind-Date="_beginnDatum" Required="true"
                                       RequiredError="Beginn ist erforderlich" />
                    </MudItem>
                    <MudItem xs="5">
                        <MudTimePicker Label="Uhrzeit" @bind-Time="_beginnZeit" />
                    </MudItem>
                </MudGrid>

                @* Ende des Beobachtungsfensters (optional). *@
                <MudGrid>
                    <MudItem xs="7">
                        <MudDatePicker Label="Ende (Datum, optional)" @bind-Date="_endeDatum" Clearable="true"
                                       HelperText="Leer lassen, wenn die Observation noch läuft / kein Ende erfasst wird." />
                    </MudItem>
                    <MudItem xs="5">
                        <MudTimePicker Label="Uhrzeit" @bind-Time="_endeZeit" Clearable="true" />
                    </MudItem>
                </MudGrid>

                <MudTextField @bind-Value="_eingabe.Ort" Label="Ort" Variant="Variant.Outlined" />
                <MudTextField @bind-Value="_eingabe.Beobachtung" Label="Beobachtung" Lines="3" Variant="Variant.Outlined" />
                <MudTextField @bind-Value="_eingabe.Ergebnis" Label="Ergebnis / Folgerung" Lines="2" Variant="Variant.Outlined" />

                @* Beobachtender Agent (Default = aktueller Nutzer). *@
                <MudAutocomplete T="Agent" Label="Beobachtender Agent" @bind-Value="_agent"
                                 SearchFunc="@SucheAgenten" ToStringFunc="@(a => a is null ? string.Empty : a.Codename)"
                                 Variant="Variant.Outlined" Clearable="true" CoerceText="false" CoerceValue="false"
                                 ResetValueOnEmptyText="true" MinCharacters="0" Immediate="true"
                                 Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Visibility"
                                 HelperText="Wer die Observation durchgeführt hat – Vorbelegung ist der erfassende Agent.">
                    <ItemTemplate Context="a">
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Color="Color.Primary" />
                            <MudText Typo="Typo.body2">@a.Codename</MudText>
                            @if (_darfKlarname && !string.IsNullOrWhiteSpace(a.Klarname))
                            {
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">(@a.Klarname)</MudText>
                            }
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@DienstgradAnzeige.Name(a.Dienstgrad)</MudText>
                        </MudStack>
                    </ItemTemplate>
                </MudAutocomplete>

                @* Optionale Verknüpfung zu einer Fraktion/Personengruppe. *@
                @if (_orgVerborgen)
                {
                    <MudAlert Severity="Severity.Info" Dense="true" Variant="Variant.Outlined">
                        Verknüpfte Akte ist hier nicht sichtbar (Verschlusssache oder gelöscht) – sie bleibt beim Speichern erhalten.
                    </MudAlert>
                }
                else
                {
                    <MudRadioGroup T="string" @bind-Value="Typ">
                        <MudRadio T="string" Value="@nameof(Fraktion)" Color="Color.Primary" Dense="true">Fraktion</MudRadio>
                        <MudRadio T="string" Value="@nameof(Personengruppe)" Color="Color.Primary" Dense="true">Personengruppe</MudRadio>
                    </MudRadioGroup>
                    <MudAutocomplete T="ZugehoerigkeitDialog.AkteTreffer" Label="Fraktion / Gruppe (verknüpft, optional)"
                                     @bind-Value="_ziel" SearchFunc="@SuchenOrg" ToStringFunc="@(a => a?.Name ?? string.Empty)"
                                     Variant="Variant.Outlined" Clearable="true" CoerceText="false" CoerceValue="false"
                                     ResetValueOnEmptyText="true" MinCharacters="0" Immediate="true"
                                     Adornment="Adornment.Start" AdornmentIcon="@(IstFraktion ? Icons.Material.Filled.Groups : Icons.Material.Filled.Diversity3)"
                                     HelperText="Bestehende Akte verknüpfen – oder leer lassen.">
                        <ItemTemplate Context="a">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@(IstFraktion ? Icons.Material.Filled.Groups : Icons.Material.Filled.Diversity3)" Size="Size.Small" Color="Color.Primary" />
                                <MudText Typo="Typo.body2">@a.Name</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@a.Aktenzeichen</MudText>
                            </MudStack>
                        </ItemTemplate>
                    </MudAutocomplete>
                }
            </MudStack>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Abbrechen">Abbrechen</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Speichern">@(IstBearbeiten ? "Änderungen speichern" : "Observation speichern")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    /// <summary>Beim Bearbeiten gesetzt: vorhandene Werte zum Vorbefüllen. Null = Anlegen.</summary>
    [Parameter] public ObservationEingabe? Vorhanden { get; set; }

    /// <summary>Steuert, ob auch Verschlusssachen in der Org-Suche erscheinen und ob Klarnamen sichtbar sind.</summary>
    [Parameter] public bool IstFuehrung { get; set; }

    /// <summary>Agent-Id, die beim Anlegen vorbelegt wird (i. d. R. der aktuelle Nutzer).</summary>
    [Parameter] public string? StandardAgentId { get; set; }

    /// <summary>Beim Bearbeiten: bereits aufgelöster Name/Aktenzeichen der verknüpften Org (zum Vorbefüllen der Suche).</summary>
    [Parameter] public string? VorhandenOrgName { get; set; }
    [Parameter] public string? VorhandenOrgAktenzeichen { get; set; }

    private bool IstBearbeiten => Vorhanden is not null;

    private MudForm _form = default!;
    private readonly ObservationEingabe _eingabe = new();
    private DateTime? _beginnDatum = DateTime.Now;
    private TimeSpan? _beginnZeit = DateTime.Now.TimeOfDay;
    private DateTime? _endeDatum;
    private TimeSpan? _endeZeit;

    private bool _darfKlarname;
    private List<Agent> _alleAgenten = new();
    private Agent? _agent;

    private string _orgTyp = nameof(Fraktion);
    private string Typ
    {
        get => _orgTyp;
        // Typwechsel verwirft die bisherige Auswahl (Fraktion- und Gruppen-Treffer sind nicht austauschbar).
        set { if (_orgTyp != value) { _orgTyp = value; _ziel = null; } }
    }
    private bool IstFraktion => _orgTyp == nameof(Fraktion);
    private ZugehoerigkeitDialog.AkteTreffer? _ziel;
    // True, wenn die bestehende Verknüpfung für den Nutzer nicht auflösbar ist (Verschlusssache/gelöscht).
    private bool _orgVerborgen;

    protected override async Task OnInitializedAsync()
    {
        _darfKlarname = IstFuehrung;
        // Auswählbare Agents laden (aktiv, ohne TeamLeitung-Marker; analog AgentZuteilenDialog).
        _alleAgenten = await AgentService.GetAuswaehlbareAsync();

        if (Vorhanden is null)
        {
            // Anlegen: beobachtenden Agent auf den aktuellen Nutzer vorbelegen.
            _agent = _alleAgenten.FirstOrDefault(a => a.Id == StandardAgentId);
            return;
        }

        // Edit-Modus: Felder + Zeitfenster (in Ortszeit) aus den vorhandenen Werten übernehmen.
        _eingabe.Ort = Vorhanden.Ort;
        _eingabe.Beobachtung = Vorhanden.Beobachtung;
        _eingabe.Ergebnis = Vorhanden.Ergebnis;
        var beginnLokal = Vorhanden.Beginn.ToLocalTime();
        _beginnDatum = beginnLokal.Date;
        _beginnZeit = beginnLokal.TimeOfDay;
        if (Vorhanden.Ende is { } ende)
        {
            var endeLokal = ende.ToLocalTime();
            _endeDatum = endeLokal.Date;
            _endeZeit = endeLokal.TimeOfDay;
        }
        _agent = _alleAgenten.FirstOrDefault(a => a.Id == Vorhanden.BeobachtenderAgentId);

        // Verknüpfung vorbefüllen – der Name stammt aus der bereits aufgelösten Anzeige (kein Extra-Roundtrip).
        if (!string.IsNullOrWhiteSpace(Vorhanden.OrgId) && !string.IsNullOrWhiteSpace(Vorhanden.OrgTyp))
        {
            _orgTyp = Vorhanden.OrgTyp;
            if (!string.IsNullOrWhiteSpace(VorhandenOrgName))
            {
                _ziel = new ZugehoerigkeitDialog.AkteTreffer(Vorhanden.OrgId, VorhandenOrgName, VorhandenOrgAktenzeichen ?? string.Empty);
            }
            else
            {
                // Verknüpfte Akte nicht auflösbar (Verschlusssache/gelöscht) → erhalten, nicht still löschen.
                _orgVerborgen = true;
            }
        }
    }

    private Task<IEnumerable<Agent>> SucheAgenten(string value, CancellationToken token)
    {
        var suche = value.Trim();
        IEnumerable<Agent> treffer = string.IsNullOrWhiteSpace(value)
            ? _alleAgenten
            : _alleAgenten.Where(a => a.Codename.Contains(suche, StringComparison.OrdinalIgnoreCase)
                            || (_darfKlarname && (a.Klarname ?? string.Empty).Contains(suche, StringComparison.OrdinalIgnoreCase)));
        return Task.FromResult(treffer);
    }

    private async Task<IEnumerable<ZugehoerigkeitDialog.AkteTreffer>> SuchenOrg(string value, CancellationToken token)
    {
        if (IstFraktion)
        {
            var treffer = await FraktionService.SucheAsync(value, IstFuehrung, 20, token);
            return treffer.Select(f => new ZugehoerigkeitDialog.AkteTreffer(f.Id, f.Name, f.Aktenzeichen));
        }
        var gruppen = await GruppeService.SucheAsync(value, IstFuehrung, 20, token);
        return gruppen.Select(g => new ZugehoerigkeitDialog.AkteTreffer(g.Id, g.Name, g.Aktenzeichen));
    }

    private async Task Speichern()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid)
        {
            return;
        }
        // Eingabe ist Ortszeit → für die Speicherung nach UTC umrechnen (vgl. Hinweis im DokDialog:
        // In Blazor Server ist „Local" die Server-Zeitzone; das Deployment muss TZ=Europe/Berlin laufen).
        var beginnDatum = (_beginnDatum ?? DateTime.Now).Date;
        var beginnZeit = _beginnZeit ?? TimeSpan.Zero;
        _eingabe.Beginn = DateTime.SpecifyKind(beginnDatum + beginnZeit, DateTimeKind.Local).ToUniversalTime();

        if (_endeDatum is { } ed)
        {
            _eingabe.Ende = DateTime.SpecifyKind(ed.Date + (_endeZeit ?? TimeSpan.Zero), DateTimeKind.Local).ToUniversalTime();
        }
        else
        {
            _eingabe.Ende = null;
        }

        _eingabe.BeobachtenderAgentId = _agent?.Id;

        if (_orgVerborgen)
        {
            // Nicht sichtbare Verknüpfung unverändert übernehmen (kein stilles Löschen durch das leere Feld).
            _eingabe.OrgId = Vorhanden!.OrgId;
            _eingabe.OrgTyp = Vorhanden.OrgTyp;
        }
        else
        {
            _eingabe.OrgId = _ziel?.Id;
            _eingabe.OrgTyp = _ziel is null ? null : _orgTyp;
        }
        MudDialog.Close(DialogResult.Ok(_eingabe));
    }

    private void Abbrechen() => MudDialog.Cancel();

    /// <summary>Zeigt den Dialog (Anlegen) und liefert die Eingabe oder null bei Abbruch.</summary>
    public static async Task<ObservationEingabe?> ZeigenAsync(IDialogService dialog, bool istFuehrung, string? standardAgentId)
    {
        var parameters = new DialogParameters<ObservationDialog>
        {
            { x => x.IstFuehrung, istFuehrung },
            { x => x.StandardAgentId, standardAgentId },
        };
        var referenz = await dialog.ShowAsync<ObservationDialog>("Neue Observation", parameters);
        var ergebnis = await referenz.Result;
        return ergebnis is { Canceled: false, Data: ObservationEingabe e } ? e : null;
    }

    /// <summary>Zeigt den Dialog im Bearbeiten-Modus (vorbefüllt) und liefert die geänderte Eingabe oder null bei Abbruch.</summary>
    public static async Task<ObservationEingabe?> ZeigenZumBearbeitenAsync(IDialogService dialog, Observation obs, bool istFuehrung,
        string? orgName, string? orgAktenzeichen)
    {
        var vorhanden = new ObservationEingabe
        {
            Beginn = obs.Beginn,
            Ende = obs.Ende,
            Ort = obs.Ort,
            Beobachtung = obs.Beobachtung,
            Ergebnis = obs.Ergebnis,
            BeobachtenderAgentId = obs.BeobachtenderAgentId,
            OrgTyp = obs.OrgTyp,
            OrgId = obs.OrgId,
        };
        var parameters = new DialogParameters<ObservationDialog>
        {
            { x => x.Vorhanden, vorhanden },
            { x => x.IstFuehrung, istFuehrung },
            { x => x.VorhandenOrgName, orgName },
            { x => x.VorhandenOrgAktenzeichen, orgAktenzeichen },
        };
        var referenz = await dialog.ShowAsync<ObservationDialog>("Observation bearbeiten", parameters);
        var ergebnis = await referenz.Result;
        return ergebnis is { Canceled: false, Data: ObservationEingabe e } ? e : null;
    }
}
