@* Detailansicht eines Personen-Doks (lesen + bearbeiten). Öffnet sich per Klick aus der Übersicht und der Akte. *@
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject IPersonDokService DokService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">
            <MudText Typo="Typo.body2">
                <b>@Dok.Zeitpunkt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</b> · @MassnahmeAusgangAnzeige.Name(Dok.Ausgang)
            </MudText>
            @if (Dok.Person is not null)
            {
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    Person: @Dok.Person.Name (@Dok.Person.Aktenzeichen)
                </MudText>
            }
            @if (!string.IsNullOrWhiteSpace(Dok.Grund))
            {
                <MudText Typo="Typo.body2"><b>Grund:</b> @Dok.Grund</MudText>
            }
            @if (!string.IsNullOrWhiteSpace(Dok.Fraktion))
            {
                <MudText Typo="Typo.body2"><b>Fraktion:</b> @Dok.Fraktion</MudText>
            }
            @if (!string.IsNullOrWhiteSpace(Dok.ErhalteneInformationen))
            {
                <div>
                    <MudText Typo="Typo.subtitle2">Erhaltene Informationen</MudText>
                    <MudText Typo="Typo.body2">@Dok.ErhalteneInformationen</MudText>
                </div>
            }
            @if (Dok.Wahrheitsserum || Dok.GedaechtnisGeloescht)
            {
                <MudStack Row="true" Spacing="2" Class="flex-wrap">
                    @if (Dok.Wahrheitsserum)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Icon="@Icons.Material.Filled.Science">Wahrheitsserum</MudChip>
                    }
                    @if (Dok.GedaechtnisGeloescht)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Icon="@Icons.Material.Filled.Psychology">Gedächtnisverlust</MudChip>
                    }
                </MudStack>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton StartIcon="@Icons.Material.Filled.Edit" OnClick="BearbeitenAsync">Bearbeiten</MudButton>
        @if (ZeigeZurAkte)
        {
            <MudButton StartIcon="@Icons.Material.Filled.Badge" OnClick="ZurAkte">Zur Akte</MudButton>
        }
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Schliessen">Schließen</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter, EditorRequired] public PersonDok Dok { get; set; } = default!;
    [Parameter, EditorRequired] public ClaimsPrincipal User { get; set; } = default!;
    [Parameter] public bool ZeigeZurAkte { get; set; } = true;

    private void Schliessen() => MudDialog.Close();

    private void ZurAkte()
    {
        MudDialog.Close();
        Nav.NavigateTo($"/personen/{Dok.PersonId}");
    }

    private async Task BearbeitenAsync()
    {
        var eingabe = await DokDialog.ZeigenZumBearbeitenAsync(DialogService, Dok);
        if (eingabe is null)
        {
            return;
        }
        await DokService.AktualisierenAsync(Dok.Id, eingabe, User);
        Snackbar.Add("Dok aktualisiert.", Severity.Success);
        // Detail schließen und dem Aufrufer „geändert" melden → Liste neu laden.
        MudDialog.Close(DialogResult.Ok(true));
    }

    /// <summary>
    /// Zeigt die Dok-Detailansicht an und liefert true, wenn das Dok darin bearbeitet wurde
    /// (damit der Aufrufer seine Liste neu laden kann).
    /// </summary>
    public static async Task<bool> ZeigenAsync(IDialogService dialog, PersonDok dok, ClaimsPrincipal user, bool zeigeZurAkte = true)
    {
        var parameters = new DialogParameters<DokDetailDialog>
        {
            { x => x.Dok, dok },
            { x => x.User, user },
            { x => x.ZeigeZurAkte, zeigeZurAkte },
        };
        var titel = dok.Person is not null ? $"Dok · {dok.Person.Name}" : "Dok";
        var referenz = await dialog.ShowAsync<DokDetailDialog>(titel, parameters);
        var ergebnis = await referenz.Result;
        return ergebnis is { Canceled: false, Data: bool geaendert } && geaendert;
    }
}
