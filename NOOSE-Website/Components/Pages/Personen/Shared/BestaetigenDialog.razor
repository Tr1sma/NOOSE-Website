@* Wiederverwendbarer Bestätigungs-Dialog (z. B. für Löschvorgänge). *@
<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.body1">@Text</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Abbrechen">Abbrechen</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="Bestaetigen">@BestaetigenText</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string Titel { get; set; } = "Bestätigen";
    [Parameter] public string Text { get; set; } = string.Empty;
    [Parameter] public string BestaetigenText { get; set; } = "Löschen";

    private void Bestaetigen() => MudDialog.Close(DialogResult.Ok(true));
    private void Abbrechen() => MudDialog.Cancel();

    /// <summary>Zeigt den Dialog und liefert true, wenn bestätigt wurde.</summary>
    public static async Task<bool> ZeigenAsync(IDialogService dialog, string titel, string text, string bestaetigenText = "Löschen")
    {
        var parameters = new DialogParameters<BestaetigenDialog>
        {
            { x => x.Titel, titel },
            { x => x.Text, text },
            { x => x.BestaetigenText, bestaetigenText },
        };
        var referenz = await dialog.ShowAsync<BestaetigenDialog>(titel, parameters);
        var ergebnis = await referenz.Result;
        return ergebnis is { Canceled: false, Data: true };
    }
}
