@* Liste der Observationen einer Person + Anlegen (Dialog) + Löschen. *@
@inject IObservationService ObservationService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudText Typo="Typo.subtitle1">Observationen (@_eintraege.Count)</MudText>
        @if (_darfSchreiben)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="NeuAsync">Neue Observation</MudButton>
        }
    </MudStack>

    @if (_laden)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_eintraege.Count == 0)
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Observationen erfasst.</MudText>
    }
    else
    {
        @foreach (var anzeige in _eintraege)
        {
            var obs = anzeige.Obs;
            <MudPaper Class="pa-3 cursor-pointer" Elevation="1" @onclick="@(() => OeffnenAsync(anzeige))">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.body2">
                        <b>@obs.Beginn.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</b>
                        @if (obs.Ende is { } ende)
                        {
                            <span> – @ende.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(anzeige.AgentCodename))
                        {
                            <span class="mud-text-secondary"> · @anzeige.AgentCodename</span>
                        }
                    </MudText>
                    @* Löschen darf den Detail-Dialog nicht mitöffnen → Klick hier stoppen. *@
                    @if (_darfSchreiben)
                    {
                        <div @onclick:stopPropagation="true">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                           OnClick="@(() => LoeschenAsync(anzeige))" aria-label="Observation löschen" />
                        </div>
                    }
                </MudStack>
                @if (!string.IsNullOrWhiteSpace(obs.Ort))
                {
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Ort: @obs.Ort</MudText>
                }
                @if (anzeige.OrgRoute is not null)
                {
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                        Verknüpft: <MudLink Href="@anzeige.OrgRoute" Typo="Typo.caption">@anzeige.OrgName</MudLink>
                    </MudText>
                }
                @if (!string.IsNullOrWhiteSpace(obs.Beobachtung))
                {
                    <MudText Typo="Typo.body2" Class="mt-1">@obs.Beobachtung</MudText>
                }
                @if (!string.IsNullOrWhiteSpace(obs.Ergebnis))
                {
                    <MudText Typo="Typo.body2" Class="mt-1"><b>Ergebnis:</b> @obs.Ergebnis</MudText>
                }
            </MudPaper>
        }
    }
</MudStack>

@code {
    [Parameter, EditorRequired] public string PersonId { get; set; } = default!;
    [Parameter, EditorRequired] public ClaimsPrincipal User { get; set; } = default!;
    [Parameter] public EventCallback Changed { get; set; }

    private bool _laden = true;
    private bool _darfSchreiben;
    private List<ObservationAnzeige> _eintraege = new();

    protected override async Task OnInitializedAsync()
    {
        _darfSchreiben = User.DarfSchreiben();
        await LadenAsync();
    }

    private async Task LadenAsync()
    {
        _laden = true;
        _eintraege = await ObservationService.GetFuerPersonAsync(PersonId, User.IstFuehrung());
        _laden = false;
    }

    // Klick auf eine Karte öffnet die Detailansicht (lesen + bearbeiten); man ist bereits in der Akte.
    private async Task OeffnenAsync(ObservationAnzeige anzeige)
    {
        var geaendert = await ObservationDetailDialog.ZeigenAsync(DialogService, anzeige, User, zeigeZurAkte: false);
        if (geaendert)
        {
            await LadenAsync();
            await Changed.InvokeAsync();
        }
    }

    private async Task NeuAsync()
    {
        var eingabe = await ObservationDialog.ZeigenAsync(DialogService, User.IstFuehrung(), User.GetAgentId());
        if (eingabe is null)
        {
            return;
        }
        try
        {
            await ObservationService.ErstellenAsync(PersonId, eingabe, User);
            Snackbar.Add("Observation gespeichert.", Severity.Success);
            await LadenAsync();
            await Changed.InvokeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task LoeschenAsync(ObservationAnzeige anzeige)
    {
        var ok = await BestaetigenDialog.ZeigenAsync(DialogService, "Observation löschen?",
            "Der Eintrag wird in den Papierkorb verschoben.");
        if (!ok)
        {
            return;
        }
        try
        {
            await ObservationService.LoeschenAsync(anzeige.Obs.Id, User);
            Snackbar.Add("Observation gelöscht.", Severity.Success);
            await LadenAsync();
            await Changed.InvokeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
