@page "/personen/{Id}"
@inject IPersonService PersonService
@inject IZugriffsLogService ZugriffsLog
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@implements IAsyncDisposable

<PageTitle>@(_person?.Name ?? "Akte") · NOOSE</PageTitle>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_person is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
        Akte nicht gefunden oder nicht zugänglich (ggf. Verschlusssache).
    </MudAlert>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/personen" aria-label="Zurück" />
        <MudIcon Icon="@Icons.Material.Filled.Badge" Color="Color.Primary" Size="Size.Large" />
        <MudText Typo="Typo.h4">@_person.Name</MudText>
        @if (_person.IstVerschlusssache)
        {
            <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Warning" Title="Verschlusssache" />
        }
        <MudSpacer />
        <MudButton Href="@($"/personen/{_person.Id}/bearbeiten")" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit">Bearbeiten</MudButton>
        <AuthorizeView Policy="@Policies.Fuehrung">
            <MudButton Color="Color.Error" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Delete" OnClick="LoeschenAsync">Löschen</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4" Class="mb-4 flex-wrap">
        <MudText Typo="Typo.body2" Class="mud-text-secondary">@_person.Aktenzeichen</MudText>
        <LebensstatusBadge Status="_person.Lebensstatus" TotBis="_person.TotBis" />
        <EinstufungBadge Wert="_person.Einstufung" />
        <MudText Typo="Typo.caption" Class="mud-text-secondary">
            Zuletzt aktualisiert: @((_person.GeaendertAm ?? _person.ErstelltAm).ToLocalTime().ToString("dd.MM.yyyy HH:mm"))
        </MudText>
    </MudStack>

    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" TabPanelsClass="pa-4">
        <MudTabPanel Text="Steckbrief" Icon="@Icons.Material.Filled.ContactPage">
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudText Typo="Typo.subtitle2">Beschreibung</MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
                        @(string.IsNullOrWhiteSpace(_person.Beschreibung) ? "—" : _person.Beschreibung)
                    </MudText>
                    <SteckbriefListe Titel="Aliase" Werte="AliasTexte()" />
                    <SteckbriefListe Titel="Telefonnummern" Werte="TelefonTexte()" />
                    <SteckbriefListe Titel="Waffen" Werte="WaffenTexte()" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <SteckbriefListe Titel="Fahrzeuge" Werte="FahrzeugTexte()" />
                    <SteckbriefListe Titel="Bekannte Orte" Werte="OrtTexte()" />
                </MudItem>
            </MudGrid>
        </MudTabPanel>
        <MudTabPanel Text="Doks" Icon="@Icons.Material.Filled.Description">
            <DokPanel PersonId="_person.Id" User="_user" PersonChanged="NeuLadenAsync" />
        </MudTabPanel>
        <MudTabPanel Text="Einstufung" Icon="@Icons.Material.Filled.Shield">
            <EinstufungPanel Person="_person" User="_user" Changed="NeuLadenAsync" />
        </MudTabPanel>
        <MudTabPanel Text="Fotos" Icon="@Icons.Material.Filled.PhotoLibrary">
            <FotoGalerie PersonId="_person.Id" Fotos="_person.Fotos" User="_user" Changed="NeuLadenAsync" />
        </MudTabPanel>
        <MudTabPanel Text="Historie" Icon="@Icons.Material.Filled.History">
            <HistorieTimeline PersonId="_person.Id" @key="_historieKey" />
        </MudTabPanel>
    </MudTabs>
}

@code {
    [Parameter] public string Id { get; set; } = default!;
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _laden = true;
    private Person? _person;
    private ClaimsPrincipal _user = default!;
    private Timer? _timer;
    private Guid _historieKey = Guid.NewGuid();

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        await LadenAsync();
        if (_person is not null)
        {
            await ZugriffsLog.LogAnsichtAsync(nameof(Person), _person.Id);
            // Hält den Tot-Countdown aktuell (rein anzeigeseitig, kein Hintergrund-Job).
            _timer = new Timer(_ => InvokeAsync(StateHasChanged), null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
        }
    }

    private async Task LadenAsync()
    {
        _laden = true;
        _person = await PersonService.GetDetailAsync(Id, _user.IstFuehrung());
        _laden = false;
    }

    private IEnumerable<string> AliasTexte() => _person!.Aliase.Select(a => a.Aliasname);
    private IEnumerable<string> WaffenTexte() => _person!.Waffen.Select(w => w.Text);
    private IEnumerable<string> TelefonTexte()
        => _person!.Telefonnummern.Select(t => t.Bezeichnung is null ? t.Nummer : $"{t.Nummer} ({t.Bezeichnung})");
    private IEnumerable<string> FahrzeugTexte()
        => _person!.Fahrzeuge.Select(f => f.Kennzeichen is null ? f.Bezeichnung : $"{f.Bezeichnung} – {f.Kennzeichen}");
    private IEnumerable<string> OrtTexte()
        => _person!.Orte.Select(o => o.Notiz is null ? o.Text : $"{o.Text} ({o.Notiz})");

    private async Task NeuLadenAsync()
    {
        await LadenAsync();
        _historieKey = Guid.NewGuid();
        StateHasChanged();
    }

    private async Task LoeschenAsync()
    {
        if (_person is null)
        {
            return;
        }
        var ok = await BestaetigenDialog.ZeigenAsync(DialogService, "Akte löschen?",
            "Die Akte wird in den Papierkorb verschoben und kann von der Führung wiederhergestellt werden.");
        if (!ok)
        {
            return;
        }
        await PersonService.LoeschenAsync(_person.Id, _user);
        Snackbar.Add("Akte in den Papierkorb verschoben.", Severity.Success);
        Nav.NavigateTo("/personen");
    }

    public ValueTask DisposeAsync()
    {
        _timer?.Dispose();
        return ValueTask.CompletedTask;
    }
}
