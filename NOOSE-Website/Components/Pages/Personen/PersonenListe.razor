@page "/personen"
@inject IPersonService PersonService
@inject IAktualitaetService Aktualitaet
@inject IDialogService DialogService
@inject NavigationManager Nav

<PageTitle>Personen-Akten · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
    <MudIcon Icon="@Icons.Material.Filled.Badge" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h4">Personen-Akten</MudText>
    <MudSpacer />
    <AuthorizeView Policy="@Policies.Fuehrung">
        <MudButton Variant="Variant.Text" Color="Color.Default" StartIcon="@Icons.Material.Filled.CallMerge"
                   OnClick="ZusammenfuehrenAsync">Zusammenführen</MudButton>
        <MudButton Href="/personen/papierkorb" Variant="Variant.Text" Color="Color.Default" StartIcon="@Icons.Material.Filled.Delete">Papierkorb</MudButton>
    </AuthorizeView>
    <AuthorizeView Policy="@Policies.Schreibrecht" Context="schreib">
        <MudButton Href="/personen/neu" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd">Neue Person</MudButton>
    </AuthorizeView>
</MudStack>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-6">
    Zentrale Personenakten des Nachrichtendienstes. Klicke eine Akte an, um Steckbrief, Doks,
    Einstufung, Fotos und Historie zu sehen.
</MudText>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudDataGrid T="PersonZeile" Items="_zeilen" Hover="true" Filterable="false" SortMode="SortMode.Multiple"
                 QuickFilter="Filter" Elevation="2" RowClick="@(args => Oeffnen(args.Item))" Dense="true">
        <ToolBarContent>
            <MudTextField @bind-Value="_suche" Placeholder="Suchen (Name, Aktenzeichen, Alias)…" Immediate="true"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" />
        </ToolBarContent>
        <Columns>
            <PropertyColumn Property="x => x.Aktenzeichen" Title="Aktenzeichen" />
            <TemplateColumn Sortable="true" Title="Name" SortBy="x => x.Name">
                <CellTemplate>
                    @* Echter Link: Mittelklick/Strg+Klick öffnet die Akte im neuen Tab; tastatur-/screenreader-erreichbar. *@
                    <MudLink Href="@($"/personen/{context.Item.Id}")" @onclick:stopPropagation="true">@context.Item.Name</MudLink>
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.Aliase" Title="Aliase" />
            <TemplateColumn Sortable="true" Title="Lebensstatus" SortBy="x => x.EffektiverLebensstatus">
                <CellTemplate>
                    <LebensstatusBadge Status="context.Item.LebensstatusRoh" TotBis="context.Item.TotBis" />
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Sortable="true" Title="Einstufung" SortBy="x => x.Einstufung">
                <CellTemplate>
                    <EinstufungBadge Wert="context.Item.Einstufung" />
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Sortable="true" Title="Gefährdung" SortBy="x => x.BedrohungsScore ?? -1" InitialDirection="SortDirection.Descending">
                <CellTemplate>
                    @if (context.Item.BedrohungsScore is { } gscore)
                    {
                        <MudTooltip Text="@($"Bedrohungs-Score {gscore}/100" + (context.Item.BedrohungsKonfidenz is { } gk ? $" · Konfidenz {gk} %" : ""))">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="@GefahrFarbe(context.Item.Gefaehrdung)">
                                @GefaehrdungsStufeLogic.Name(context.Item.Gefaehrdung)
                            </MudChip>
                        </MudTooltip>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">—</MudText>
                    }
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Sortable="true" Title="Verschluss" SortBy="x => x.IstVerschlusssache">
                <CellTemplate>
                    @if (context.Item.IstVerschlusssache)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Warning" Size="Size.Small" Title="Verschlusssache" />
                    }
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Sortable="true" Title="Aktualität" SortBy="x => x.Stufe">
                <CellTemplate>
                    <AktualitaetsAmpel Stufe="context.Item.Stufe" ReferenzdatumUtc="context.Item.AktualisiertUtc" />
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.Aktualisiert" Title="Zuletzt" Format="dd.MM.yyyy HH:mm" />
        </Columns>
        <NoRecordsContent>
            <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-6">
                <MudIcon Icon="@Icons.Material.Filled.Badge" Color="Color.Default" Size="Size.Large" />
                <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Personen-Akten – lege die erste an.</MudText>
                <AuthorizeView Policy="@Policies.Schreibrecht" Context="schreib">
                    <MudButton Href="/personen/neu" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd">Neue Person</MudButton>
                </AuthorizeView>
            </MudStack>
        </NoRecordsContent>
        <PagerContent>
            <MudDataGridPager T="PersonZeile" />
        </PagerContent>
    </MudDataGrid>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _laden = true;
    private string _suche = string.Empty;
    private List<PersonZeile> _zeilen = new();

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthStateTask).User;
        var personen = await PersonService.GetListeAsync(user.DarfVerschlusssacheLesen());
        var (warnungTage, veraltetTage) = await Aktualitaet.GetSchwelleAsync(nameof(Person));
        var jetzt = DateTime.UtcNow;
        _zeilen = personen.Select(p =>
        {
            var referenzUtc = p.GeaendertAm ?? p.ErstelltAm;
            return new PersonZeile
            {
                Id = p.Id,
                Aktenzeichen = p.Aktenzeichen,
                Name = p.Name,
                Aliase = string.Join(", ", p.Aliase.Select(a => a.Aliasname)),
                LebensstatusRoh = p.Lebensstatus,
                TotBis = p.TotBis,
                EffektiverLebensstatus = LebensstatusAnzeige.Name(LebensstatusLogic.Effektiv(p.Lebensstatus, p.TotBis, jetzt)),
                Einstufung = p.Einstufung,
                BedrohungsScore = p.BedrohungsScore,
                BedrohungsKonfidenz = p.BedrohungsKonfidenz,
                Gefaehrdung = GefaehrdungsStufeLogic.Aus(p.BedrohungsScore),
                IstVerschlusssache = p.IstVerschlusssache,
                AktualisiertUtc = referenzUtc,
                Aktualisiert = referenzUtc.ToLocalTime(),
                Stufe = AktualitaetsBewertung.Stufe(warnungTage, veraltetTage, referenzUtc, jetzt),
            };
        }).ToList();
        _laden = false;
    }

    private bool Filter(PersonZeile z)
    {
        if (string.IsNullOrWhiteSpace(_suche))
        {
            return true;
        }
        var s = _suche.Trim();
        return z.Name.Contains(s, StringComparison.OrdinalIgnoreCase)
            || z.Aktenzeichen.Contains(s, StringComparison.OrdinalIgnoreCase)
            || z.Aliase.Contains(s, StringComparison.OrdinalIgnoreCase);
    }

    private void Oeffnen(PersonZeile z) => Nav.NavigateTo($"/personen/{z.Id}");

    private static Color GefahrFarbe(GefaehrdungsStufe s) => s switch
    {
        GefaehrdungsStufe.Kritisch => Color.Error,
        GefaehrdungsStufe.Hoch => Color.Error,
        GefaehrdungsStufe.Mittel => Color.Warning,
        GefaehrdungsStufe.Niedrig => Color.Info,
        _ => Color.Default,
    };

    // Duplikat-Zusammenführen (Phase 7): nach erfolgreichem Merge direkt in die Ziel-Akte springen.
    private async Task ZusammenfuehrenAsync()
    {
        var zielId = await PersonMergeDialog.ZeigenAsync(DialogService);
        if (zielId is not null)
        {
            Nav.NavigateTo($"/personen/{zielId}");
        }
    }

    private sealed class PersonZeile
    {
        public string Id { get; set; } = string.Empty;
        public string Aktenzeichen { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string Aliase { get; set; } = string.Empty;
        public Lebensstatus LebensstatusRoh { get; set; }
        public DateTime? TotBis { get; set; }
        public string EffektiverLebensstatus { get; set; } = string.Empty;
        public Einstufung Einstufung { get; set; }
        public int? BedrohungsScore { get; set; }
        public int? BedrohungsKonfidenz { get; set; }
        public GefaehrdungsStufe Gefaehrdung { get; set; }
        public bool IstVerschlusssache { get; set; }
        public DateTime AktualisiertUtc { get; set; }
        public DateTime Aktualisiert { get; set; }
        public AktualitaetsStufe Stufe { get; set; }
    }
}
