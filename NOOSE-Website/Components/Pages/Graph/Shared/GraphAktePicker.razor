@* Auswahl einer Akte (Aktentyp + Autocomplete) für den Beziehungsgraph – Fokusknoten bzw. Pfad-Endpunkt.
   Nutzt die vorhandenen, sichtbarkeitsgefilterten SucheAsync-Dienste (wie VerknuepfungDialog). *@
@inject IPersonService PersonService
@inject IFraktionService FraktionService
@inject IPersonengruppeService GruppeService
@inject IParteiService ParteiService
@inject IOperationService OperationService
@inject IVorgangService VorgangService
@inject ITaskforceService TaskforceService

<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="flex-wrap">
    <MudSelect T="string" @bind-Value="_typ" @bind-Value:after="TypGewechseltAsync" Label="Typ" Dense="true"
               Variant="Variant.Outlined" Style="min-width:160px;" Margin="Margin.Dense">
        @foreach (var t in _typen)
        {
            <MudSelectItem Value="@t.Wert">@t.Anzeige</MudSelectItem>
        }
    </MudSelect>

    @switch (_typ)
    {
        case nameof(Person):
            <MudAutocomplete T="Person" Label="@Label" @bind-Value="_person" @bind-Value:after="Emit"
                             SearchFunc="@SuchePerson" ToStringFunc="@(p => p?.Name ?? string.Empty)"
                             Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Clearable="true" CoerceText="false"
                             ResetValueOnEmptyText="true" MinCharacters="0" Immediate="true" Style="min-width:240px;"
                             Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.PersonSearch" />
            break;
        case nameof(Fraktion):
            <MudAutocomplete T="Fraktion" Label="@Label" @bind-Value="_fraktion" @bind-Value:after="Emit"
                             SearchFunc="@SucheFraktion" ToStringFunc="@(f => f?.Name ?? string.Empty)"
                             Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Clearable="true" CoerceText="false"
                             ResetValueOnEmptyText="true" MinCharacters="0" Immediate="true" Style="min-width:240px;"
                             Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Groups" />
            break;
        case nameof(Personengruppe):
            <MudAutocomplete T="Personengruppe" Label="@Label" @bind-Value="_gruppe" @bind-Value:after="Emit"
                             SearchFunc="@SucheGruppe" ToStringFunc="@(g => g?.Name ?? string.Empty)"
                             Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Clearable="true" CoerceText="false"
                             ResetValueOnEmptyText="true" MinCharacters="0" Immediate="true" Style="min-width:240px;"
                             Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Diversity3" />
            break;
        case nameof(Partei):
            <MudAutocomplete T="Partei" Label="@Label" @bind-Value="_partei" @bind-Value:after="Emit"
                             SearchFunc="@SuchePartei" ToStringFunc="@(p => p?.Name ?? string.Empty)"
                             Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Clearable="true" CoerceText="false"
                             ResetValueOnEmptyText="true" MinCharacters="0" Immediate="true" Style="min-width:240px;"
                             Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AccountBalance" />
            break;
        case nameof(Operation):
            <MudAutocomplete T="Operation" Label="@Label" @bind-Value="_operation" @bind-Value:after="Emit"
                             SearchFunc="@SucheOperation" ToStringFunc="@(o => o?.Titel ?? string.Empty)"
                             Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Clearable="true" CoerceText="false"
                             ResetValueOnEmptyText="true" MinCharacters="0" Immediate="true" Style="min-width:240px;"
                             Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Radar" />
            break;
        case nameof(Vorgang):
            <MudAutocomplete T="Vorgang" Label="@Label" @bind-Value="_vorgang" @bind-Value:after="Emit"
                             SearchFunc="@SucheVorgang" ToStringFunc="@(v => v?.Titel ?? string.Empty)"
                             Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Clearable="true" CoerceText="false"
                             ResetValueOnEmptyText="true" MinCharacters="0" Immediate="true" Style="min-width:240px;"
                             Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.FolderSpecial" />
            break;
        case nameof(Taskforce):
            <MudAutocomplete T="Taskforce" Label="@Label" @bind-Value="_taskforce" @bind-Value:after="Emit"
                             SearchFunc="@SucheTaskforce" ToStringFunc="@(t => t?.Name ?? string.Empty)"
                             Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Clearable="true" CoerceText="false"
                             ResetValueOnEmptyText="true" MinCharacters="0" Immediate="true" Style="min-width:240px;"
                             Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Groups2" />
            break;
    }
</MudStack>

@code {
    [Parameter] public string Label { get; set; } = "Akte suchen";
    [Parameter] public bool IstFuehrung { get; set; }
    [Parameter] public string? MeId { get; set; }
    [Parameter] public bool DarfAlleTf { get; set; }
    /// <summary>Wird bei jeder Auswahländerung gefeuert (null = Auswahl geleert).</summary>
    [Parameter] public EventCallback<GraphAkteWahl?> Gewaehlt { get; set; }

    private record TypOption(string Wert, string Anzeige);
    private static readonly TypOption[] _typen =
    {
        new(nameof(Person), "Person"),
        new(nameof(Fraktion), "Fraktion"),
        new(nameof(Personengruppe), "Personengruppe"),
        new(nameof(Partei), "Partei"),
        new(nameof(Operation), "Operation"),
        new(nameof(Vorgang), "Vorgang"),
        new(nameof(Taskforce), "Taskforce"),
    };

    private string _typ = nameof(Person);
    private Person? _person;
    private Fraktion? _fraktion;
    private Personengruppe? _gruppe;
    private Partei? _partei;
    private Operation? _operation;
    private Vorgang? _vorgang;
    private Taskforce? _taskforce;

    private async Task<IEnumerable<Person>> SuchePerson(string value, CancellationToken token)
        => await PersonService.SucheAsync(value, IstFuehrung, 20, token);
    private async Task<IEnumerable<Fraktion>> SucheFraktion(string value, CancellationToken token)
        => await FraktionService.SucheAsync(value, IstFuehrung, 20, token);
    private async Task<IEnumerable<Personengruppe>> SucheGruppe(string value, CancellationToken token)
        => await GruppeService.SucheAsync(value, IstFuehrung, 20, token);
    private async Task<IEnumerable<Partei>> SuchePartei(string value, CancellationToken token)
        => await ParteiService.SucheAsync(value, IstFuehrung, 20, token);
    private async Task<IEnumerable<Operation>> SucheOperation(string value, CancellationToken token)
        => await OperationService.SucheAsync(value, IstFuehrung, 20, token);
    private async Task<IEnumerable<Vorgang>> SucheVorgang(string value, CancellationToken token)
        => await VorgangService.SucheAsync(value, IstFuehrung, 20, token);
    private async Task<IEnumerable<Taskforce>> SucheTaskforce(string value, CancellationToken token)
        => await TaskforceService.SucheAsync(value, DarfAlleTf, MeId, 20, token);

    private async Task TypGewechseltAsync()
    {
        _person = null; _fraktion = null; _gruppe = null; _partei = null; _operation = null; _vorgang = null; _taskforce = null;
        await Emit();
    }

    private async Task Emit()
    {
        var wahl = _typ switch
        {
            nameof(Person) when _person is not null => new GraphAkteWahl(nameof(Person), _person.Id, _person.Name),
            nameof(Fraktion) when _fraktion is not null => new GraphAkteWahl(nameof(Fraktion), _fraktion.Id, _fraktion.Name),
            nameof(Personengruppe) when _gruppe is not null => new GraphAkteWahl(nameof(Personengruppe), _gruppe.Id, _gruppe.Name),
            nameof(Partei) when _partei is not null => new GraphAkteWahl(nameof(Partei), _partei.Id, _partei.Name),
            nameof(Operation) when _operation is not null => new GraphAkteWahl(nameof(Operation), _operation.Id, _operation.Titel),
            nameof(Vorgang) when _vorgang is not null => new GraphAkteWahl(nameof(Vorgang), _vorgang.Id, _vorgang.Titel),
            nameof(Taskforce) when _taskforce is not null => new GraphAkteWahl(nameof(Taskforce), _taskforce.Id, _taskforce.Name),
            _ => (GraphAkteWahl?)null,
        };
        await Gewaehlt.InvokeAsync(wahl);
    }
}
