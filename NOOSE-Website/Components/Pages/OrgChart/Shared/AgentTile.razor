<MudPaper Class="pa-3" Elevation="1" Style="height:100%;">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
        <MudAvatar Color="@(IsLead ? Color.Warning : Color.Primary)" Rounded="true">@Initials(Agent.Codename)</MudAvatar>
        <MudStack Spacing="0" Style="min-width:0;">
            <MudLink Href="@($"/personal/{Agent.Id}")" Typo="Typo.body1">
                <b>@(string.IsNullOrWhiteSpace(Agent.Codename) ? "Unbenannter Agent" : Agent.Codename)</b>
            </MudLink>
            @if (MayRealName && !string.IsNullOrWhiteSpace(Agent.RealName))
            {
                <MudText Typo="Typo.caption" Class="mud-text-secondary">@Agent.RealName</MudText>
            }
            <MudStack Row="true" Spacing="1" Class="flex-wrap mt-1" AlignItems="AlignItems.Center">
                @if (ShowRank)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined"
                             Icon="@Icons.Material.Filled.MilitaryTech">@RankDisplay.Name(Agent.Rank)</MudChip>
                }
                @if (Agent.IsTRU)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">TRU</MudChip>
                }
                @if (Agent.IsHRB)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">HRB</MudChip>
                }
                @if (!string.IsNullOrWhiteSpace(RoleText))
                {
                    <MudChip T="string" Size="Size.Small" Color="@(IsLead ? Color.Warning : Color.Default)"
                             Variant="@(IsLead ? Variant.Filled : Variant.Outlined)"
                             Icon="@(IsLead ? Icons.Material.Filled.LocalPolice : null)">@RoleText</MudChip>
                }
            </MudStack>
        </MudStack>
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired] public Agent Agent { get; set; } = default!;
    [Parameter] public bool MayRealName { get; set; }
    [Parameter] public bool ShowRank { get; set; } = true;
    [Parameter] public string? RoleText { get; set; }
    [Parameter] public bool IsLead { get; set; }

    private static string Initials(string? codename)
    {
        if (string.IsNullOrWhiteSpace(codename))
        {
            return "?";
        }
        var parts = codename.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
        {
            return string.Concat(char.ToUpperInvariant(parts[0][0]), char.ToUpperInvariant(parts[1][0]));
        }
        var word = parts[0];
        return word.Length >= 2 ? word[..2].ToUpperInvariant() : word[..1].ToUpperInvariant();
    }
}
