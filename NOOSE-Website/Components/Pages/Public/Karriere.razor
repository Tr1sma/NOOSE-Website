@page "/karriere"
@layout PublicSiteLayout
@attribute [AllowAnonymous]
@attribute [ExcludeFromInteractiveRouting]

<PageTitle>Karriere · NOOSE</PageTitle>

<MudPaper Elevation="4" Class="pa-8">
    <MudStack Spacing="4">
        <MudText Typo="Typo.h4">Bewerbung beim National Office of Security Enforcement</MudText>
        <MudText Typo="Typo.body1" Class="mud-text-secondary">
            Das NOOSE rekrutiert ausgewählte Bewerber für den Dienst in der Criminal Investigation Division.
            Das Auswahlverfahren umfasst eine Sicherheitsüberprüfung, ggf. einen Eignungstest und ein
            persönliches Vorstellungsgespräch. Der gesamte Ablauf wird vertraulich über dieses Portal abgewickelt.
        </MudText>

        <AuthorizeView>
            <NotAuthorized>
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                    Melde dich mit Discord an, um eine Bewerbung einzureichen und ihren Status zu verfolgen.
                </MudAlert>
                <div>
                    <form method="post" action="/Account/PerformExternalLogin">
                        <AntiforgeryToken />
                        <input type="hidden" name="returnUrl" value="/portal" />
                        <input type="hidden" name="source" value="bewerbung" />
                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary"
                                   Size="Size.Large" StartIcon="@Icons.Material.Filled.Login">
                            Mit Discord bewerben
                        </MudButton>
                    </form>
                </div>
            </NotAuthorized>
            <Authorized Context="authCtx">
                @if (authCtx.User.IsApplicant())
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                        Du bist angemeldet. Verwalte deine Bewerbung und die Kommunikation mit dem HRB im Bewerber-Portal.
                    </MudAlert>
                    <div>
                        <MudButton Href="/portal" Variant="Variant.Filled" Color="Color.Primary"
                                   Size="Size.Large" StartIcon="@Icons.Material.Filled.Badge">
                            Zum Bewerber-Portal
                        </MudButton>
                    </div>
                }
                else
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                        Du bist als NOOSE-Agent angemeldet.
                    </MudAlert>
                    <div>
                        <MudButton Href="/dashboard" Variant="Variant.Filled" Color="Color.Primary"
                                   Size="Size.Large" StartIcon="@Icons.Material.Filled.Shield">
                            Zum Agent-Portal
                        </MudButton>
                    </div>
                }
            </Authorized>
        </AuthorizeView>

        <MudText Typo="Typo.caption" Class="mud-text-secondary">
            Das National Office of Security Enforcement entspricht hohen Standards und der höchsten Stufe der
            Geheimhaltung. Sprich mit niemandem über dein Interesse oder den Stand des Auswahlverfahrens.
        </MudText>
    </MudStack>
</MudPaper>
