<MudPaper Class="pa-4" Elevation="2">
    <MudStack Spacing="3">
        <MudStack AlignItems="AlignItems.Center" Class="py-2">
            <MudAvatar Color="Color.Primary" Rounded="true" Style="height:120px;width:120px;">
                <MudIcon Icon="@Icons.Material.Filled.Diversity3" Style="font-size:3rem;" />
            </MudAvatar>
        </MudStack>

        <div>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudText Typo="Typo.h5">@Group.Name</MudText>
                @if (Group.IsClassified)
                {
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Warning" Size="Size.Small" Title="@DocumentClassificationDisplay.Label(Group.SecrecyLevel)" />
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">@DocumentClassificationDisplay.ChipLabel(Group.SecrecyLevel)</MudChip>
                }
            </MudStack>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">@Group.CaseNumber</MudText>
        </div>

        <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Filled"
                 Icon="@KindIcon(Group.Kind)" Class="align-self-start">
            @GroupsKindDisplay.Name(Group.Kind)
        </MudChip>

        <ClassificationBadge Value="Group.Classification" />

        <InvestigationLeadDisplay Names="InvestigationLead" />

        <MudDivider />

        <div>
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudText Typo="Typo.subtitle2">Erfassungsfortschritt</MudText>
                <MudText Typo="Typo.body2">@Progress.Captured / @(Progress.Estimated?.ToString() ?? "?")</MudText>
            </MudStack>
            @if (Progress.Estimated is > 0)
            {
                <MudProgressLinear Color="Color.Primary" Value="@Percent()" Class="mt-1" Rounded="true" Size="Size.Medium" />
            }
            else
            {
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    @Progress.Captured Mitglied(er) erfasst – keine geschätzte Gesamtgröße hinterlegt.
                </MudText>
            }
        </div>

        <MudDivider />

        <MudStack Spacing="1">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <RecencyIndicator Level="@(Group.AgingDisabled ? RecencyLevel.Fresh : (RecencyLevel?)null)"
                                  RecordsType="@nameof(PersonGroup)" ReferenceDateUtc="@(Group.ModifiedAt ?? Group.CreatedAt)" />
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    Zuletzt aktualisiert: @((Group.ModifiedAt ?? Group.CreatedAt).ToLocalTime().ToString("dd.MM.yyyy HH:mm"))
                </MudText>
            </MudStack>
            <AuthorizeView Policy="@Policies.Leadership">
                <MudSwitch T="bool" Value="Group.AgingDisabled" ValueChanged="ToggleAgingAsync"
                           Color="Color.Info" Size="Size.Small" Label="Veralterung deaktiviert" />
            </AuthorizeView>
        </MudStack>
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired] public PersonGroup Group { get; set; } = default!;
    [Parameter, EditorRequired] public PersonGroupProgress Progress { get; set; } = default!;

    /// <summary>Investigation lead codenames for prominent display.</summary>
    [Parameter] public IReadOnlyList<string> InvestigationLead { get; set; } = Array.Empty<string>();

    [Parameter] public ClaimsPrincipal? User { get; set; }
    [Parameter] public EventCallback Changed { get; set; }

    [Inject] private IRecencyService Recency { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    /// <summary>Toggle this record's aging exemption.</summary>
    private async Task ToggleAgingAsync(bool value)
    {
        if (User is null)
        {
            return;
        }
        try
        {
            await Recency.SetRecordExemptionAsync(nameof(PersonGroup), Group.Id, value, User);
            Snackbar.Add(value ? "Veralterung für diese Akte deaktiviert." : "Veralterung wieder aktiv.", Severity.Success);
            await Changed.InvokeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
            StateHasChanged();
        }
    }

    private double Percent()
    {
        if (Progress.Estimated is not > 0)
        {
            return 0;
        }
        var p = (double)Progress.Captured / Progress.Estimated.Value * 100;
        return Math.Clamp(p, 0, 100);
    }

    private static string KindIcon(GroupsKind kind) => kind switch
    {
        GroupsKind.Personality => Icons.Material.Filled.Star,
        GroupsKind.PersonOfInterest => Icons.Material.Filled.PersonSearch,
        _ => Icons.Material.Filled.Diversity3,
    };
}
