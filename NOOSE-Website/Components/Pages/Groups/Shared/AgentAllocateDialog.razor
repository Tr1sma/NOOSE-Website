@inject IAgentManagementService AgentService

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3" Style="min-width:360px;">
            <MudAutocomplete T="Agent" Label="Agent" @bind-Value="_agent" AutoFocus="true"
                             SearchFunc="@SearchAgents" ToStringFunc="@(a => a is null ? string.Empty : a.Codename)"
                             Variant="Variant.Outlined" Clearable="true" CoerceText="false" CoerceValue="false"
                             ResetValueOnEmptyText="true" MinCharacters="0" Immediate="true"
                             Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.ManageAccounts"
                             HelperText="Aktiven Agent der Gruppe zuteilen.">
                <ItemTemplate Context="a">
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@(a.PartnerAgency is null ? Icons.Material.Filled.Person : Icons.Material.Filled.Handshake)"
                                 Size="Size.Small" Color="@(a.PartnerAgency is null ? Color.Primary : Color.Info)" />
                        <MudText Typo="Typo.body2">@a.Codename</MudText>
                        @if (MayRealName && !string.IsNullOrWhiteSpace(a.RealName))
                        {
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">(@a.RealName)</MudText>
                        }
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@(a.PartnerAgency is { } ag ? PartnerRankDisplay.Full(ag, a.PartnerRank) : RankDisplay.Name(a.Rank))</MudText>
                    </MudStack>
                </ItemTemplate>
            </MudAutocomplete>

            @if (MayInvestigationLeadSet)
            {
                <MudCheckBox @bind-Value="_asInvestigationLead" Color="Color.Primary" Dense="true"
                             Label="@LeadLabel" />
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Abbrechen</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save" Disabled="@(_agent is null)">Zuteilen</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public IReadOnlyList<string> ExclusionAgentIds { get; set; } = Array.Empty<string>();

    /// <summary>Only real-name viewers may search/see it, else search would leak the secret field.</summary>
    [Parameter] public bool MayRealName { get; set; }

    /// <summary>Only leadership may set the investigation-lead flag; gates the checkbox.</summary>
    [Parameter] public bool MayInvestigationLeadSet { get; set; }

    /// <summary>Label for the lead checkbox, module-dependent.</summary>
    [Parameter] public string LeadLabel { get; set; } = "Als Ermittlungsleiter zuteilen";

    private Agent? _agent;
    private bool _asInvestigationLead;
    private List<Agent> _all = new();

    protected override async Task OnInitializedAsync()
    {
        // Also exclude already-allocated agents
        var selectable = await AgentService.GetSelectableAsync();
        _all = selectable.Where(a => !ExclusionAgentIds.Contains(a.Id)).ToList();
    }

    private Task<IEnumerable<Agent>> SearchAgents(string value, CancellationToken token)
    {
        var search = value.Trim();
        IEnumerable<Agent> hit = string.IsNullOrWhiteSpace(value)
            ? _all
            : _all.Where(a => a.Codename.Contains(search, StringComparison.OrdinalIgnoreCase)
                            || (MayRealName && (a.RealName ?? string.Empty).Contains(search, StringComparison.OrdinalIgnoreCase)));
        return Task.FromResult(hit);
    }

    private void Save()
    {
        if (_agent is null)
        {
            return;
        }
        MudDialog.Close(DialogResult.Ok(new Choice(_agent.Id, MayInvestigationLeadSet && _asInvestigationLead)));
    }

    private void Cancel() => MudDialog.Cancel();

    public record Choice(string AgentId, bool AsInvestigationLead);

    /// <summary>Shows the dialog; returns the choice or null on cancel.</summary>
    public static async Task<Choice?> ShowAsync(IDialogService dialog, IReadOnlyList<string> exclusionAgentIds,
        bool mayRealName, bool mayInvestigationLeadSet, string? leadLabel = null)
    {
        var parameters = new DialogParameters<AgentAllocateDialog>
        {
            { x => x.ExclusionAgentIds, exclusionAgentIds },
            { x => x.MayRealName, mayRealName },
            { x => x.MayInvestigationLeadSet, mayInvestigationLeadSet },
        };
        if (leadLabel is not null)
        {
            parameters.Add(x => x.LeadLabel, leadLabel);
        }
        var reference = await dialog.ShowAsync<AgentAllocateDialog>("Agent zuteilen", parameters);
        var result = await reference.Result;
        return result is { Canceled: false, Data: Choice choice } ? choice : null;
    }
}
