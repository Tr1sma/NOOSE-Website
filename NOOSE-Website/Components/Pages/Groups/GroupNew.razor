@page "/personengruppen/neu"
@inject IPersonGroupService GroupService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Neue Personengruppe · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/personengruppen" aria-label="Zurück" />
    <MudIcon Icon="@Icons.Material.Filled.Diversity3" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h4">Neue Personengruppe anlegen</MudText>
</MudStack>

<MudForm @ref="_form">
    <GroupForm Input="_input" ShowClassification="true" MayHighest="_mayHighest"
                ShowMembers="true" IsLeadership="_isLeadership" SecrecyOptions="_secrecyOptions" />
</MudForm>

<MudStack Row="true" Spacing="2" Class="mt-4">
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveAsync" Disabled="_saves">Anlegen</MudButton>
    <MudButton Variant="Variant.Text" Href="/personengruppen">Abbrechen</MudButton>
</MudStack>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private MudForm _form = default!;
    private readonly PersonGroupInput _input = new();
    private ClaimsPrincipal _user = default!;
    private bool _mayHighest;
    private bool _isLeadership;
    private bool _saves;
    private IReadOnlyList<DocumentClassification> _secrecyOptions = Array.Empty<DocumentClassification>();

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        _mayHighest = _user.MayHighestClassification();
        _isLeadership = _user.IsLeadership();
        _secrecyOptions = DocumentViewerScope.AssignableOptions(_user);
    }

    private async Task SaveAsync()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid)
        {
            return;
        }

        _saves = true;
        try
        {
            var group = await GroupService.CreateAsync(_input, _user);
            Snackbar.Add($"Personengruppe {group.CaseNumber} angelegt.", Severity.Success);
            Nav.NavigateTo($"/personengruppen/{group.Id}");
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
            _saves = false;
        }
    }
}
