@page "/personengruppen/{Id}"
@inject IPersonGroupService GroupService
@inject IAccessLogService AccessLog
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IPartnerVisibilityPolicyService PartnerPolicy

<PageTitle>@(_group?.Name ?? "Personengruppe") · NOOSE</PageTitle>

@if (_load)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_group is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
        Personengruppe nicht gefunden oder nicht zugänglich (ggf. Verschlusssache).
    </MudAlert>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/personengruppen" aria-label="Zurück" />
        <MudSpacer />
        <MudTooltip Text="Druckansicht – Akte drucken / als PDF speichern">
            <MudIconButton Icon="@Icons.Material.Filled.Print" Color="Color.Default"
                           Href="@($"/personengruppen/{Id}/druck")" Target="_blank"
                           aria-label="Druckansicht öffnen" />
        </MudTooltip>
        @if (!_isPartner)
        {
            <FollowButton EntityType="@nameof(PersonGroup)" EntityId="@_group.Id" User="_user" />
            <JobCreateButton EntityType="@nameof(PersonGroup)" EntityId="@_group.Id" />
        }
        <AuthorizeView Policy="@Policies.Leadership" Context="freigabe">
            <PartnerShareButton EntityType="@nameof(PersonGroup)" EntityId="@_group.Id" />
        </AuthorizeView>
        <AuthorizeView Policy="@Policies.WriteAccess" Context="schreib">
            <MudButton Href="@($"/personengruppen/{_group.Id}/bearbeiten")" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit">Bearbeiten</MudButton>
        </AuthorizeView>
        <AuthorizeView Policy="@Policies.Leadership">
            <MudButton Color="Color.Error" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Delete" OnClick="DeleteAsync">Löschen</MudButton>
        </AuthorizeView>
    </MudStack>

    @if (!_isPartner)
    {
        <MudPaper Class="pa-2 mb-4" Elevation="1">
            <TagChips EntityType="@nameof(PersonGroup)" EntityId="@_group.Id" User="_user" />
        </MudPaper>
    }

    <MudGrid>
        <MudItem xs="12" md="4" lg="3">
            <div class="akte-steckkarte">
                <GroupCard Group="_group" Progress="_progress" InvestigationLead="_investigationLead" />
            </div>
        </MudItem>

        <MudItem xs="12" md="8" lg="9">
            @if (_renderTabs.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    Für Ihren Zugang sind in dieser Akte keine Bereiche freigegeben.
                </MudAlert>
            }
            else
            {
            <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" TabPanelsClass="pa-4"
                     @bind-ActivePanelIndex="_activeTab"
                     @bind-ActivePanelIndex:after="@(() => TabUrlState.WriteAsync(JS, Nav, _renderTabs, _activeTab))">
                @if (TabOn("stammdaten"))
                {
                <MudTabPanel Text="Stammdaten" Icon="@Icons.Material.Filled.Info">
                    <MudStack Spacing="3">
                        @if (!string.IsNullOrWhiteSpace(_group.Targets))
                        {
                            <div>
                                <MudText Typo="Typo.subtitle2">Ziele</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary">@_group.Targets</MudText>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(_group.Description))
                        {
                            <div>
                                <MudText Typo="Typo.subtitle2">Beschreibung</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary">@_group.Description</MudText>
                            </div>
                        }
                        @if (string.IsNullOrWhiteSpace(_group.Targets) && string.IsNullOrWhiteSpace(_group.Description))
                        {
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">Keine weiteren Stammdaten erfasst.</MudText>
                        }
                    </MudStack>
                </MudTabPanel>
                }
                @if (TabOn("mitglieder"))
                {
                <MudTabPanel Text="Mitglieder" Icon="@Icons.Material.Filled.Group">
                    <GroupMembersPanel GroupId="@_group.Id" User="_user" Changed="ProgressRefreshAsync" />
                </MudTabPanel>
                }
                @* assigned NOOSE agents: internal only *@
                @if (!_isPartner)
                {
                <MudTabPanel Text="Zugeteilte Agents" Icon="@Icons.Material.Filled.ManageAccounts">
                    <AgentsPanel GroupId="@_group.Id" User="_user" Changed="InvestigationLeadRefreshAsync" />
                </MudTabPanel>
                }
                @if (TabOn("einstufung"))
                {
                <MudTabPanel Text="Einstufung" Icon="@Icons.Material.Filled.Shield">
                    <ClassificationPanel Current="_group.Classification" History="_classificationHistory" User="_user" OnSet="ClassificationSetAsync"
                                     EntityType="@nameof(PersonGroup)" EntityId="@_group.Id" TargetDesignation="@($"{_group.Name} ({_group.CaseNumber})")" />
                </MudTabPanel>
                }
                @if (TabOn("doks"))
                {
                <MudTabPanel Text="Doks" Icon="@Icons.Material.Filled.Description">
                    <OrgDocsPanel OrgType="@nameof(PersonGroup)" OrgId="@_group.Id" User="_user" />
                </MudTabPanel>
                }
                @* partner-safe child services *@
                @if (TabOn("beziehungen"))
                {
                <MudTabPanel Text="Beziehungen" Icon="@Icons.Material.Filled.Hub">
                    <OrgRelationsPanel EntityType="@nameof(PersonGroup)" EntityId="@_group.Id" User="_user" />
                </MudTabPanel>
                }
                @if (TabOn("quellen"))
                {
                <MudTabPanel Text="Quellen" Icon="@Icons.Material.Filled.AttachFile">
                    <SourcesPanel EntityType="@nameof(PersonGroup)" EntityId="@_group.Id" User="_user" />
                </MudTabPanel>
                }
                @if (TabOn("wiedervorlagen"))
                {
                <MudTabPanel Text="Wiedervorlagen" Icon="@Icons.Material.Filled.EventRepeat">
                    <FollowupPanel EntityType="@nameof(PersonGroup)" EntityId="@_group.Id" User="_user" />
                </MudTabPanel>
                }
                @if (TabOn("kommentare"))
                {
                <MudTabPanel Text="Kommentare" Icon="@Icons.Material.Filled.Comment">
                    <CommentPanel EntityType="@nameof(PersonGroup)" EntityId="@_group.Id" User="_user" />
                </MudTabPanel>
                }
                @if (TabOn("zusatzfelder"))
                {
                <MudTabPanel Text="Zusatzfelder" Icon="@Icons.Material.Filled.Tune">
                    <CustomFieldsPanel EntityType="@nameof(PersonGroup)" EntityId="@_group.Id" User="_user" />
                </MudTabPanel>
                }
                @* partner-safe: timeline filters cross-refs for partners *@
                @if (TabOn("historie"))
                {
                <MudTabPanel Text="Zeitstrahl" Icon="@Icons.Material.Filled.Timeline">
                    <TimelinePanel EntityType="@nameof(PersonGroup)" EntityId="@_group.Id" User="_user" @key="_historyKey" />
                </MudTabPanel>
                }
            </MudTabs>
            }
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public string Id { get; set; } = default!;
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _load = true;
    private bool _isPartner;
    private PersonGroup? _group;
    private PersonGroupProgress _progress = new(0, null);
    private List<string> _investigationLead = new();
    private List<ClassificationHistory> _classificationHistory = new();
    private ClaimsPrincipal _user = default!;
    private Guid _historyKey = Guid.NewGuid();
    private string? _loadedId;

    // Active tab persisted in URL; order must match the MudTabPanels
    private int _activeTab;
    private static readonly string[] _tabs =
    {
        "stammdaten", "mitglieder", "agents", "einstufung", "doks",
        "beziehungen", "quellen", "wiedervorlagen", "kommentare", "zusatzfelder", "historie",
    };

    // partner tab gating: null = no restriction (internal/unconfigured/individually released)
    private IReadOnlySet<string>? _visibleTabs;
    private List<string> _renderTabs = new();
    private bool TabOn(string slug) => _visibleTabs is null || _visibleTabs.Contains(slug);
    private void RebuildRenderTabs() => _renderTabs = _tabs.Where(s => (s != "agents" || !_isPartner) && TabOn(s)).ToList();

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        _isPartner = _user.IsPartner();
    }

    // Component is reused across ids; react to id changes here since OnInitialized won't rerun
    protected override async Task OnParametersSetAsync()
    {
        if (_loadedId == Id)
        {
            return;
        }
        _loadedId = Id;
        _load = true;
        _group = null;
        await LoadAsync();
        _activeTab = TabUrlState.Read(Nav, _renderTabs);
        if (_group is not null)
        {
            await AccessLog.LogViewAsync(nameof(PersonGroup), _group.Id);
        }
    }

    private async Task LoadAsync()
    {
        // Don't set _load on reload: it would remount MudTabs and jump to the first tab
        var scope = ViewerScope.From(_user);
        _group = await GroupService.GetDetailAsync(Id, scope);
        if (_group is not null)
        {
            _classificationHistory = await GroupService.GetClassificationHistoryAsync(_group.Id, scope);
            // partners: skip progress/agent fan-out
            if (!_isPartner)
            {
                _progress = await GroupService.GetProgressAsync(_group.Id);
                await InvestigationLeadLoadAsync();
            }
        }
        _visibleTabs = _isPartner && _group is not null
            ? await PartnerPolicy.GetVisibleTabsAsync(_user, nameof(PersonGroup), _group.Id)
            : null;
        RebuildRenderTabs();
        _load = false;
    }

    private async Task InvestigationLeadLoadAsync()
    {
        if (_group is null)
        {
            return;
        }
        var el = await GroupService.GetInvestigationLeadAsync(_group.Id);
        _investigationLead = el.Select(a => a.Agent?.Codename ?? "?").ToList();
    }

    private async Task InvestigationLeadRefreshAsync()
    {
        await InvestigationLeadLoadAsync();
        StateHasChanged();
    }

    private async Task NewLoadAsync()
    {
        await LoadAsync();
        _historyKey = Guid.NewGuid();
        StateHasChanged();
    }

    private async Task ProgressRefreshAsync()
    {
        if (_group is not null)
        {
            _progress = await GroupService.GetProgressAsync(_group.Id);
            StateHasChanged();
        }
    }

    private async Task ClassificationSetAsync((Classification New, string? Justification) input)
    {
        if (_group is null)
        {
            return;
        }
        await GroupService.ClassificationSetAsync(_group.Id, input.New, input.Justification, _user);
        await NewLoadAsync();
    }

    private async Task DeleteAsync()
    {
        if (_group is null)
        {
            return;
        }
        var ok = await ConfirmDialog.ShowAsync(DialogService, "Personengruppe löschen?",
            "Die Gruppe wird in den Papierkorb verschoben und kann von der Führung wiederhergestellt werden.");
        if (!ok)
        {
            return;
        }
        await GroupService.DeleteAsync(_group.Id, _user);
        Snackbar.Add("Personengruppe in den Papierkorb verschoben.", Severity.Success);
        Nav.NavigateTo("/personengruppen");
    }
}
