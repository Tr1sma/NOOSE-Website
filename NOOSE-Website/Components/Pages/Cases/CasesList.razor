@page "/vorgaenge"
@inject ICaseService CaseService
@inject IRecencyService Recency
@inject NavigationManager Nav

<PageTitle>Vorgänge · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
    <MudIcon Icon="@Icons.Material.Filled.FolderSpecial" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h4">Vorgänge</MudText>
    <MudSpacer />
    <AuthorizeView Policy="@Policies.Leadership">
        <MudButton Href="/vorgaenge/papierkorb" Variant="Variant.Text" Color="Color.Default" StartIcon="@Icons.Material.Filled.Delete">Papierkorb</MudButton>
    </AuthorizeView>
    <AuthorizeView Policy="@Policies.WriteAccess" Context="schreib">
        <MudButton Href="/vorgaenge/neu" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add">Neuer Vorgang</MudButton>
    </AuthorizeView>
</MudStack>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-6">
    Vorgangs-/Fallakten: bündeln Personen, Operationen, Observationen und Doks zu einem Ermittlungs-Vorgang mit eigenem Status.
</MudText>

@if (_load)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudDataGrid T="CaseRow" Items="_rows" Hover="true" Filterable="false" SortMode="SortMode.Multiple"
                 QuickFilter="Filter" Elevation="2" RowClick="@(args => Open(args.Item))" Dense="true">
        <ToolBarContent>
            <MudTextField @bind-Value="_search" Placeholder="Suchen (Titel, Aktenzeichen, Typ)…" Immediate="true"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" />
            <MudSpacer />
            <MudSelect T="CaseStatus?" Value="_statusFilter" ValueChanged="StatusSelected" Label="Status" Dense="true"
                       Clearable="true" Variant="Variant.Outlined" Style="max-width:220px;">
                <MudSelectItem T="CaseStatus?" Value="@((CaseStatus?)null)">Alle</MudSelectItem>
                @foreach (var s in CaseStatusDisplay.All)
                {
                    <MudSelectItem T="CaseStatus?" Value="@s">@CaseStatusDisplay.Name(s)</MudSelectItem>
                }
            </MudSelect>
        </ToolBarContent>
        <Columns>
            <PropertyColumn Property="x => x.CaseNumber" Title="Aktenzeichen" />
            <TemplateColumn Sortable="true" Title="Titel" SortBy="x => x.Title">
                <CellTemplate>
                    @* Echter Link: Mittelklick/Strg+Klick öffnet die Akte im neuen Tab; tastatur-/screenreader-erreichbar. *@
                    <MudLink Href="@($"/vorgaenge/{context.Item.Id}")" @onclick:stopPropagation="true">@context.Item.Title</MudLink>
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.Type" Title="Typ" />
            <TemplateColumn Sortable="true" Title="Status" SortBy="x => x.Status">
                <CellTemplate>
                    <CaseStatusChip Status="context.Item.Status" />
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Sortable="true" Title="Einstufung" SortBy="x => x.Classification">
                <CellTemplate>
                    <ClassificationBadge Value="context.Item.Classification" />
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Sortable="true" Title="Verschluss" SortBy="x => x.IsClassified">
                <CellTemplate>
                    @if (context.Item.IsClassified)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Warning" Size="Size.Small" Title="Verschlusssache" />
                    }
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Sortable="true" Title="Aktualität" SortBy="x => x.Level">
                <CellTemplate>
                    <RecencyIndicator Level="context.Item.Level" ReferenceDateUtc="context.Item.RefreshedUtc" />
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.Refreshed" Title="Zuletzt" Format="dd.MM.yyyy HH:mm" />
        </Columns>
        <NoRecordsContent>
            <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-6">
                <MudIcon Icon="@Icons.Material.Filled.FolderSpecial" Color="Color.Default" Size="Size.Large" />
                <AuthorizeView Policy="@Policies.PartnerView" Context="partnerEmpty">
                    <Authorized>
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">Für Ihre Behörde wurde noch kein Vorgang freigegeben.</MudText>
                    </Authorized>
                    <NotAuthorized>
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Vorgänge – lege den ersten an.</MudText>
                    </NotAuthorized>
                </AuthorizeView>
                <AuthorizeView Policy="@Policies.WriteAccess" Context="schreib">
                    <MudButton Href="/vorgaenge/neu" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add">Neuer Vorgang</MudButton>
                </AuthorizeView>
            </MudStack>
        </NoRecordsContent>
        <PagerContent>
            <MudDataGridPager T="CaseRow" />
        </PagerContent>
    </MudDataGrid>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _load = true;
    private string _search = string.Empty;
    private CaseStatus? _statusFilter;
    private List<CaseRow> _rows = new();

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthStateTask).User;
        var cases = await CaseService.GetListAsync(ViewerScope.From(user));
        var (warningDays, staleDays) = await Recency.GetThresholdAsync(nameof(Case));
        var now = DateTime.UtcNow;
        _rows = cases.Select(v =>
        {
            var referenceUtc = v.ModifiedAt ?? v.CreatedAt;
            return new CaseRow
            {
                Id = v.Id,
                CaseNumber = v.CaseNumber,
                Title = v.Title,
                Type = v.Type ?? string.Empty,
                Status = v.Status,
                Classification = v.Classification,
                IsClassified = v.IsClassified,
                RefreshedUtc = referenceUtc,
                Refreshed = referenceUtc.ToLocalTime(),
                Level = RecencyAssessment.Level(warningDays, staleDays, referenceUtc, now),
            };
        }).ToList();
        _load = false;
    }

    private void StatusSelected(CaseStatus? status)
    {
        _statusFilter = status;
        StateHasChanged();
    }

    private bool Filter(CaseRow z)
    {
        if (_statusFilter is not null && z.Status != _statusFilter)
        {
            return false;
        }
        if (string.IsNullOrWhiteSpace(_search))
        {
            return true;
        }
        var s = _search.Trim();
        return z.Title.Contains(s, StringComparison.OrdinalIgnoreCase)
            || z.CaseNumber.Contains(s, StringComparison.OrdinalIgnoreCase)
            || z.Type.Contains(s, StringComparison.OrdinalIgnoreCase);
    }

    private void Open(CaseRow z) => Nav.NavigateTo($"/vorgaenge/{z.Id}");

    private sealed class CaseRow
    {
        public string Id { get; set; } = string.Empty;
        public string CaseNumber { get; set; } = string.Empty;
        public string Title { get; set; } = string.Empty;
        public string Type { get; set; } = string.Empty;
        public CaseStatus Status { get; set; }
        public Classification Classification { get; set; }
        public bool IsClassified { get; set; }
        public DateTime RefreshedUtc { get; set; }
        public DateTime Refreshed { get; set; }
        public RecencyLevel Level { get; set; }
    }
}
