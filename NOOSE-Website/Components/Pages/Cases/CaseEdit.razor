@page "/vorgaenge/{Id}/bearbeiten"
@inject ICaseService CaseService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Vorgang bearbeiten · NOOSE</PageTitle>

@if (_load)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_input is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
        Vorgang nicht gefunden oder nicht zugänglich.
    </MudAlert>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="@($"/vorgaenge/{Id}")" aria-label="Zurück" />
        <MudIcon Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Large" />
        <MudText Typo="Typo.h4">Vorgang bearbeiten</MudText>
    </MudStack>

    <MudForm @ref="_form">
        <CaseForm Input="_input" ShowClassification="false" IsLeadership="_isLeadership" SecrecyOptions="_secrecyOptions" />
    </MudForm>
    <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2">
        Hinweis: Die Einstufung wird in der Akte unter „Einstufung" geändert (mit Verlauf und Rang-Prüfung).
    </MudText>

    <MudStack Row="true" Spacing="2" Class="mt-4">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveAsync" Disabled="_saves">Speichern</MudButton>
        <MudButton Variant="Variant.Text" Href="@($"/vorgaenge/{Id}")">Abbrechen</MudButton>
    </MudStack>
}

@code {
    [Parameter] public string Id { get; set; } = default!;
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private MudForm _form = default!;
    private CaseInput? _input;
    private ClaimsPrincipal _user = default!;
    private bool _isLeadership;
    private bool _load = true;
    private bool _saves;
    private string? _loadedId;
    private IReadOnlyList<DocumentClassification> _secrecyOptions = Array.Empty<DocumentClassification>();

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        _isLeadership = _user.IsLeadership();
        _secrecyOptions = DocumentViewerScope.AssignableOptions(_user);
    }

    // component is reused across Id navigation; OnInitializedAsync won't re-run
    protected override async Task OnParametersSetAsync()
    {
        if (_loadedId == Id)
        {
            return;
        }
        _loadedId = Id;
        _load = true;
        _input = null;
        var v = await CaseService.GetDetailAsync(Id, ViewerScope.From(_user));
        if (v is not null)
        {
            _input = new CaseInput
            {
                Title = v.Title,
                Type = v.Type,
                Status = v.Status,
                Description = v.Description,
                Summary = v.Summary,
                ClosingNote = v.ClosingNote,
                Classification = v.Classification,
                SecrecyLevel = v.SecrecyLevel,
            };
        }
        _load = false;
    }

    private async Task SaveAsync()
    {
        if (_input is null)
        {
            return;
        }
        await _form.ValidateAsync();
        if (!_form.IsValid)
        {
            return;
        }

        _saves = true;
        try
        {
            await CaseService.RefreshAsync(Id, _input, _user);
            Snackbar.Add("Änderungen gespeichert.", Severity.Success);
            Nav.NavigateTo($"/vorgaenge/{Id}");
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
            _saves = false;
        }
    }
}
