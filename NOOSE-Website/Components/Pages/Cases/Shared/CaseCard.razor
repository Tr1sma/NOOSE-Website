<MudPaper Class="pa-4" Elevation="2">
    <MudStack Spacing="3">
        <MudStack AlignItems="AlignItems.Center" Class="py-2">
            <MudAvatar Color="Color.Primary" Rounded="true" Style="height:120px;width:120px;">
                <MudIcon Icon="@Icons.Material.Filled.FolderSpecial" Style="font-size:3rem;" />
            </MudAvatar>
        </MudStack>

        <div>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudText Typo="Typo.h5">@Case.Title</MudText>
                @if (Case.IsClassified)
                {
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Warning" Size="Size.Small" Title="Verschlusssache" />
                }
            </MudStack>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">@Case.CaseNumber</MudText>
        </div>

        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="flex-wrap">
            <CaseStatusChip Status="Case.Status" />
            @if (!string.IsNullOrWhiteSpace(Case.Type))
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">@Case.Type</MudChip>
            }
        </MudStack>

        <ClassificationBadge Value="Case.Classification" />

        <div>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-1">
                <MudIcon Icon="@Icons.Material.Filled.LocalPolice" Color="Color.Warning" Size="Size.Small" />
                <MudText Typo="Typo.subtitle2">Fallführer</MudText>
            </MudStack>
            @if (CaseLead.Count == 0)
            {
                <MudText Typo="Typo.body2" Class="mud-text-secondary">— nicht zugewiesen</MudText>
            }
            else
            {
                <MudStack Row="true" Spacing="1" Class="flex-wrap">
                    @foreach (var name in CaseLead)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined"
                                 Icon="@Icons.Material.Filled.LocalPolice">@name</MudChip>
                    }
                </MudStack>
            }
        </div>

        <MudDivider />

        @if (Case.CompletedAt is not null)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" />
                <MudText Typo="Typo.body2">Abgeschlossen: @Case.CompletedAt.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</MudText>
            </MudStack>
        }

        <MudText Typo="Typo.caption" Class="mud-text-secondary">
            Eröffnet: @Case.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
        </MudText>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <RecencyIndicator RecordsType="@nameof(Case)" ReferenceDateUtc="@(Case.ModifiedAt ?? Case.CreatedAt)" />
            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                Zuletzt aktualisiert: @((Case.ModifiedAt ?? Case.CreatedAt).ToLocalTime().ToString("dd.MM.yyyy HH:mm"))
            </MudText>
        </MudStack>
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired] public Case Case { get; set; } = default!;

    /// <summary>Case-lead codenames.</summary>
    [Parameter] public IReadOnlyList<string> CaseLead { get; set; } = Array.Empty<string>();
}
