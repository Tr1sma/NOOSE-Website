@* Belobigungen bzw. Disziplinar-Einträge eines Agents (über die Art-Parameter gesteuert). Für alle Agenten
   sichtbar; Hinzufügen/Löschen nur durch die Führung (UI + Service-Gate). Vorlage: KommentarPanel. *@
@inject IPersonalakteService PersonalakteService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudStack Spacing="3">
    <MudText Typo="Typo.subtitle1">@Titel (@_vermerke.Count)</MudText>

    <AuthorizeView Policy="@Policies.Fuehrung">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Start">
            <MudTextField @bind-Value="_neuerText" Placeholder="@($"{Titel}: neuer Eintrag …")" Lines="2"
                          Variant="Variant.Outlined" Immediate="true" Class="flex-grow-1" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="HinzufuegenAsync" Disabled="@(_speichert || string.IsNullOrWhiteSpace(_neuerText))">Hinzufügen</MudButton>
        </MudStack>
    </AuthorizeView>

    @if (_laden)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_vermerke.Count == 0)
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">Keine Einträge.</MudText>
    }
    else
    {
        @foreach (var v in _vermerke)
        {
            <MudPaper Class="pa-3" Elevation="1">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                    <div>
                        <MudText Typo="Typo.body2" Style="white-space:pre-wrap;">@v.Text</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                            @(string.IsNullOrWhiteSpace(v.AutorName) ? "—" : v.AutorName) · @v.ErstelltAm.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                        </MudText>
                    </div>
                    <AuthorizeView Policy="@Policies.Fuehrung">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                       OnClick="@(() => LoeschenAsync(v))" aria-label="Eintrag löschen" />
                    </AuthorizeView>
                </MudStack>
            </MudPaper>
        }
    }
</MudStack>

@code {
    [Parameter, EditorRequired] public string AgentId { get; set; } = default!;
    [Parameter, EditorRequired] public AgentVermerkArt Art { get; set; }
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _laden = true;
    private bool _speichert;
    private string _neuerText = string.Empty;
    private ClaimsPrincipal _user = default!;
    private List<AgentVermerk> _vermerke = new();

    private string Titel => Art == AgentVermerkArt.Belobigung ? "Belobigungen" : "Disziplinarisches";

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        await LadenAsync();
    }

    private async Task LadenAsync()
    {
        _laden = true;
        _vermerke = await PersonalakteService.GetVermerkeAsync(AgentId, Art);
        _laden = false;
    }

    private async Task HinzufuegenAsync()
    {
        if (string.IsNullOrWhiteSpace(_neuerText) || _speichert)
        {
            return;
        }
        _speichert = true;
        try
        {
            await PersonalakteService.VermerkErstellenAsync(AgentId, Art, _neuerText, _user);
            _neuerText = string.Empty;
            await LadenAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        _speichert = false;
    }

    private async Task LoeschenAsync(AgentVermerk v)
    {
        var ok = await BestaetigenDialog.ZeigenAsync(DialogService, "Eintrag löschen?", "Der Eintrag wird entfernt.");
        if (!ok)
        {
            return;
        }
        try
        {
            await PersonalakteService.VermerkLoeschenAsync(v.Id, _user);
            await LadenAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
