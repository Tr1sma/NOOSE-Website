@* Dienstgrad-Verlauf eines Agents (Timeline, neueste zuerst). Für alle Agenten sichtbar. *@
@inject IPersonalakteService PersonalakteService

<MudStack Spacing="2">
    <MudText Typo="Typo.subtitle1">Dienstgrad-Verlauf</MudText>
    @if (_laden)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_verlauf.Count == 0)
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Rangänderungen erfasst.</MudText>
    }
    else
    {
        <MudTimeline TimelinePosition="TimelinePosition.Start">
            @foreach (var v in _verlauf)
            {
                <MudTimelineItem Color="Color.Info" Size="Size.Small">
                    <MudText Typo="Typo.body2"><b>@DienstgradAnzeige.Name(v.Alt) → @DienstgradAnzeige.Name(v.Neu)</b></MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                        @v.Zeitpunkt.ToLocalTime().ToString("dd.MM.yyyy HH:mm") · @(v.AkteurName ?? "System")@(string.IsNullOrWhiteSpace(v.Grund) ? "" : " · " + v.Grund)
                    </MudText>
                </MudTimelineItem>
            }
        </MudTimeline>
    }
</MudStack>

@code {
    [Parameter, EditorRequired] public string AgentId { get; set; } = default!;

    private bool _laden = true;
    private List<AgentDienstgradVerlauf> _verlauf = new();

    protected override async Task OnInitializedAsync()
    {
        _verlauf = await PersonalakteService.GetDienstgradVerlaufAsync(AgentId);
        _laden = false;
    }
}
