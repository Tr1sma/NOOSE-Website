@* Beförderungsanträge eines Agents: Liste (für alle sichtbar), Beantragen (Führung) und Entscheiden
   (Deputy Director+/Admin). Die Entscheidung setzt den Rang (im AgentVerwaltungService) → Changed-Callback. *@
@inject IPersonalakteService PersonalakteService
@inject IAgentVerwaltungService AgentService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudText Typo="Typo.subtitle1">Beförderungsanträge (@_antraege.Count)</MudText>
        <AuthorizeView Policy="@Policies.Fuehrung">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.TrendingUp"
                       OnClick="BeantragenAsync">Beförderung beantragen</MudButton>
        </AuthorizeView>
    </MudStack>

    @if (_laden)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_antraege.Count == 0)
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">Keine Beförderungsanträge.</MudText>
    }
    else
    {
        @foreach (var a in _antraege)
        {
            <MudPaper Class="pa-3" Elevation="1">
                <MudStack Spacing="1">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="flex-wrap">
                        <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Small" Color="Color.Primary" />
                        <MudText Typo="Typo.body2"><b>Ziel: @DienstgradAnzeige.Name(a.ZielDienstgrad)</b></MudText>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="@StatusFarbe(a.Status)">@BefoerderungStatusAnzeige.Name(a.Status)</MudChip>
                    </MudStack>
                    @if (!string.IsNullOrWhiteSpace(a.Begruendung))
                    {
                        <MudText Typo="Typo.body2" Style="white-space:pre-wrap;">@a.Begruendung</MudText>
                    }
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                        Beantragt von @(a.AntragstellerName ?? "—") · @a.ErstelltAm.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                        @if (a.Status != BefoerderungStatus.Beantragt && a.EntschiedenAm is not null)
                        {
                            <span> · entschieden von @(a.EntscheiderName ?? "—") am @a.EntschiedenAm.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                        }
                    </MudText>

                    @if (a.Status == BefoerderungStatus.Beantragt)
                    {
                        <AuthorizeView Policy="@Policies.BefoerderungEntscheiden">
                            <MudStack Row="true" Spacing="2" Class="mt-1">
                                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success"
                                           StartIcon="@Icons.Material.Filled.Check" OnClick="@(() => EntscheidenAsync(a, true))">Genehmigen</MudButton>
                                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error"
                                           StartIcon="@Icons.Material.Filled.Close" OnClick="@(() => EntscheidenAsync(a, false))">Ablehnen</MudButton>
                            </MudStack>
                        </AuthorizeView>
                    }
                </MudStack>
            </MudPaper>
        }
    }
</MudStack>

@code {
    [Parameter, EditorRequired] public Agent Agent { get; set; } = default!;
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    /// <summary>Wird nach einer Entscheidung ausgelöst (Rang kann sich geändert haben → Steckkarte/Verlauf neu laden).</summary>
    [Parameter] public EventCallback Changed { get; set; }

    private bool _laden = true;
    private ClaimsPrincipal _user = default!;
    private List<AgentBefoerderungsantrag> _antraege = new();

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        await LadenAsync();
    }

    private async Task LadenAsync()
    {
        _laden = true;
        _antraege = await PersonalakteService.GetBefoerderungsantraegeAsync(Agent.Id);
        _laden = false;
    }

    private async Task BeantragenAsync()
    {
        var wahl = await BefoerderungDialog.ZeigenAsync(DialogService, Agent.Codename, Agent.Dienstgrad ?? Dienstgrad.JuniorAgent);
        if (wahl is null)
        {
            return;
        }
        try
        {
            await PersonalakteService.BefoerderungBeantragenAsync(Agent.Id, wahl.ZielDienstgrad, wahl.Begruendung, _user);
            Snackbar.Add("Beförderungsantrag eingereicht.", Severity.Success);
            await LadenAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task EntscheidenAsync(AgentBefoerderungsantrag a, bool genehmigt)
    {
        var ok = await BestaetigenDialog.ZeigenAsync(DialogService,
            genehmigt ? "Beförderung genehmigen?" : "Beförderung ablehnen?",
            genehmigt
                ? $"{Agent.Codename} erhält den Dienstgrad {DienstgradAnzeige.Name(a.ZielDienstgrad)}. Der Agent muss sich danach neu anmelden (neuer Sicherheits-Stamp)."
                : "Der Antrag wird abgelehnt.",
            genehmigt ? "Genehmigen" : "Ablehnen");
        if (!ok)
        {
            return;
        }
        try
        {
            await AgentService.BefoerderungEntscheidenAsync(a.Id, genehmigt, null, _user);
            Snackbar.Add(genehmigt ? "Beförderung genehmigt." : "Antrag abgelehnt.", Severity.Success);
            await LadenAsync();
            await Changed.InvokeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private static Color StatusFarbe(BefoerderungStatus s) => s switch
    {
        BefoerderungStatus.Beantragt => Color.Info,
        BefoerderungStatus.Genehmigt => Color.Success,
        BefoerderungStatus.Abgelehnt => Color.Error,
        _ => Color.Default,
    };
}
