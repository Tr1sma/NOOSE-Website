@* Steckkarte der Personalakte: Codename, Dienstgrad, Status, TRU/Admin, Dienstnummer; Klarname nur für Führung. *@
<MudPaper Class="pa-4" Elevation="2">
    <MudStack Spacing="3">
        <MudStack AlignItems="AlignItems.Center" Class="py-2">
            <MudAvatar Color="Color.Primary" Rounded="true" Style="height:120px;width:120px;">
                <MudIcon Icon="@Icons.Material.Filled.Badge" Style="font-size:3rem;" />
            </MudAvatar>
        </MudStack>

        <div>
            <MudText Typo="Typo.h5">@(string.IsNullOrWhiteSpace(Agent.Codename) ? "Unbenannter Agent" : Agent.Codename)</MudText>
            @if (DarfKlarname && !string.IsNullOrWhiteSpace(Agent.Klarname))
            {
                <MudText Typo="Typo.body2" Class="mud-text-secondary">@Agent.Klarname</MudText>
            }
            @if (!string.IsNullOrWhiteSpace(Agent.Dienstnummer))
            {
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Dienstnummer: @Agent.Dienstnummer</MudText>
            }
        </div>

        <MudStack Row="true" Spacing="2" Class="flex-wrap" AlignItems="AlignItems.Center">
            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled" Icon="@Icons.Material.Filled.MilitaryTech">@DienstgradAnzeige.Name(Agent.Dienstgrad)</MudChip>
            <MudChip T="string" Size="Size.Small" Color="@StatusFarbe(Agent.Status)" Variant="Variant.Outlined">@StatusName(Agent.Status)</MudChip>
            @if (Agent.IstTRU)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">TRU</MudChip>
            }
            @if (Agent.IstAdmin)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined">Admin</MudChip>
            }
        </MudStack>

        @if (!string.IsNullOrWhiteSpace(Agent.DiscordUsername) && DarfKlarname)
        {
            <MudText Typo="Typo.caption" Class="mud-text-secondary">Discord: @Agent.DiscordUsername</MudText>
        }
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired] public Agent Agent { get; set; } = default!;
    [Parameter] public bool DarfKlarname { get; set; }

    private static string StatusName(AgentStatus s) => s switch
    {
        AgentStatus.Aktiv => "Aktiv",
        AgentStatus.Ausstehend => "Ausstehend",
        AgentStatus.Gesperrt => "Gesperrt",
        _ => "—",
    };

    private static Color StatusFarbe(AgentStatus s) => s switch
    {
        AgentStatus.Aktiv => Color.Success,
        AgentStatus.Ausstehend => Color.Warning,
        AgentStatus.Gesperrt => Color.Error,
        _ => Color.Default,
    };
}
