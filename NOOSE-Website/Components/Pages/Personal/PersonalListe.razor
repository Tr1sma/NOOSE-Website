@page "/personal"
@inject IAgentVerwaltungService AgentService
@inject NavigationManager Nav

<PageTitle>Personal · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
    <MudIcon Icon="@Icons.Material.Filled.Badge" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h4">Personal</MudText>
</MudStack>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-6">
    Personalakten aller NOOSE-Agenten: Dienstgrad-Verlauf, Belobigungen, Disziplinarisches und Beförderungen.
</MudText>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudTextField @bind-Value="_suche" Placeholder="Suchen (Codename, Dienstnummer)…" Immediate="true"
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Class="mb-3" Variant="Variant.Outlined" />

    <MudTable Items="_gefiltert" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="2" Dense="true"
              OnRowClick="@((TableRowClickEventArgs<Agent> e) => Oeffnen(e.Item))" T="Agent">
        <HeaderContent>
            <MudTh><MudTableSortLabel T="Agent" SortBy="@(x => x.Codename)">Codename</MudTableSortLabel></MudTh>
            @if (_darfKlarname)
            {
                <MudTh><MudTableSortLabel T="Agent" SortBy="@(x => x.Klarname)">Klarname</MudTableSortLabel></MudTh>
            }
            <MudTh><MudTableSortLabel T="Agent" SortBy="@(x => x.Dienstgrad)">Dienstgrad</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="Agent" SortBy="@(x => StatusName(x.Status))">Status</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="Agent" SortBy="@(x => x.IstTRU)">TRU</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="Agent" SortBy="@(x => x.IstHRB)">HRB</MudTableSortLabel></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Codename">
                <MudLink Href="@($"/personal/{context.Id}")" @onclick:stopPropagation="true">
                    @(string.IsNullOrWhiteSpace(context.Codename) ? "Unbenannter Agent" : context.Codename)
                </MudLink>
            </MudTd>
            @if (_darfKlarname)
            {
                <MudTd DataLabel="Klarname"><MudText Typo="Typo.body2" Class="mud-text-secondary">@(context.Klarname ?? "—")</MudText></MudTd>
            }
            <MudTd DataLabel="Dienstgrad">@DienstgradAnzeige.Name(context.Dienstgrad)</MudTd>
            <MudTd DataLabel="Status">@StatusName(context.Status)</MudTd>
            <MudTd DataLabel="TRU">@(context.IstTRU ? "TRU" : "")</MudTd>
            <MudTd DataLabel="HRB">@(context.IstHRB ? "HRB" : "")</MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Typo="Typo.body2" Class="mud-text-secondary pa-4">Keine Agenten gefunden.</MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _laden = true;
    private bool _darfKlarname;
    private string _suche = string.Empty;
    private List<Agent> _agenten = new();

    private IEnumerable<Agent> _gefiltert => string.IsNullOrWhiteSpace(_suche)
        ? _agenten
        : _agenten.Where(a => (a.Codename ?? string.Empty).Contains(_suche.Trim(), StringComparison.OrdinalIgnoreCase)
                           || (a.Dienstnummer ?? string.Empty).Contains(_suche.Trim(), StringComparison.OrdinalIgnoreCase)
                           || (_darfKlarname && (a.Klarname ?? string.Empty).Contains(_suche.Trim(), StringComparison.OrdinalIgnoreCase)));

    protected override async Task OnInitializedAsync()
    {
        _darfKlarname = (await AuthStateTask).User.DarfKlarnameSehen();
        // TeamLeitungen (FiveM-Aufsicht) sind im RP-Betrieb unsichtbar – aus dem Personalroster ausblenden.
        _agenten = (await AgentService.GetAlleAsync()).Where(a => !a.IstTeamLeitung).ToList();
        _laden = false;
    }

    private void Oeffnen(Agent? a)
    {
        if (a is not null)
        {
            Nav.NavigateTo($"/personal/{a.Id}");
        }
    }

    private static string StatusName(AgentStatus s) => s switch
    {
        AgentStatus.Aktiv => "Aktiv",
        AgentStatus.Ausstehend => "Ausstehend",
        AgentStatus.Gesperrt => "Gesperrt",
        _ => "—",
    };
}
