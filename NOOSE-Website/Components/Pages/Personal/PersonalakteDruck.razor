@* Druckansicht der Personalakte eines Agenten (Phase 7): Laufbahn als strukturiertes Dokument.
   Klarname nur für Berechtigte (DarfKlarnameSehen). *@
@page "/personal/{Id}/druck"
@layout DruckLayout
@inject IAgentVerwaltungService AgentService
@inject IPersonalakteService PersonalakteService
@inject IZugriffsLogService ZugriffsLog

<PageTitle>@(_agent is null ? "Druckansicht" : $"Personalakte {_agent.Codename}") · NOOSE</PageTitle>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_agent is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">Diese Personalakte existiert nicht (mehr).</MudAlert>
}
else
{
    <DruckRahmen Titel="@($"Personalakte – {AnzeigeName(_agent)}")" ZurueckHref="@($"/personal/{Id}")"
                 GedrucktVon="@_druckVon" IstVerschlusssache="false"
                 Fusszeile="NOOSE-interne Personalakte · Weitergabe nur nach Freigabe durch die Führung.">
        <section>
            <h2>Stammdaten</h2>
            <table class="druck-felder">
                <tbody>
                    <tr><th>Codename</th><td>@AnzeigeName(_agent)</td></tr>
                    @if (_darfKlarname && !string.IsNullOrWhiteSpace(_agent.Klarname))
                    {
                        <tr><th>Klarname</th><td>@_agent.Klarname</td></tr>
                    }
                    @if (!string.IsNullOrWhiteSpace(_agent.Dienstnummer))
                    {
                        <tr><th>Dienstnummer</th><td>@_agent.Dienstnummer</td></tr>
                    }
                    <tr><th>Dienstgrad</th><td>@DienstgradAnzeige.Name(_agent.Dienstgrad)</td></tr>
                    <tr><th>Status</th><td>@AgentStatusAnzeige.Name(_agent.Status)</td></tr>
                    @if (_agent.IstTRU)
                    {
                        <tr><th>Einheit</th><td>TRU (Tactical Response Unit)</td></tr>
                    }
                    @if (_agent.IstHRB)
                    {
                        <tr><th>Einheit</th><td>HRB (Human Resources Branch)</td></tr>
                    }
                    <tr><th>Registriert am</th><td>@_agent.RegistriertAm.ToLocalTime().ToString("dd.MM.yyyy")</td></tr>
                </tbody>
            </table>
        </section>

        @if (_dienstgradVerlauf.Count > 0)
        {
            <section>
                <h2>Dienstgrad-Verlauf</h2>
                <table class="druck-tabelle">
                    <thead><tr><th>Zeitpunkt</th><th>Änderung</th><th>Grund</th><th>Durch</th></tr></thead>
                    <tbody>
                        @foreach (var v in _dienstgradVerlauf)
                        {
                            <tr>
                                <td>@v.Zeitpunkt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                <td>@DienstgradAnzeige.Name(v.Alt) → @DienstgradAnzeige.Name(v.Neu)</td>
                                <td>@(string.IsNullOrWhiteSpace(v.Grund) ? "—" : v.Grund)</td>
                                <td>@(v.AkteurName ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>
        }

        @if (_belobigungen.Count > 0)
        {
            <section>
                <h2>Belobigungen</h2>
                @foreach (var v in _belobigungen)
                {
                    <div class="druck-eintrag">
                        <div class="druck-eintrag-kopf">
                            <b>@v.ErstelltAm.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</b>
                            @if (!string.IsNullOrWhiteSpace(v.AutorName))
                            {
                                <text> · @v.AutorName</text>
                            }
                        </div>
                        <div class="druck-mehrzeilig">@v.Text</div>
                    </div>
                }
            </section>
        }

        @if (_disziplinarisches.Count > 0)
        {
            <section>
                <h2>Disziplinarisches</h2>
                @foreach (var v in _disziplinarisches)
                {
                    <div class="druck-eintrag">
                        <div class="druck-eintrag-kopf">
                            <b>@v.ErstelltAm.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</b>
                            @if (!string.IsNullOrWhiteSpace(v.AutorName))
                            {
                                <text> · @v.AutorName</text>
                            }
                        </div>
                        <div class="druck-mehrzeilig">@v.Text</div>
                    </div>
                }
            </section>
        }
    </DruckRahmen>
}

@code {
    [Parameter] public string Id { get; set; } = string.Empty;
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _laden = true;
    private bool _darfKlarname;
    private string? _druckVon;
    private Agent? _agent;
    private List<AgentDienstgradVerlauf> _dienstgradVerlauf = new();
    private List<AgentVermerk> _belobigungen = new();
    private List<AgentVermerk> _disziplinarisches = new();

    private static string AnzeigeName(Agent a)
        => string.IsNullOrWhiteSpace(a.Codename) ? "Unbenannter Agent" : a.Codename;

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthStateTask).User;
        _darfKlarname = user.DarfKlarnameSehen();
        _druckVon = user.GetCodename();

        _agent = await AgentService.FindAsync(Id);
        if (_agent is not null)
        {
            _dienstgradVerlauf = await PersonalakteService.GetDienstgradVerlaufAsync(Id);
            _belobigungen = await PersonalakteService.GetVermerkeAsync(Id, AgentVermerkArt.Belobigung);
            _disziplinarisches = await PersonalakteService.GetVermerkeAsync(Id, AgentVermerkArt.Disziplinarisch);
            await ZugriffsLog.LogAnsichtAsync(nameof(Agent), Id);
        }
        _laden = false;
    }
}
