@* Inhalt des Vorgangs: die gebündelten Akten (Personen, Doks, Observationen, Operationen, Taskforces,
   Organisationen …) über die generische Verknüpfungs-Engine. Beidseitig klickbar; die Notiz dient als
   Rolle/Funktion im Vorgang. Beteiligte Agents laufen separat über das Agent-Panel. *@
@inject IVerknuepfungService VerknuepfungService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudText Typo="Typo.subtitle1">Gebündelte Akten (@_liste.Count)</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AddLink" OnClick="HinzufuegenAsync">
            Akte hinzufügen
        </MudButton>
    </MudStack>

    @if (_laden)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_liste.Count == 0)
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">
            Noch keine Akten gebündelt. (Beteiligte Agents werden im Tab „Beteiligte Agents" zugeteilt.)
        </MudText>
    }
    else
    {
        @foreach (var gruppe in _gruppiert)
        {
            <div>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-1">
                    <MudIcon Icon="@TypIcon(gruppe.Key)" Color="Color.Primary" Size="Size.Small" />
                    <MudText Typo="Typo.subtitle2">@TypAnzeige(gruppe.Key) (@gruppe.Count())</MudText>
                </MudStack>
                @foreach (var v in gruppe)
                {
                    <MudPaper Class="pa-3 mb-2" Elevation="1">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="flex-wrap">
                                @if (v.Href is not null)
                                {
                                    <MudLink Href="@v.Href" Typo="Typo.body2"><b>@v.AndereBezeichnung</b></MudLink>
                                }
                                else
                                {
                                    <MudText Typo="Typo.body2"><b>@v.AndereBezeichnung</b></MudText>
                                }
                                @if (!string.IsNullOrWhiteSpace(v.Label))
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">@v.Label</MudChip>
                                }
                            </MudStack>
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                           OnClick="@(() => EntfernenAsync(v))" aria-label="Akte aus dem Vorgang entfernen" />
                        </MudStack>
                    </MudPaper>
                }
            </div>
        }
    }
</MudStack>

@code {
    [Parameter, EditorRequired] public string VorgangId { get; set; } = default!;
    [Parameter, EditorRequired] public ClaimsPrincipal User { get; set; } = default!;

    private bool _laden = true;
    private List<VerknuepfungAnzeige> _liste = new();

    // Anzeige-Reihenfolge der Aktentypen im Inhalt (alles übrige landet am Ende).
    private static readonly string[] _reihenfolge =
    {
        nameof(Person), nameof(PersonDok), nameof(Observation), nameof(Operation),
        nameof(Taskforce), nameof(Fraktion), nameof(Personengruppe), nameof(Partei), nameof(Agent),
    };

    private IEnumerable<IGrouping<string, VerknuepfungAnzeige>> _gruppiert =>
        _liste.GroupBy(v => v.AndereTyp)
              .OrderBy(g => Array.IndexOf(_reihenfolge, g.Key) is var i && i >= 0 ? i : int.MaxValue)
              .ThenBy(g => g.Key);

    protected override async Task OnInitializedAsync() => await LadenAsync();

    private async Task LadenAsync()
    {
        _laden = true;
        var alle = await VerknuepfungService.GetFuerAkteAsync(nameof(Vorgang), VorgangId, User.IstFuehrung(), User.GetAgentId(), VerknuepfungArt.Standard);
        // Nur manuell gebündelte Akten zeigen (ein Vorgang hat keine automatischen Verknüpfungen).
        _liste = alle.Where(v => !v.Automatisch).ToList();
        _laden = false;
    }

    private async Task HinzufuegenAsync()
    {
        var wahl = await VerknuepfungDialog.ZeigenAsync(DialogService, User.IstFuehrung());
        if (wahl is null)
        {
            return;
        }
        try
        {
            await VerknuepfungService.ErstellenAsync(nameof(Vorgang), VorgangId, wahl.ZielTyp, wahl.ZielId, wahl.Label, User, VerknuepfungArt.Standard);
            Snackbar.Add("Akte dem Vorgang hinzugefügt.", Severity.Success);
            await LadenAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task EntfernenAsync(VerknuepfungAnzeige v)
    {
        var ok = await BestaetigenDialog.ZeigenAsync(DialogService, "Akte entfernen?",
            $"„{v.AndereBezeichnung}“ wird aus dem Vorgang entfernt.", "Entfernen");
        if (!ok)
        {
            return;
        }
        await VerknuepfungService.EntfernenAsync(v.VerknuepfungId, User);
        Snackbar.Add("Akte aus dem Vorgang entfernt.", Severity.Success);
        await LadenAsync();
    }

    private static string TypAnzeige(string typ) => typ switch
    {
        nameof(Person) => "Personen",
        nameof(PersonDok) => "Personen-Doks",
        nameof(Observation) => "Observationen",
        nameof(Operation) => "Operationen",
        nameof(Taskforce) => "Taskforces",
        nameof(Fraktion) => "Fraktionen",
        nameof(Personengruppe) => "Personengruppen",
        nameof(Partei) => "Parteien",
        nameof(Agent) => "Agenten",
        nameof(Vorgang) => "Vorgänge",
        _ => typ,
    };

    private static string TypIcon(string typ) => typ switch
    {
        nameof(Person) => Icons.Material.Filled.Badge,
        nameof(PersonDok) => Icons.Material.Filled.Description,
        nameof(Observation) => Icons.Material.Filled.Visibility,
        nameof(Operation) => Icons.Material.Filled.Radar,
        nameof(Taskforce) => Icons.Material.Filled.Groups2,
        nameof(Fraktion) => Icons.Material.Filled.Groups,
        nameof(Personengruppe) => Icons.Material.Filled.Diversity3,
        nameof(Partei) => Icons.Material.Filled.AccountBalance,
        nameof(Agent) => Icons.Material.Filled.Person,
        nameof(Vorgang) => Icons.Material.Filled.FolderSpecial,
        _ => Icons.Material.Filled.Hub,
    };
}
