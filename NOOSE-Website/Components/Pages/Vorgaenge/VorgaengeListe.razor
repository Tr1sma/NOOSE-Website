@page "/vorgaenge"
@inject IVorgangService VorgangService
@inject IAktualitaetService Aktualitaet
@inject NavigationManager Nav

<PageTitle>Vorgänge · NOOSE</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
    <MudIcon Icon="@Icons.Material.Filled.FolderSpecial" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h4">Vorgänge</MudText>
    <MudSpacer />
    <AuthorizeView Policy="@Policies.Fuehrung">
        <MudButton Href="/vorgaenge/papierkorb" Variant="Variant.Text" Color="Color.Default" StartIcon="@Icons.Material.Filled.Delete">Papierkorb</MudButton>
    </AuthorizeView>
    <MudButton Href="/vorgaenge/neu" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add">Neuer Vorgang</MudButton>
</MudStack>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-6">
    Vorgangs-/Fallakten: bündeln Personen, Operationen, Observationen und Doks zu einem Ermittlungs-Vorgang mit eigenem Status.
</MudText>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudDataGrid T="VorgangZeile" Items="_zeilen" Hover="true" Filterable="false" SortMode="SortMode.Multiple"
                 QuickFilter="Filter" Elevation="2" RowClick="@(args => Oeffnen(args.Item))" Dense="true">
        <ToolBarContent>
            <MudTextField @bind-Value="_suche" Placeholder="Suchen (Titel, Aktenzeichen, Typ)…" Immediate="true"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" />
            <MudSpacer />
            <MudSelect T="VorgangStatus?" Value="_statusFilter" ValueChanged="StatusGewaehlt" Label="Status" Dense="true"
                       Clearable="true" Variant="Variant.Outlined" Style="max-width:220px;">
                <MudSelectItem T="VorgangStatus?" Value="@((VorgangStatus?)null)">Alle</MudSelectItem>
                @foreach (var s in VorgangStatusAnzeige.Alle)
                {
                    <MudSelectItem T="VorgangStatus?" Value="@s">@VorgangStatusAnzeige.Name(s)</MudSelectItem>
                }
            </MudSelect>
        </ToolBarContent>
        <Columns>
            <PropertyColumn Property="x => x.Aktenzeichen" Title="Aktenzeichen" />
            <TemplateColumn Title="Titel" SortBy="x => x.Titel">
                <CellTemplate>
                    @* Echter Link: Mittelklick/Strg+Klick öffnet die Akte im neuen Tab; tastatur-/screenreader-erreichbar. *@
                    <MudLink Href="@($"/vorgaenge/{context.Item.Id}")" @onclick:stopPropagation="true">@context.Item.Titel</MudLink>
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.Typ" Title="Typ" />
            <TemplateColumn Title="Status" SortBy="x => x.Status">
                <CellTemplate>
                    <VorgangStatusChip Status="context.Item.Status" />
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Einstufung" SortBy="x => x.Einstufung">
                <CellTemplate>
                    <EinstufungBadge Wert="context.Item.Einstufung" />
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Verschluss" Sortable="false">
                <CellTemplate>
                    @if (context.Item.IstVerschlusssache)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Warning" Size="Size.Small" Title="Verschlusssache" />
                    }
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Aktualität" SortBy="x => x.Stufe">
                <CellTemplate>
                    <AktualitaetsAmpel Stufe="context.Item.Stufe" ReferenzdatumUtc="context.Item.AktualisiertUtc" />
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.Aktualisiert" Title="Zuletzt" Format="dd.MM.yyyy HH:mm" />
        </Columns>
        <NoRecordsContent>
            <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-6">
                <MudIcon Icon="@Icons.Material.Filled.FolderSpecial" Color="Color.Default" Size="Size.Large" />
                <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Vorgänge – lege den ersten an.</MudText>
                <MudButton Href="/vorgaenge/neu" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add">Neuer Vorgang</MudButton>
            </MudStack>
        </NoRecordsContent>
        <PagerContent>
            <MudDataGridPager T="VorgangZeile" />
        </PagerContent>
    </MudDataGrid>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _laden = true;
    private string _suche = string.Empty;
    private VorgangStatus? _statusFilter;
    private List<VorgangZeile> _zeilen = new();

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthStateTask).User;
        var istFuehrung = user.IstFuehrung();
        var vorgaenge = await VorgangService.GetListeAsync(istFuehrung);
        var (warnungTage, veraltetTage) = await Aktualitaet.GetSchwelleAsync(nameof(Vorgang));
        var jetzt = DateTime.UtcNow;
        _zeilen = vorgaenge.Select(v =>
        {
            var referenzUtc = v.GeaendertAm ?? v.ErstelltAm;
            return new VorgangZeile
            {
                Id = v.Id,
                Aktenzeichen = v.Aktenzeichen,
                Titel = v.Titel,
                Typ = v.Typ ?? string.Empty,
                Status = v.Status,
                Einstufung = v.Einstufung,
                IstVerschlusssache = v.IstVerschlusssache,
                AktualisiertUtc = referenzUtc,
                Aktualisiert = referenzUtc.ToLocalTime(),
                Stufe = AktualitaetsBewertung.Stufe(warnungTage, veraltetTage, referenzUtc, jetzt),
            };
        }).ToList();
        _laden = false;
    }

    private void StatusGewaehlt(VorgangStatus? status)
    {
        _statusFilter = status;
        StateHasChanged();
    }

    private bool Filter(VorgangZeile z)
    {
        if (_statusFilter is not null && z.Status != _statusFilter)
        {
            return false;
        }
        if (string.IsNullOrWhiteSpace(_suche))
        {
            return true;
        }
        var s = _suche.Trim();
        return z.Titel.Contains(s, StringComparison.OrdinalIgnoreCase)
            || z.Aktenzeichen.Contains(s, StringComparison.OrdinalIgnoreCase)
            || z.Typ.Contains(s, StringComparison.OrdinalIgnoreCase);
    }

    private void Oeffnen(VorgangZeile z) => Nav.NavigateTo($"/vorgaenge/{z.Id}");

    private sealed class VorgangZeile
    {
        public string Id { get; set; } = string.Empty;
        public string Aktenzeichen { get; set; } = string.Empty;
        public string Titel { get; set; } = string.Empty;
        public string Typ { get; set; } = string.Empty;
        public VorgangStatus Status { get; set; }
        public Einstufung Einstufung { get; set; }
        public bool IstVerschlusssache { get; set; }
        public DateTime AktualisiertUtc { get; set; }
        public DateTime Aktualisiert { get; set; }
        public AktualitaetsStufe Stufe { get; set; }
    }
}
