@* Druckansicht der Vorgangs-/Fallakte (Phase 7): kompletter Fall als strukturiertes Dokument. *@
@page "/vorgaenge/{Id}/druck"
@layout DruckLayout
@inject IVorgangService VorgangService
@inject IVerknuepfungService VerknuepfungService
@inject IKommentarService KommentarService
@inject IZugriffsLogService ZugriffsLog

<PageTitle>@(_vorgang is null ? "Druckansicht" : $"Vorgangsakte {_vorgang.Aktenzeichen}") · NOOSE</PageTitle>

@if (_laden)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_vorgang is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">Diese Akte existiert nicht (mehr) oder ist nicht sichtbar.</MudAlert>
}
else
{
    <DruckRahmen Titel="@($"Vorgangsakte {_vorgang.Aktenzeichen}")" ZurueckHref="@($"/vorgaenge/{Id}")"
                 GedrucktVon="@_druckVon" IstVerschlusssache="_vorgang.IstVerschlusssache">
        <section>
            <h2>Stammdaten</h2>
            <table class="druck-felder">
                <tbody>
                    <tr><th>Titel</th><td>@_vorgang.Titel</td></tr>
                    <tr><th>Aktenzeichen</th><td>@_vorgang.Aktenzeichen</td></tr>
                    <tr><th>Status</th><td>@VorgangStatusAnzeige.Name(_vorgang.Status)</td></tr>
                    @if (!string.IsNullOrWhiteSpace(_vorgang.Typ))
                    {
                        <tr><th>Typ</th><td>@_vorgang.Typ</td></tr>
                    }
                    <tr><th>Einstufung</th><td>@EinstufungAnzeige.Name(_vorgang.Einstufung)</td></tr>
                    <tr><th>Eröffnet</th><td>@_vorgang.ErstelltAm.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td></tr>
                    @if (_vorgang.AbgeschlossenAm is { } abgeschlossen)
                    {
                        <tr><th>Abgeschlossen</th><td>@abgeschlossen.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td></tr>
                    }
                    <tr><th>Zuletzt aktualisiert</th><td>@((_vorgang.GeaendertAm ?? _vorgang.ErstelltAm).ToLocalTime().ToString("dd.MM.yyyy HH:mm"))</td></tr>
                </tbody>
            </table>
        </section>

        @if (!string.IsNullOrWhiteSpace(_vorgang.Beschreibung))
        {
            <section>
                <h2>Sachverhalt</h2>
                <div class="druck-mehrzeilig">@_vorgang.Beschreibung</div>
            </section>
        }

        @if (!string.IsNullOrWhiteSpace(_vorgang.Zusammenfassung))
        {
            <section>
                <h2>Aktueller Stand</h2>
                <div class="druck-mehrzeilig">@_vorgang.Zusammenfassung</div>
            </section>
        }

        @if (!string.IsNullOrWhiteSpace(_vorgang.Abschlussvermerk))
        {
            <section>
                <h2>Abschlussvermerk</h2>
                <div class="druck-mehrzeilig">@_vorgang.Abschlussvermerk</div>
            </section>
        }

        @if (_vorgang.Agenten.Count > 0)
        {
            <section>
                <h2>Fallführung &amp; zugeteilte Agenten</h2>
                <table class="druck-tabelle">
                    <thead><tr><th>Agent</th><th>Funktion</th></tr></thead>
                    <tbody>
                        @foreach (var a in _vorgang.Agenten)
                        {
                            <tr>
                                <td>@(a.Agent?.Codename ?? "—")</td>
                                <td>@(a.IstFallfuehrer ? "Fallführer" : "Zugeteilt")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>
        }

        <DruckVerknuepfungen Eintraege="_verknuepfungen" Ueberschrift="Gebündelte Inhalte (Personen, Doks, Operationen …)" />
        <DruckEinstufungVerlauf Eintraege="_einstufungVerlauf" />
        <DruckKommentare Eintraege="_kommentare" />
    </DruckRahmen>
}

@code {
    [Parameter] public string Id { get; set; } = string.Empty;
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _laden = true;
    private string? _druckVon;
    private Vorgang? _vorgang;
    private List<EinstufungVerlauf> _einstufungVerlauf = new();
    private List<VerknuepfungAnzeige> _verknuepfungen = new();
    private List<Kommentar> _kommentare = new();

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthStateTask).User;
        var istFuehrung = user.IstFuehrung();
        _druckVon = user.GetCodename();

        _vorgang = await VorgangService.GetDetailAsync(Id, istFuehrung);
        if (_vorgang is not null)
        {
            _einstufungVerlauf = await VorgangService.GetEinstufungVerlaufAsync(Id, istFuehrung);
            _verknuepfungen = await VerknuepfungService.GetFuerAkteAsync(nameof(Vorgang), Id, istFuehrung, user.GetAgentId());
            _kommentare = await KommentarService.GetFuerAkteAsync(nameof(Vorgang), Id, istFuehrung);
            await ZugriffsLog.LogAnsichtAsync(nameof(Vorgang), Id);
        }
        _laden = false;
    }
}
