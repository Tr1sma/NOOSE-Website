@page "/Account/Gesperrt"
@layout AccountLayout
@attribute [AllowAnonymous]
@attribute [ExcludeFromInteractiveRouting]

<PageTitle>Konto gesperrt · NOOSE</PageTitle>

<MudPaper Elevation="4" Class="pa-8" Style="max-width:460px;width:100%;">
    <MudStack AlignItems="AlignItems.Center" Spacing="4">
        <MudIcon Icon="@Icons.Material.Filled.Block" Color="Color.Error" Size="Size.Large" />
        <MudText Typo="Typo.h5" Align="Align.Center">Konto gesperrt</MudText>
        <MudText Typo="Typo.body2" Align="Align.Center" Class="mud-text-secondary">
            Dein Zugang wurde durch die Führung gesperrt. Falls du das für einen Irrtum hältst,
            wende dich bitte an die NOOSE-Administration.
        </MudText>
        <MudButton Href="/Account/Login" Variant="Variant.Outlined" Color="Color.Default"
                   StartIcon="@Icons.Material.Filled.ArrowBack">Zurück zur Anmeldung</MudButton>
    </MudStack>
</MudPaper>
