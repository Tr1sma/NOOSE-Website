@* Wird von <AuthorizeRouteView> angezeigt, wenn ein eingeloggter Agent eine Seite ohne
   ausreichende Rechte aufruft. Rendert innerhalb des MainLayout (Navigation bleibt sichtbar). *@
<PageTitle>Keine Berechtigung · NOOSE</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudPaper Class="pa-8" Elevation="2">
        <MudStack AlignItems="AlignItems.Center" Spacing="3">
            <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Error" Size="Size.Large" />
            <MudText Typo="Typo.h5" Align="Align.Center">Keine Berechtigung</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary" Align="Align.Center">
                Dein Dienstgrad reicht für diese Aktion nicht aus. Wenn du Zugriff benötigst,
                wende dich an die Führung.
            </MudText>
            <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Home">Zum Dashboard</MudButton>
        </MudStack>
    </MudPaper>
</MudContainer>
