@inherits LayoutComponentBase

@* Schlanke, eigenständige Hülle für die Konto-Seiten (Login/Ausstehend/Gesperrt) – ohne
   Navigation/Drawer. Static SSR, daher nur der ThemeProvider für den dunklen NOOSE-Look. *@
<MudThemeProvider Theme="NooseTheme.Theme" IsDarkMode="true" />

<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px;background:#0E1116;">
    @Body
</div>
