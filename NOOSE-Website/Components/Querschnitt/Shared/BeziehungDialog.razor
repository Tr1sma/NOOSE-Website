@* Dialog zum Anlegen einer Person-zu-Person-Beziehung (Zielperson + Typ + Notiz). *@
@inject IPersonService PersonService

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3" Style="min-width:340px;">
            <MudAutocomplete T="Person" Label="Person" @bind-Value="_ziel"
                             SearchFunc="@SuchePersonen" ToStringFunc="@(p => p?.Name ?? string.Empty)"
                             Variant="Variant.Outlined" Clearable="true" CoerceText="false" CoerceValue="false"
                             ResetValueOnEmptyText="true" MinCharacters="0" Immediate="true"
                             Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.PersonSearch"
                             HelperText="Gegenüber auswählen.">
                <ItemTemplate Context="p">
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.Badge" Size="Size.Small" Color="Color.Primary" />
                        <MudText Typo="Typo.body2">@p.Name</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@p.Aktenzeichen</MudText>
                    </MudStack>
                </ItemTemplate>
            </MudAutocomplete>
            <MudSelect T="BeziehungsTyp" Label="Art der Beziehung" @bind-Value="_typ" Variant="Variant.Outlined">
                @foreach (var t in BeziehungsTypAnzeige.Alle)
                {
                    <MudSelectItem Value="t">@BeziehungsTypAnzeige.Name(t)</MudSelectItem>
                }
            </MudSelect>
            <MudTextField @bind-Value="_notiz" Label="Notiz (optional)" Lines="2" Variant="Variant.Outlined" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Abbrechen">Abbrechen</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Speichern">Beziehung speichern</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public bool IstFuehrung { get; set; }
    /// <summary>Die aktuelle Person wird aus der Auswahl ausgeschlossen.</summary>
    [Parameter] public string? AusschlussPersonId { get; set; }

    private Person? _ziel;
    private BeziehungsTyp _typ = BeziehungsTyp.Bekannt;
    private string? _notiz;

    private async Task<IEnumerable<Person>> SuchePersonen(string value, CancellationToken token)
    {
        var treffer = await PersonService.SucheAsync(value, IstFuehrung, 20, token);
        return AusschlussPersonId is null ? treffer : treffer.Where(p => p.Id != AusschlussPersonId);
    }

    private void Speichern()
    {
        if (_ziel is null)
        {
            return;
        }
        MudDialog.Close(DialogResult.Ok(new BeziehungEingabe { ZielPersonId = _ziel.Id, Typ = _typ, Notiz = _notiz }));
    }

    private void Abbrechen() => MudDialog.Cancel();

    /// <summary>Zeigt den Dialog und liefert die Eingabe oder null bei Abbruch.</summary>
    public static async Task<BeziehungEingabe?> ZeigenAsync(IDialogService dialog, bool istFuehrung, string ausschlussPersonId)
    {
        var parameters = new DialogParameters<BeziehungDialog>
        {
            { x => x.IstFuehrung, istFuehrung },
            { x => x.AusschlussPersonId, ausschlussPersonId },
        };
        var referenz = await dialog.ShowAsync<BeziehungDialog>("Beziehung hinzufügen", parameters);
        var ergebnis = await referenz.Result;
        return ergebnis is { Canceled: false, Data: BeziehungEingabe e } ? e : null;
    }
}
