@* Tag-Chips einer Akte mit Picker-Button. Sichtbar ohne Tab-Wechsel. *@
@inject ITagService TagService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="flex-wrap">
    <MudIcon Icon="@Icons.Material.Filled.Label" Size="Size.Small" Class="mud-text-secondary" />
    @foreach (var tag in _tags)
    {
        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="@FarbeVon(tag.Farbe)">@tag.Name</MudChip>
    }
    @if (_tags.Count == 0)
    {
        <MudText Typo="Typo.caption" Class="mud-text-secondary">Keine Tags</MudText>
    }
    <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Primary"
             Icon="@Icons.Material.Filled.Edit" OnClick="VerwaltenAsync">Tags …</MudChip>
</MudStack>

@code {
    [Parameter, EditorRequired] public string EntitaetTyp { get; set; } = default!;
    [Parameter, EditorRequired] public string EntitaetId { get; set; } = default!;
    [Parameter, EditorRequired] public ClaimsPrincipal User { get; set; } = default!;

    private List<Tag> _tags = new();

    protected override async Task OnInitializedAsync() => await LadenAsync();

    private async Task LadenAsync() => _tags = await TagService.GetFuerAkteAsync(EntitaetTyp, EntitaetId);

    private async Task VerwaltenAsync()
    {
        var aktuelle = _tags.Select(t => t.Id).ToList();
        var gewaehlt = await TagPickerDialog.ZeigenAsync(DialogService, aktuelle, User);
        if (gewaehlt is null)
        {
            return;
        }
        try
        {
            await TagService.SetzenAsync(EntitaetTyp, EntitaetId, gewaehlt, User);
            await LadenAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private static Color FarbeVon(string? farbe) => Enum.TryParse<Color>(farbe, out var c) ? c : Color.Default;
}
