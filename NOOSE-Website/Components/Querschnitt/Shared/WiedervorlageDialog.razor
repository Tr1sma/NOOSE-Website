@* Dialog zum Anlegen/Bearbeiten einer Wiedervorlage: Termin, Notiz und optional ein zuständiger Agent. *@
@inject IAgentVerwaltungService AgentService

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3" Style="min-width:380px;">
            <MudDatePicker @bind-Date="_faellig" Label="Fällig am" Editable="true"
                           Variant="Variant.Outlined" DateFormat="dd.MM.yyyy"
                           Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Event" />

            <MudTextField @bind-Value="_notiz" Label="Notiz (optional)" Variant="Variant.Outlined"
                          Lines="3" MaxLength="500" HelperText="Worum geht es bei dieser Wiedervorlage?" />

            <MudAutocomplete T="Agent" Label="Zuständig (optional)" @bind-Value="_agent"
                             SearchFunc="@SucheAgenten" ToStringFunc="@(a => a is null ? string.Empty : a.Codename)"
                             Variant="Variant.Outlined" Clearable="true" CoerceText="false" CoerceValue="false"
                             ResetValueOnEmptyText="true" MinCharacters="0" Immediate="true"
                             Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.ManageAccounts"
                             HelperText="Leer = du selbst. Zuständiger und Follower der Akte werden bei Fälligkeit erinnert.">
                <ItemTemplate Context="a">
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Color="Color.Primary" />
                        <MudText Typo="Typo.body2">@a.Codename</MudText>
                        @if (DarfKlarname && !string.IsNullOrWhiteSpace(a.Klarname))
                        {
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">(@a.Klarname)</MudText>
                        }
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@DienstgradAnzeige.Name(a.Dienstgrad)</MudText>
                    </MudStack>
                </ItemTemplate>
            </MudAutocomplete>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Abbrechen">Abbrechen</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Speichern" Disabled="@(_faellig is null)">Speichern</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public DateTime? FaelligAm { get; set; }
    [Parameter] public string? Notiz { get; set; }
    [Parameter] public string? ZustaendigerAgentId { get; set; }

    /// <summary>Wer den Klarnamen sehen darf (Führung/Admin) – sieht ihn auch hier in der Liste. Über <c>User.DarfKlarnameSehen()</c>.</summary>
    [Parameter] public bool DarfKlarname { get; set; }

    private DateTime? _faellig;
    private string? _notiz;
    private Agent? _agent;
    private List<Agent> _alle = new();

    protected override async Task OnInitializedAsync()
    {
        // Vorbelegung (Neu: morgen; Bearbeiten: vorhandener Termin lokal).
        _faellig = (FaelligAm ?? DateTime.UtcNow.AddDays(1)).ToLocalTime().Date;
        _notiz = Notiz;

        var alle = await AgentService.GetAlleAsync();
        _alle = alle.Where(a => a.Status == AgentStatus.Aktiv).ToList();
        if (!string.IsNullOrEmpty(ZustaendigerAgentId))
        {
            _agent = _alle.FirstOrDefault(a => a.Id == ZustaendigerAgentId);
        }
    }

    private Task<IEnumerable<Agent>> SucheAgenten(string value, CancellationToken token)
    {
        var suche = value.Trim();
        IEnumerable<Agent> treffer = string.IsNullOrWhiteSpace(value)
            ? _alle
            : _alle.Where(a => a.Codename.Contains(suche, StringComparison.OrdinalIgnoreCase)
                            || (DarfKlarname && (a.Klarname ?? string.Empty).Contains(suche, StringComparison.OrdinalIgnoreCase)));
        return Task.FromResult(treffer);
    }

    private void Speichern()
    {
        if (_faellig is null)
        {
            return;
        }
        MudDialog.Close(DialogResult.Ok(new WiedervorlageEingabe(_faellig.Value, _notiz, _agent?.Id)));
    }

    private void Abbrechen() => MudDialog.Cancel();

    /// <summary>Zeigt den Dialog (Anlegen oder Bearbeiten); liefert die Eingabe oder null bei Abbruch.</summary>
    public static async Task<WiedervorlageEingabe?> ZeigenAsync(IDialogService dialog, bool darfKlarname,
        string titel = "Wiedervorlage planen", DateTime? faelligAm = null, string? notiz = null, string? zustaendigerAgentId = null)
    {
        var parameters = new DialogParameters<WiedervorlageDialog>
        {
            { x => x.DarfKlarname, darfKlarname },
            { x => x.FaelligAm, faelligAm },
            { x => x.Notiz, notiz },
            { x => x.ZustaendigerAgentId, zustaendigerAgentId },
        };
        var referenz = await dialog.ShowAsync<WiedervorlageDialog>(titel, parameters);
        var ergebnis = await referenz.Result;
        return ergebnis is { Canceled: false, Data: WiedervorlageEingabe eingabe } ? eingabe : null;
    }
}
