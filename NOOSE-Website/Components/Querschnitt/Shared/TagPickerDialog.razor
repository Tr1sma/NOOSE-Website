@* Dialog zur Mehrfachauswahl von Tags für eine Akte – inkl. Inline-Anlegen neuer Tags.
   Liefert die gewählten Tag-IDs zurück. *@
@inject ITagService TagService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3" Style="min-width:340px;">
            @if (_laden)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            }
            else
            {
                @if (_alle.Count == 0)
                {
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Tags vorhanden – unten ein neues anlegen.</MudText>
                }
                else
                {
                    <MudStack Row="true" Spacing="1" Class="flex-wrap">
                        @foreach (var tag in _alle)
                        {
                            var gewaehlt = _gewaehlt.Contains(tag.Id);
                            <MudChip T="string" Size="Size.Small"
                                     Color="@FarbeVon(tag.Farbe)"
                                     Variant="@(gewaehlt ? Variant.Filled : Variant.Outlined)"
                                     OnClick="@(() => Umschalten(tag.Id))">
                                @(gewaehlt ? "✓ " : string.Empty)@tag.Name
                            </MudChip>
                        }
                    </MudStack>
                }

                <MudDivider />

                <MudText Typo="Typo.subtitle2">Neuen Tag anlegen</MudText>
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                    <MudTextField @bind-Value="_neuName" Placeholder="Name" Variant="Variant.Outlined" Margin="Margin.Dense" Class="flex-grow-1" />
                    <MudSelect T="Color" @bind-Value="_neuFarbe" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:140px;">
                        @foreach (var c in Farben)
                        {
                            <MudSelectItem Value="c">@c.ToString()</MudSelectItem>
                        }
                    </MudSelect>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                               OnClick="AnlegenAsync" Disabled="@string.IsNullOrWhiteSpace(_neuName)">Anlegen</MudButton>
                </MudStack>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Abbrechen">Abbrechen</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Uebernehmen">Übernehmen</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    /// <summary>Aktuell der Akte zugeordnete Tag-IDs (Vorauswahl).</summary>
    [Parameter] public List<string> BereitsGesetzt { get; set; } = new();

    /// <summary>Handelnder Agent (für das Anlegen neuer Tags / Audit-Kontext).</summary>
    [Parameter, EditorRequired] public System.Security.Claims.ClaimsPrincipal User { get; set; } = default!;

    private bool _laden = true;
    private List<Tag> _alle = new();
    private HashSet<string> _gewaehlt = new();

    private string _neuName = string.Empty;
    private Color _neuFarbe = Color.Primary;

    private static readonly Color[] Farben =
    {
        Color.Default, Color.Primary, Color.Secondary, Color.Tertiary,
        Color.Info, Color.Success, Color.Warning, Color.Error, Color.Dark,
    };

    protected override async Task OnInitializedAsync()
    {
        _gewaehlt = new HashSet<string>(BereitsGesetzt);
        await LadenAsync();
    }

    private async Task LadenAsync()
    {
        _laden = true;
        _alle = await TagService.GetAlleAsync();
        _laden = false;
    }

    private void Umschalten(string tagId)
    {
        if (!_gewaehlt.Remove(tagId))
        {
            _gewaehlt.Add(tagId);
        }
    }

    private async Task AnlegenAsync()
    {
        if (string.IsNullOrWhiteSpace(_neuName))
        {
            return;
        }
        try
        {
            var farbe = _neuFarbe == Color.Default ? null : _neuFarbe.ToString();
            var tag = await TagService.ErstellenAsync(_neuName, farbe, User);
            _gewaehlt.Add(tag.Id);
            _neuName = string.Empty;
            await LadenAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private void Uebernehmen() => MudDialog.Close(DialogResult.Ok(_gewaehlt.ToList()));
    private void Abbrechen() => MudDialog.Cancel();

    private static Color FarbeVon(string? farbe) => Enum.TryParse<Color>(farbe, out var c) ? c : Color.Default;

    /// <summary>Zeigt den Picker und liefert die gewählten Tag-IDs oder null bei Abbruch.</summary>
    public static async Task<List<string>?> ZeigenAsync(IDialogService dialog, List<string> bereitsGesetzt, System.Security.Claims.ClaimsPrincipal user)
    {
        var parameters = new DialogParameters<TagPickerDialog>
        {
            { x => x.BereitsGesetzt, bereitsGesetzt },
            { x => x.User, user },
        };
        var referenz = await dialog.ShowAsync<TagPickerDialog>("Tags zuordnen", parameters);
        var ergebnis = await referenz.Result;
        return ergebnis is { Canceled: false, Data: List<string> ids } ? ids : null;
    }
}
