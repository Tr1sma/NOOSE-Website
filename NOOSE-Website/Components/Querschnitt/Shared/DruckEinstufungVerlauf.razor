@* Druck-Sektion „Einstufungs-Verlauf" (gemeinsam für alle Druckansichten; rendert nichts bei leer). *@
@if (Eintraege.Count > 0)
{
    <section>
        <h2>Einstufungs-Verlauf</h2>
        <table class="druck-tabelle">
            <thead>
                <tr><th>Zeitpunkt</th><th>Einstufung</th><th>Begründung</th><th>Agent</th></tr>
            </thead>
            <tbody>
                @foreach (var e in Eintraege)
                {
                    <tr>
                        <td>@e.Zeitpunkt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                        <td>@EinstufungAnzeige.Name(e.Wert)</td>
                        <td>@(string.IsNullOrWhiteSpace(e.Begruendung) ? "—" : e.Begruendung)</td>
                        <td>@(e.AgentName ?? "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
}

@code {
    [Parameter, EditorRequired] public List<EinstufungVerlauf> Eintraege { get; set; } = new();
}
