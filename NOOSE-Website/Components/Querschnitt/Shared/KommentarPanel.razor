@* Kommentare/Vermerke einer Akte: neueste zuerst, Inline-Verfassen mit @-Verlinkung (Akten/Quellen/Agenten),
   aufgelöste Verweise in der Anzeige, Löschen (eigene oder Führung). *@
@inject IKommentarService KommentarService
@inject IMentionService MentionService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudStack Spacing="3">
    <MudText Typo="Typo.subtitle1">Kommentare (@_eintraege.Count)</MudText>

    @if (_darfSchreiben)
    {
        <MudStack Spacing="2">
            <MentionEingabe @bind-Text="_neuerText" IstFuehrung="_istFuehrung"
                            DarfVerschlusssacheLesen="_darfVsLesen" DarfKlarname="_darfKlarname"
                            Placeholder="@Platzhalter" OnSubmit="HinzufuegenAsync" />
            <MudStack Row="true" Justify="Justify.FlexEnd">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Send"
                           OnClick="HinzufuegenAsync" Disabled="@(_speichert || string.IsNullOrWhiteSpace(_neuerText))">
                    Kommentieren
                </MudButton>
            </MudStack>
        </MudStack>
    }

    @if (_laden)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_eintraege.Count == 0)
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Kommentare.</MudText>
    }
    else
    {
        @foreach (var e in _eintraege)
        {
            <MudPaper Class="pa-3" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Size="Size.Small" Color="Color.Default" />
                        <MudText Typo="Typo.body2"><b>@(string.IsNullOrWhiteSpace(e.K.AutorName) ? "Unbekannt" : e.K.AutorName)</b></MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                            · @e.K.ErstelltAm.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                        </MudText>
                    </MudStack>
                    @if (_darfSchreiben && DarfLoeschen(e.K))
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                       OnClick="@(() => LoeschenAsync(e.K))" aria-label="Kommentar löschen" />
                    }
                </MudStack>
                <div class="mt-1">
                    <MentionText Segmente="e.Segmente" />
                </div>
            </MudPaper>
        }
    }
</MudStack>

@code {
    [Parameter, EditorRequired] public string EntitaetTyp { get; set; } = default!;
    [Parameter, EditorRequired] public string EntitaetId { get; set; } = default!;
    [Parameter, EditorRequired] public ClaimsPrincipal User { get; set; } = default!;

    private const string Platzhalter = "Vermerk hinzufügen … (Verlinken per @, Strg+Enter sendet)";
    private bool _laden = true;
    private bool _speichert;
    private bool _istFuehrung;
    private bool _darfVsLesen;
    private bool _darfKlarname;
    private bool _darfSchreiben;
    private string _neuerText = string.Empty;
    private List<Eintrag> _eintraege = new();

    private sealed record Eintrag(Kommentar K, IReadOnlyList<MentionSegment> Segmente);

    protected override async Task OnInitializedAsync()
    {
        _istFuehrung = User.IstFuehrung();
        _darfVsLesen = User.DarfVerschlusssacheLesen();
        _darfKlarname = User.DarfKlarnameSehen();
        _darfSchreiben = User.DarfSchreiben();
        await LadenAsync();
    }

    private async Task LadenAsync()
    {
        _laden = true;
        var kommentare = await KommentarService.GetFuerAkteAsync(EntitaetTyp, EntitaetId, _darfVsLesen);
        // Alle Kommentar-Texte in EINER Sammelabfrage auflösen (@-Tokens → anzeigefertige Segmente, VS-/Klarname-gefiltert).
        var segmente = await MentionService.AufloesenVieleAsync(
            kommentare.Select(k => (string?)k.Text).ToList(), _darfVsLesen, User.GetAgentId());
        _eintraege = kommentare.Select((k, i) => new Eintrag(k, segmente[i])).ToList();
        _laden = false;
    }

    private async Task HinzufuegenAsync()
    {
        if (string.IsNullOrWhiteSpace(_neuerText))
        {
            return;
        }
        _speichert = true;
        try
        {
            await KommentarService.ErstellenAsync(EntitaetTyp, EntitaetId, _neuerText, User);
            _neuerText = string.Empty;
            Snackbar.Add("Kommentar gespeichert.", Severity.Success);
            await LadenAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _speichert = false;
        }
    }

    private async Task LoeschenAsync(Kommentar kommentar)
    {
        var ok = await BestaetigenDialog.ZeigenAsync(DialogService, "Kommentar löschen?",
            "Der Kommentar wird in den Papierkorb verschoben.");
        if (!ok)
        {
            return;
        }
        await KommentarService.LoeschenAsync(kommentar.Id, User);
        Snackbar.Add("Kommentar gelöscht.", Severity.Success);
        await LadenAsync();
    }

    // Löschen darf der Verfasser selbst oder die Führung.
    private bool DarfLoeschen(Kommentar k)
        => _istFuehrung || (k.ErstelltVonId is not null && k.ErstelltVonId == User.GetAgentId());
}
