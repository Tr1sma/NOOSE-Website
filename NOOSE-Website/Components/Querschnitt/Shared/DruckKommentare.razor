@* Druck-Sektion „Vermerke/Kommentare" (gemeinsam für alle Druckansichten; rendert nichts bei leer). *@
@if (Eintraege.Count > 0)
{
    <section>
        <h2>Vermerke</h2>
        @foreach (var k in Eintraege)
        {
            <div class="druck-eintrag">
                <div class="druck-eintrag-kopf">
                    <b>@k.ErstelltAm.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</b>
                    @if (!string.IsNullOrWhiteSpace(k.AutorName))
                    {
                        <text> · @k.AutorName</text>
                    }
                </div>
                <div class="druck-mehrzeilig">@k.Text</div>
            </div>
        }
    </section>
}

@code {
    [Parameter, EditorRequired] public List<Kommentar> Eintraege { get; set; } = new();
}
