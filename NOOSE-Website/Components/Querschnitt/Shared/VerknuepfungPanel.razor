@* Verknüpfungen einer Personen-Akte. Reihenfolge: (1) Verknüpfte Akten (manuell, beliebige Aktentypen),
   (2) Beziehungen (typisierte Person-Beziehungen + automatische Kollegen aus geteilten Organisationen),
   (3) abgeleitete Verbündete/Gegner aus Bündnissen/Konflikten der Organisationen der Person. *@
@inject IVerknuepfungService VerknuepfungService
@inject IBeziehungService BeziehungService
@inject IPersonService PersonService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudStack Spacing="6">
    @* ---- Verknüpfte Akten (manuell, jede Aktenart) ---- *@
    <MudStack Spacing="3">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudText Typo="Typo.subtitle1">Verknüpfte Akten (@_manuell.Count)</MudText>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AddLink" OnClick="NeueVerknuepfungAsync">
                Verknüpfung hinzufügen
            </MudButton>
        </MudStack>

        @if (_laden)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (_manuell.Count == 0)
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Verknüpfungen erfasst.</MudText>
        }
        else
        {
            @foreach (var v in _manuell)
            {
                <MudPaper Class="pa-3" Elevation="1">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="flex-wrap">
                            <MudIcon Icon="@Icons.Material.Filled.AccountTree" Color="Color.Primary" Size="Size.Small" />
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">@TypAnzeige(v.AndereTyp)</MudChip>
                            @if (v.Href is not null)
                            {
                                <MudLink Href="@v.Href" Typo="Typo.body2"><b>@v.AndereBezeichnung</b></MudLink>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2"><b>@v.AndereBezeichnung</b></MudText>
                            }
                            @if (!string.IsNullOrWhiteSpace(v.Label))
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@v.Label</MudChip>
                            }
                        </MudStack>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                       OnClick="@(() => VerknuepfungEntfernenAsync(v))" aria-label="Verknüpfung löschen" />
                    </MudStack>
                </MudPaper>
            }
        }
    </MudStack>

    <MudDivider />

    @* ---- Person-Beziehungen (typisiert) + automatische Kollegen ---- *@
    <MudStack Spacing="3">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudText Typo="Typo.subtitle1">Beziehungen (@(_beziehungen.Count + _kollegen.Count))</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="NeueBeziehungAsync">
                Beziehung hinzufügen
            </MudButton>
        </MudStack>

        @if (_laden)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (_beziehungen.Count == 0 && _kollegen.Count == 0)
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Beziehungen erfasst.</MudText>
        }
        else
        {
            @* Manuell erfasste, typisierte Beziehungen *@
            @foreach (var b in _beziehungen)
            {
                <MudPaper Class="pa-3" Elevation="1">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudChip T="string" Size="Size.Small" Color="@TypFarbe(b.Typ)" Variant="Variant.Filled">@BeziehungsTypAnzeige.Name(b.Typ)</MudChip>
                            <MudLink Href="@($"/personen/{b.AnderePersonId}")" Typo="Typo.body2">
                                <b>@b.AnderePersonName</b>
                            </MudLink>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@b.AnderePersonAktenzeichen</MudText>
                        </MudStack>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                       OnClick="@(() => BeziehungEntfernenAsync(b))" aria-label="Beziehung löschen" />
                    </MudStack>
                    @if (!string.IsNullOrWhiteSpace(b.Notiz))
                    {
                        <MudText Typo="Typo.body2" Class="mt-1 mud-text-secondary">@b.Notiz</MudText>
                    }
                </MudPaper>
            }

            @* Automatische Kollegen aus geteilten Fraktionen/Gruppen/Parteien (systemgepflegt, nicht löschbar) *@
            @foreach (var k in _kollegen)
            {
                <MudPaper Class="pa-3" Elevation="1">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">@k.Label</MudChip>
                            @if (k.Href is not null)
                            {
                                <MudLink Href="@k.Href" Typo="Typo.body2"><b>@k.AndereBezeichnung</b></MudLink>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2"><b>@k.AndereBezeichnung</b></MudText>
                            }
                        </MudStack>
                        <MudTooltip Text="@AutoTooltip(k.Label)">
                            <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Color="Color.Default" Size="Size.Small" />
                        </MudTooltip>
                    </MudStack>
                </MudPaper>
            }
        }
    </MudStack>

    <MudDivider />

    @* ---- Abgeleitet: Verbündete/Gegner über Bündnisse/Konflikte der eigenen Organisationen ---- *@
    <MudStack Spacing="3">
        <MudText Typo="Typo.subtitle1">Über Bündnisse &amp; Konflikte (@_abgeleitete.Count)</MudText>
        @if (!_laden && _abgeleitete.Count == 0)
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Keine abgeleiteten Verbündeten/Gegner. (Ergibt sich automatisch, wenn eine Fraktion/Gruppe der Person
                ein Bündnis oder einen Konflikt hat.)
            </MudText>
        }
        else if (!_laden)
        {
            @foreach (var a in _abgeleitete)
            {
                var verbuendet = a.Art == VerknuepfungArt.Buendnis;
                <MudPaper Class="pa-3" Elevation="1">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="flex-wrap">
                            <MudIcon Icon="@(verbuendet ? Icons.Material.Filled.Handshake : Icons.Material.Filled.Bolt)"
                                     Color="@(verbuendet ? Color.Success : Color.Error)" Size="Size.Small" />
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="@(verbuendet ? Color.Success : Color.Error)">
                                @(verbuendet ? "Verbündeter" : "Gegner")
                            </MudChip>
                            <MudLink Href="@($"/personen/{a.PersonId}")" Typo="Typo.body2"><b>@a.PersonName</b></MudLink>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@a.Aktenzeichen</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">· über @a.QuelleName ↔ @a.PartnerName</MudText>
                        </MudStack>
                        <MudTooltip Text="@AbgeleitetTooltip(verbuendet)">
                            <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Color="Color.Default" Size="Size.Small" />
                        </MudTooltip>
                    </MudStack>
                </MudPaper>
            }
        }
    </MudStack>
</MudStack>

@code {
    [Parameter, EditorRequired] public string PersonId { get; set; } = default!;
    [Parameter, EditorRequired] public ClaimsPrincipal User { get; set; } = default!;

    private bool _laden = true;
    private List<BeziehungAnzeige> _beziehungen = new();
    private List<VerknuepfungAnzeige> _manuell = new();
    private List<VerknuepfungAnzeige> _kollegen = new();
    private List<AbgeleiteteBeziehung> _abgeleitete = new();

    protected override async Task OnInitializedAsync() => await LadenAsync();

    private async Task LadenAsync()
    {
        _laden = true;
        var istFuehrung = User.IstFuehrung();
        _beziehungen = await BeziehungService.GetFuerPersonAsync(PersonId, istFuehrung);
        // Standard-Verknüpfungen aufteilen: automatische Kollegen wandern zu den Beziehungen,
        // manuell angelegte bleiben unter „Verknüpfte Akten".
        var standard = await VerknuepfungService.GetFuerAkteAsync(nameof(Person), PersonId, istFuehrung, VerknuepfungArt.Standard);
        _manuell = standard.Where(v => !v.Automatisch).ToList();
        _kollegen = standard.Where(v => v.Automatisch).ToList();
        _abgeleitete = await PersonService.GetAbgeleiteteBeziehungenAsync(PersonId, istFuehrung);
        _laden = false;
    }

    private async Task NeueBeziehungAsync()
    {
        var eingabe = await BeziehungDialog.ZeigenAsync(DialogService, User.IstFuehrung(), PersonId);
        if (eingabe is null)
        {
            return;
        }
        try
        {
            await BeziehungService.ErstellenAsync(PersonId, eingabe.ZielPersonId, eingabe.Typ, eingabe.Notiz, User);
            Snackbar.Add("Beziehung gespeichert.", Severity.Success);
            await LadenAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task NeueVerknuepfungAsync()
    {
        var eingabe = await VerknuepfungDialog.ZeigenAsync(DialogService, User.IstFuehrung(), PersonId);
        if (eingabe is null)
        {
            return;
        }
        try
        {
            await VerknuepfungService.ErstellenAsync(nameof(Person), PersonId, eingabe.ZielTyp, eingabe.ZielId, eingabe.Label, User);
            Snackbar.Add("Verknüpfung gespeichert.", Severity.Success);
            await LadenAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task BeziehungEntfernenAsync(BeziehungAnzeige b)
    {
        var ok = await BestaetigenDialog.ZeigenAsync(DialogService, "Beziehung löschen?",
            $"Die Beziehung zu „{b.AnderePersonName}“ wird in den Papierkorb verschoben.");
        if (!ok)
        {
            return;
        }
        await BeziehungService.EntfernenAsync(b.BeziehungId, User);
        Snackbar.Add("Beziehung gelöscht.", Severity.Success);
        await LadenAsync();
    }

    private async Task VerknuepfungEntfernenAsync(VerknuepfungAnzeige v)
    {
        var ok = await BestaetigenDialog.ZeigenAsync(DialogService, "Verknüpfung löschen?",
            $"Die Verknüpfung zu „{v.AndereBezeichnung}“ wird in den Papierkorb verschoben.");
        if (!ok)
        {
            return;
        }
        await VerknuepfungService.EntfernenAsync(v.VerknuepfungId, User);
        Snackbar.Add("Verknüpfung gelöscht.", Severity.Success);
        await LadenAsync();
    }

    // Tooltip für automatische Kollegen-Verknüpfungen je nach Quelle (Fraktion/Gruppe/Partei).
    private static string AutoTooltip(string? label) => label switch
    {
        KollegenSync.Gruppenkollege => "Automatisch durch eine gemeinsame Personengruppe – wird mit der Mitgliedschaft gepflegt.",
        KollegenSync.Parteikollege => "Automatisch durch eine gemeinsame Partei – wird mit der Mitgliedschaft gepflegt.",
        _ => "Automatisch durch eine gemeinsame Fraktion – wird mit der Mitgliedschaft gepflegt.",
    };

    // Tooltip für abgeleitete Verbündete/Gegner – ergeben sich aus Bündnissen/Konflikten der Organisationen.
    private static string AbgeleitetTooltip(bool verbuendet) => verbuendet
        ? "Automatisch durch ein Bündnis der Organisation – wird mit dem Bündnis gepflegt."
        : "Automatisch durch einen Konflikt der Organisation – wird mit dem Konflikt gepflegt.";

    // Lesbarer Aktentyp-Name für die Verknüpfungs-Chips.
    private static string TypAnzeige(string typ) => typ switch
    {
        nameof(Person) => "Person",
        nameof(Fraktion) => "Fraktion",
        nameof(Personengruppe) => "Personengruppe",
        nameof(Partei) => "Partei",
        nameof(Agent) => "Agent",
        nameof(PersonDok) => "Dok",
        nameof(Operation) => "Operation",
        nameof(Taskforce) => "Taskforce",
        nameof(Vorgang) => "Vorgang",
        nameof(Observation) => "Observation",
        _ => typ,
    };

    private static Color TypFarbe(BeziehungsTyp typ) => typ switch
    {
        BeziehungsTyp.Familie => Color.Info,
        BeziehungsTyp.Verbuendeter => Color.Success,
        BeziehungsTyp.Feind => Color.Error,
        BeziehungsTyp.Geschaeftspartner => Color.Warning,
        _ => Color.Default,
    };
}
