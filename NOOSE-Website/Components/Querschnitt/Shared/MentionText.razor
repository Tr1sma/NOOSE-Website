@* Rendert einen bereits aufgelösten Mention-Text (Segmente) inline: Klartext + klickbare Verweise/Chips.
   Verschlusssachen ohne Berechtigung erscheinen als neutraler Schloss-Chip ohne Name/Link. Reiner Renderer –
   die Auflösung (DB) macht der Aufrufer (bei Listen gebündelt via IMentionService.AufloesenVieleAsync). *@
<span style="white-space:pre-wrap;word-break:break-word;">
@foreach (var seg in Segmente)
{
    if (!seg.IstVerweis)
    {
        @seg.Text
    }
    else if (seg.Verborgen)
    {
        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning"
                 Icon="@Icons.Material.Filled.Lock" Class="mx-1">Verschlusssache</MudChip>
    }
    else if (!string.IsNullOrEmpty(seg.Href))
    {
        <MudLink Href="@seg.Href" Class="mx-1">
            <MudIcon Icon="@Symbol(seg.Typ)" Size="Size.Small" Class="mr-1" />@seg.Text
        </MudLink>
    }
    else
    {
        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary"
                 Icon="@Symbol(seg.Typ)" Class="mx-1">@seg.Text</MudChip>
    }
}
</span>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<MentionSegment> Segmente { get; set; } = Array.Empty<MentionSegment>();

    private static string Symbol(string? typ) => typ switch
    {
        nameof(Person) => Icons.Material.Filled.Badge,
        nameof(Fraktion) => Icons.Material.Filled.Groups,
        nameof(Personengruppe) => Icons.Material.Filled.Diversity3,
        nameof(Partei) => Icons.Material.Filled.AccountBalance,
        nameof(Operation) => Icons.Material.Filled.Radar,
        nameof(Taskforce) => Icons.Material.Filled.Groups2,
        nameof(Quelle) => Icons.Material.Filled.AttachFile,
        nameof(Agent) => Icons.Material.Filled.Person,
        _ => Icons.Material.Filled.Link,
    };
}
