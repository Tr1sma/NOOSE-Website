@* Dialog zum Anlegen eines Konflikts/Bündnisses zwischen Organisationen: Ziel (Fraktion oder Personengruppe) + Notiz. *@
@inject IFraktionService FraktionService
@inject IPersonengruppeService GruppeService

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3" Style="min-width:380px;">
            <MudRadioGroup T="string" @bind-Value="Typ">
                <MudRadio T="string" Value="@nameof(Fraktion)" Color="Color.Primary" Dense="true">Fraktion</MudRadio>
                <MudRadio T="string" Value="@nameof(Personengruppe)" Color="Color.Primary" Dense="true">Personengruppe</MudRadio>
            </MudRadioGroup>

            <MudAutocomplete T="AkteTreffer" Label="@(IstFraktion ? "Fraktion" : "Personengruppe")"
                             @bind-Value="_ziel" SearchFunc="@Suchen" ToStringFunc="@(a => a?.Name ?? string.Empty)"
                             Variant="Variant.Outlined" Clearable="true" CoerceText="false" CoerceValue="false"
                             ResetValueOnEmptyText="true" MinCharacters="0" Immediate="true"
                             Adornment="Adornment.Start" AdornmentIcon="@(IstFraktion ? Icons.Material.Filled.Groups : Icons.Material.Filled.Diversity3)"
                             HelperText="Organisation auswählen.">
                <ItemTemplate Context="a">
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@(IstFraktion ? Icons.Material.Filled.Groups : Icons.Material.Filled.Diversity3)" Size="Size.Small" Color="Color.Primary" />
                        <MudText Typo="Typo.body2">@a.Name</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@a.Aktenzeichen</MudText>
                    </MudStack>
                </ItemTemplate>
            </MudAutocomplete>

            <MudTextField @bind-Value="_notiz" Label="Notiz (optional)" Variant="Variant.Outlined"
                          Placeholder="@NotizPlaceholder" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Abbrechen">Abbrechen</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Speichern">Hinzufügen</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public bool IstFuehrung { get; set; }
    /// <summary>„Konflikt" oder „Bündnis" – nur für Texte/Platzhalter.</summary>
    [Parameter] public string Bezeichnung { get; set; } = "Konflikt";
    [Parameter] public IReadOnlyList<string> AusschlussFraktionIds { get; set; } = Array.Empty<string>();
    [Parameter] public IReadOnlyList<string> AusschlussGruppenIds { get; set; } = Array.Empty<string>();

    private string _typ = nameof(Fraktion);
    private string Typ
    {
        get => _typ;
        set { if (_typ != value) { _typ = value; _ziel = null; } }
    }
    private bool IstFraktion => _typ == nameof(Fraktion);
    private AkteTreffer? _ziel;
    private string? _notiz;

    private string NotizPlaceholder => Bezeichnung == "Bündnis"
        ? "z. B. Waffenbruderschaft, Nichtangriffspakt"
        : "z. B. Revierkonflikt, langjährige Feindschaft";

    private async Task<IEnumerable<AkteTreffer>> Suchen(string value, CancellationToken token)
    {
        if (IstFraktion)
        {
            var treffer = await FraktionService.SucheAsync(value, IstFuehrung, 20, token);
            return treffer.Where(f => !AusschlussFraktionIds.Contains(f.Id))
                .Select(f => new AkteTreffer(f.Id, f.Name, f.Aktenzeichen));
        }
        var gruppen = await GruppeService.SucheAsync(value, IstFuehrung, 20, token);
        return gruppen.Where(g => !AusschlussGruppenIds.Contains(g.Id))
            .Select(g => new AkteTreffer(g.Id, g.Name, g.Aktenzeichen));
    }

    private void Speichern()
    {
        if (_ziel is null)
        {
            return;
        }
        MudDialog.Close(DialogResult.Ok(new OrgBeziehungWahl(_typ, _ziel.Id,
            string.IsNullOrWhiteSpace(_notiz) ? null : _notiz.Trim())));
    }

    private void Abbrechen() => MudDialog.Cancel();

    public record AkteTreffer(string Id, string Name, string Aktenzeichen);
    public record OrgBeziehungWahl(string ZielTyp, string ZielId, string? Notiz);

    public static async Task<OrgBeziehungWahl?> ZeigenAsync(IDialogService dialog, string bezeichnung, bool istFuehrung,
        IReadOnlyList<string> ausschlussFraktionIds, IReadOnlyList<string> ausschlussGruppenIds)
    {
        var parameters = new DialogParameters<OrgBeziehungDialog>
        {
            { x => x.Bezeichnung, bezeichnung },
            { x => x.IstFuehrung, istFuehrung },
            { x => x.AusschlussFraktionIds, ausschlussFraktionIds },
            { x => x.AusschlussGruppenIds, ausschlussGruppenIds },
        };
        var referenz = await dialog.ShowAsync<OrgBeziehungDialog>($"{bezeichnung} hinzufügen", parameters);
        var ergebnis = await referenz.Result;
        return ergebnis is { Canceled: false, Data: OrgBeziehungWahl w } ? w : null;
    }
}
