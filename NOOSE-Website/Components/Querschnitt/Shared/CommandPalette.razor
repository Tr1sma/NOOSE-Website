@* Command-Palette (Strg+K / Cmd+K): Schnellzugriff auf Akten und Funktionen.
   Als Singleton im MainLayout platziert; der Hotkey wird per JS-Interop registriert. *@
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject ISearchService SearchService
@inject Microsoft.Extensions.Logging.ILogger<CommandPalette> Logger
@implements IAsyncDisposable

<MudDialog @bind-Visible="_open" Options="_options">
    <TitleContent>
        <MudText Typo="Typo.subtitle1">
            <MudIcon Icon="@Icons.Material.Filled.Bolt" Size="Size.Small" Class="mr-1" />Schnellzugriff
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudAutocomplete T="PaletteItem" @ref="_auto" SearchFunc="Suche" ToStringFunc="@(i => i?.Label ?? string.Empty)"
                         ValueChanged="GewaehltAsync" Placeholder="Akte suchen oder Befehl wählen…"
                         Variant="Variant.Outlined" MinCharacters="0" Immediate="true" Clearable="true"
                         ResetValueOnEmptyText="true" AutoFocus="true"
                         Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search">
            <ItemTemplate Context="i">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@i.Icon" Size="Size.Small" Color="Color.Primary" />
                    <MudText Typo="Typo.body2">@i.Label</MudText>
                    @if (!string.IsNullOrEmpty(i.Sub))
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@i.Sub</MudText>
                    }
                </MudStack>
            </ItemTemplate>
            <NoItemsTemplate>
                <MudText Typo="Typo.caption" Class="mud-text-secondary pa-2">Keine Treffer.</MudText>
            </NoItemsTemplate>
        </MudAutocomplete>
        <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2 d-block">Strg+K öffnet diesen Schnellzugriff überall.</MudText>
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _open;
    private bool _istFuehrung;
    private MudAutocomplete<PaletteItem> _auto = default!;
    private IJSObjectReference? _modul;
    private DotNetObjectReference<CommandPalette>? _ref;
    private readonly DialogOptions _options = new() { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };
    private List<PaletteItem> _befehle = new();

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthStateTask).User;
        _istFuehrung = user.IstFuehrung();
        _befehle = new List<PaletteItem>
        {
            new("Personen-Akten", "Liste", Icons.Material.Filled.Badge, "/personen"),
            new("Neue Person anlegen", null, Icons.Material.Filled.PersonAdd, "/personen/neu"),
            new("Personen-Doks", "Übersicht", Icons.Material.Filled.Description, "/doks"),
            new("Fraktionen", "Liste", Icons.Material.Filled.Groups, "/fraktionen"),
            new("Neue Fraktion anlegen", null, Icons.Material.Filled.Add, "/fraktionen/neu"),
            new("Personengruppen", "Liste", Icons.Material.Filled.Diversity3, "/personengruppen"),
            new("Neue Personengruppe anlegen", null, Icons.Material.Filled.Add, "/personengruppen/neu"),
            new("Parteien", "Liste", Icons.Material.Filled.AccountBalance, "/parteien"),
            new("Neue Partei anlegen", null, Icons.Material.Filled.Add, "/parteien/neu"),
            new("Operationen", "Liste", Icons.Material.Filled.Radar, "/operationen"),
            new("Neue Operation anlegen", null, Icons.Material.Filled.Add, "/operationen/neu"),
            new("Taskforces", "Liste", Icons.Material.Filled.Groups2, "/taskforces"),
            new("Neue Taskforce anlegen", null, Icons.Material.Filled.Add, "/taskforces/neu"),
            new("Vorgänge", "Liste", Icons.Material.Filled.FolderSpecial, "/vorgaenge"),
            new("Neuen Vorgang anlegen", null, Icons.Material.Filled.Add, "/vorgaenge/neu"),
            new("Globale Suche", null, Icons.Material.Filled.Search, "/suche"),
        };
        // Papierkörbe und Verwaltung sind Führungs-gated → für Nicht-Führung nicht anbieten (sonst ACCESS DENIED).
        if (_istFuehrung)
        {
            _befehle.Add(new PaletteItem("Freigaben", "Posteingang", Icons.Material.Filled.HowToReg, "/admin/freigaben"));
            _befehle.Add(new PaletteItem("Tags verwalten", null, Icons.Material.Filled.Label, "/admin/tags"));
            _befehle.Add(new PaletteItem("Papierkorb · Personen", null, Icons.Material.Filled.Delete, "/personen/papierkorb"));
            _befehle.Add(new PaletteItem("Papierkorb · Fraktionen", null, Icons.Material.Filled.Delete, "/fraktionen/papierkorb"));
            _befehle.Add(new PaletteItem("Papierkorb · Personengruppen", null, Icons.Material.Filled.Delete, "/personengruppen/papierkorb"));
            _befehle.Add(new PaletteItem("Papierkorb · Parteien", null, Icons.Material.Filled.Delete, "/parteien/papierkorb"));
            _befehle.Add(new PaletteItem("Papierkorb · Operationen", null, Icons.Material.Filled.Delete, "/operationen/papierkorb"));
            _befehle.Add(new PaletteItem("Papierkorb · Taskforces", null, Icons.Material.Filled.Delete, "/taskforces/papierkorb"));
            _befehle.Add(new PaletteItem("Papierkorb · Vorgänge", null, Icons.Material.Filled.Delete, "/vorgaenge/papierkorb"));
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // JS-Interop erst nach dem ersten Render verfügbar (Interactive Server).
        if (firstRender)
        {
            _modul = await JS.InvokeAsync<IJSObjectReference>("import", "./app.js");
            _ref = DotNetObjectReference.Create(this);
            await _modul.InvokeVoidAsync("registerCommandPalette", _ref);
        }
    }

    [JSInvokable]
    public Task Oeffnen()
    {
        _open = true;
        return InvokeAsync(StateHasChanged);
    }

    private async Task<IEnumerable<PaletteItem>> Suche(string value, CancellationToken token)
    {
        var v = value?.Trim() ?? string.Empty;
        var ergebnis = new List<PaletteItem>();
        ergebnis.AddRange(string.IsNullOrEmpty(v)
            ? _befehle
            : _befehle.Where(b => b.Label.Contains(v, StringComparison.OrdinalIgnoreCase)));

        if (!string.IsNullOrEmpty(v))
        {
            try
            {
                var treffer = await SearchService.SchnellsucheAsync(v, _istFuehrung, 8, token);
                ergebnis.AddRange(treffer.Select(t => new PaletteItem(t.Name, t.Aktenzeichen, PaletteIcon(t.Kategorie), SuchNavigation.Route(t.Kategorie, t.ZielId))));
            }
            catch (Exception ex)
            {
                // Schnellsuche-Fehler nicht eskalieren (dann nur die statischen Befehle anzeigen), aber loggen.
                Logger.LogDebug(ex, "Schnellsuche in der Command-Palette fehlgeschlagen.");
            }
        }
        return ergebnis;
    }

    private async Task GewaehltAsync(PaletteItem? item)
    {
        if (item is null)
        {
            return;
        }
        _open = false;
        await _auto.ClearAsync();
        Nav.NavigateTo(item.Url);
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_modul is not null)
            {
                await _modul.InvokeVoidAsync("unregisterCommandPalette");
                await _modul.DisposeAsync();
            }
        }
        catch (JSDisconnectedException)
        {
            // Circuit bereits getrennt – nichts zu tun.
        }
        _ref?.Dispose();
    }

    private static string PaletteIcon(string kategorie) => kategorie switch
    {
        nameof(Fraktion) => Icons.Material.Filled.Groups,
        nameof(Personengruppe) => Icons.Material.Filled.Diversity3,
        nameof(Partei) => Icons.Material.Filled.AccountBalance,
        nameof(Operation) => Icons.Material.Filled.Radar,
        nameof(Taskforce) => Icons.Material.Filled.Groups2,
        nameof(Vorgang) => Icons.Material.Filled.FolderSpecial,
        _ => Icons.Material.Filled.Badge,
    };

    private record PaletteItem(string Label, string? Sub, string Icon, string Url);
}
