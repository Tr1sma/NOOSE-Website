@* Dialog zum Anlegen/Bearbeiten eines Tags (Name + Farbe). Liefert eine TagEingabe zurück. *@

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form">
            <MudStack Spacing="3">
                <MudTextField @bind-Value="_name" Label="Tag-Name" Variant="Variant.Outlined"
                              Required="true" RequiredError="Name ist erforderlich" />
                <MudSelect T="Color" Label="Farbe" @bind-Value="_farbe" Variant="Variant.Outlined">
                    @foreach (var c in Farben)
                    {
                        <MudSelectItem Value="c">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudChip T="string" Size="Size.Small" Color="c" Variant="Variant.Filled">@_name</MudChip>
                                <MudText Typo="Typo.body2">@c.ToString()</MudText>
                            </MudStack>
                        </MudSelectItem>
                    }
                </MudSelect>
            </MudStack>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Abbrechen">Abbrechen</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Speichern">Speichern</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string? Name { get; set; }
    [Parameter] public string? Farbe { get; set; }

    private MudForm _form = default!;
    private string _name = string.Empty;
    private Color _farbe = Color.Default;

    private static readonly Color[] Farben =
    {
        Color.Default, Color.Primary, Color.Secondary, Color.Tertiary,
        Color.Info, Color.Success, Color.Warning, Color.Error, Color.Dark,
    };

    protected override void OnInitialized()
    {
        _name = Name ?? string.Empty;
        _farbe = Enum.TryParse<Color>(Farbe, out var c) ? c : Color.Default;
    }

    private async Task Speichern()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid)
        {
            return;
        }
        MudDialog.Close(DialogResult.Ok(new TagEingabe
        {
            Name = _name.Trim(),
            Farbe = _farbe == Color.Default ? null : _farbe.ToString(),
        }));
    }

    private void Abbrechen() => MudDialog.Cancel();

    /// <summary>Zeigt den Dialog zum Anlegen (ohne Werte) oder Bearbeiten (mit Werten). Liefert null bei Abbruch.</summary>
    public static async Task<TagEingabe?> ZeigenAsync(IDialogService dialog, string titel, string? name = null, string? farbe = null)
    {
        var parameters = new DialogParameters<TagDialog>
        {
            { x => x.Name, name },
            { x => x.Farbe, farbe },
        };
        var referenz = await dialog.ShowAsync<TagDialog>(titel, parameters);
        var ergebnis = await referenz.Result;
        return ergebnis is { Canceled: false, Data: TagEingabe e } ? e : null;
    }
}
