@* Konflikte und Bündnisse einer Organisation (Fraktion/Personengruppe) zu anderen Organisationen –
   über die generische Verknüpfungs-Engine, getrennt nach VerknuepfungArt. Ziele typübergreifend. *@
@inject IVerknuepfungService VerknuepfungService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudStack Spacing="6">
    @foreach (var s in Sektionen)
    {
        var liste = _listen.TryGetValue(s.Art, out var l) ? l : new();
        <MudStack Spacing="3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudText Typo="Typo.subtitle1" Color="s.Farbe">@s.Titel (@liste.Count)</MudText>
                <MudButton Variant="Variant.Outlined" Color="s.Farbe" StartIcon="@s.Icon" OnClick="@(() => HinzufuegenAsync(s))">
                    @s.AddText
                </MudButton>
            </MudStack>

            @if (_laden)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            }
            else if (liste.Count == 0)
            {
                <MudText Typo="Typo.body2" Class="mud-text-secondary">@s.LeerText</MudText>
            }
            else
            {
                @foreach (var v in liste)
                {
                    <MudPaper Class="pa-3" Elevation="1">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@s.Icon" Color="s.Farbe" Size="Size.Small" />
                                <MudLink Href="@SuchNavigation.Route(v.AndereTyp, v.AndereId)" Typo="Typo.body2"><b>@v.AndereBezeichnung</b></MudLink>
                                @if (!string.IsNullOrWhiteSpace(v.Label))
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">@v.Label</MudChip>
                                }
                            </MudStack>
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                           OnClick="@(() => EntfernenAsync(s, v))" aria-label="@($"{s.Bezeichnung} entfernen")" />
                        </MudStack>
                    </MudPaper>
                }
            }
        </MudStack>
    }
</MudStack>

@code {
    [Parameter, EditorRequired] public string EntitaetTyp { get; set; } = default!;
    [Parameter, EditorRequired] public string EntitaetId { get; set; } = default!;
    [Parameter, EditorRequired] public ClaimsPrincipal User { get; set; } = default!;

    private bool _laden = true;
    private readonly Dictionary<VerknuepfungArt, List<VerknuepfungAnzeige>> _listen = new();

    private sealed record Sektion(VerknuepfungArt Art, string Titel, string Bezeichnung, string AddText, string LeerText, Color Farbe, string Icon);

    private static readonly Sektion[] Sektionen =
    {
        new(VerknuepfungArt.Konflikt, "Konflikte", "Konflikt", "Konflikt hinzufügen", "Keine Konflikte erfasst.",
            Color.Error, Icons.Material.Filled.Bolt),
        new(VerknuepfungArt.Buendnis, "Bündnisse", "Bündnis", "Bündnis hinzufügen", "Keine Bündnisse erfasst.",
            Color.Success, Icons.Material.Filled.Handshake),
    };

    protected override async Task OnInitializedAsync() => await LadenAsync();

    private async Task LadenAsync()
    {
        _laden = true;
        var istFuehrung = User.IstFuehrung();
        foreach (var s in Sektionen)
        {
            _listen[s.Art] = await VerknuepfungService.GetFuerAkteAsync(EntitaetTyp, EntitaetId, istFuehrung, s.Art);
        }
        _laden = false;
    }

    private async Task HinzufuegenAsync(Sektion s)
    {
        // Bereits verknüpfte Ziele (beide Arten) + die eigene Akte ausschließen.
        var alle = _listen.Values.SelectMany(l => l).ToList();
        var fraktionAus = alle.Where(v => v.AndereTyp == nameof(Fraktion)).Select(v => v.AndereId).ToList();
        var gruppenAus = alle.Where(v => v.AndereTyp == nameof(Personengruppe)).Select(v => v.AndereId).ToList();
        var parteiAus = alle.Where(v => v.AndereTyp == nameof(Partei)).Select(v => v.AndereId).ToList();
        switch (EntitaetTyp)
        {
            case nameof(Fraktion): fraktionAus.Add(EntitaetId); break;
            case nameof(Personengruppe): gruppenAus.Add(EntitaetId); break;
            case nameof(Partei): parteiAus.Add(EntitaetId); break;
        }

        var wahl = await OrgBeziehungDialog.ZeigenAsync(DialogService, s.Bezeichnung, User.IstFuehrung(), fraktionAus, gruppenAus, parteiAus);
        if (wahl is null)
        {
            return;
        }
        try
        {
            await VerknuepfungService.ErstellenAsync(EntitaetTyp, EntitaetId, wahl.ZielTyp, wahl.ZielId, wahl.Notiz, User, s.Art);
            Snackbar.Add($"{s.Bezeichnung} gespeichert.", Severity.Success);
            await LadenAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task EntfernenAsync(Sektion s, VerknuepfungAnzeige v)
    {
        var ok = await BestaetigenDialog.ZeigenAsync(DialogService, $"{s.Bezeichnung} löschen?",
            $"Die Beziehung zu „{v.AndereBezeichnung}“ wird entfernt.");
        if (!ok)
        {
            return;
        }
        await VerknuepfungService.EntfernenAsync(v.VerknuepfungId, User);
        Snackbar.Add($"{s.Bezeichnung} gelöscht.", Severity.Success);
        await LadenAsync();
    }
}
