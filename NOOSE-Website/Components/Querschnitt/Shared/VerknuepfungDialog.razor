@* Dialog zum Anlegen einer Verknüpfung auf eine beliebige Akte: Aktentyp wählen, Ziel suchen, optionaler Label. *@
@inject IPersonService PersonService
@inject IFraktionService FraktionService
@inject IPersonengruppeService GruppeService
@inject IParteiService ParteiService
@inject IAgentVerwaltungService AgentService
@inject IPersonDokService DokService

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3" Style="min-width:380px;">
            <MudSelect T="string" Label="Aktentyp" @bind-Value="_zielTyp" @bind-Value:after="TypGewechseltAsync"
                       Variant="Variant.Outlined" Dense="true"
                       Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Category">
                @foreach (var t in _typen)
                {
                    <MudSelectItem Value="@t.Wert">@t.Anzeige</MudSelectItem>
                }
            </MudSelect>

            @switch (_zielTyp)
            {
                case nameof(Person):
                    <MudAutocomplete T="Person" Label="Person" @bind-Value="_person" AutoFocus="true"
                                     SearchFunc="@SuchePersonen" ToStringFunc="@(p => p?.Name ?? string.Empty)"
                                     Variant="Variant.Outlined" Clearable="true" CoerceText="false" CoerceValue="false"
                                     ResetValueOnEmptyText="true" MinCharacters="0" Immediate="true"
                                     Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.PersonSearch">
                        <ItemTemplate Context="p">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.Badge" Size="Size.Small" Color="Color.Primary" />
                                <MudText Typo="Typo.body2">@p.Name</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@p.Aktenzeichen</MudText>
                            </MudStack>
                        </ItemTemplate>
                    </MudAutocomplete>
                    break;

                case nameof(Fraktion):
                    <MudAutocomplete T="Fraktion" Label="Fraktion" @bind-Value="_fraktion" AutoFocus="true"
                                     SearchFunc="@SucheFraktionen" ToStringFunc="@(f => f?.Name ?? string.Empty)"
                                     Variant="Variant.Outlined" Clearable="true" CoerceText="false" CoerceValue="false"
                                     ResetValueOnEmptyText="true" MinCharacters="0" Immediate="true"
                                     Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Groups">
                        <ItemTemplate Context="f">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.Groups" Size="Size.Small" Color="Color.Primary" />
                                <MudText Typo="Typo.body2">@f.Name</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@f.Aktenzeichen</MudText>
                            </MudStack>
                        </ItemTemplate>
                    </MudAutocomplete>
                    break;

                case nameof(Personengruppe):
                    <MudAutocomplete T="Personengruppe" Label="Personengruppe" @bind-Value="_gruppe" AutoFocus="true"
                                     SearchFunc="@SucheGruppen" ToStringFunc="@(g => g?.Name ?? string.Empty)"
                                     Variant="Variant.Outlined" Clearable="true" CoerceText="false" CoerceValue="false"
                                     ResetValueOnEmptyText="true" MinCharacters="0" Immediate="true"
                                     Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Diversity3">
                        <ItemTemplate Context="g">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.Diversity3" Size="Size.Small" Color="Color.Primary" />
                                <MudText Typo="Typo.body2">@g.Name</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@g.Aktenzeichen</MudText>
                            </MudStack>
                        </ItemTemplate>
                    </MudAutocomplete>
                    break;

                case nameof(Partei):
                    <MudAutocomplete T="Partei" Label="Partei" @bind-Value="_partei" AutoFocus="true"
                                     SearchFunc="@SucheParteien" ToStringFunc="@(p => p?.Name ?? string.Empty)"
                                     Variant="Variant.Outlined" Clearable="true" CoerceText="false" CoerceValue="false"
                                     ResetValueOnEmptyText="true" MinCharacters="0" Immediate="true"
                                     Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AccountBalance">
                        <ItemTemplate Context="p">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Size="Size.Small" Color="Color.Primary" />
                                <MudText Typo="Typo.body2">@p.Name</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@p.Aktenzeichen</MudText>
                            </MudStack>
                        </ItemTemplate>
                    </MudAutocomplete>
                    break;

                case nameof(Agent):
                    <MudAutocomplete T="Agent" Label="Agent" @bind-Value="_agent" AutoFocus="true"
                                     SearchFunc="@SucheAgenten" ToStringFunc="@(a => a?.Codename ?? string.Empty)"
                                     Variant="Variant.Outlined" Clearable="true" CoerceText="false" CoerceValue="false"
                                     ResetValueOnEmptyText="true" MinCharacters="0" Immediate="true"
                                     Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.ManageAccounts">
                        <ItemTemplate Context="a">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Color="Color.Primary" />
                                <MudText Typo="Typo.body2">@a.Codename</MudText>
                                @if (IstFuehrung && !string.IsNullOrWhiteSpace(a.Klarname))
                                {
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">(@a.Klarname)</MudText>
                                }
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@DienstgradAnzeige.Name(a.Dienstgrad)</MudText>
                            </MudStack>
                        </ItemTemplate>
                    </MudAutocomplete>
                    break;

                case nameof(PersonDok):
                    <MudAutocomplete T="PersonDokAnzeige" Label="Personen-Dok" @bind-Value="_dok" AutoFocus="true"
                                     SearchFunc="@SucheDoks" ToStringFunc="@DokText"
                                     Variant="Variant.Outlined" Clearable="true" CoerceText="false" CoerceValue="false"
                                     ResetValueOnEmptyText="true" MinCharacters="0" Immediate="true"
                                     Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Description">
                        <ItemTemplate Context="d">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" Color="Color.Primary" />
                                <MudText Typo="Typo.body2">@d.Dok.Person?.Name</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@d.Dok.Zeitpunkt.ToLocalTime().ToString("dd.MM.yyyy")</MudText>
                                @if (!string.IsNullOrWhiteSpace(d.Dok.Grund))
                                {
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">· @d.Dok.Grund</MudText>
                                }
                            </MudStack>
                        </ItemTemplate>
                    </MudAutocomplete>
                    break;
            }

            <MudTextField @bind-Value="_label" Label="Bezeichnung (optional)" Variant="Variant.Outlined"
                          Placeholder="z. B. siehe auch / Quelle für" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Abbrechen">Abbrechen</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Speichern" Disabled="@(AktuelleZielId is null)">Verknüpfen</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public bool IstFuehrung { get; set; }
    /// <summary>Diese Person (die aktuelle Akte) wird aus der Personen-Auswahl ausgeschlossen.</summary>
    [Parameter] public string? AusschlussPersonId { get; set; }

    private record TypOption(string Wert, string Anzeige);
    private static readonly TypOption[] _typen =
    {
        new(nameof(Person), "Person"),
        new(nameof(Fraktion), "Fraktion"),
        new(nameof(Personengruppe), "Personengruppe"),
        new(nameof(Partei), "Partei"),
        new(nameof(Agent), "Agent"),
        new(nameof(PersonDok), "Personen-Dok"),
    };

    private string _zielTyp = nameof(Person);
    private string? _label;

    private Person? _person;
    private Fraktion? _fraktion;
    private Personengruppe? _gruppe;
    private Partei? _partei;
    private Agent? _agent;
    private PersonDokAnzeige? _dok;

    // Agent-/Dok-Listen werden bei Bedarf einmalig geladen (clientseitige Suche).
    private List<Agent>? _alleAgenten;
    private List<PersonDokAnzeige>? _alleDoks;

    private string? AktuelleZielId => _zielTyp switch
    {
        nameof(Person) => _person?.Id,
        nameof(Fraktion) => _fraktion?.Id,
        nameof(Personengruppe) => _gruppe?.Id,
        nameof(Partei) => _partei?.Id,
        nameof(Agent) => _agent?.Id,
        nameof(PersonDok) => _dok?.Dok.Id,
        _ => null,
    };

    private async Task TypGewechseltAsync()
    {
        // Auswahl der vorherigen Art verwerfen, Listen für client-seitige Suche bei Bedarf laden.
        _person = null; _fraktion = null; _gruppe = null; _partei = null; _agent = null; _dok = null;
        if (_zielTyp == nameof(Agent) && _alleAgenten is null)
        {
            _alleAgenten = (await AgentService.GetAlleAsync()).Where(a => a.Status == AgentStatus.Aktiv).ToList();
        }
        if (_zielTyp == nameof(PersonDok) && _alleDoks is null)
        {
            _alleDoks = await DokService.GetAlleAsync(IstFuehrung);
        }
    }

    private async Task<IEnumerable<Person>> SuchePersonen(string value, CancellationToken token)
    {
        var treffer = await PersonService.SucheAsync(value, IstFuehrung, 20, token);
        return AusschlussPersonId is null ? treffer : treffer.Where(p => p.Id != AusschlussPersonId);
    }

    private async Task<IEnumerable<Fraktion>> SucheFraktionen(string value, CancellationToken token)
        => await FraktionService.SucheAsync(value, IstFuehrung, 20, token);

    private async Task<IEnumerable<Personengruppe>> SucheGruppen(string value, CancellationToken token)
        => await GruppeService.SucheAsync(value, IstFuehrung, 20, token);

    private async Task<IEnumerable<Partei>> SucheParteien(string value, CancellationToken token)
        => await ParteiService.SucheAsync(value, IstFuehrung, 20, token);

    private Task<IEnumerable<Agent>> SucheAgenten(string value, CancellationToken token)
    {
        var alle = (IEnumerable<Agent>?)_alleAgenten ?? Array.Empty<Agent>();
        var s = value?.Trim();
        if (!string.IsNullOrWhiteSpace(s))
        {
            alle = alle.Where(a => a.Codename.Contains(s, StringComparison.OrdinalIgnoreCase)
                                || (IstFuehrung && (a.Klarname ?? string.Empty).Contains(s, StringComparison.OrdinalIgnoreCase)));
        }
        return Task.FromResult(alle);
    }

    private Task<IEnumerable<PersonDokAnzeige>> SucheDoks(string value, CancellationToken token)
    {
        var alle = (IEnumerable<PersonDokAnzeige>?)_alleDoks ?? Array.Empty<PersonDokAnzeige>();
        var s = value?.Trim();
        if (!string.IsNullOrWhiteSpace(s))
        {
            alle = alle.Where(d => (d.Dok.Person?.Name ?? string.Empty).Contains(s, StringComparison.OrdinalIgnoreCase)
                                || (d.Dok.Person?.Aktenzeichen ?? string.Empty).Contains(s, StringComparison.OrdinalIgnoreCase)
                                || (d.Dok.Grund ?? string.Empty).Contains(s, StringComparison.OrdinalIgnoreCase));
        }
        return Task.FromResult(alle);
    }

    private static string DokText(PersonDokAnzeige? d)
        => d is null ? string.Empty : $"{d.Dok.Person?.Name} – {d.Dok.Zeitpunkt.ToLocalTime():dd.MM.yyyy}";

    private void Speichern()
    {
        var id = AktuelleZielId;
        if (id is null)
        {
            return;
        }
        MudDialog.Close(DialogResult.Ok(new VerknuepfungEingabe { ZielTyp = _zielTyp, ZielId = id, Label = _label }));
    }

    private void Abbrechen() => MudDialog.Cancel();

    /// <summary>Zeigt den Dialog und liefert die Eingabe (inkl. Zieltyp) oder null bei Abbruch.</summary>
    public static async Task<VerknuepfungEingabe?> ZeigenAsync(IDialogService dialog, bool istFuehrung, string ausschlussPersonId)
    {
        var parameters = new DialogParameters<VerknuepfungDialog>
        {
            { x => x.IstFuehrung, istFuehrung },
            { x => x.AusschlussPersonId, ausschlussPersonId },
        };
        var referenz = await dialog.ShowAsync<VerknuepfungDialog>("Verknüpfung hinzufügen", parameters);
        var ergebnis = await referenz.Result;
        return ergebnis is { Canceled: false, Data: VerknuepfungEingabe e } ? e : null;
    }
}
