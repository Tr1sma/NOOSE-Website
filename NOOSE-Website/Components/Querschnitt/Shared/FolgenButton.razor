@* Folgen/Entfolgen-Umschalter für eine Akte (Watchlist). Wird in die Aktionsleiste der Detailseiten gesetzt. *@
@inject IWatchlistService WatchlistService
@inject ISnackbar Snackbar

<MudButton Variant="@(_gefolgt ? Variant.Filled : Variant.Outlined)"
           Color="@(_gefolgt ? Color.Warning : Color.Default)"
           StartIcon="@(_gefolgt ? Icons.Material.Filled.Star : Icons.Material.Filled.StarBorder)"
           OnClick="UmschaltenAsync" Disabled="_busy"
           aria-label="@(_gefolgt ? "Nicht mehr folgen" : "Dieser Akte folgen")">
    @(_gefolgt ? "Beobachtet" : "Folgen")
</MudButton>

@code {
    [Parameter, EditorRequired] public string EntitaetTyp { get; set; } = default!;
    [Parameter, EditorRequired] public string EntitaetId { get; set; } = default!;
    [Parameter, EditorRequired] public ClaimsPrincipal User { get; set; } = default!;

    private bool _gefolgt;
    private bool _busy;
    private string? _geladen;

    // Wird mit der Detailseite bei /…/{A} → /…/{B} wiederverwendet → auf Typ+Id-Wechsel reagieren (Projekt-Lifecycle).
    protected override async Task OnParametersSetAsync()
    {
        var schluessel = $"{EntitaetTyp}:{EntitaetId}";
        if (_geladen == schluessel)
        {
            return;
        }
        _geladen = schluessel;
        _gefolgt = await WatchlistService.IstGefolgtAsync(EntitaetTyp, EntitaetId, User);
    }

    private async Task UmschaltenAsync()
    {
        if (_busy)
        {
            return;
        }
        _busy = true;
        try
        {
            if (_gefolgt)
            {
                await WatchlistService.EntfolgenAsync(EntitaetTyp, EntitaetId, User);
                _gefolgt = false;
                Snackbar.Add("Du folgst dieser Akte nicht mehr.", Severity.Info);
            }
            else
            {
                await WatchlistService.FolgenAsync(EntitaetTyp, EntitaetId, User);
                _gefolgt = true;
                Snackbar.Add("Du folgst dieser Akte – Änderungen erscheinen in deinen Benachrichtigungen.", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }
}
