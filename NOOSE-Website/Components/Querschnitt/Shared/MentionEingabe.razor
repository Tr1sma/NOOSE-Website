@* Eingabefeld mit @-Picker: beim Tippen von @… erscheinen Vorschläge (Akten/Quellen/Agenten); die Auswahl
   fügt ein @{Typ:Id}-Token an der Tippstelle ein. Darunter eine „Verlinkt:"-Chipleiste mit ✕ zum Entfernen.
   Ctrl+Enter löst OnSubmit aus. Zweiweg-Bindung über @bind-Text. Wiederverwendbar. *@
@using System.Text.RegularExpressions
@inject IMentionService MentionService

<MudTextField T="string" Value="@_text" ValueChanged="OnTextChanged" Immediate="true"
              Placeholder="@Placeholder" Variant="Variant.Outlined" Lines="2"
              Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.AlternateEmail"
              OnAdornmentClick="ManuellOeffnenAsync" AdornmentAriaLabel="Objekt verlinken"
              OnKeyDown="OnKeyDown" />

@if (_pickerOffen && _kandidaten.Count > 0)
{
    <MudPaper Class="pa-1 mt-1" Elevation="4" Style="max-height:260px;overflow-y:auto;">
        @foreach (var k in _kandidaten)
        {
            <MudButton FullWidth="true" Variant="Variant.Text" Class="justify-start text-none px-2"
                       OnClick="@(() => EinfuegenAsync(k))">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="flex-grow-1" Style="width:100%;">
                    <MudIcon Icon="@Symbol(k.Typ)" Size="Size.Small" Color="Color.Primary" />
                    <MudText Typo="Typo.body2">@k.Anzeige</MudText>
                    @if (!string.IsNullOrWhiteSpace(k.Sub))
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@k.Sub</MudText>
                    }
                    <MudSpacer />
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@TypLabel(k.Typ)</MudText>
                </MudStack>
            </MudButton>
        }
    </MudPaper>
}

@if (_verweise.Count > 0)
{
    <MudStack Row="true" Spacing="1" Class="flex-wrap mt-1" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.caption" Class="mud-text-secondary">Verlinkt:</MudText>
        @for (var i = 0; i < _verweise.Count; i++)
        {
            var idx = i;
            var v = _verweise[i];
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                     Color="@(v.Verborgen ? Color.Warning : Color.Primary)"
                     Icon="@Symbol(v.Typ)" OnClose="@(() => EntferneTokenAsync(idx))">@v.Text</MudChip>
        }
    </MudStack>
}

@code {
    [Parameter] public string Text { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> TextChanged { get; set; }
    [Parameter] public bool IstFuehrung { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    /// <summary>Wird bei Ctrl+Enter ausgelöst (Senden).</summary>
    [Parameter] public EventCallback OnSubmit { get; set; }

    private string _text = string.Empty;
    private bool _pickerOffen;
    private List<MentionTreffer> _kandidaten = new();
    private List<MentionSegment> _verweise = new();
    private string _verweisSignatur = string.Empty;

    // Aktive @-Abfrage am Tippende: @ gefolgt von Zeichen ohne Leerraum/@/Klammern (schließt fertige Tokens aus).
    private static readonly Regex AktiveQuery = new(@"@([^\s@{}]*)$", RegexOptions.Compiled);

    protected override async Task OnParametersSetAsync()
    {
        if (_text != (Text ?? string.Empty))
        {
            _text = Text ?? string.Empty;
            await VerweiseAktualisierenAsync();
        }
    }

    private async Task OnTextChanged(string? neu)
    {
        _text = neu ?? string.Empty;
        await TextChanged.InvokeAsync(_text);
        await PickerAktualisierenAsync();
        await VerweiseAktualisierenAsync();
    }

    private async Task PickerAktualisierenAsync()
    {
        var m = AktiveQuery.Match(_text);
        if (!m.Success || m.Groups[1].Value.Length < 1)
        {
            _pickerOffen = false;
            _kandidaten = new();
            return;
        }
        _kandidaten = await MentionService.KandidatenAsync(m.Groups[1].Value, IstFuehrung);
        _pickerOffen = _kandidaten.Count > 0;
    }

    private async Task EinfuegenAsync(MentionTreffer k)
    {
        var m = AktiveQuery.Match(_text);
        // Die aktive „@query" durch das Token ersetzen (sonst anhängen).
        _text = m.Success
            ? string.Concat(_text.AsSpan(0, m.Index), MentionParser.Token(k.Typ, k.Id), " ")
            : _text + MentionParser.Token(k.Typ, k.Id) + " ";
        _pickerOffen = false;
        _kandidaten = new();
        await TextChanged.InvokeAsync(_text);
        await VerweiseAktualisierenAsync();
    }

    private async Task EntferneTokenAsync(int index)
    {
        var tokens = MentionParser.Parse(_text);
        if (index < 0 || index >= tokens.Count)
        {
            return;
        }
        var t = tokens[index];
        _text = _text.Remove(t.Start, t.Laenge);
        await TextChanged.InvokeAsync(_text);
        await VerweiseAktualisierenAsync();
    }

    private async Task VerweiseAktualisierenAsync()
    {
        // Nur erneut auflösen, wenn sich die Token-Menge geändert hat (spart DB-Abfragen beim normalen Tippen).
        var sig = string.Join(",", MentionParser.Parse(_text).Select(t => $"{t.Typ}:{t.Id}"));
        if (sig == _verweisSignatur)
        {
            return;
        }
        _verweisSignatur = sig;
        if (string.IsNullOrEmpty(sig))
        {
            _verweise = new();
            return;
        }
        var segmente = await MentionService.AufloesenAsync(_text, IstFuehrung);
        _verweise = segmente.Where(s => s.IstVerweis).ToList();
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape" && _pickerOffen)
        {
            _pickerOffen = false;
            return;
        }
        if (e.Key == "Enter" && e.CtrlKey)
        {
            _pickerOffen = false;
            await OnSubmit.InvokeAsync();
        }
    }

    // Adornment-Klick: „@" einfügen als Starthilfe; die Vorschläge erscheinen, sobald ein Zeichen folgt.
    private async Task ManuellOeffnenAsync()
    {
        var trenner = _text.Length > 0 && !_text.EndsWith(" ") && !_text.EndsWith("\n") ? " " : string.Empty;
        _text = $"{_text}{trenner}@";
        await TextChanged.InvokeAsync(_text);
    }

    private static string Symbol(string? typ) => typ switch
    {
        nameof(Person) => Icons.Material.Filled.Badge,
        nameof(Fraktion) => Icons.Material.Filled.Groups,
        nameof(Personengruppe) => Icons.Material.Filled.Diversity3,
        nameof(Partei) => Icons.Material.Filled.AccountBalance,
        nameof(Operation) => Icons.Material.Filled.Radar,
        nameof(Taskforce) => Icons.Material.Filled.Groups2,
        nameof(Quelle) => Icons.Material.Filled.AttachFile,
        nameof(Agent) => Icons.Material.Filled.Person,
        _ => Icons.Material.Filled.Link,
    };

    private static string TypLabel(string? typ) => typ switch
    {
        nameof(Person) => "Person",
        nameof(Fraktion) => "Fraktion",
        nameof(Personengruppe) => "Gruppe",
        nameof(Partei) => "Partei",
        nameof(Operation) => "Operation",
        nameof(Taskforce) => "Taskforce",
        nameof(Quelle) => "Quelle",
        nameof(Agent) => "Agent",
        _ => "",
    };
}
