@* Zusatzfelder-Panel einer Akte: zeigt die admin-definierten Custom-Felder des Aktentyps und speichert deren Werte. *@
@using System.Globalization
@inject ICustomFeldWertService WertService
@inject ISnackbar Snackbar

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudText Typo="Typo.subtitle1">Zusatzfelder</MudText>
        @if (_felder.Count > 0)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save"
                       OnClick="SpeichernAsync" Disabled="_speichert">
                Speichern
            </MudButton>
        }
    </MudStack>

    @if (_laden)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_felder.Count == 0)
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">
            Für diesen Aktentyp sind keine Zusatzfelder definiert. Admins können sie unter
            <MudLink Href="/admin/custom-felder">Verwaltung → Custom-Felder</MudLink> anlegen.
        </MudText>
    }
    else
    {
        @foreach (var f in _felder)
        {
            var id = f.Definition.Id;
            var label = f.Definition.Pflicht ? $"{f.Definition.Name} *" : f.Definition.Name;

            switch (f.Definition.FeldTyp)
            {
                case CustomFeldTyp.Mehrzeilig:
                    <MudTextField T="string" Label="@label" Lines="3" Variant="Variant.Outlined"
                                  Value="@_werte[id]" ValueChanged="@(v => _werte[id] = v)" />
                    break;
                case CustomFeldTyp.Zahl:
                    <MudNumericField T="decimal?" Label="@label" Variant="Variant.Outlined" Culture="@CultureInfo.InvariantCulture"
                                     Value="@AlsZahl(_werte[id])" ValueChanged="@(v => _werte[id] = v?.ToString(CultureInfo.InvariantCulture))" />
                    break;
                case CustomFeldTyp.Datum:
                    <MudDatePicker Label="@label" Variant="Variant.Outlined" DateFormat="dd.MM.yyyy"
                                   Date="@AlsDatum(_werte[id])" DateChanged="@(d => _werte[id] = d?.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture))" />
                    break;
                case CustomFeldTyp.JaNein:
                    <MudSwitch T="bool" Label="@label" Color="Color.Primary"
                               Value="@(_werte[id] == "true")" ValueChanged="@(v => _werte[id] = v ? "true" : "false")" />
                    break;
                case CustomFeldTyp.Auswahl:
                    <MudSelect T="string" Label="@label" Variant="Variant.Outlined" Clearable="true"
                               Value="@_werte[id]" ValueChanged="@(v => _werte[id] = v)">
                        @foreach (var opt in Optionen(f.Definition.Optionen))
                        {
                            <MudSelectItem T="string" Value="@opt">@opt</MudSelectItem>
                        }
                    </MudSelect>
                    break;
                default:
                    <MudTextField T="string" Label="@label" Variant="Variant.Outlined"
                                  Value="@_werte[id]" ValueChanged="@(v => _werte[id] = v)" />
                    break;
            }
        }
    }
</MudStack>

@code {
    [Parameter, EditorRequired] public string EntitaetTyp { get; set; } = default!;
    [Parameter, EditorRequired] public string EntitaetId { get; set; } = default!;
    [Parameter, EditorRequired] public ClaimsPrincipal User { get; set; } = default!;

    private bool _laden = true;
    private bool _speichert;
    private List<CustomFeldWertAnzeige> _felder = new();
    private readonly Dictionary<string, string?> _werte = new();

    protected override async Task OnInitializedAsync() => await LadenAsync();

    private async Task LadenAsync()
    {
        _laden = true;
        _felder = await WertService.GetFuerAkteAsync(EntitaetTyp, EntitaetId);
        _werte.Clear();
        foreach (var f in _felder)
        {
            _werte[f.Definition.Id] = f.Wert;
        }
        _laden = false;
    }

    private async Task SpeichernAsync()
    {
        _speichert = true;
        try
        {
            await WertService.SetzenAsync(EntitaetTyp, EntitaetId, _werte, User);
            Snackbar.Add("Zusatzfelder gespeichert.", Severity.Success);
            await LadenAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _speichert = false;
        }
    }

    private static decimal? AlsZahl(string? wert)
        => decimal.TryParse(wert, NumberStyles.Any, CultureInfo.InvariantCulture, out var d) ? d : null;

    private static DateTime? AlsDatum(string? wert)
        => DateTime.TryParse(wert, CultureInfo.InvariantCulture, DateTimeStyles.None, out var dt) ? dt : null;

    private static IEnumerable<string> Optionen(string? optionen) => string.IsNullOrWhiteSpace(optionen)
        ? Enumerable.Empty<string>()
        : optionen.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
}
