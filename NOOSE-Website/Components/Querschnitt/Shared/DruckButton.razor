@* Druck-/PDF-Export (Phase 7): öffnet den Browser-Druckdialog. Über die @media-print-Regeln in
   app.css wird dabei nur der Akteninhalt (ohne Navigation/Topbar/Buttons) gedruckt; „Als PDF
   speichern" im Druckdialog erzeugt den PDF-Export. *@
@inject IJSRuntime JS

<MudTooltip Text="Drucken / als PDF speichern">
    <MudIconButton Icon="@Icons.Material.Filled.Print" Color="Color.Default" OnClick="Drucken"
                   aria-label="Drucken oder als PDF speichern" />
</MudTooltip>

@code {
    private async Task Drucken() => await JS.InvokeVoidAsync("window.print");
}
