@* Glocke in der Topbar: Badge mit Anzahl ungelesener Benachrichtigungen + Dropdown der neuesten. Klick markiert
   als gelesen und navigiert zum Ziel. Live-Aktualisierung über den NotificationBroadcaster (Muster TaskforceChatPanel). *@
@implements IAsyncDisposable
@inject INotificationService NotificationService
@inject NotificationBroadcaster Broadcaster
@inject NavigationManager Nav

<MudBadge Content="_ungelesen" Color="Color.Error" Overlap="true" Bordered="true" Visible="@(_ungelesen > 0)">
    <MudMenu Icon="@(_ungelesen > 0 ? Icons.Material.Filled.Notifications : Icons.Material.Filled.NotificationsNone)"
             Color="Color.Inherit" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight"
             Dense="true" aria-label="Benachrichtigungen" title="Benachrichtigungen">
        <div style="min-width:320px;max-width:380px;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="px-3 py-2">
                <MudText Typo="Typo.subtitle2">Benachrichtigungen</MudText>
                <MudSpacer />
                @if (_ungelesen > 0)
                {
                    <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="AlleGelesenAsync">Alle als gelesen</MudButton>
                }
            </MudStack>
            <MudDivider />
            @if (_laden)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="my-2" />
            }
            else if (_liste.Count == 0)
            {
                <MudText Typo="Typo.body2" Class="mud-text-secondary pa-3">Keine Benachrichtigungen.</MudText>
            }
            else
            {
                <div style="max-height:420px;overflow-y:auto;">
                    @foreach (var n in _liste)
                    {
                        var ungelesen = n.GelesenAm is null;
                        <MudMenuItem Icon="@NotificationTypAnzeige.Icon(n.Typ)"
                                     IconColor="@(ungelesen ? Color.Primary : Color.Default)"
                                     OnClick="@(() => OeffnenAsync(n))">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.body2" Style="@(ungelesen ? "font-weight:600;" : "")">@n.Titel</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                    @n.ErstelltAm.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                </MudText>
                            </MudStack>
                        </MudMenuItem>
                    }
                </div>
            }
        </div>
    </MudMenu>
</MudBadge>

@code {
    [Parameter, EditorRequired] public ClaimsPrincipal User { get; set; } = default!;

    private string? _agentId;
    private bool _laden = true;
    private int _ungelesen;
    private List<Benachrichtigung> _liste = new();

    protected override async Task OnInitializedAsync()
    {
        _agentId = User.GetAgentId();
        Broadcaster.Empfangen += OnEmpfangen;
        await LadenAsync();
    }

    private async Task LadenAsync()
    {
        if (string.IsNullOrWhiteSpace(_agentId))
        {
            _laden = false;
            return;
        }
        _ungelesen = await NotificationService.GetUngeleseneAnzahlAsync(User);
        _liste = await NotificationService.GetEigeneAsync(User, 20);
        _laden = false;
    }

    private async Task OeffnenAsync(Benachrichtigung n)
    {
        await NotificationService.AlsGelesenMarkierenAsync(n.Id, User); // Broadcaster lädt die Glocke neu.
        if (!string.IsNullOrWhiteSpace(n.Href))
        {
            Nav.NavigateTo(n.Href);
        }
    }

    private async Task AlleGelesenAsync()
    {
        await NotificationService.AlleAlsGelesenAsync(User); // Broadcaster lädt die Glocke neu.
    }

    // Live-Signal (ggf. aus anderem Circuit) → nur für die eigene Empfänger-Id in den eigenen Circuit marshallen.
    private void OnEmpfangen(string empfaengerId)
    {
        if (empfaengerId != _agentId)
        {
            return;
        }
        _ = InvokeAsync(async () =>
        {
            await LadenAsync();
            StateHasChanged();
        });
    }

    public ValueTask DisposeAsync()
    {
        Broadcaster.Empfangen -= OnEmpfangen;
        return ValueTask.CompletedTask;
    }
}
