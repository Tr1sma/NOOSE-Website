@* Minimal layout for print views: light theme, no navigation; the page itself is the document. *@
@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject IPartnerVisibilityPolicyService PartnerPolicy

<MudThemeProvider Theme="NooseTheme.Theme" IsDarkMode="false" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="druck-seite">
    @if (PartnerBlocked(Nav.ToBaseRelativePath(Nav.Uri)))
    {
        <p>Kein Zugriff – dieser Bereich ist für Partnerbehörden nicht freigegeben.</p>
    }
    else
    {
        @Body
    }
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthStateTask { get; set; }

    private bool _isPartner;
    private IReadOnlySet<string>? _allowedPartnerTypes;

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask is not null)
        {
            var user = (await AuthStateTask).User;
            _isPartner = user.IsPartner();
            if (_isPartner)
            {
                _allowedPartnerTypes = await PartnerPolicy.GetAllowedTypesAsync(user);
            }
        }
    }

    private bool PartnerBlocked(string path)
    {
        if (!_isPartner)
        {
            return false;
        }
        if (!PartnerRoutes.IsAllowed(path))
        {
            return true;
        }
        // documents enforce their own per-record visibility at the page layer
        if (PartnerTabCatalog.IsTypeGateExempt(path))
        {
            return false;
        }
        var typeKey = PartnerTabCatalog.TypeKeyForPath(path);
        return typeKey is not null && _allowedPartnerTypes is not null && !_allowedPartnerTypes.Contains(typeKey);
    }
}
