@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject ISystemEinstellungService EinstellungService
@inject IDialogService DialogService

<MudThemeProvider Theme="_theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="2">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="ToggleDrawer" aria-label="Navigation umschalten" />
        <MudImage Src="@(_konfiguration?.HatLogo == true ? "/system/logo" : "NooseIcon.png")" Alt="NOOSE Wappen" Height="36" Class="mr-3" />
        <MudText Typo="Typo.h6" Class="mr-3" Style="font-weight:700;letter-spacing:.12em;">N.O.O.S.E.</MudText>
        <MudText Typo="Typo.caption" Class="mud-text-secondary d-none d-md-flex">
            National Office of Security Enforcement
        </MudText>
        <MudSpacer />
        <AuthorizeView>
            <Authorized Context="auth">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                    @* Quick-Add (Phase 7): Schnellerfassung neuer Akten direkt aus der Topbar. *@
                    <AuthorizeView Policy="@Policies.Schreibrecht" Context="schreib">
                        <MudTooltip Text="Schnellerfassung – neue Akte anlegen">
                            <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Inherit"
                                           OnClick="QuickAddAsync" aria-label="Schnellerfassung" />
                        </MudTooltip>
                    </AuthorizeView>
                    <MudTextField T="string" @bind-Value="_suche" Placeholder="Suchen…" Immediate="true"
                                  Margin="Margin.Dense" Variant="Variant.Outlined"
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                                  OnKeyDown="SucheKeyDown" Class="d-none d-md-flex mt-0" Style="max-width:240px;" />
                    @* Auf kleinen Screens (ohne Suchfeld/Strg+K) ein Such-Icon, das direkt zur globalen Suche führt. *@
                    <MudIconButton Icon="@Icons.Material.Filled.Search" Color="Color.Inherit" Href="/suche"
                                   Class="d-flex d-md-none" aria-label="Suche" title="Suche" />
                    <BenachrichtigungGlocke User="auth.User" />
                    <MudLink Href="/profil" Underline="Underline.None" Color="Color.Inherit"
                             Class="d-flex align-center" title="Mein Profil">
                        <MudStack Spacing="0" AlignItems="AlignItems.End" Class="d-none d-sm-flex mr-3">
                            <MudText Typo="Typo.body2" Style="line-height:1.2;">@AnzeigeName(auth.User)</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="line-height:1.2;">
                                @RangZeile(auth.User)
                            </MudText>
                        </MudStack>
                        <MudAvatar Color="Color.Primary" Size="Size.Medium">@Initiale(AnzeigeName(auth.User))</MudAvatar>
                    </MudLink>
                    <form method="post" action="/Account/Logout">
                        <AntiforgeryToken />
                        <MudIconButton ButtonType="ButtonType.Submit" Icon="@Icons.Material.Filled.Logout"
                                       Color="Color.Inherit" aria-label="Abmelden" title="Abmelden" />
                    </form>
                </MudStack>
            </Authorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="1" ClipMode="DrawerClipMode.Always"
               Variant="DrawerVariant.Responsive" Breakpoint="Breakpoint.Md">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="px-4 py-6">
            <AuthorizeView Policy="@Policies.NurLeseModus" Context="ro">
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-4">
                    Nur-Lese-Modus (Aufsicht): Sie können alle Inhalte einsehen, aber keine Änderungen speichern.
                </MudAlert>
            </AuthorizeView>

            @* Ankündigungsbanner (Phase 7): von der Führung/Admins unter /admin/system gepflegt. *@
            @if (!string.IsNullOrWhiteSpace(_konfiguration?.BannerText))
            {
                <MudAlert Severity="@BannerSeverity" Dense="true" Class="mb-4 no-print">@_konfiguration!.BannerText</MudAlert>
            }

            @if (_konfiguration?.WartungsmodusAktiv == true && _istAdmin)
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mb-4 no-print">
                    Wartungsmodus aktiv – normale Agenten sehen derzeit nur die Wartungsseite.
                    Deaktivieren unter <MudLink Href="/admin/system" Color="Color.Inherit"><b>System</b></MudLink>.
                </MudAlert>
            }

            @* Wartungsmodus (Phase 7): sperrt die Inhalte für alle außer Admins. *@
            @if (_konfiguration?.WartungsmodusAktiv == true && !_istAdmin)
            {
                <MudStack AlignItems="AlignItems.Center" Spacing="3" Class="pa-12">
                    <MudIcon Icon="@Icons.Material.Filled.Construction" Color="Color.Warning" Style="font-size:4rem;" />
                    <MudText Typo="Typo.h5">Wartungsmodus</MudText>
                    <MudText Typo="Typo.body1" Class="mud-text-secondary" Style="max-width:480px;text-align:center;">
                        @(_konfiguration!.WartungsmodusText ?? "Das System wird gerade gewartet. Bitte versuche es in Kürze erneut.")
                    </MudText>
                </MudStack>
            }
            else
            {
                @Body
            }
        </MudContainer>
    </MudMainContent>

    @* Command-Palette (Strg+K) – nur für eingeloggte Agenten aktiv. *@
    <AuthorizeView>
        <Authorized Context="cp">
            <CommandPalette />
        </Authorized>
    </AuthorizeView>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    Ein unerwarteter Fehler ist aufgetreten.
    <a href="." class="reload">Neu laden</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthStateTask { get; set; }

    private bool _drawerOpen = true;
    private string _suche = string.Empty;
    private SystemKonfiguration? _konfiguration;
    private MudTheme _theme = NooseTheme.Theme;
    private bool _istAdmin;

    protected override async Task OnInitializedAsync()
    {
        // Systemkonfiguration (gecacht): Theme-Farben, Logo, Banner, Wartungsmodus.
        _konfiguration = await EinstellungService.GetAsync();
        _theme = NooseTheme.MitFarben(_konfiguration.ThemePrimary, _konfiguration.ThemeSecondary, _konfiguration.ThemeTertiary);

        if (AuthStateTask is not null)
        {
            _istAdmin = (await AuthStateTask).User.IstAdmin();
        }
    }

    private Severity BannerSeverity => _konfiguration?.BannerStufe switch
    {
        BannerStufen.Warnung => Severity.Warning,
        BannerStufen.Fehler => Severity.Error,
        _ => Severity.Info,
    };

    private Task QuickAddAsync() => QuickAddDialog.ZeigenAsync(DialogService);

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private void SucheKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_suche))
        {
            Nav.NavigateTo($"/suche?q={Uri.EscapeDataString(_suche.Trim())}");
        }
    }

    private static string Initiale(string? name)
        => string.IsNullOrWhiteSpace(name) ? "?" : name.Trim()[..1].ToUpperInvariant();

    private static string AnzeigeName(System.Security.Claims.ClaimsPrincipal user)
    {
        var codename = user.GetCodename();
        return string.IsNullOrWhiteSpace(codename) ? "Unbenannter Agent" : codename;
    }

    private static string RangZeile(System.Security.Claims.ClaimsPrincipal user)
    {
        var teile = new List<string>();
        var dienstnummer = user.GetDienstnummer();
        if (!string.IsNullOrWhiteSpace(dienstnummer)) teile.Add($"Nr. {dienstnummer}");
        teile.Add(DienstgradAnzeige.Name(user.GetDienstgrad()));
        if (user.IstTRU()) teile.Add("TRU");
        if (user.IstAdmin()) teile.Add("Admin");
        return string.Join(" · ", teile);
    }
}
