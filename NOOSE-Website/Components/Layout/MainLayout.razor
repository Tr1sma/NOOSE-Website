@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject ISystemSettingService SettingService
@inject IPartnerVisibilityPolicyService PartnerPolicy
@inject INavPreferencesService NavPrefs
@inject IDialogService DialogService

<MudThemeProvider Theme="_theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="2">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="ToggleDrawer" aria-label="Navigation umschalten" />
        <MudImage Src="@(_configuration?.HasLogo == true ? "/system/logo" : "NooseIcon.png")" Alt="NOOSE Wappen" Height="36" Class="mr-3" />
        <MudText Typo="Typo.h6" Class="mr-3" Style="font-weight:700;letter-spacing:.12em;">N.O.O.S.E.</MudText>
        <MudText Typo="Typo.caption" Class="mud-text-secondary d-none d-md-flex">
            National Office of Security Enforcement
        </MudText>
        <MudSpacer />
        <AuthorizeView>
            <Authorized Context="auth">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                    @* Quick-add new records from the topbar. *@
                    <AuthorizeView Policy="@Policies.WriteAccess" Context="schreib">
                        <MudTooltip Text="Schnellerfassung – neue Akte anlegen">
                            <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Inherit"
                                           OnClick="QuickAddAsync" aria-label="Schnellerfassung" />
                        </MudTooltip>
                    </AuthorizeView>
                    <MudTextField T="string" @bind-Value="_search" Placeholder="Suchen…" Immediate="true"
                                  Margin="Margin.Dense" Variant="Variant.Outlined"
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                                  OnKeyDown="SearchKeyDown" Class="d-none d-md-flex mt-0" Style="max-width:240px;" />
                    @* Search icon for small screens (no search field/Ctrl+K). *@
                    <MudIconButton Icon="@Icons.Material.Filled.Search" Color="Color.Inherit" Href="/suche"
                                   Class="d-flex d-md-none" aria-label="Suche" title="Suche" />
                    <NotificationBell User="auth.User" />
                    <MudLink Href="/profil" Underline="Underline.None" Color="Color.Inherit"
                             Class="d-flex align-center" title="Mein Profil">
                        <MudStack Spacing="0" AlignItems="AlignItems.End" Class="d-none d-sm-flex mr-3">
                            <MudText Typo="Typo.body2" Style="line-height:1.2;">@DisplayName(auth.User)</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="line-height:1.2;">
                                @RankRow(auth.User)
                            </MudText>
                        </MudStack>
                        <MudAvatar Color="Color.Primary" Size="Size.Medium">@Initial(DisplayName(auth.User))</MudAvatar>
                    </MudLink>
                    <form method="post" action="/Account/Logout">
                        <AntiforgeryToken />
                        <MudIconButton ButtonType="ButtonType.Submit" Icon="@Icons.Material.Filled.Logout"
                                       Color="Color.Inherit" aria-label="Abmelden" title="Abmelden" />
                    </form>
                </MudStack>
            </Authorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="1" ClipMode="DrawerClipMode.Always"
               Variant="DrawerVariant.Responsive" Breakpoint="Breakpoint.Md">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="px-4 py-6">
            <AuthorizeView Policy="@Policies.OnlyReadMode" Context="ro">
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-4">
                    Nur-Lese-Modus (Aufsicht): Sie können alle Inhalte einsehen, aber keine Änderungen speichern.
                </MudAlert>
            </AuthorizeView>

            @* Announcement banner, maintained by leadership/admins under /admin/system. *@
            @if (!string.IsNullOrWhiteSpace(_configuration?.BannerText))
            {
                <MudAlert Severity="@BannerSeverity" Dense="true" Class="mb-4 no-print">@_configuration!.BannerText</MudAlert>
            }

            @if (_configuration?.MaintenanceModeActive == true && _isAdmin)
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mb-4 no-print">
                    Wartungsmodus aktiv – normale Agenten sehen derzeit nur die Wartungsseite.
                    Deaktivieren unter <MudLink Href="/admin/system" Color="Color.Inherit"><b>System</b></MudLink>.
                </MudAlert>
            }

            @* Maintenance mode: blocks content for everyone except admins. *@
            @if (_configuration?.MaintenanceModeActive == true && !_isAdmin)
            {
                <MudStack AlignItems="AlignItems.Center" Spacing="3" Class="pa-12">
                    <MudIcon Icon="@Icons.Material.Filled.Construction" Color="Color.Warning" Style="font-size:4rem;" />
                    <MudText Typo="Typo.h5">Wartungsmodus</MudText>
                    <MudText Typo="Typo.body1" Class="mud-text-secondary" Style="max-width:480px;text-align:center;">
                        @(_configuration!.MaintenanceModeText ?? "Das System wird gerade gewartet. Bitte versuche es in Kürze erneut.")
                    </MudText>
                </MudStack>
            }
            else if (PartnerBlocked(CurrentPath))
            {
                @* partner read access: released areas only *@
                <MudStack AlignItems="AlignItems.Center" Spacing="3" Class="pa-12">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Warning" Style="font-size:4rem;" />
                    <MudText Typo="Typo.h5">Kein Zugriff</MudText>
                    <MudText Typo="Typo.body1" Class="mud-text-secondary" Style="max-width:480px;text-align:center;">
                        Dieser Bereich ist für Partnerbehörden nicht freigegeben. Sie sehen ausschließlich die für Ihre
                        Behörde freigegebenen Akten.
                    </MudText>
                    <MudButton Href="/dashboard" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Home">Zur Startseite</MudButton>
                </MudStack>
            }
            else
            {
                <NavBreadcrumbs />
                @* safety net: a single page error must not kill the whole circuit *@
                <ErrorBoundary @key="CurrentPath">
                    <ChildContent>
                        @Body
                    </ChildContent>
                    <ErrorContent>
                        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="my-4">
                            Ein unerwarteter Fehler ist aufgetreten – die Aktion wurde abgebrochen.
                            <MudLink Href="@($"/{CurrentPath}")" Color="Color.Inherit"><b>Seite neu laden</b></MudLink>
                        </MudAlert>
                    </ErrorContent>
                </ErrorBoundary>
            }
        </MudContainer>

        @* Legal footer, reachable from anywhere. *@
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="px-4 pb-4 no-print">
            <MudDivider Class="mb-2" />
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="2">
                <MudLink Href="@LegalData.ImprintUrl" Target="_blank" rel="noopener noreferrer"
                         Typo="Typo.caption" Color="Color.Default">Impressum</MudLink>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">·</MudText>
                <MudLink Href="/datenschutz" Typo="Typo.caption" Color="Color.Default">Datenschutz</MudLink>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">·</MudText>
                <MudLink Href="/nutzungsbedingungen" Typo="Typo.caption" Color="Color.Default">Nutzungsbedingungen</MudLink>
            </MudStack>
        </MudContainer>
    </MudMainContent>

    @* Command palette (Ctrl+K), only for signed-in agents. *@
    <AuthorizeView>
        <Authorized Context="cp">
            <CommandPalette />
            <RecentsTracker />
        </Authorized>
    </AuthorizeView>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    Ein unerwarteter Fehler ist aufgetreten.
    <a href="." class="reload">Neu laden</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthStateTask { get; set; }

    private bool _drawerOpen = true;
    private string? _agentId;
    private string _search = string.Empty;
    private SystemConfiguration? _configuration;
    private MudTheme _theme = NooseTheme.Theme;
    private bool _isAdmin;
    private bool _isPartner;
    private IReadOnlySet<string>? _allowedPartnerTypes;

    // re-evaluated each render
    private string CurrentPath => Nav.ToBaseRelativePath(Nav.Uri);

    protected override async Task OnInitializedAsync()
    {
        _configuration = await SettingService.GetAsync();
        _theme = NooseTheme.WithColours(_configuration.ThemePrimary, _configuration.ThemeSecondary, _configuration.ThemeTertiary);

        if (AuthStateTask is not null)
        {
            var user = (await AuthStateTask).User;
            _isAdmin = user.IsAdmin();
            _isPartner = user.IsPartner();
            if (_isPartner)
            {
                _allowedPartnerTypes = await PartnerPolicy.GetAllowedTypesAsync(user);
            }

            // remembered drawer state (read at prerender → no post-hydration flicker)
            _agentId = user.GetAgentId();
            if (!string.IsNullOrEmpty(_agentId))
            {
                _drawerOpen = (await NavPrefs.GetAsync(_agentId)).DrawerOpen;
            }
        }
    }

    // partner gate: allowlisted route AND (not a record type OR the rank may access that type)
    private bool PartnerBlocked(string path)
    {
        if (!_isPartner)
        {
            return false;
        }
        if (!PartnerRoutes.IsAllowed(path))
        {
            return true;
        }
        var typeKey = PartnerTabCatalog.TypeKeyForPath(path);
        return typeKey is not null && _allowedPartnerTypes is not null && !_allowedPartnerTypes.Contains(typeKey);
    }

    private Severity BannerSeverity => _configuration?.BannerLevel switch
    {
        BannerLevels.Warning => Severity.Warning,
        BannerLevels.Error => Severity.Error,
        _ => Severity.Info,
    };

    private Task QuickAddAsync() => QuickAddDialog.ShowAsync(DialogService);

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
        if (!string.IsNullOrEmpty(_agentId))
        {
            // remember preference (fire-and-forget)
            _ = NavPrefs.SetDrawerOpenAsync(_agentId, _drawerOpen);
        }
    }

    private void SearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_search))
        {
            Nav.NavigateTo($"/suche?q={Uri.EscapeDataString(_search.Trim())}");
        }
    }

    private static string Initial(string? name)
        => string.IsNullOrWhiteSpace(name) ? "?" : name.Trim()[..1].ToUpperInvariant();

    private static string DisplayName(System.Security.Claims.ClaimsPrincipal user)
    {
        var codename = user.GetCodename();
        return string.IsNullOrWhiteSpace(codename) ? "Unbenannter Agent" : codename;
    }

    private static string RankRow(System.Security.Claims.ClaimsPrincipal user)
    {
        var parts = new List<string>();
        var badgeNumber = user.GetBadgeNumber();
        if (!string.IsNullOrWhiteSpace(badgeNumber)) parts.Add($"Nr. {badgeNumber}");
        parts.Add(RankDisplay.Name(user.GetRank()));
        if (user.IsTRU()) parts.Add("TRU");
        if (user.IsHRB()) parts.Add("HRB");
        if (user.IsAdmin()) parts.Add("Admin");
        return string.Join(" · ", parts);
    }
}
