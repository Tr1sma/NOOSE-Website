@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;
    [Inject] private IAgentManagementService AgentService { get; set; } = default!;
    [Inject] private ITaskforceService TaskforceService { get; set; } = default!;
    [Inject] private IPersonnelFileService PersonnelFileService { get; set; } = default!;
    [Inject] private IRequestService RequestService { get; set; } = default!;
    [Inject] private IAnnouncementService BoardService { get; set; } = default!;
    [Inject] private SharesBroadcaster SharesBroadcaster { get; set; } = default!;
    [Inject] private AcknowledgmentBroadcaster AcknowledgmentBroadcaster { get; set; } = default!;
    [Inject] private Microsoft.Extensions.Logging.ILogger<NavMenu> Logger { get; set; } = default!;

    private ClaimsPrincipal? _user;
    private int _openShares;
    private int _openAcknowledgments;

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;

        // Beide Badges melden sich nach einer Aktion über ihren Broadcaster → live neu zählen. Ohne diese Abos
        // blieben die Zahlen bis zum nächsten kompletten Seiten-Reload eingefroren.
        SharesBroadcaster.Modified += OnSharesModified;
        AcknowledgmentBroadcaster.Modified += OnAcknowledgmentModified;
        await LoadSharesAsync();
        await LoadAcknowledgmentsAsync();
    }

    // Offene Lesebestätigungen (Quittierungen) am Schwarzen Brett – für jeden aktiven Agenten.
    // Defensiv: Die Badges sind dekorativ – ein DB-Fehler hier darf weder das Prerender (→ generische
    // Fehlerseite) noch den Circuit (Broadcaster-Handler) reißen. Im Fehlerfall bleibt der Zähler stehen.
    private async Task LoadAcknowledgmentsAsync()
    {
        if (_user is null)
        {
            return;
        }
        try
        {
            _openAcknowledgments = await BoardService.GetOpenAcknowledgmentsCountAsync(_user);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Quittierungs-Badge konnte nicht geladen werden.");
        }
    }

    // Summiert die offenen Posteingangs-Vorgänge (dieselben Quellen wie die Freigaben-Seite). Wird beim Start und
    // nach jedem Broadcaster-Signal aufgerufen; setzt den Wert jedes Mal frisch (kein +=).
    private async Task LoadSharesAsync()
    {
        if (_user is null)
        {
            return;
        }
        try
        {
            var open = 0;

            // Hochstufungs-Anträge entscheidet bereits Senior Special Agent+ – sie zählen für diese Gruppe.
            if (_user.MayHighestClassification())
            {
                open += await RequestService.GetOpenCountAsync(_user.IsLeadership());
            }

            // Registrierungen + Namensänderungen + Taskforce- + Beförderungsanträge sind der Führung vorbehalten.
            if (_user.IsLeadership())
            {
                open += (await AgentService.GetPendingAsync()).Count
                    + (await AgentService.GetPendingNameChangesAsync()).Count
                    + (await TaskforceService.GetRequestedAsync()).Count
                    + (await PersonnelFileService.GetOpenPromotionRequestsAsync()).Count;
            }
            _openShares = open;
        }
        catch (Exception ex)
        {
            // Defensiv (s. LadeQuittierungenAsync): dekorativer Zähler, Fehler nie eskalieren.
            Logger.LogWarning(ex, "Freigaben-Badge konnte nicht geladen werden.");
        }
    }

    // Live-Signal (aus der Freigaben-Seite desselben Circuits) → in den Circuit marshallen und neu zählen.
    private void OnSharesModified()
        => _ = InvokeAsync(async () =>
        {
            await LoadSharesAsync();
            StateHasChanged();
        });

    // Live-Signal nach einer Quittierung – nur für die eigene Agent-Id in den eigenen Circuit marshallen.
    private void OnAcknowledgmentModified(string agentId)
    {
        if (agentId != _user?.GetAgentId())
        {
            return;
        }
        _ = InvokeAsync(async () =>
        {
            await LoadAcknowledgmentsAsync();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        SharesBroadcaster.Modified -= OnSharesModified;
        AcknowledgmentBroadcaster.Modified -= OnAcknowledgmentModified;
    }
}
