    @* Den Freigabe-Posteingang erreicht bereits Senior Special Agent+ (entscheidet Hochstufungen);
       die übrigen Verwaltungs-Links bleiben Führung bzw. Admin vorbehalten. Die *Seite-Policies lassen
       zusätzlich die Nur-Lese-Aufsicht (TeamLeitung ohne Admin) zum reinen Lesen herein. *@
    <AuthorizeView Policy="@Policies.HoechsteEinstufungSeite" Context="posteingang">
        <MudDivider Class="my-2" />
        <MudText Typo="Typo.caption" Class="px-4 py-1 mud-text-secondary">VERWALTUNG</MudText>
        <MudNavLink Href="/admin/freigaben" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.HowToReg">
            Freigaben
            @if (_offeneFreigaben > 0)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled" Class="ml-2">@_offeneFreigaben</MudChip>
            }
        </MudNavLink>
        <AuthorizeView Policy="@Policies.FuehrungSeite" Context="fuehrung">
            <MudNavLink Href="/admin/tags" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Label">
                Tags
            </MudNavLink>
            <MudNavLink Href="/admin/vorlagen" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Dvr">
                Vorlagen
            </MudNavLink>
            <MudNavLink Href="/admin/custom-felder" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Tune">
                Custom-Felder
            </MudNavLink>
            <MudNavLink Href="/admin/aktualitaet" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Timelapse">
                Aktualität
            </MudNavLink>
            <MudNavLink Href="/admin/agenten" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.ManageAccounts">
                Agenten-Verwaltung
            </MudNavLink>
            <MudNavLink Href="/admin/basisdaten" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Storage">
                Basisdaten
            </MudNavLink>
            <AuthorizeView Policy="@Policies.AdminSeite" Context="adminInner">
                <MudNavLink Href="/admin/system" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.SettingsApplications">
                    System
                </MudNavLink>
                <MudNavLink Href="/status" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.MonitorHeart">
                    System-Status
                </MudNavLink>
            </AuthorizeView>
        </AuthorizeView>
    </AuthorizeView>

</MudNavMenu>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;
    [Inject] private IAgentVerwaltungService AgentService { get; set; } = default!;
    [Inject] private ITaskforceService TaskforceService { get; set; } = default!;
    [Inject] private IPersonalakteService PersonalakteService { get; set; } = default!;
    [Inject] private IAntragService AntragService { get; set; } = default!;
    [Inject] private IAnkuendigungService BrettService { get; set; } = default!;
    [Inject] private FreigabenBroadcaster FreigabenBroadcaster { get; set; } = default!;
    [Inject] private QuittierungBroadcaster QuittierungBroadcaster { get; set; } = default!;
    [Inject] private Microsoft.Extensions.Logging.ILogger<NavMenu> Logger { get; set; } = default!;

    private ClaimsPrincipal? _user;
    private int _offeneFreigaben;
    private int _offeneQuittierungen;

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;

        // Beide Badges melden sich nach einer Aktion über ihren Broadcaster → live neu zählen. Ohne diese Abos
        // blieben die Zahlen bis zum nächsten kompletten Seiten-Reload eingefroren.
        FreigabenBroadcaster.Geaendert += OnFreigabenGeaendert;
        QuittierungBroadcaster.Geaendert += OnQuittierungGeaendert;
        await LadeFreigabenAsync();
        await LadeQuittierungenAsync();
    }

    // Offene Lesebestätigungen (Quittierungen) am Schwarzen Brett – für jeden aktiven Agenten.
    // Defensiv: Die Badges sind dekorativ – ein DB-Fehler hier darf weder das Prerender (→ generische
    // Fehlerseite) noch den Circuit (Broadcaster-Handler) reißen. Im Fehlerfall bleibt der Zähler stehen.
    private async Task LadeQuittierungenAsync()
    {
        if (_user is null)
        {
            return;
        }
        try
        {
            _offeneQuittierungen = await BrettService.GetOffeneQuittierungenAnzahlAsync(_user);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Quittierungs-Badge konnte nicht geladen werden.");
        }
    }

    // Summiert die offenen Posteingangs-Vorgänge (dieselben Quellen wie die Freigaben-Seite). Wird beim Start und
    // nach jedem Broadcaster-Signal aufgerufen; setzt den Wert jedes Mal frisch (kein +=).
    private async Task LadeFreigabenAsync()
    {
        if (_user is null)
        {
            return;
        }
        try
        {
            var offen = 0;

            // Hochstufungs-Anträge entscheidet bereits Senior Special Agent+ – sie zählen für diese Gruppe.
            if (_user.DarfHoechsteEinstufung())
            {
                offen += await AntragService.GetOffeneAnzahlAsync(_user.IstFuehrung());
            }

            // Registrierungen + Namensänderungen + Taskforce- + Beförderungsanträge sind der Führung vorbehalten.
            if (_user.IstFuehrung())
            {
                offen += (await AgentService.GetAusstehendeAsync()).Count
                    + (await AgentService.GetAusstehendeNamensaenderungenAsync()).Count
                    + (await TaskforceService.GetBeantragteAsync()).Count
                    + (await PersonalakteService.GetOffeneBefoerderungsantraegeAsync()).Count;
            }
            _offeneFreigaben = offen;
        }
        catch (Exception ex)
        {
            // Defensiv (s. LadeQuittierungenAsync): dekorativer Zähler, Fehler nie eskalieren.
            Logger.LogWarning(ex, "Freigaben-Badge konnte nicht geladen werden.");
        }
    }

    // Live-Signal (aus der Freigaben-Seite desselben Circuits) → in den Circuit marshallen und neu zählen.
    private void OnFreigabenGeaendert()
        => _ = InvokeAsync(async () =>
        {
            await LadeFreigabenAsync();
            StateHasChanged();
        });

    // Live-Signal nach einer Quittierung – nur für die eigene Agent-Id in den eigenen Circuit marshallen.
    private void OnQuittierungGeaendert(string agentId)
    {
        if (agentId != _user?.GetAgentId())
        {
            return;
        }
        _ = InvokeAsync(async () =>
        {
            await LadeQuittierungenAsync();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        FreigabenBroadcaster.Geaendert -= OnFreigabenGeaendert;
        QuittierungBroadcaster.Geaendert -= OnQuittierungGeaendert;
    }
}
