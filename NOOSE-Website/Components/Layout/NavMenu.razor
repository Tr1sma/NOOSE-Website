<MudNavMenu Color="Color.Primary" Bordered="true">
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.SpaceDashboard">Dashboard</MudNavLink>
    <MudNavLink Href="/profil" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.AccountCircle">Mein Profil</MudNavLink>

    <MudDivider Class="my-2" />
    <MudText Typo="Typo.caption" Class="px-4 py-1 mud-text-secondary">AKTEN</MudText>
    <MudNavLink Href="/personen" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Badge">Personen-Akten</MudNavLink>
    <MudNavLink Href="/doks" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Description">Personen-Doks</MudNavLink>
    <MudNavLink Href="/fraktionen" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Groups">Fraktionen</MudNavLink>
    <MudNavLink Href="/personengruppen" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Diversity3">Personengruppen</MudNavLink>
    <MudNavLink Href="/parteien" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.AccountBalance">Parteien</MudNavLink>
    <MudNavLink Href="/operationen" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Radar">Operationen</MudNavLink>
    <MudNavLink Href="/suche" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Search">Globale Suche</MudNavLink>

    <AuthorizeView Policy="@Policies.Fuehrung" Context="fuehrung">
        <MudDivider Class="my-2" />
        <MudText Typo="Typo.caption" Class="px-4 py-1 mud-text-secondary">VERWALTUNG</MudText>
        <MudNavLink Href="/admin/freigaben" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.HowToReg">
            Freigaben
            @if (_offeneFreigaben > 0)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled" Class="ml-2">@_offeneFreigaben</MudChip>
            }
        </MudNavLink>
        <MudNavLink Href="/admin/tags" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Label">
            Tags
        </MudNavLink>
        <AuthorizeView Policy="@Policies.Admin" Context="adminInner">
            <MudNavLink Href="/admin/agenten" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.ManageAccounts">
                Agenten-Verwaltung
            </MudNavLink>
            <MudNavLink Href="/status" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.MonitorHeart">
                System-Status
            </MudNavLink>
        </AuthorizeView>
    </AuthorizeView>

    <MudDivider Class="my-2" />
    <MudText Typo="Typo.caption" Class="px-4 py-1 mud-text-secondary">BALD VERFÜGBAR</MudText>

    <MudNavLink Icon="@Icons.Material.Filled.Hub" Disabled="true">Beziehungsgraph</MudNavLink>
</MudNavMenu>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;
    [Inject] private IAgentVerwaltungService AgentService { get; set; } = default!;

    private int _offeneFreigaben;

    protected override async Task OnInitializedAsync()
    {
        // Nur für die Führung relevant – Badge mit der Anzahl offener Registrierungen + Namensänderungen.
        if ((await AuthStateTask).User.IstFuehrung())
        {
            _offeneFreigaben = (await AgentService.GetAusstehendeAsync()).Count
                + (await AgentService.GetAusstehendeNamensaenderungenAsync()).Count;
        }
    }
}
