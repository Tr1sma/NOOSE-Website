<MudNavMenu Color="Color.Primary" Bordered="true">
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.SpaceDashboard">Dashboard</MudNavLink>

    <MudDivider Class="my-2" />
    <MudText Typo="Typo.caption" Class="px-4 py-1 mud-text-secondary">AKTEN</MudText>
    <MudNavLink Href="/personen" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Badge">Personen-Akten</MudNavLink>
    <MudNavLink Href="/doks" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Description">Personen-Doks</MudNavLink>

    <AuthorizeView Policy="@Policies.Fuehrung" Context="fuehrung">
        <MudDivider Class="my-2" />
        <MudText Typo="Typo.caption" Class="px-4 py-1 mud-text-secondary">VERWALTUNG</MudText>
        <MudNavLink Href="/admin/freigaben" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.HowToReg">
            Freigaben
        </MudNavLink>
        <AuthorizeView Policy="@Policies.Admin" Context="adminInner">
            <MudNavLink Href="/admin/agenten" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.ManageAccounts">
                Agenten-Verwaltung
            </MudNavLink>
            <MudNavLink Href="/status" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.MonitorHeart">
                System-Status
            </MudNavLink>
        </AuthorizeView>
    </AuthorizeView>

    <MudDivider Class="my-2" />
    <MudText Typo="Typo.caption" Class="px-4 py-1 mud-text-secondary">BALD VERFÜGBAR</MudText>

    <MudNavLink Icon="@Icons.Material.Filled.Groups" Disabled="true">Fraktionen &amp; Gruppen</MudNavLink>
    <MudNavLink Icon="@Icons.Material.Filled.AccountTree" Disabled="true">Verknüpfungen</MudNavLink>
    <MudNavLink Icon="@Icons.Material.Filled.Search" Disabled="true">Suche</MudNavLink>
</MudNavMenu>
