<MudNavMenu Color="Color.Primary" Bordered="true">
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.SpaceDashboard">Dashboard</MudNavLink>
    <MudNavLink Href="/profil" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.AccountCircle">Mein Profil</MudNavLink>
    <MudNavLink Href="/watchlist" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Star">Beobachtete Akten</MudNavLink>
    <MudNavLink Href="/personal" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.People">Personal</MudNavLink>
    <MudNavLink Href="/brett" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Campaign">
        Schwarzes Brett
        @if (_offeneQuittierungen > 0)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled" Class="ml-2">@_offeneQuittierungen</MudChip>
        }
    </MudNavLink>

    <MudDivider Class="my-2" />
    <MudText Typo="Typo.caption" Class="px-4 py-1 mud-text-secondary">AKTEN</MudText>
    <MudNavLink Href="/personen" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Badge">Personen-Akten</MudNavLink>
    <MudNavLink Href="/doks" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Description">Personen-Doks</MudNavLink>
    <MudNavLink Href="/dokumente" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.MenuBook">Dokumente</MudNavLink>
    <MudNavLink Href="/observationen" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Visibility">Observationen</MudNavLink>
    <MudNavLink Href="/fraktionen" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Groups">Fraktionen</MudNavLink>
    <MudNavLink Href="/personengruppen" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Diversity3">Personengruppen</MudNavLink>
    <MudNavLink Href="/parteien" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.AccountBalance">Parteien</MudNavLink>
    <MudNavLink Href="/operationen" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Radar">Operationen</MudNavLink>
    <MudNavLink Href="/taskforces" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Groups2">Taskforces</MudNavLink>
    <MudNavLink Href="/vorgaenge" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.FolderSpecial">Vorgänge</MudNavLink>
    <MudNavLink Href="/aufgaben" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.AssignmentTurnedIn">Aufgaben</MudNavLink>
    <MudNavLink Href="/suche" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Search">Globale Suche</MudNavLink>

    @* Den Freigabe-Posteingang erreicht bereits Senior Special Agent+ (entscheidet Hochstufungen);
       die übrigen Verwaltungs-Links bleiben Führung bzw. Admin vorbehalten. *@
    <AuthorizeView Policy="@Policies.HoechsteEinstufung" Context="posteingang">
        <MudDivider Class="my-2" />
        <MudText Typo="Typo.caption" Class="px-4 py-1 mud-text-secondary">VERWALTUNG</MudText>
        <MudNavLink Href="/admin/freigaben" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.HowToReg">
            Freigaben
            @if (_offeneFreigaben > 0)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled" Class="ml-2">@_offeneFreigaben</MudChip>
            }
        </MudNavLink>
        <AuthorizeView Policy="@Policies.Fuehrung" Context="fuehrung">
            <MudNavLink Href="/admin/tags" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Label">
                Tags
            </MudNavLink>
            <MudNavLink Href="/admin/vorlagen" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Dvr">
                Vorlagen
            </MudNavLink>
            <MudNavLink Href="/admin/custom-felder" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Tune">
                Custom-Felder
            </MudNavLink>
            <MudNavLink Href="/admin/aktualitaet" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Timelapse">
                Aktualität
            </MudNavLink>
            <AuthorizeView Policy="@Policies.Admin" Context="adminInner">
                <MudNavLink Href="/admin/agenten" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.ManageAccounts">
                    Agenten-Verwaltung
                </MudNavLink>
                <MudNavLink Href="/status" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.MonitorHeart">
                    System-Status
                </MudNavLink>
            </AuthorizeView>
        </AuthorizeView>
    </AuthorizeView>

    <MudDivider Class="my-2" />
    <MudText Typo="Typo.caption" Class="px-4 py-1 mud-text-secondary">BALD VERFÜGBAR</MudText>

    <MudNavLink Icon="@Icons.Material.Filled.Hub" Disabled="true">Beziehungsgraph</MudNavLink>
</MudNavMenu>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;
    [Inject] private IAgentVerwaltungService AgentService { get; set; } = default!;
    [Inject] private ITaskforceService TaskforceService { get; set; } = default!;
    [Inject] private IPersonalakteService PersonalakteService { get; set; } = default!;
    [Inject] private IAntragService AntragService { get; set; } = default!;
    [Inject] private IAnkuendigungService BrettService { get; set; } = default!;

    private int _offeneFreigaben;
    private int _offeneQuittierungen;

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthStateTask).User;

        // Offene Lesebestätigungen (Quittierungen) am Schwarzen Brett – für jeden aktiven Agenten.
        _offeneQuittierungen = await BrettService.GetOffeneQuittierungenAnzahlAsync(user);

        // Hochstufungs-Anträge entscheidet bereits Senior Special Agent+ – sie zählen für diese Gruppe.
        if (user.DarfHoechsteEinstufung())
        {
            _offeneFreigaben += await AntragService.GetOffeneAnzahlAsync(user.IstFuehrung());
        }

        // Registrierungen + Namensänderungen + Taskforce- + Beförderungsanträge sind der Führung vorbehalten.
        if (user.IstFuehrung())
        {
            _offeneFreigaben += (await AgentService.GetAusstehendeAsync()).Count
                + (await AgentService.GetAusstehendeNamensaenderungenAsync()).Count
                + (await TaskforceService.GetBeantragteAsync()).Count
                + (await PersonalakteService.GetOffeneBefoerderungsantraegeAsync()).Count;
        }
    }
}
