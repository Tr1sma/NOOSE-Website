@implements IDisposable
@using NOOSE_Website.Navigation
@using NOOSE_Website.Models.Navigation
@using NOOSE_Website.Components.Common.Navigation
@inject INavPreferencesService NavPrefs
@inject IDialogService DialogService

<MudNavMenu Color="Color.Primary" Bordered="true">
    <div class="d-flex align-center px-3 py-2">
        <MudText Typo="Typo.caption" Class="mud-text-secondary">NAVIGATION</MudText>
        <MudSpacer />
        <MudTooltip Text="Navigation anpassen">
            <MudIconButton Icon="@Icons.Material.Filled.Tune" Size="Size.Small" OnClick="OpenCustomizeAsync" aria-label="Navigation anpassen" />
        </MudTooltip>
    </div>

    @if (_prefs.Favorites.Count > 0)
    {
        <MudText Typo="Typo.caption" Class="px-4 py-1 mud-text-secondary">FAVORITEN</MudText>
        @foreach (var fav in _prefs.Favorites)
        {
            @Favorite(fav)
        }
        <MudDivider Class="my-2" />
    }

    <AuthorizeView Policy="@Policies.InternalAgent" Context="internalNav">
    @foreach (var entry in SectionEntries(NavSection.Primary))
    {
        @NavLink(entry)
    }

    <MudNavGroup Title="Akten" Icon="@Icons.Material.Filled.FolderCopy"
                 Expanded="@(!IsCollapsed("Akten"))" ExpandedChanged="@(v => GroupToggledAsync("Akten", v))">
        @foreach (var entry in SectionEntries(NavSection.Akten))
        {
            @NavLink(entry)
        }
    </MudNavGroup>

    @* Senior Special Agent+ reaches the release inbox; the rest stays leadership/admin (Page-policies also let read-only oversight in). *@
    <AuthorizeView Policy="@Policies.HighestClassificationPage" Context="posteingang">
        <MudNavGroup Title="Verwaltung" Icon="@Icons.Material.Filled.AdminPanelSettings"
                     Expanded="@(!IsCollapsed("Verwaltung"))" ExpandedChanged="@(v => GroupToggledAsync("Verwaltung", v))">
            @foreach (var entry in SectionEntries(NavSection.VerwaltungFreigaben))
            {
                @NavLink(entry)
            }
            <AuthorizeView Policy="@Policies.LeadershipPage" Context="fuehrung">
                @foreach (var entry in SectionEntries(NavSection.VerwaltungFuehrung))
                {
                    @NavLink(entry)
                }
                <AuthorizeView Policy="@Policies.AdminPage" Context="adminInner">
                    @foreach (var entry in SectionEntries(NavSection.VerwaltungAdmin))
                    {
                        @NavLink(entry)
                    }
                </AuthorizeView>
            </AuthorizeView>
        </MudNavGroup>
    </AuthorizeView>
    </AuthorizeView>

    <AuthorizeView Policy="@Policies.PartnerView" Context="partnerNav">
        <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.SpaceDashboard">Dashboard</MudNavLink>
        <MudNavLink Href="/profil" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.AccountCircle">Mein Profil</MudNavLink>
        <MudDivider Class="my-2" />
        <MudText Typo="Typo.caption" Class="px-4 py-1 mud-text-secondary">FREIGEGEBENE AKTEN</MudText>
        @* record-type links filtered by the rank's allowed types (null = no restriction) *@
        @foreach (var entry in NavPersonalization.Apply(NavCatalog.PartnerRecordEntries(_allowedPartnerTypes), _prefs))
        {
            <MudNavLink Href="@entry.Route" Match="NavLinkMatch.Prefix" Icon="@entry.Icon">@entry.Label</MudNavLink>
        }
        <MudDivider Class="my-2" />
        <MudNavLink Href="/suche" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Search">Globale Suche</MudNavLink>
    </AuthorizeView>

</MudNavMenu>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;
    [Inject] private IAgentManagementService AgentService { get; set; } = default!;
    [Inject] private ITaskforceService TaskforceService { get; set; } = default!;
    [Inject] private IPersonnelFileService PersonnelFileService { get; set; } = default!;
    [Inject] private IRequestService RequestService { get; set; } = default!;
    [Inject] private IAnnouncementService BoardService { get; set; } = default!;
    [Inject] private SharesBroadcaster SharesBroadcaster { get; set; } = default!;
    [Inject] private AcknowledgmentBroadcaster AcknowledgmentBroadcaster { get; set; } = default!;
    [Inject] private IPartnerVisibilityPolicyService PartnerPolicy { get; set; } = default!;
    [Inject] private Microsoft.Extensions.Logging.ILogger<NavMenu> Logger { get; set; } = default!;

    private ClaimsPrincipal? _user;
    private string? _agentId;
    private NavPreferences _prefs = new();
    private int _openShares;
    private int _openAcknowledgments;
    private IReadOnlySet<string>? _allowedPartnerTypes;

    // catalog-driven entries per policy-gated section, personalized (hidden/order)
    private IEnumerable<NavEntry> SectionEntries(NavSection section) => NavPersonalization.Apply(NavCatalog.Section(section), _prefs);

    private RenderFragment NavLink(NavEntry entry) =>@<MudNavLink Href="@entry.Route" Match="@entry.Match" Icon="@entry.Icon">
        @entry.Label
        @if (entry.BadgeKey == "acknowledgments" && _openAcknowledgments > 0)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled" Class="ml-2">@_openAcknowledgments</MudChip>
        }
        @if (entry.BadgeKey == "shares" && _openShares > 0)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled" Class="ml-2">@_openShares</MudChip>
        }
    </MudNavLink>;

    // page favorites gate by their section policy; partner page favorites gate by allowed types; records re-check on click
    private RenderFragment Favorite(NavFavorite fav) => __builder =>
    {
        if (fav.Kind == "page" && NavCatalog.ByKey(fav.Key ?? string.Empty) is { } e)
        {
            <AuthorizeView Policy="@NavSectionPolicy.For(e.Section)" Context="favCtx">
                <MudNavLink Href="@e.Route" Match="NavLinkMatch.Prefix" Icon="@e.Icon">@e.Label</MudNavLink>
            </AuthorizeView>
        }
        else if (fav.Kind == "page" && _user?.IsPartner() == true && PartnerTypeAllowed(fav.Key))
        {
            <MudNavLink Href="@fav.Route" Match="NavLinkMatch.Prefix" Icon="@fav.Icon">@fav.Label</MudNavLink>
        }
        else if (fav.Kind == "record")
        {
            <MudNavLink Href="@fav.Route" Match="NavLinkMatch.Prefix" Icon="@fav.Icon">@fav.Label</MudNavLink>
        }
    };

    // partner page favorite "partner.<Type>" still within the rank's allowed set
    private bool PartnerTypeAllowed(string? key)
    {
        if (key is null || !key.StartsWith("partner.", StringComparison.Ordinal))
        {
            return false;
        }
        var typeKey = key["partner.".Length..];
        return _allowedPartnerTypes is null || _allowedPartnerTypes.Contains(typeKey);
    }

    private Task OpenCustomizeAsync() => NavCustomizeDialog.ShowAsync(DialogService);

    private bool IsCollapsed(string key) => _prefs.CollapsedGroups.Contains(key);

    // keep local prefs in sync (drives Expanded), then persist
    private async Task GroupToggledAsync(string key, bool expanded)
    {
        if (expanded)
        {
            _prefs.CollapsedGroups.Remove(key);
        }
        else
        {
            _prefs.CollapsedGroups.Add(key);
        }
        if (!string.IsNullOrEmpty(_agentId))
        {
            await NavPrefs.SetGroupCollapsedAsync(_agentId, key, !expanded);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        _agentId = _user.GetAgentId();
        NavPrefs.Changed += OnPrefsChanged;
        if (!string.IsNullOrEmpty(_agentId))
        {
            _prefs = await NavPrefs.GetAsync(_agentId);
        }

        // partners: skip leadership calls, restrict record-type links by rank
        if (_user?.IsPartner() == true)
        {
            _allowedPartnerTypes = await PartnerPolicy.GetAllowedTypesAsync(_user);
            return;
        }

        // Beide Badges melden sich nach einer Aktion über ihren Broadcaster → live neu zählen. Ohne diese Abos
        // blieben die Zahlen bis zum nächsten kompletten Seiten-Reload eingefroren.
        SharesBroadcaster.Modified += OnSharesModified;
        AcknowledgmentBroadcaster.Modified += OnAcknowledgmentModified;
        await LoadSharesAsync();
        await LoadAcknowledgmentsAsync();
    }

    // reload personalized menu after the customizer saved (same circuit)
    private void OnPrefsChanged()
        => _ = InvokeAsync(async () =>
        {
            if (!string.IsNullOrEmpty(_agentId))
            {
                _prefs = await NavPrefs.GetAsync(_agentId);
                StateHasChanged();
            }
        });

    // Offene Lesebestätigungen (Quittierungen) am Schwarzen Brett – für jeden aktiven Agenten.
    // Defensiv: Die Badges sind dekorativ – ein DB-Fehler hier darf weder das Prerender (→ generische
    // Fehlerseite) noch den Circuit (Broadcaster-Handler) reißen. Im Fehlerfall bleibt der Zähler stehen.
    private async Task LoadAcknowledgmentsAsync()
    {
        if (_user is null)
        {
            return;
        }
        try
        {
            _openAcknowledgments = await BoardService.GetOpenAcknowledgmentsCountAsync(_user);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Quittierungs-Badge konnte nicht geladen werden.");
        }
    }

    // Summiert die offenen Posteingangs-Vorgänge (dieselben Quellen wie die Freigaben-Seite). Wird beim Start und
    // nach jedem Broadcaster-Signal aufgerufen; setzt den Wert jedes Mal frisch (kein +=).
    private async Task LoadSharesAsync()
    {
        if (_user is null)
        {
            return;
        }
        try
        {
            var open = 0;

            // Hochstufungs-Anträge entscheidet bereits Senior Special Agent+ – sie zählen für diese Gruppe.
            if (_user.MayHighestClassification())
            {
                open += await RequestService.GetOpenCountAsync(_user.IsLeadership());
            }

            // Registrierungen + Namensänderungen + Taskforce- + Beförderungsanträge sind der Führung vorbehalten.
            if (_user.IsLeadership())
            {
                open += (await AgentService.GetPendingAsync()).Count
                    + (await AgentService.GetPendingNameChangesAsync()).Count
                    + (await TaskforceService.GetRequestedAsync()).Count
                    + (await PersonnelFileService.GetOpenPromotionRequestsAsync()).Count;
            }
            _openShares = open;
        }
        catch (Exception ex)
        {
            // Defensiv (s. LadeQuittierungenAsync): dekorativer Zähler, Fehler nie eskalieren.
            Logger.LogWarning(ex, "Freigaben-Badge konnte nicht geladen werden.");
        }
    }

    // Live-Signal (aus der Freigaben-Seite desselben Circuits) → in den Circuit marshallen und neu zählen.
    private void OnSharesModified()
        => _ = InvokeAsync(async () =>
        {
            await LoadSharesAsync();
            StateHasChanged();
        });

    // Live-Signal nach einer Quittierung – nur für die eigene Agent-Id in den eigenen Circuit marshallen.
    private void OnAcknowledgmentModified(string agentId)
    {
        if (agentId != _user?.GetAgentId())
        {
            return;
        }
        _ = InvokeAsync(async () =>
        {
            await LoadAcknowledgmentsAsync();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        NavPrefs.Changed -= OnPrefsChanged;
        SharesBroadcaster.Modified -= OnSharesModified;
        AcknowledgmentBroadcaster.Modified -= OnAcknowledgmentModified;
    }
}
