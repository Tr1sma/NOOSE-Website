@inherits LayoutComponentBase

@* Public shell (career page, invite, applicant portal); no nav/drawer, no maintenance wall, no auth chrome. *@
<MudThemeProvider Theme="NooseTheme.Theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div style="min-height:100vh;background:#0E1116;padding:32px 16px;">
    <div style="max-width:880px;margin:0 auto;">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                <MudImage Src="NooseIcon.png" Alt="NOOSE Wappen" Height="40" />
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h6" Style="font-weight:700;letter-spacing:.12em;line-height:1.1;">N.O.O.S.E.</MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">National Office of Security Enforcement</MudText>
                </MudStack>
            </MudStack>
        </MudStack>

        @Body

        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="2" Class="mt-6">
            <MudLink Href="@LegalData.ImprintUrl" Target="_blank" rel="noopener noreferrer"
                     Typo="Typo.caption" Color="Color.Default">Impressum</MudLink>
            <MudText Typo="Typo.caption" Class="mud-text-secondary">·</MudText>
            <MudLink Href="/datenschutz" Typo="Typo.caption" Color="Color.Default">Datenschutz</MudLink>
            <MudText Typo="Typo.caption" Class="mud-text-secondary">·</MudText>
            <MudLink Href="/nutzungsbedingungen" Typo="Typo.caption" Color="Color.Default">Nutzungsbedingungen</MudLink>
        </MudStack>
    </div>
</div>

@code {
    // no [Authorize]/[AllowAnonymous] here on purpose; each page controls its own visibility
}
