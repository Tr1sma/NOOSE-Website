@inherits LayoutComponentBase

@* Schlanke, öffentlich erreichbare Hülle für die Rechtstexte (Datenschutz) – ohne Navigation/Drawer,
   mit gut lesbarer, schmaler Spalte. Static SSR, daher nur der ThemeProvider für den dunklen NOOSE-Look. *@
<MudThemeProvider Theme="NooseTheme.Theme" IsDarkMode="true" />

<div style="min-height:100vh;background:#0E1116;padding:32px 16px;">
    <div style="max-width:820px;margin:0 auto;">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
            <MudLink Href="/" Underline="Underline.None" Color="Color.Inherit">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                    <MudImage Src="NooseIcon.png" Alt="NOOSE Wappen" Height="40" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.h6" Style="font-weight:700;letter-spacing:.12em;line-height:1.1;">N.O.O.S.E.</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">National Office of Security Enforcement</MudText>
                    </MudStack>
                </MudStack>
            </MudLink>
            <MudButton Href="/" Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.ArrowBack">Zurück</MudButton>
        </MudStack>

        <MudPaper Elevation="4" Class="pa-8">
            @Body
        </MudPaper>

        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="2" Class="mt-4">
            <MudLink Href="@RechtlichesDaten.ImpressumUrl" Target="_blank" rel="noopener noreferrer"
                     Typo="Typo.caption" Color="Color.Default">Impressum</MudLink>
            <MudText Typo="Typo.caption" Class="mud-text-secondary">·</MudText>
            <MudLink Href="/datenschutz" Typo="Typo.caption" Color="Color.Default">Datenschutz</MudLink>
            <MudText Typo="Typo.caption" Class="mud-text-secondary">·</MudText>
            <MudLink Href="/nutzungsbedingungen" Typo="Typo.caption" Color="Color.Default">Nutzungsbedingungen</MudLink>
        </MudStack>
    </div>
</div>

@code {
    // Hülle für /datenschutz. Bewusst ohne eigene [Authorize]/[AllowAnonymous]-Attribute – die
    // Sichtbarkeit steuert die jeweilige Seite (Datenschutz.razor ist [AllowAnonymous]).
}
