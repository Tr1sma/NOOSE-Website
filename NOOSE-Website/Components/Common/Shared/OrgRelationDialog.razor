@* Dialog zum Anlegen einer Beziehung zu einer anderen Akte: Ziel (Fraktion, Personengruppe, Partei und –
   bei PersonenErlauben, z. B. für Operationen – auch Person) + Notiz. *@
@inject IFactionService FactionService
@inject IPersonGroupService GroupService
@inject IPartyService PartyService
@inject IPersonService PersonService

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3" Style="min-width:380px;">
            <MudRadioGroup T="string" @bind-Value="Type">
                @if (PeopleAllow)
                {
                    <MudRadio T="string" Value="@nameof(Person)" Color="Color.Primary" Dense="true">Person</MudRadio>
                }
                <MudRadio T="string" Value="@nameof(Faction)" Color="Color.Primary" Dense="true">Fraktion</MudRadio>
                <MudRadio T="string" Value="@nameof(PersonGroup)" Color="Color.Primary" Dense="true">Personengruppe</MudRadio>
                <MudRadio T="string" Value="@nameof(Party)" Color="Color.Primary" Dense="true">Partei</MudRadio>
            </MudRadioGroup>

            <MudAutocomplete T="RecordHit" Label="@TargetLabel" AutoFocus="true"
                             @bind-Value="_target" SearchFunc="@Search" ToStringFunc="@(a => a?.Name ?? string.Empty)"
                             Variant="Variant.Outlined" Clearable="true" CoerceText="false" CoerceValue="false"
                             ResetValueOnEmptyText="true" MinCharacters="0" Immediate="true"
                             Adornment="Adornment.Start" AdornmentIcon="@TargetIcon"
                             HelperText="@(PeopleAllow ? "Beteiligte Akte auswählen." : "Organisation auswählen.")">
                <ItemTemplate Context="a">
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@TargetIcon" Size="Size.Small" Color="Color.Primary" />
                        <MudText Typo="Typo.body2">@a.Name</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@a.CaseNumber</MudText>
                    </MudStack>
                </ItemTemplate>
            </MudAutocomplete>

            <MudTextField @bind-Value="_note" Label="Notiz (optional)" Variant="Variant.Outlined"
                          Placeholder="@NotePlaceholder" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Abbrechen</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save" Disabled="@(_target is null)">Hinzufügen</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public bool IsLeadership { get; set; }
    /// <summary>„Konflikt" oder „Bündnis" – nur für Texte/Platzhalter.</summary>
    [Parameter] public string Designation { get; set; } = "Konflikt";
    [Parameter] public IReadOnlyList<string> ExclusionFactionIds { get; set; } = Array.Empty<string>();
    [Parameter] public IReadOnlyList<string> ExclusionGroupsIds { get; set; } = Array.Empty<string>();
    [Parameter] public IReadOnlyList<string> ExclusionPartyIds { get; set; } = Array.Empty<string>();
    [Parameter] public IReadOnlyList<string> ExclusionPersonIds { get; set; } = Array.Empty<string>();

    /// <summary>Erlaubt zusätzlich Personen als Ziel (z. B. Beteiligte einer Operation). Standard: nur Organisationen.</summary>
    [Parameter] public bool PeopleAllow { get; set; }

    private string _type = nameof(Faction);
    private string Type
    {
        get => _type;
        set { if (_type != value) { _type = value; _target = null; } }
    }
    private RecordHit? _target;
    private string? _note;

    protected override void OnInitialized()
    {
        // Bei erlaubten Personen ist „Person" die häufigste Wahl (z. B. Operations-Beteiligte) → vorbelegen.
        if (PeopleAllow)
        {
            _type = nameof(Person);
        }
    }

    private string TargetLabel => _type switch
    {
        nameof(Person) => "Person",
        nameof(PersonGroup) => "Personengruppe",
        nameof(Party) => "Partei",
        _ => "Fraktion",
    };

    private string TargetIcon => _type switch
    {
        nameof(Person) => Icons.Material.Filled.Badge,
        nameof(PersonGroup) => Icons.Material.Filled.Diversity3,
        nameof(Party) => Icons.Material.Filled.AccountBalance,
        _ => Icons.Material.Filled.Groups,
    };

    private string NotePlaceholder => PeopleAllow
        ? "z. B. Zielperson, Zeuge, beteiligte Bande"
        : Designation == "Bündnis"
            ? "z. B. Waffenbruderschaft, Nichtangriffspakt"
            : "z. B. Revierkonflikt, langjährige Feindschaft";

    private async Task<IEnumerable<RecordHit>> Search(string value, CancellationToken token)
    {
        switch (_type)
        {
            case nameof(Person):
                var people = await PersonService.SearchAsync(value, IsLeadership, 20, token);
                return people.Where(p => !ExclusionPersonIds.Contains(p.Id))
                    .Select(p => new RecordHit(p.Id, p.Name, p.CaseNumber));
            case nameof(PersonGroup):
                var groups = await GroupService.SearchAsync(value, IsLeadership, 20, token);
                return groups.Where(g => !ExclusionGroupsIds.Contains(g.Id))
                    .Select(g => new RecordHit(g.Id, g.Name, g.CaseNumber));
            case nameof(Party):
                var parties = await PartyService.SearchAsync(value, IsLeadership, 20, token);
                return parties.Where(p => !ExclusionPartyIds.Contains(p.Id))
                    .Select(p => new RecordHit(p.Id, p.Name, p.CaseNumber));
            default:
                var factions = await FactionService.SearchAsync(value, IsLeadership, 20, token);
                return factions.Where(f => !ExclusionFactionIds.Contains(f.Id))
                    .Select(f => new RecordHit(f.Id, f.Name, f.CaseNumber));
        }
    }

    private void Save()
    {
        if (_target is null)
        {
            return;
        }
        MudDialog.Close(DialogResult.Ok(new OrgRelationChoice(_type, _target.Id,
            string.IsNullOrWhiteSpace(_note) ? null : _note.Trim())));
    }

    private void Cancel() => MudDialog.Cancel();

    public record RecordHit(string Id, string Name, string CaseNumber);
    public record OrgRelationChoice(string TargetType, string TargetId, string? Note);

    public static async Task<OrgRelationChoice?> ShowAsync(IDialogService dialog, string designation, bool isLeadership,
        IReadOnlyList<string> exclusionFactionIds, IReadOnlyList<string> exclusionGroupsIds, IReadOnlyList<string> exclusionPartyIds,
        IReadOnlyList<string>? exclusionPersonIds = null, bool peopleAllow = false)
    {
        var parameters = new DialogParameters<OrgRelationDialog>
        {
            { x => x.Designation, designation },
            { x => x.IsLeadership, isLeadership },
            { x => x.ExclusionFactionIds, exclusionFactionIds },
            { x => x.ExclusionGroupsIds, exclusionGroupsIds },
            { x => x.ExclusionPartyIds, exclusionPartyIds },
            { x => x.ExclusionPersonIds, exclusionPersonIds ?? Array.Empty<string>() },
            { x => x.PeopleAllow, peopleAllow },
        };
        var reference = await dialog.ShowAsync<OrgRelationDialog>($"{designation} hinzufügen", parameters);
        var result = await reference.Result;
        return result is { Canceled: false, Data: OrgRelationChoice w } ? w : null;
    }
}
