@* Wiederverwendbarer WYSIWYG-Editor (Quill). Der HTML-Inhalt wird über @bind-Value gehalten; der
   endgültige Inhalt sollte beim Speichern mit GetHtmlAsync() frisch aus dem Editor gelesen werden.
   Alle JS-Interop-Aufrufe sind abgesichert: Ein JS-Fehler (z. B. gecachtes/fehlendes Editor-Modul)
   darf NIE den Blazor-Circuit abreißen – stattdessen erscheint eine Fehlermeldung mit Reload-Hinweis. *@
@inject IJSRuntime JS
@inject Microsoft.Extensions.Logging.ILogger<RichTextEditor> Logger
@implements IAsyncDisposable

@if (_loadError)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-2">
        Der Editor konnte nicht geladen werden. Bitte die Seite mit Strg+F5 neu laden –
        besteht das Problem weiter, wende dich an die NOOSE-Administration.
    </MudAlert>
}
<div @ref="_element" class="noose-rte"></div>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    private ElementReference _element;
    private IJSObjectReference? _module;
    private DotNetObjectReference<RichTextEditor>? _ref;
    private bool _ready;
    private bool _loadError;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }
        try
        {
            // JS-Interop erst nach dem ersten Render verfügbar (Interactive Server).
            // ?v=2 ist ein Cache-Buster: dynamische import()-Pfade laufen NICHT durch das Asset-
            // Fingerprinting (@Assets/ImportMap) – Browser mit einer alten gecachten Modul-Version
            // (Quill-2-Zwischenstand) würden sonst auf nicht mehr existierende Dateien zeigen.
            // Bei künftigen Änderungen an richtext.js die Versionsnummer hochzählen!
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/richtext.js?v=4");
            _ref = DotNetObjectReference.Create(this);
            await _module.InvokeVoidAsync("initRichText", _element, _ref, Value ?? string.Empty);
            _ready = true;
        }
        catch (JSDisconnectedException)
        {
            // Circuit bereits getrennt (Navigation/Reload mitten im Init) – nichts zu tun.
        }
        catch (Exception ex)
        {
            // Unbehandelte Ausnahmen in OnAfterRenderAsync reißen den GANZEN Circuit ab (Reconnect-
            // Schleife für den Nutzer). Stattdessen: loggen und eine Fehlermeldung anzeigen.
            Logger.LogWarning(ex, "WYSIWYG-Editor konnte nicht initialisiert werden (JS-Interop).");
            _loadError = true;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task OnHtmlChanged(string html)
    {
        Value = html;
        if (ValueChanged.HasDelegate)
        {
            await ValueChanged.InvokeAsync(html);
        }
    }

    /// <summary>Setzt den Editor-Inhalt (z. B. beim Anwenden einer Vorlage). Bei JS-Fehlern no-op
    /// (geloggt) – die Aufrufer sind teils ValueChanged-Handler ohne eigenes try/catch.</summary>
    public async Task SetHtmlAsync(string html)
    {
        if (_module is null || !_ready)
        {
            return;
        }
        try
        {
            await _module.InvokeVoidAsync("setHtml", _element, html ?? string.Empty);
            Value = html;
        }
        catch (JSDisconnectedException)
        {
            // Circuit bereits getrennt – nichts zu tun.
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "WYSIWYG-Editor: SetHtml fehlgeschlagen (JS-Interop).");
        }
    }

    /// <summary>Liest den aktuellen HTML-Inhalt frisch aus dem Editor (verlässlich für das Speichern).
    /// Bei JS-Fehlern wird der letzte über OnHtmlChanged gemeldete Stand zurückgegeben (entprellter
    /// Zwischenstand) – besser als ein Circuit-Abriss beim Speichern.</summary>
    public async Task<string> GetHtmlAsync()
    {
        if (_module is not null && _ready)
        {
            try
            {
                Value = await _module.InvokeAsync<string>("getHtml", _element);
            }
            catch (JSDisconnectedException)
            {
                // Circuit bereits getrennt – letzter bekannter Stand genügt.
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "WYSIWYG-Editor: GetHtml fehlgeschlagen (JS-Interop) – letzter bekannter Stand wird verwendet.");
            }
        }
        return Value ?? string.Empty;
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_module is not null)
            {
                await _module.InvokeVoidAsync("destroyRichText", _element);
                await _module.DisposeAsync();
            }
        }
        catch (JSDisconnectedException)
        {
            // Circuit bereits getrennt – nichts zu tun.
        }
        catch (Exception)
        {
            // Aufräum-Fehler beim Dispose sind folgenlos – nie eskalieren.
        }
        _ref?.Dispose();
    }
}
