@* Reusable Quill WYSIWYG editor; read final HTML via GetHtmlAsync. All JS interop is guarded so a JS error never kills the circuit. *@
@inject IJSRuntime JS
@inject Microsoft.Extensions.Logging.ILogger<RichTextEditor> Logger
@implements IAsyncDisposable

@if (_loadError)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-2">
        Der Editor konnte nicht geladen werden. Bitte die Seite mit Strg+F5 neu laden –
        besteht das Problem weiter, wende dich an die NOOSE-Administration.
    </MudAlert>
}
<div @ref="_element" class="noose-rte"></div>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    private ElementReference _element;
    private IJSObjectReference? _module;
    private DotNetObjectReference<RichTextEditor>? _ref;
    private bool _ready;
    private bool _loadError;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }
        try
        {
            // ?v= cache-buster: bump it on every richtext.js change (dynamic imports bypass asset fingerprinting)
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/richtext.js?v=4");
            _ref = DotNetObjectReference.Create(this);
            await _module.InvokeVoidAsync("initRichText", _element, _ref, Value ?? string.Empty);
            _ready = true;
        }
        catch (JSDisconnectedException)
        {
            /* ignore */
        }
        catch (Exception ex)
        {
            // never let OnAfterRenderAsync kill the circuit
            Logger.LogWarning(ex, "WYSIWYG-Editor konnte nicht initialisiert werden (JS-Interop).");
            _loadError = true;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task OnHtmlChanged(string html)
    {
        Value = html;
        if (ValueChanged.HasDelegate)
        {
            await ValueChanged.InvokeAsync(html);
        }
    }

    /// <summary>Sets the editor content; no-op on JS errors.</summary>
    public async Task SetHtmlAsync(string html)
    {
        if (_module is null || !_ready)
        {
            return;
        }
        try
        {
            await _module.InvokeVoidAsync("setHtml", _element, html ?? string.Empty);
            Value = html;
        }
        catch (JSDisconnectedException)
        {
            /* ignore */
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "WYSIWYG-Editor: SetHtml fehlgeschlagen (JS-Interop).");
        }
    }

    /// <summary>Reads the current HTML fresh from the editor; falls back to last known value on JS errors.</summary>
    public async Task<string> GetHtmlAsync()
    {
        if (_module is not null && _ready)
        {
            try
            {
                Value = await _module.InvokeAsync<string>("getHtml", _element);
            }
            catch (JSDisconnectedException)
            {
                /* ignore */
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "WYSIWYG-Editor: GetHtml fehlgeschlagen (JS-Interop) – letzter bekannter Stand wird verwendet.");
            }
        }
        return Value ?? string.Empty;
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_module is not null)
            {
                await _module.InvokeVoidAsync("destroyRichText", _element);
                await _module.DisposeAsync();
            }
        }
        catch (JSDisconnectedException)
        {
            /* ignore */
        }
        catch (Exception)
        {
            /* best effort */
        }
        _ref?.Dispose();
    }
}
