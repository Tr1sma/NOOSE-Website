@inject IPersonService PersonService

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3" Style="min-width:340px;">
            <MudAutocomplete T="Person" Label="Person" @bind-Value="_target" AutoFocus="true"
                             SearchFunc="@SearchPeople" ToStringFunc="@(p => p?.Name ?? string.Empty)"
                             Variant="Variant.Outlined" Clearable="true" CoerceText="false" CoerceValue="false"
                             ResetValueOnEmptyText="true" MinCharacters="0" Immediate="true"
                             Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.PersonSearch"
                             HelperText="Gegenüber auswählen.">
                <ItemTemplate Context="p">
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.Badge" Size="Size.Small" Color="Color.Primary" />
                        <MudText Typo="Typo.body2">@p.Name</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@p.CaseNumber</MudText>
                    </MudStack>
                </ItemTemplate>
            </MudAutocomplete>
            <MudSelect T="RelationType" Label="Art der Beziehung" @bind-Value="_type" Variant="Variant.Outlined">
                @foreach (var t in RelationTypeDisplay.All)
                {
                    <MudSelectItem Value="t">@RelationTypeDisplay.Name(t)</MudSelectItem>
                }
            </MudSelect>
            <MudTextField @bind-Value="_note" Label="Notiz (optional)" Lines="2" Variant="Variant.Outlined" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Abbrechen</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save" Disabled="@(_target is null)">Beziehung speichern</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public bool IsLeadership { get; set; }
    /// <summary>Person excluded from the picker.</summary>
    [Parameter] public string? ExclusionPersonId { get; set; }

    private Person? _target;
    private RelationType _type = RelationType.Known;
    private string? _note;

    private async Task<IEnumerable<Person>> SearchPeople(string value, CancellationToken token)
    {
        var hit = await PersonService.SearchAsync(value, IsLeadership, 20, token);
        return ExclusionPersonId is null ? hit : hit.Where(p => p.Id != ExclusionPersonId);
    }

    private void Save()
    {
        if (_target is null)
        {
            return;
        }
        MudDialog.Close(DialogResult.Ok(new RelationInput { TargetPersonId = _target.Id, Type = _type, Note = _note }));
    }

    private void Cancel() => MudDialog.Cancel();

    /// <summary>Shows the dialog; returns the input or null on cancel.</summary>
    public static async Task<RelationInput?> ShowAsync(IDialogService dialog, bool isLeadership, string exclusionPersonId)
    {
        var parameters = new DialogParameters<RelationDialog>
        {
            { x => x.IsLeadership, isLeadership },
            { x => x.ExclusionPersonId, exclusionPersonId },
        };
        var reference = await dialog.ShowAsync<RelationDialog>("Beziehung hinzufügen", parameters);
        var result = await reference.Result;
        return result is { Canceled: false, Data: RelationInput e } ? e : null;
    }
}
