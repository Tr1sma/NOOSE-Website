@inject ISourceService SourceService
@inject ISourcesStorageService SourcesStorage
@inject IDialogService DialogService
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IPartnerShareService PartnerShareService

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudText Typo="Typo.subtitle1">Quellen &amp; Anhänge (@_sources.Count)</MudText>
        @if (_mayWrite)
        {
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudFileUpload T="IReadOnlyList<IBrowserFile>" FilesChanged="UploadImagesAsync"
                               Accept="image/*" MaximumFileCount="20">
                    <CustomContent>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Image"
                                   OnClick="@context.OpenFilePickerAsync" Disabled="_load">
                            Bilder hochladen
                        </MudButton>
                    </CustomContent>
                    <SelectedTemplate />
                </MudFileUpload>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="NewAsync">
                    Quelle hinzufügen
                </MudButton>
            </MudStack>
        }
    </MudStack>

    @if (_load)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_sources.Count == 0)
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Quellen erfasst.</MudText>
    }
    else
    {
        @foreach (var q in _sources)
        {
            <MudPaper Class="pa-3" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Style="flex-wrap:wrap;">
                        <MudIcon Icon="@TypeIcon(q.Type)" Color="Color.Primary" Size="Size.Small" />
                        <MudText Typo="Typo.body2"><b>@q.Title</b></MudText>
                        @if (q.Pinned)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.PushPin" Color="Color.Primary" Size="Size.Small" Title="Angepinnt" />
                        }
                        @if (q.IsInternalOnly)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined"
                                     Icon="@Icons.Material.Filled.Lock">Nur intern</MudChip>
                        }
                    </MudStack>
                    @if (_mayWrite)
                    {
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="0">
                            <PartnerChildShareButton Show="@(_canShareChildren && !q.IsInternalOnly)" ChildType="@nameof(Source)" ChildId="@q.Id" />
                            <MudIconButton Size="Size.Small"
                                           Icon="@(q.Pinned ? Icons.Material.Filled.PushPin : Icons.Material.Outlined.PushPin)"
                                           Color="@(q.Pinned ? Color.Primary : Color.Default)"
                                           OnClick="@(() => PinToggleAsync(q))"
                                           aria-label="@(q.Pinned ? "Quelle lösen" : "Quelle anpinnen")" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                           OnClick="@(() => RemoveAsync(q))" aria-label="Quelle löschen" />
                        </MudStack>
                    }
                </MudStack>

                @switch (q.Type)
                {
                    case SourceType.Link:
                        <MudLink Href="@q.Url" Target="_blank" Typo="Typo.body2" Class="d-block mt-1">@q.Url</MudLink>
                        break;
                    case SourceType.Upload when IsImage(q.ContentType):
                        <div @onclick="@(() => OpenImageAsync(q))" style="cursor:pointer;width:max-content;" class="mt-1">
                            <MudImage Src="@($"/dateien/quellen/{q.Id}?inline=true")" Alt="@q.OriginalName"
                                      Height="96" ObjectFit="ObjectFit.Cover" Class="rounded" />
                        </div>
                        break;
                    case SourceType.Upload:
                        <MudLink Href="@($"/dateien/quellen/{q.Id}")" Target="_blank" Typo="Typo.body2" Class="d-block mt-1">
                            <MudIcon Icon="@Icons.Material.Filled.Download" Size="Size.Small" Class="mr-1" />@(q.OriginalName ?? "Datei herunterladen")
                        </MudLink>
                        break;
                    case SourceType.Internal when q.TargetType == nameof(Person) && q.TargetId is not null:
                        <MudLink Href="@($"/personen/{q.TargetId}")" Typo="Typo.body2" Class="d-block mt-1">
                            <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" Class="mr-1" />Verknüpfte Akte öffnen
                        </MudLink>
                        break;
                    case SourceType.Internal when q.TargetType == nameof(Case) && q.TargetId is not null:
                        <MudLink Href="@($"/vorgaenge/{q.TargetId}")" Typo="Typo.body2" Class="d-block mt-1">
                            <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" Class="mr-1" />Verknüpften Vorgang öffnen
                        </MudLink>
                        break;
                    case SourceType.FreeText:
                        <MudText Typo="Typo.body2" Class="mt-1" Style="white-space:pre-wrap;">@q.Description</MudText>
                        break;
                    case SourceType.Document when q.TargetId is not null:
                        <MudLink Href="@($"/dokumente/{q.TargetId}")" Typo="Typo.body2" Class="d-block mt-1">
                            <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" Class="mr-1" />Dokument öffnen
                        </MudLink>
                        break;
                }

                @if (q.Type != SourceType.FreeText && !string.IsNullOrWhiteSpace(q.Description))
                {
                    <MudText Typo="Typo.body2" Class="mt-1 mud-text-secondary">@q.Description</MudText>
                }

                <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mt-1">
                    @SourceTypeDisplay.Name(q.Type) · @q.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                </MudText>
            </MudPaper>
        }
    }
</MudStack>

@code {
    [Parameter, EditorRequired] public string EntityType { get; set; } = default!;
    [Parameter, EditorRequired] public string EntityId { get; set; } = default!;
    [Parameter, EditorRequired] public ClaimsPrincipal User { get; set; } = default!;

    private bool _load = true;
    private bool _mayWrite;
    private bool _canShareChildren;
    private List<Source> _sources = new();

    protected override async Task OnInitializedAsync()
    {
        _mayWrite = User.MayWrite();
        // leadership: per-item release only matters when the record is shell-released
        if (User.IsLeadership())
        {
            _canShareChildren = (await PartnerShareService.GetForRecordAsync(EntityType, EntityId))
                .Any(s => s.Released && !s.IncludesChildren);
        }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _load = true;
        _sources = await SourceService.GetForRecordAsync(EntityType, EntityId, ViewerScope.From(User));
        _load = false;
    }

    private async Task NewAsync()
    {
        var input = await SourceDialog.ShowAsync(DialogService, User, showInternalToggle: EntityType == nameof(Taskforce));
        if (input is null)
        {
            return;
        }

        // new document: go to the editor, attach=1 links it back on save
        if (input.NewDocumentCreate)
        {
            Nav.NavigateTo($"/dokumente/neu?entitaetTyp={Uri.EscapeDataString(EntityType)}&entitaetId={Uri.EscapeDataString(EntityId)}&attach=1");
            return;
        }

        try
        {
            await SourceService.CreateAsync(EntityType, EntityId, input, User);
            Snackbar.Add("Quelle gespeichert.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private static bool IsImage(string? contentType)
        => contentType?.StartsWith("image/", StringComparison.OrdinalIgnoreCase) == true;

    private async Task OpenImageAsync(Source clicked)
    {
        var imgs = _sources.Where(s => s.Type == SourceType.Upload && IsImage(s.ContentType)).ToList();
        var list = imgs
            .Select(s => new ImageLightbox.LightboxImage($"/dateien/quellen/{s.Id}?inline=true", s.Title))
            .ToList();
        var start = imgs.FindIndex(s => s.Id == clicked.Id);
        await ImageLightbox.ShowAsync(DialogService, list, Math.Max(0, start));
    }

    private async Task UploadImagesAsync(IReadOnlyList<IBrowserFile> files)
    {
        _load = true;
        try
        {
            var uploaded = 0;
            foreach (var file in files)
            {
                if (!IsImage(file.ContentType) || !SourcesStorage.IsAllowedType(file.ContentType))
                {
                    Snackbar.Add($"„{file.Name}“: kein erlaubtes Bild.", Severity.Warning);
                    continue;
                }
                if (file.Size > SourcesStorage.MaxBytes)
                {
                    Snackbar.Add($"„{file.Name}“: zu groß (max. {SourcesStorage.MaxBytes / (1024 * 1024)} MB).", Severity.Warning);
                    continue;
                }

                using var ms = new MemoryStream();
                await using (var stream = file.OpenReadStream(SourcesStorage.MaxBytes))
                {
                    await stream.CopyToAsync(ms);
                }
                var input = new SourceInput
                {
                    Type = SourceType.Upload,
                    Title = file.Name,
                    FileContent = ms.ToArray(),
                    OriginalName = file.Name,
                    ContentType = file.ContentType,
                    SizeBytes = file.Size,
                };
                await SourceService.CreateAsync(EntityType, EntityId, input, User);
                uploaded++;
            }

            if (uploaded > 0)
            {
                Snackbar.Add(uploaded == 1 ? "Bild hochgeladen." : $"{uploaded} Bilder hochgeladen.", Severity.Success);
                await LoadAsync();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Upload fehlgeschlagen: {ex.Message}", Severity.Error);
        }
        finally
        {
            _load = false;
        }
    }

    private async Task RemoveAsync(Source source)
    {
        var ok = await ConfirmDialog.ShowAsync(DialogService, "Quelle löschen?",
            $"„{source.Title}“ wird in den Papierkorb verschoben.");
        if (!ok)
        {
            return;
        }
        await SourceService.RemoveAsync(source.Id, User);
        Snackbar.Add("Quelle gelöscht.", Severity.Success);
        await LoadAsync();
    }

    private async Task PinToggleAsync(Source source)
    {
        try
        {
            var @new = !source.Pinned;
            await SourceService.PinSetAsync(source.Id, @new, User);
            Snackbar.Add(@new ? "Quelle angepinnt." : "Anpinnen gelöst.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private static string TypeIcon(SourceType type) => type switch
    {
        SourceType.Upload => Icons.Material.Filled.AttachFile,
        SourceType.Link => Icons.Material.Filled.Link,
        SourceType.Internal => Icons.Material.Filled.AccountTree,
        SourceType.FreeText => Icons.Material.Filled.Notes,
        SourceType.Document => Icons.Material.Filled.Article,
        _ => Icons.Material.Filled.Description,
    };
}
