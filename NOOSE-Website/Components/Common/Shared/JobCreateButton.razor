@* Button auf einer Akten-Detailseite: legt eine neue Aufgabe an, die mit dieser Akte vorverknüpft wird
   (Bezug per Query-Parameter an /aufgaben/neu übergeben). *@
@inject NavigationManager Nav

@* Aufgabe anlegen ist eine Mutation → für die Nur-Lese-Aufsicht ausblenden. *@
<AuthorizeView Policy="@Policies.WriteAccess" Context="schreib">
    <MudTooltip Text="Aufgabe zu dieser Akte anlegen">
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AddTask"
                   OnClick="Create">Aufgabe</MudButton>
    </MudTooltip>
</AuthorizeView>

@code {
    [Parameter, EditorRequired] public string EntityType { get; set; } = default!;
    [Parameter, EditorRequired] public string EntityId { get; set; } = default!;

    private void Create()
        => Nav.NavigateTo($"/aufgaben/neu?bezugTyp={Uri.EscapeDataString(EntityType)}&bezugId={Uri.EscapeDataString(EntityId)}");
}
