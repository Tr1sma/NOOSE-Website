@* Release dialog; leadership sees full release UI, others see a request form. *@
@inject IPartnerShareService ShareService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        @if (_load)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (_user.IsLeadership())
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
                Geben Sie diese Akte gezielt für einzelne Partnerbehörden frei. „Ganze Akte" schließt alle
                Inhalte ein (außer Verschlusssachen); ohne diesen Haken ist nur die Akte selbst sichtbar.
            </MudText>
            @foreach (var st in _states)
            {
                <MudPaper Class="pa-3 mb-2" Outlined="true">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <div>
                            <MudText Typo="Typo.subtitle2">@PartnerAgencyDisplay.Name(st.Agency)</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@PartnerAgencyDisplay.LongName(st.Agency)</MudText>
                        </div>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                            <MudSwitch T="bool" Value="st.Released" ValueChanged="@(v => ReleasedChanged(st, v))"
                                       Color="Color.Primary" Label="Freigegeben" />
                            <MudCheckBox T="bool" Value="st.IncludesChildren" ValueChanged="@(v => ChildrenChanged(st, v))"
                                         Disabled="@(!st.Released)" Color="Color.Primary" Label="Ganze Akte" />
                        </MudStack>
                    </MudStack>
                </MudPaper>
            }

            <MudDivider Class="my-4" />

            <MudText Typo="Typo.subtitle1" Class="mb-1">Einzelne Partner-Konten</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
                Geben Sie die Akte zusätzlich gezielt für einzelne Partner frei – unabhängig von der Behörden-Freigabe.
            </MudText>

            @foreach (var ind in _individual)
            {
                <MudPaper Class="pa-3 mb-2" Outlined="true">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <div>
                            <MudText Typo="Typo.subtitle2">@ind.Codename</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@PartnerRankDisplay.Full(ind.Agency, ind.Rank)</MudText>
                        </div>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                            <MudCheckBox T="bool" Value="ind.IncludesChildren" ValueChanged="@(v => IndividualChildrenChanged(ind, v))"
                                         Color="Color.Primary" Label="Ganze Akte" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                           OnClick="@(() => RemoveIndividual(ind))" aria-label="Einzel-Freigabe entfernen" />
                        </MudStack>
                    </MudStack>
                </MudPaper>
            }

            <MudAutocomplete T="PartnerAccountOption" Label="Partner-Konto hinzufügen" Class="mt-2"
                             Value="_toAdd" ValueChanged="OnPartnerSelected"
                             SearchFunc="SearchPartners" Dense="true" ResetValueOnEmptyText="true"
                             ToStringFunc="@(o => o is null ? string.Empty : $"{o.Codename} · {PartnerRankDisplay.Full(o.Agency, o.Rank)}")"
                             Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.PersonAdd" />
        }
        else
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
                Beantragen Sie, dass diese Akte für eine Partnerbehörde oder einen einzelnen Partner freigegeben
                wird. Die Führung entscheidet über den Antrag; bei Genehmigung wird die Freigabe automatisch gesetzt.
            </MudText>
            <MudRadioGroup T="bool" @bind-Value="_reqIndividual" Class="mb-3">
                <MudRadio T="bool" Value="false" Color="Color.Primary">Behörde</MudRadio>
                <MudRadio T="bool" Value="true" Color="Color.Primary">Einzelner Partner</MudRadio>
            </MudRadioGroup>
            @if (!_reqIndividual)
            {
                <MudSelect T="PartnerAgency" @bind-Value="_reqAgency" Label="Behörde" Variant="Variant.Outlined"
                           Required="true" Class="mb-3">
                    @foreach (var a in PartnerAgencyDisplay.All)
                    {
                        <MudSelectItem Value="a">@PartnerAgencyDisplay.Name(a) · @PartnerAgencyDisplay.LongName(a)</MudSelectItem>
                    }
                </MudSelect>
            }
            else
            {
                <MudAutocomplete T="PartnerAccountOption" Label="Partner-Konto" Variant="Variant.Outlined" Class="mb-3"
                                 @bind-Value="_reqPartner" SearchFunc="SearchPartners" Dense="true" ResetValueOnEmptyText="true"
                                 Required="true"
                                 ToStringFunc="@(o => o is null ? string.Empty : $"{o.Codename} · {PartnerRankDisplay.Full(o.Agency, o.Rank)}")"
                                 Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.PersonAdd" />
            }
            <MudCheckBox T="bool" @bind-Value="_reqIncludesChildren" Color="Color.Primary" Label="Ganze Akte (inklusive Unterpunkte)" Class="mb-3" />
            <MudTextField @bind-Value="_reqJustification" Label="Begründung" Variant="Variant.Outlined"
                          Lines="3" Required="true" Placeholder="Warum sollte diese Akte freigegeben werden?" />
        }
    </DialogContent>
    <DialogActions>
        @if (!_load && !_user.IsLeadership())
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="_submitting"
                       OnClick="SubmitRequestAsync">Antrag stellen</MudButton>
        }
        <MudButton OnClick="Close">Schließen</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    [Parameter, EditorRequired] public string EntityType { get; set; } = default!;
    [Parameter, EditorRequired] public string EntityId { get; set; } = default!;

    private bool _load = true;
    private ClaimsPrincipal _user = default!;
    private List<PartnerShareState> _states = new();
    private List<PartnerIndividualShareState> _individual = new();
    private IReadOnlyList<PartnerAccountOption> _partners = new List<PartnerAccountOption>();
    private PartnerAccountOption? _toAdd;

    // request-mode fields
    private bool _reqIndividual;
    private PartnerAgency _reqAgency;
    private PartnerAccountOption? _reqPartner;
    private bool _reqIncludesChildren;
    private string? _reqJustification;
    private bool _submitting;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _user = (await AuthStateTask).User;
            _partners = await ShareService.GetSelectablePartnersAsync();
            if (_user.IsLeadership())
            {
                await ReloadAsync();
            }
        }
        catch (Exception ex)
        {
            // surface instead of killing the circuit
            Snackbar.Add($"Partner-Freigabe konnte nicht geladen werden: {ex.Message}", Severity.Error);
        }
        finally
        {
            _load = false;
        }
    }

    private async Task ReloadAsync()
    {
        _states = (await ShareService.GetForRecordAsync(EntityType, EntityId)).ToList();
        _individual = (await ShareService.GetIndividualSharesForRecordAsync(EntityType, EntityId)).ToList();
    }

    private async Task ReleasedChanged(PartnerShareState st, bool released)
        => await ApplyAsync(st.Agency, released, released && st.IncludesChildren);

    private async Task ChildrenChanged(PartnerShareState st, bool includesChildren)
        => await ApplyAsync(st.Agency, true, includesChildren);

    private async Task ApplyAsync(PartnerAgency agency, bool released, bool includesChildren)
    {
        try
        {
            await ShareService.SetParentAsync(EntityType, EntityId, agency, released, includesChildren, _user);
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    // exclude already-released accounts from the picker
    private Task<IEnumerable<PartnerAccountOption>> SearchPartners(string value, CancellationToken token)
    {
        var taken = _individual.Select(i => i.AgentId).ToHashSet();
        var q = _partners.Where(p => !taken.Contains(p.AgentId));
        if (!string.IsNullOrWhiteSpace(value))
        {
            q = q.Where(p => p.Codename.Contains(value, StringComparison.OrdinalIgnoreCase));
        }
        return Task.FromResult<IEnumerable<PartnerAccountOption>>(q.Take(20).ToList());
    }

    private async Task OnPartnerSelected(PartnerAccountOption? option)
    {
        _toAdd = null;
        if (option is null)
        {
            return;
        }
        await ApplyIndividualAsync(option.AgentId, true, false);
    }

    private Task IndividualChildrenChanged(PartnerIndividualShareState ind, bool includesChildren)
        => ApplyIndividualAsync(ind.AgentId, true, includesChildren);

    private Task RemoveIndividual(PartnerIndividualShareState ind)
        => ApplyIndividualAsync(ind.AgentId, false, false);

    private async Task ApplyIndividualAsync(string partnerAgentId, bool released, bool includesChildren)
    {
        try
        {
            await ShareService.SetIndividualParentAsync(EntityType, EntityId, partnerAgentId, released, includesChildren, _user);
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task SubmitRequestAsync()
    {
        if (string.IsNullOrWhiteSpace(_reqJustification))
        {
            Snackbar.Add("Bitte eine Begründung angeben.", Severity.Warning);
            return;
        }
        if (_reqIndividual && _reqPartner is null)
        {
            Snackbar.Add("Bitte ein Partner-Konto auswählen.", Severity.Warning);
            return;
        }
        _submitting = true;
        try
        {
            var agency = _reqIndividual ? _reqPartner!.Agency : _reqAgency;
            var partnerAgentId = _reqIndividual ? _reqPartner!.AgentId : null;
            await ShareService.RequestPartnerShareAsync(
                _user, EntityType, EntityId, agency, partnerAgentId, _reqIncludesChildren, _reqJustification);
            Snackbar.Add("Freigabe-Antrag gestellt. Die Führung entscheidet zeitnah.", Severity.Success);
            MudDialog.Close();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _submitting = false;
        }
    }

    private void Close() => MudDialog.Close();

    public static Task ShowAsync(IDialogService dialog, string entityType, string entityId)
    {
        var parameters = new DialogParameters<PartnerShareDialog>
        {
            { x => x.EntityType, entityType },
            { x => x.EntityId, entityId },
        };
        return dialog.ShowAsync<PartnerShareDialog>("Partner-Freigabe", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
    }
}
