@* Reusable distribution donut; shows a hint instead of an empty ring when all values are 0 (MudChart would draw NaN geometry). *@
@using NOOSE_Website.Models.Dashboard

@if (Bare)
{
    <div class="d-flex flex-column flex-grow-1" style="min-width:0;width:100%;">
        <MudText Typo="Typo.subtitle2" Align="Align.Center" Class="mb-1">@Title</MudText>
        @Diagram
    </div>
}
else
{
    <MudPaper Class="pa-4" Elevation="2">
        <MudText Typo="Typo.subtitle1" Class="mb-2">@Title</MudText>
        @Diagram
    </MudPaper>
}

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;

    [Parameter, EditorRequired] public IReadOnlyList<DistributionSegment> Segments { get; set; } = Array.Empty<DistributionSegment>();

    /// <summary>Hex colours per segment, same order as Segments.</summary>
    [Parameter, EditorRequired] public string[] Colours { get; set; } = Array.Empty<string>();

    [Parameter] public string Height { get; set; } = "300px";

    /// <summary>Render without an own MudPaper tile.</summary>
    [Parameter] public bool Bare { get; set; }

    private bool _empty = true;
    private double[] _data = Array.Empty<double>();
    private string[] _labels = Array.Empty<string>();
    private ChartOptions _options = new();

    protected override void OnParametersSet()
    {
        _empty = Segments.Count == 0 || Segments.All(s => s.Count == 0);
        _data = Segments.Select(s => (double)s.Count).ToArray();
        _labels = Segments.Select(s => $"{s.Designation} ({s.Count})").ToArray();
        _options = new ChartOptions { ChartPalette = Colours, ShowLegend = true };
    }

    private RenderFragment Diagram =>@<text>
        @if (_empty)
        {
            <div class="d-flex align-center justify-center" style="@($"min-height:{Height};")">
                <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Daten</MudText>
            </div>
        }
        else
        {
            <MudChart ChartType="ChartType.Donut" ChartSeries="@(_data.AsChartDataSet())" ChartLabels="@_labels"
                      ChartOptions="@_options" Width="100%" Height="@Height" />
        }
    </text>;
}
