@* Reusable time-series chart; shows a hint instead of an empty chart when all values are 0 (MudChart would draw NaN geometry). *@
@using NOOSE_Website.Models.Statistics

<div class="d-flex flex-column" style="width:100%;min-width:0;">
    <MudText Typo="Typo.subtitle1" Class="mb-2">@Title</MudText>
    @if (_empty)
    {
        <div class="d-flex align-center justify-center" style="@($"min-height:{Height};")">
            <MudText Typo="Typo.body2" Class="mud-text-secondary">Noch keine Daten</MudText>
        </div>
    }
    else
    {
        <MudChart ChartType="@DiagramType" ChartSeries="@_series" ChartLabels="@_labels"
                  ChartOptions="@_options" Width="100%" Height="@Height" />
    }
</div>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;

    /// <summary>Month points supplying the X-axis labels.</summary>
    [Parameter, EditorRequired] public IReadOnlyList<StatisticsMonth> Points { get; set; } = Array.Empty<StatisticsMonth>();

    /// <summary>Data rows (name + per-month values), each as long as Points.</summary>
    [Parameter, EditorRequired] public IReadOnlyList<(string Name, IReadOnlyList<int> Values)> Rows { get; set; }
        = Array.Empty<(string, IReadOnlyList<int>)>();

    /// <summary>Hex colours per row, same order as Rows.</summary>
    [Parameter, EditorRequired] public string[] Colours { get; set; } = Array.Empty<string>();

    [Parameter] public string Height { get; set; } = "300px";

    [Parameter] public ChartType DiagramType { get; set; } = ChartType.Line;

    private bool _empty = true;
    private List<ChartSeries<double>> _series = new();
    private string[] _labels = Array.Empty<string>();
    private ChartOptions _options = new();

    protected override void OnParametersSet()
    {
        _labels = Points.Select(p => p.Label).ToArray();
        _series = Rows
            .Select(r => new ChartSeries<double> { Name = r.Name, Data = r.Values.Select(w => (double)w).ToArray() })
            .ToList();
        _empty = Points.Count == 0 || Rows.Count == 0 || Rows.All(r => r.Values.All(w => w == 0));
        _options = new ChartOptions { ChartPalette = Colours, ShowLegend = true };
    }
}
