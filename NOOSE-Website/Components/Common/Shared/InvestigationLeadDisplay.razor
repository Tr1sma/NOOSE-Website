@* Zeigt die Ermittlungsleiter einer Akte (Codenames) prominent in der linken Steckkarte.
   Generisch über eine Namensliste – entkoppelt von den konkreten Join-Entitäten (Gruppe/Fraktion/Partei). *@
<div>
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-1">
        <MudIcon Icon="@Icons.Material.Filled.LocalPolice" Color="Color.Warning" Size="Size.Small" />
        <MudText Typo="Typo.subtitle2">Ermittlungsleiter</MudText>
    </MudStack>
    @if (Names.Count == 0)
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">— nicht zugewiesen</MudText>
    }
    else
    {
        <MudStack Row="true" Spacing="1" Class="flex-wrap">
            @foreach (var name in Names)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined"
                         Icon="@Icons.Material.Filled.LocalPolice">@name</MudChip>
            }
        </MudStack>
    }
</div>

@code {
    /// <summary>Codenames der als Ermittlungsleiter markierten Agents (leer = niemand zugewiesen).</summary>
    [Parameter] public IReadOnlyList<string> Names { get; set; } = Array.Empty<string>();
}
