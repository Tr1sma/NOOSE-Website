@* Command-Palette (Strg+K / Cmd+K): Schnellzugriff auf Akten und Funktionen.
   Als Singleton im MainLayout platziert; der Hotkey wird per JS-Interop registriert. *@
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject ISearchService SearchService
@inject Microsoft.Extensions.Logging.ILogger<CommandPalette> Logger
@implements IAsyncDisposable

<MudDialog @bind-Visible="_open" Options="_options">
    <TitleContent>
        <MudText Typo="Typo.subtitle1">
            <MudIcon Icon="@Icons.Material.Filled.Bolt" Size="Size.Small" Class="mr-1" />Schnellzugriff
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudAutocomplete T="PaletteItem" @ref="_auto" SearchFunc="Search" ToStringFunc="@(i => i?.Label ?? string.Empty)"
                         ValueChanged="SelectedAsync" Placeholder="Akte suchen oder Befehl wählen…"
                         Variant="Variant.Outlined" MinCharacters="0" Immediate="true" Clearable="true"
                         ResetValueOnEmptyText="true" AutoFocus="true"
                         Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search">
            <ItemTemplate Context="i">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@i.Icon" Size="Size.Small" Color="Color.Primary" />
                    <MudText Typo="Typo.body2">@i.Label</MudText>
                    @if (!string.IsNullOrEmpty(i.Sub))
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@i.Sub</MudText>
                    }
                </MudStack>
            </ItemTemplate>
            <NoItemsTemplate>
                <MudText Typo="Typo.caption" Class="mud-text-secondary pa-2">Keine Treffer.</MudText>
            </NoItemsTemplate>
        </MudAutocomplete>
        <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2 d-block">Strg+K öffnet diesen Schnellzugriff überall.</MudText>
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _open;
    private bool _isLeadership;
    private ViewerScope _scope;
    private MudAutocomplete<PaletteItem> _auto = default!;
    private IJSObjectReference? _module;
    private DotNetObjectReference<CommandPalette>? _ref;
    private readonly DialogOptions _options = new() { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };
    private List<PaletteItem> _commands = new();

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthStateTask).User;
        _isLeadership = user.IsLeadership();
        _scope = ViewerScope.From(user);
        if (user.IsPartner())
        {
            // partners: only released-record areas + global search
            _commands = new List<PaletteItem>
            {
                new("Personen-Akten", "Liste", Icons.Material.Filled.Badge, "/personen"),
                new("Fraktionen", "Liste", Icons.Material.Filled.Groups, "/fraktionen"),
                new("Personengruppen", "Liste", Icons.Material.Filled.Diversity3, "/personengruppen"),
                new("Parteien", "Liste", Icons.Material.Filled.AccountBalance, "/parteien"),
                new("Operationen", "Liste", Icons.Material.Filled.Radar, "/operationen"),
                new("Vorgänge", "Liste", Icons.Material.Filled.FolderSpecial, "/vorgaenge"),
                new("Dokumente", "Bibliothek", Icons.Material.Filled.MenuBook, "/dokumente"),
                new("Gesetzbuch", "Rechtsgrundlagen", Icons.Material.Filled.Gavel, "/gesetze"),
                new("Globale Suche", null, Icons.Material.Filled.Search, "/suche"),
            };
            return;
        }
        _commands = new List<PaletteItem>
        {
            new("Personen-Akten", "Liste", Icons.Material.Filled.Badge, "/personen"),
            new("Neue Person anlegen", null, Icons.Material.Filled.PersonAdd, "/personen/neu"),
            new("Personen-Doks", "Übersicht", Icons.Material.Filled.Description, "/doks"),
            new("Fraktionen", "Liste", Icons.Material.Filled.Groups, "/fraktionen"),
            new("Neue Fraktion anlegen", null, Icons.Material.Filled.Add, "/fraktionen/neu"),
            new("Personengruppen", "Liste", Icons.Material.Filled.Diversity3, "/personengruppen"),
            new("Neue Personengruppe anlegen", null, Icons.Material.Filled.Add, "/personengruppen/neu"),
            new("Parteien", "Liste", Icons.Material.Filled.AccountBalance, "/parteien"),
            new("Neue Partei anlegen", null, Icons.Material.Filled.Add, "/parteien/neu"),
            new("Operationen", "Liste", Icons.Material.Filled.Radar, "/operationen"),
            new("Neue Operation anlegen", null, Icons.Material.Filled.Add, "/operationen/neu"),
            new("Taskforces", "Liste", Icons.Material.Filled.Groups2, "/taskforces"),
            new("Neue Taskforce anlegen", null, Icons.Material.Filled.Add, "/taskforces/neu"),
            new("Vorgänge", "Liste", Icons.Material.Filled.FolderSpecial, "/vorgaenge"),
            new("Neuen Vorgang anlegen", null, Icons.Material.Filled.Add, "/vorgaenge/neu"),
            new("Aufgaben", "Team-Board", Icons.Material.Filled.AssignmentTurnedIn, "/aufgaben"),
            new("Neue Aufgabe anlegen", null, Icons.Material.Filled.Add, "/aufgaben/neu"),
            new("Dokumente", "Bibliothek", Icons.Material.Filled.MenuBook, "/dokumente"),
            new("Neues Dokument erstellen", null, Icons.Material.Filled.Add, "/dokumente/neu"),
            new("Gesetzbuch", "Rechtsgrundlagen", Icons.Material.Filled.Gavel, "/gesetze"),
            new("Globale Suche", null, Icons.Material.Filled.Search, "/suche"),
        };
        // Papierkörbe und Verwaltung sind Führungs-gated → für Nicht-Führung nicht anbieten (sonst ACCESS DENIED).
        if (_isLeadership)
        {
            _commands.Add(new PaletteItem("Freigaben", "Posteingang", Icons.Material.Filled.HowToReg, "/admin/freigaben"));
            _commands.Add(new PaletteItem("Tags verwalten", null, Icons.Material.Filled.Label, "/admin/tags"));
            _commands.Add(new PaletteItem("Vorlagen verwalten", null, Icons.Material.Filled.Dvr, "/admin/vorlagen"));
            _commands.Add(new PaletteItem("Papierkorb · Personen", null, Icons.Material.Filled.Delete, "/personen/papierkorb"));
            _commands.Add(new PaletteItem("Papierkorb · Fraktionen", null, Icons.Material.Filled.Delete, "/fraktionen/papierkorb"));
            _commands.Add(new PaletteItem("Papierkorb · Personengruppen", null, Icons.Material.Filled.Delete, "/personengruppen/papierkorb"));
            _commands.Add(new PaletteItem("Papierkorb · Parteien", null, Icons.Material.Filled.Delete, "/parteien/papierkorb"));
            _commands.Add(new PaletteItem("Papierkorb · Operationen", null, Icons.Material.Filled.Delete, "/operationen/papierkorb"));
            _commands.Add(new PaletteItem("Papierkorb · Taskforces", null, Icons.Material.Filled.Delete, "/taskforces/papierkorb"));
            _commands.Add(new PaletteItem("Papierkorb · Vorgänge", null, Icons.Material.Filled.Delete, "/vorgaenge/papierkorb"));
            _commands.Add(new PaletteItem("Papierkorb · Aufgaben", null, Icons.Material.Filled.Delete, "/aufgaben/papierkorb"));
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // JS-Interop erst nach dem ersten Render verfügbar (Interactive Server).
        if (firstRender)
        {
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "./app.js?v=2");
            _ref = DotNetObjectReference.Create(this);
            await _module.InvokeVoidAsync("registerCommandPalette", _ref);
        }
    }

    [JSInvokable]
    public Task Open()
    {
        _open = true;
        return InvokeAsync(StateHasChanged);
    }

    private async Task<IEnumerable<PaletteItem>> Search(string value, CancellationToken token)
    {
        var v = value?.Trim() ?? string.Empty;
        var result = new List<PaletteItem>();
        result.AddRange(string.IsNullOrEmpty(v)
            ? _commands
            : _commands.Where(b => b.Label.Contains(v, StringComparison.OrdinalIgnoreCase)));

        if (!string.IsNullOrEmpty(v))
        {
            try
            {
                var hit = await SearchService.QuickSearchAsync(v, _scope, 8, token);
                result.AddRange(hit.Select(t => new PaletteItem(t.Name, t.CaseNumber, PaletteIcon(t.Category), SearchNavigation.Route(t.Category, t.TargetId))));
            }
            catch (Exception ex)
            {
                // Schnellsuche-Fehler nicht eskalieren (dann nur die statischen Befehle anzeigen), aber loggen.
                Logger.LogDebug(ex, "Schnellsuche in der Command-Palette fehlgeschlagen.");
            }
        }
        return result;
    }

    private async Task SelectedAsync(PaletteItem? item)
    {
        if (item is null)
        {
            return;
        }
        _open = false;
        await _auto.ClearAsync();
        Nav.NavigateTo(item.Url);
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_module is not null)
            {
                await _module.InvokeVoidAsync("unregisterCommandPalette");
                await _module.DisposeAsync();
            }
        }
        catch (JSDisconnectedException)
        {
            // Circuit bereits getrennt – nichts zu tun.
        }
        _ref?.Dispose();
    }

    private static string PaletteIcon(string category) => category switch
    {
        nameof(Faction) => Icons.Material.Filled.Groups,
        nameof(PersonGroup) => Icons.Material.Filled.Diversity3,
        nameof(Party) => Icons.Material.Filled.AccountBalance,
        nameof(Operation) => Icons.Material.Filled.Radar,
        nameof(Taskforce) => Icons.Material.Filled.Groups2,
        nameof(Case) => Icons.Material.Filled.FolderSpecial,
        nameof(Job) => Icons.Material.Filled.AssignmentTurnedIn,
        _ => Icons.Material.Filled.Badge,
    };

    private record PaletteItem(string Label, string? Sub, string Icon, string Url);
}
