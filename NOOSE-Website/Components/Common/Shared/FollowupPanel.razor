@inject IFollowupService FollowupService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IPartnerShareService PartnerShareService

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudText Typo="Typo.subtitle1">Wiedervorlagen (@_open.Count)</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.EventRepeat" OnClick="NewAsync">
            Wiedervorlage planen
        </MudButton>
    </MudStack>

    @if (_load)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else
    {
        @if (_open.Count == 0)
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary">Keine offenen Wiedervorlagen.</MudText>
        }
        else
        {
            @foreach (var w in _open)
            {
                <MudPaper Class="pa-3" Elevation="1">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@(w.Overdue ? Icons.Material.Filled.EventBusy : Icons.Material.Filled.Event)"
                                     Color="@(w.Overdue ? Color.Error : Color.Primary)" Size="Size.Small" />
                            <MudText Typo="Typo.body2"><b>@w.DueAt.ToLocalTime().ToString("dd.MM.yyyy")</b></MudText>
                            @if (w.Overdue)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled">überfällig</MudChip>
                            }
                        </MudStack>
                        <MudStack Row="true" Spacing="0" AlignItems="AlignItems.Center">
                            <PartnerChildShareButton Show="_canShareChildren" ChildType="@nameof(Followup)" ChildId="@w.Id" />
                            @if (w.MayEdit)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Success" Size="Size.Small"
                                               OnClick="@(() => CompleteAsync(w))" aria-label="Als erledigt markieren" />
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Default" Size="Size.Small"
                                               OnClick="@(() => EditAsync(w))" aria-label="Bearbeiten" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                               OnClick="@(() => DeleteAsync(w))" aria-label="Löschen" />
                            }
                        </MudStack>
                    </MudStack>

                    @if (!string.IsNullOrWhiteSpace(w.Note))
                    {
                        <MudText Typo="Typo.body2" Class="mt-1" Style="white-space:pre-wrap;">@w.Note</MudText>
                    }
                    <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mt-1">
                        Zuständig: @(w.ResponsibleCodename ?? "—")
                    </MudText>
                </MudPaper>
            }
        }

        @if (_done.Count > 0)
        {
            <MudExpansionPanels Elevation="0" Dense="true">
                <MudExpansionPanel Text="@($"Erledigt ({_done.Count})")">
                    <MudStack Spacing="2">
                        @foreach (var w in _done)
                        {
                            <MudPaper Class="pa-3" Elevation="0" Style="opacity:.75;">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                                        <MudText Typo="Typo.body2">@w.DueAt.ToLocalTime().ToString("dd.MM.yyyy")</MudText>
                                        @if (w.DoneAt is { } done)
                                        {
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">erledigt @done.ToLocalTime().ToString("dd.MM.yyyy")</MudText>
                                        }
                                    </MudStack>
                                    @if (w.MayEdit)
                                    {
                                        <MudStack Row="true" Spacing="0">
                                            <MudIconButton Icon="@Icons.Material.Filled.Undo" Color="Color.Default" Size="Size.Small"
                                                           OnClick="@(() => ReopenAsync(w))" aria-label="Wieder öffnen" />
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                                           OnClick="@(() => DeleteAsync(w))" aria-label="Löschen" />
                                        </MudStack>
                                    }
                                </MudStack>
                                @if (!string.IsNullOrWhiteSpace(w.Note))
                                {
                                    <MudText Typo="Typo.body2" Class="mt-1" Style="white-space:pre-wrap;">@w.Note</MudText>
                                }
                            </MudPaper>
                        }
                    </MudStack>
                </MudExpansionPanel>
            </MudExpansionPanels>
        }
    }
</MudStack>

@code {
    [Parameter, EditorRequired] public string EntityType { get; set; } = default!;
    [Parameter, EditorRequired] public string EntityId { get; set; } = default!;
    [Parameter, EditorRequired] public ClaimsPrincipal User { get; set; } = default!;

    private bool _load = true;
    private bool _canShareChildren;
    private List<FollowupItem> _open = new();
    private List<FollowupItem> _done = new();

    protected override async Task OnInitializedAsync()
    {
        // leadership: per-item release only matters when the record is shell-released
        if (User.IsLeadership())
        {
            _canShareChildren = (await PartnerShareService.GetForRecordAsync(EntityType, EntityId))
                .Any(s => s.Released && !s.IncludesChildren);
        }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _load = true;
        var all = await FollowupService.GetForRecordAsync(EntityType, EntityId, User);
        _open = all.Where(w => !w.Done).ToList();
        _done = all.Where(w => w.Done).ToList();
        _load = false;
    }

    private async Task NewAsync()
    {
        var input = await FollowupDialog.ShowAsync(DialogService, User.MayRealNameSee());
        if (input is null)
        {
            return;
        }
        await ExecuteAsync(() => FollowupService.CreateAsync(EntityType, EntityId, input, User),
            "Wiedervorlage geplant.");
    }

    private async Task EditAsync(FollowupItem w)
    {
        var input = await FollowupDialog.ShowAsync(DialogService, User.MayRealNameSee(),
            "Wiedervorlage bearbeiten", w.DueAt, w.Note, w.ResponsibleAgentId);
        if (input is null)
        {
            return;
        }
        await ExecuteAsync(() => FollowupService.RefreshAsync(w.Id, input, User), "Wiedervorlage aktualisiert.");
    }

    private Task CompleteAsync(FollowupItem w)
        => ExecuteAsync(() => FollowupService.CompleteAsync(w.Id, User), "Als erledigt markiert.");

    private Task ReopenAsync(FollowupItem w)
        => ExecuteAsync(() => FollowupService.ReopenAsync(w.Id, User), "Wieder geöffnet.");

    private async Task DeleteAsync(FollowupItem w)
    {
        var ok = await ConfirmDialog.ShowAsync(DialogService, "Wiedervorlage löschen?",
            "Die Wiedervorlage wird in den Papierkorb verschoben.");
        if (!ok)
        {
            return;
        }
        await ExecuteAsync(() => FollowupService.DeleteAsync(w.Id, User), "Wiedervorlage gelöscht.");
    }

    private async Task ExecuteAsync(Func<Task> action, string success)
    {
        try
        {
            await action();
            Snackbar.Add(success, Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
