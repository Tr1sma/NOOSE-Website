@inject IAgentManagementService AgentService

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3" Style="min-width:380px;">
            <MudDatePicker @bind-Date="_due" Label="Fällig am" Editable="true"
                           Variant="Variant.Outlined" DateFormat="dd.MM.yyyy"
                           Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Event" />

            <MudTextField @bind-Value="_note" Label="Notiz (optional)" Variant="Variant.Outlined"
                          Lines="3" MaxLength="500" HelperText="Worum geht es bei dieser Wiedervorlage?" />

            <MudAutocomplete T="Agent" Label="Zuständig (optional)" @bind-Value="_agent"
                             SearchFunc="@SearchAgents" ToStringFunc="@(a => a is null ? string.Empty : a.Codename)"
                             Variant="Variant.Outlined" Clearable="true" CoerceText="false" CoerceValue="false"
                             ResetValueOnEmptyText="true" MinCharacters="0" Immediate="true"
                             Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.ManageAccounts"
                             HelperText="Leer = du selbst. Zuständiger und Follower der Akte werden bei Fälligkeit erinnert.">
                <ItemTemplate Context="a">
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Color="Color.Primary" />
                        <MudText Typo="Typo.body2">@a.Codename</MudText>
                        @if (MayRealName && !string.IsNullOrWhiteSpace(a.RealName))
                        {
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">(@a.RealName)</MudText>
                        }
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@RankDisplay.Name(a.Rank)</MudText>
                    </MudStack>
                </ItemTemplate>
            </MudAutocomplete>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Abbrechen</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save" Disabled="@(_due is null)">Speichern</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public DateTime? DueAt { get; set; }
    [Parameter] public string? Note { get; set; }
    [Parameter] public string? ResponsibleAgentId { get; set; }

    /// <summary>Whether the viewer may see real names.</summary>
    [Parameter] public bool MayRealName { get; set; }

    private DateTime? _due;
    private string? _note;
    private Agent? _agent;
    private List<Agent> _all = new();

    protected override async Task OnInitializedAsync()
    {
        _due = (DueAt ?? DateTime.UtcNow.AddDays(1)).ToLocalTime().Date;
        _note = Note;

        var all = await AgentService.GetAllAsync();
        _all = all.Where(a => a.Status == AgentStatus.Active).ToList();
        if (!string.IsNullOrEmpty(ResponsibleAgentId))
        {
            _agent = _all.FirstOrDefault(a => a.Id == ResponsibleAgentId);
        }
    }

    private Task<IEnumerable<Agent>> SearchAgents(string value, CancellationToken token)
    {
        var search = value.Trim();
        IEnumerable<Agent> hit = string.IsNullOrWhiteSpace(value)
            ? _all
            : _all.Where(a => a.Codename.Contains(search, StringComparison.OrdinalIgnoreCase)
                            || (MayRealName && (a.RealName ?? string.Empty).Contains(search, StringComparison.OrdinalIgnoreCase)));
        return Task.FromResult(hit);
    }

    private void Save()
    {
        if (_due is null)
        {
            return;
        }
        MudDialog.Close(DialogResult.Ok(new FollowupInput(_due.Value, _note, _agent?.Id)));
    }

    private void Cancel() => MudDialog.Cancel();

    /// <summary>Shows the dialog; returns the input or null on cancel.</summary>
    public static async Task<FollowupInput?> ShowAsync(IDialogService dialog, bool mayRealName,
        string title = "Wiedervorlage planen", DateTime? dueAt = null, string? note = null, string? responsibleAgentId = null)
    {
        var parameters = new DialogParameters<FollowupDialog>
        {
            { x => x.MayRealName, mayRealName },
            { x => x.DueAt, dueAt },
            { x => x.Note, note },
            { x => x.ResponsibleAgentId, responsibleAgentId },
        };
        var reference = await dialog.ShowAsync<FollowupDialog>(title, parameters);
        var result = await reference.Result;
        return result is { Canceled: false, Data: FollowupInput input } ? input : null;
    }
}
