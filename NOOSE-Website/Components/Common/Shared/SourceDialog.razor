@inject ISourcesStorageService Storage
@inject IPersonService PersonService
@inject ICaseService CaseService
@inject IDocumentService DocumentService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form">
            <MudStack Spacing="3">
                <MudSelect T="SourceType" Label="Art der Quelle" @bind-Value="_input.Type" Variant="Variant.Outlined">
                    @foreach (var t in SourceTypeDisplay.All)
                    {
                        <MudSelectItem Value="t">@SourceTypeDisplay.Name(t)</MudSelectItem>
                    }
                </MudSelect>

                <MudTextField @bind-Value="_input.Title" Label="Titel" Variant="Variant.Outlined"
                              Required="true" RequiredError="Titel ist erforderlich" AutoFocus="true" />

                @if (ShowInternalToggle)
                {
                    <MudSwitch @bind-Value="_input.IsInternalOnly" Label="Nur Taskforce-intern (nicht für Partner sichtbar)"
                               Color="Color.Warning" />
                }

                @switch (_input.Type)
                {
                    case SourceType.Link:
                        <MudTextField @bind-Value="_input.Url" Label="URL" Variant="Variant.Outlined"
                                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Link"
                                      Placeholder="https://…" />
                        <MudTextField @bind-Value="_input.Description" Label="Notiz (optional)" Lines="2" Variant="Variant.Outlined" />
                        break;

                    case SourceType.FreeText:
                        <MudTextField @bind-Value="_input.Description" Label="Inhalt" Lines="5" Variant="Variant.Outlined"
                                      Required="true" RequiredError="Bitte einen Text eingeben" />
                        break;

                    case SourceType.Document:
                        <MudAutocomplete T="DocumentListItem" Label="Vorhandenes Dokument" Value="_selectedDocument"
                                         ValueChanged="DocumentSelected" SearchFunc="@SearchDocuments"
                                         ToStringFunc="@(d => d?.Title ?? string.Empty)"
                                         Variant="Variant.Outlined" Clearable="true" CoerceText="false" CoerceValue="false"
                                         ResetValueOnEmptyText="true" MinCharacters="0" Immediate="true"
                                         Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Article"
                                         HelperText="Dokument aus der Bibliothek auswählen – oder unten ein neues erstellen.">
                            <ItemTemplate Context="d">
                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Filled.Article" Size="Size.Small" Color="Color.Primary" />
                                    <MudText Typo="Typo.body2">@d.Title</MudText>
                                    @if (!string.IsNullOrWhiteSpace(d.Category))
                                    {
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@d.Category</MudText>
                                    }
                                </MudStack>
                            </ItemTemplate>
                        </MudAutocomplete>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="NewDocument">
                            Neues Dokument erstellen
                        </MudButton>
                        <MudTextField @bind-Value="_input.Description" Label="Notiz (optional)" Lines="2" Variant="Variant.Outlined" />
                        break;

                    case SourceType.Internal:
                        <MudRadioGroup T="string" @bind-Value="_internalTargetMode">
                            <MudRadio Value="@("Person")" Color="Color.Primary">Person</MudRadio>
                            <MudRadio Value="@("Case")" Color="Color.Primary">Vorgang</MudRadio>
                        </MudRadioGroup>
                        @if (_internalTargetMode == "Case")
                        {
                            <MudAutocomplete T="Case" Label="Ziel-Vorgang" @bind-Value="_targetCase"
                                             SearchFunc="@SearchCases" ToStringFunc="@(c => c is null ? string.Empty : $"{c.CaseNumber} – {c.Title}")"
                                             Variant="Variant.Outlined" Clearable="true" CoerceText="false" CoerceValue="false"
                                             ResetValueOnEmptyText="true" MinCharacters="0" Immediate="true"
                                             Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.FolderOpen"
                                             HelperText="Verknüpften Vorgang auswählen.">
                                <ItemTemplate Context="c">
                                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                        <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Size="Size.Small" Color="Color.Primary" />
                                        <MudText Typo="Typo.body2">@c.Title</MudText>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@c.CaseNumber</MudText>
                                    </MudStack>
                                </ItemTemplate>
                            </MudAutocomplete>
                        }
                        else
                        {
                            <MudAutocomplete T="Person" Label="Ziel-Akte (Person)" @bind-Value="_targetPerson"
                                             SearchFunc="@SearchPeople" ToStringFunc="@(p => p?.Name ?? string.Empty)"
                                             Variant="Variant.Outlined" Clearable="true" CoerceText="false" CoerceValue="false"
                                             ResetValueOnEmptyText="true" MinCharacters="0" Immediate="true"
                                             Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.PersonSearch"
                                             HelperText="Verknüpfte Person auswählen.">
                                <ItemTemplate Context="p">
                                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                        <MudIcon Icon="@Icons.Material.Filled.Badge" Size="Size.Small" Color="Color.Primary" />
                                        <MudText Typo="Typo.body2">@p.Name</MudText>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@p.CaseNumber</MudText>
                                    </MudStack>
                                </ItemTemplate>
                            </MudAutocomplete>
                        }
                        <MudTextField @bind-Value="_input.Description" Label="Notiz (optional)" Lines="2" Variant="Variant.Outlined" />
                        break;

                    case SourceType.Upload:
                        <MudFileUpload T="IBrowserFile" FilesChanged="FileSelected">
                            <CustomContent>
                                <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AttachFile"
                                           OnClick="@context.OpenFilePickerAsync">
                                    Datei auswählen
                                </MudButton>
                            </CustomContent>
                        </MudFileUpload>
                        @if (!string.IsNullOrEmpty(_fileName))
                        {
                            <MudAlert Severity="Severity.Success" Dense="true" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.InsertDriveFile">
                                @_fileName
                            </MudAlert>
                        }
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                            Erlaubt: PDF, Bilder, Office-Dokumente, Text, ZIP – max. @(Storage.MaxBytes / (1024 * 1024)) MB.
                        </MudText>
                        <MudTextField @bind-Value="_input.Description" Label="Notiz (optional)" Lines="2" Variant="Variant.Outlined" />
                        break;
                }
            </MudStack>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Abbrechen</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save">Quelle speichern</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public bool IsLeadership { get; set; }

    /// <summary>Viewer's classification scope for the document picker.</summary>
    [Parameter] public DocumentViewerScope DocumentScope { get; set; }

    /// <summary>Show the intern toggle; set only when the parent entity is a Taskforce.</summary>
    [Parameter] public bool ShowInternalToggle { get; set; }

    private MudForm _form = default!;
    private readonly SourceInput _input = new();
    private Person? _targetPerson;
    private Case? _targetCase;
    private string _internalTargetMode = "Person";
    private DocumentListItem? _selectedDocument;
    private string? _fileName;

    private async Task<IEnumerable<Person>> SearchPeople(string value, CancellationToken token)
        => await PersonService.SearchAsync(value, IsLeadership, 20, token);

    private async Task<IEnumerable<Case>> SearchCases(string value, CancellationToken token)
        => await CaseService.SearchAsync(value, IsLeadership, 20, token);

    private async Task<IEnumerable<DocumentListItem>> SearchDocuments(string value, CancellationToken token)
        => await DocumentService.SearchAsync(value, DocumentScope, 20, token);

    private void DocumentSelected(DocumentListItem? document)
    {
        _selectedDocument = document;
        if (document is not null && string.IsNullOrWhiteSpace(_input.Title))
        {
            _input.Title = document.Title;
        }
    }

    private void NewDocument()
    {
        _input.NewDocumentCreate = true;
        MudDialog.Close(DialogResult.Ok(_input));
    }

    private async Task FileSelected(IBrowserFile? file)
    {
        if (file is null)
        {
            return;
        }
        if (file.Size > Storage.MaxBytes)
        {
            Snackbar.Add($"„{file.Name}“: zu groß (max. {Storage.MaxBytes / (1024 * 1024)} MB).", Severity.Warning);
            return;
        }
        if (!Storage.IsAllowedType(file.ContentType))
        {
            Snackbar.Add($"„{file.Name}“: Dateityp nicht erlaubt.", Severity.Warning);
            return;
        }

        using var ms = new MemoryStream();
        await file.OpenReadStream(Storage.MaxBytes).CopyToAsync(ms);
        _input.FileContent = ms.ToArray();
        _input.OriginalName = file.Name;
        _input.ContentType = file.ContentType;
        _input.SizeBytes = file.Size;
        _fileName = file.Name;

        if (string.IsNullOrWhiteSpace(_input.Title))
        {
            _input.Title = file.Name;
        }
    }

    private async Task Save()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid)
        {
            return;
        }

        switch (_input.Type)
        {
            case SourceType.Link when string.IsNullOrWhiteSpace(_input.Url):
                Snackbar.Add("Bitte eine URL angeben.", Severity.Warning);
                return;
            case SourceType.Internal when _internalTargetMode == "Case":
                if (_targetCase is null)
                {
                    Snackbar.Add("Bitte einen Vorgang auswählen.", Severity.Warning);
                    return;
                }
                _input.TargetType = nameof(Case);
                _input.TargetId = _targetCase.Id;
                if (string.IsNullOrWhiteSpace(_input.Title))
                {
                    _input.Title = _targetCase.Title;
                }
                break;
            case SourceType.Internal:
                if (_targetPerson is null)
                {
                    Snackbar.Add("Bitte eine Ziel-Akte auswählen.", Severity.Warning);
                    return;
                }
                _input.TargetType = nameof(Person);
                _input.TargetId = _targetPerson.Id;
                if (string.IsNullOrWhiteSpace(_input.Title))
                {
                    _input.Title = _targetPerson.Name;
                }
                break;
            case SourceType.Upload when _input.FileContent is null:
                Snackbar.Add("Bitte eine Datei auswählen.", Severity.Warning);
                return;
            case SourceType.Document:
                if (_selectedDocument is null)
                {
                    Snackbar.Add("Bitte ein Dokument auswählen oder ein neues erstellen.", Severity.Warning);
                    return;
                }
                _input.TargetType = nameof(Document);
                _input.TargetId = _selectedDocument.Id;
                if (string.IsNullOrWhiteSpace(_input.Title))
                {
                    _input.Title = _selectedDocument.Title;
                }
                break;
        }

        MudDialog.Close(DialogResult.Ok(_input));
    }

    private void Cancel() => MudDialog.Cancel();

    /// <summary>Shows the dialog; returns the input or null on cancel.</summary>
    public static async Task<SourceInput?> ShowAsync(IDialogService dialog, ClaimsPrincipal user, bool showInternalToggle = false)
    {
        var parameters = new DialogParameters<SourceDialog>
        {
            { x => x.IsLeadership, user.IsLeadership() },
            { x => x.DocumentScope, DocumentViewerScope.From(user) },
            { x => x.ShowInternalToggle, showInternalToggle },
        };
        var reference = await dialog.ShowAsync<SourceDialog>("Quelle hinzufügen", parameters);
        var result = await reference.Result;
        return result is { Canceled: false, Data: SourceInput e } ? e : null;
    }
}
